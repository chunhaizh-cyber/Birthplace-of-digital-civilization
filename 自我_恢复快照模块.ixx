module;

#include <cstdint>
#include <string>

#include "基础数据类型.h"

export module 自我_恢复快照模块;

import 自我模块;
import 自我线程模块;
import 自我_初始化模块;
import 自我_核心状态模块;

export {

struct 结构_自我恢复快照_最小_v0 {
    bool 有效 = false;
    结构_自我初始化结果_最小_v0 初始化结果{};
    结构_自我核心状态快照_最小_v0 核心状态{};
    枚举_线程生命周期状态 线程生命周期状态 = 枚举_线程生命周期状态::未启动;
    枚举_自我线程运行阶段 最近运行阶段 = 枚举_自我线程运行阶段::未定义;
    枚举_自我线程最终去向 最近最终去向 = 枚举_自我线程最终去向::未定义;
    std::uint64_t Tick计数 = 0;
    std::uint64_t 累计故障次数 = 0;
    std::uint64_t 累计恢复次数 = 0;
    bool 最近结算已生成 = false;
    bool 最近已执行固定机制 = false;
    std::string 最近故障摘要{};
    std::string 最近运行摘要{};
    std::string 最近恢复摘要{};
    std::string 最近结算摘要{};
    std::string 最近固定机制摘要{};
    std::string 最近主派发判定二次特征摘要{};
};

inline 结构_自我恢复快照_最小_v0 生成自我恢复快照_最小_v0(
    const 自我类& 自我对象,
    const 自我线程类* 自我线程对象 = nullptr) noexcept
{
    结构_自我恢复快照_最小_v0 输出{};
    输出.有效 = true;
    输出.初始化结果 = 读取自我初始化结果_最小_v0(自我对象);
    输出.核心状态 = 读取自我核心状态快照_最小_v0(自我对象);

    if (!自我线程对象) {
        return 输出;
    }

    输出.线程生命周期状态 = 自我线程对象->读取生命周期状态();
    输出.最近运行阶段 = 自我线程对象->读取最近运行阶段();
    输出.最近最终去向 = 自我线程对象->读取最近最终去向();
    输出.Tick计数 = 自我线程对象->读取Tick计数();
    输出.累计故障次数 = 自我线程对象->读取累计故障次数();
    输出.累计恢复次数 = 自我线程对象->读取累计恢复次数();
    const auto 结算快照 = 自我线程对象->读取最近结算治理输出快照();
    输出.最近结算已生成 = 结算快照.已生成;
    输出.最近已执行固定机制 = 结算快照.已执行固定机制;
    输出.最近故障摘要 = 自我线程对象->读取最近故障摘要();
    输出.最近运行摘要 = 自我线程对象->读取最近运行摘要();
    输出.最近恢复摘要 = 自我线程对象->读取最近恢复摘要();
    输出.最近结算摘要 = 结算快照.摘要;
    输出.最近固定机制摘要 = 结算快照.固定机制摘要;
    输出.最近主派发判定二次特征摘要 =
        自我线程对象->读取最近主派发输出快照().主派发判定二次特征摘要;
    return 输出;
}

} // export
