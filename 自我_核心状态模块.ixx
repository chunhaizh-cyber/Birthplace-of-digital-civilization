module;

#include <string>

#include "需求类.h"
#include "任务类.h"
#include "方法类.h"

export module 自我_核心状态模块;

import 自我模块;
import 自我模块.特征定义;

export {

struct 结构_自我核心状态快照_最小_v0 {
    I64 安全值 = 0;
    I64 服务值 = 0;
    I64 物理安全值 = 0;
    I64 风险安全值 = 0;
    I64 待处理方法数量 = 0;
    I64 可用方法数量 = 0;
    bool 方法补齐状态 = false;
    I64 时序正向步长 = 0;
    I64 时序反向步长 = 0;
    I64 服务时序衰减步长 = 0;
    需求类::节点类* 当前主需求 = nullptr;
    任务类::节点类* 当前主任务 = nullptr;
    方法类::节点类* 当前主方法 = nullptr;
    bool 已消亡 = false;
    bool 待机状态 = false;
};

inline bool 读取自我I64特征_最小_v0(
    const 自我类& 自我对象,
    const 词性节点类* 特征类型,
    I64& 输出值) noexcept
{
    return 特征类型
        && 自我对象.读取自我I64特征当前值(特征类型, 输出值);
}

inline 结构_自我核心状态快照_最小_v0 读取自我核心状态快照_最小_v0(
    const 自我类& 自我对象) noexcept
{
    结构_自我核心状态快照_最小_v0 输出{};
    输出.安全值 = 自我对象.获取安全值();
    输出.服务值 = 自我对象.获取服务值();
    输出.物理安全值 = 自我对象.获取物理安全值();
    输出.风险安全值 = 自我对象.获取风险安全值();
    (void)读取自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_待处理方法数量(),
        输出.待处理方法数量);
    (void)读取自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_可用方法数量(),
        输出.可用方法数量);

    I64 方法补齐状态值 = 0;
    (void)读取自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_方法补齐状态(),
        方法补齐状态值);
    输出.方法补齐状态 = 方法补齐状态值 != 0;

    (void)读取自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_时序正向步长(),
        输出.时序正向步长);
    (void)读取自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_时序反向步长(),
        输出.时序反向步长);
    (void)读取自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_服务时序衰减步长(),
        输出.服务时序衰减步长);

    输出.当前主需求 = 自我对象.获取当前主需求();
    输出.当前主任务 = 自我对象.获取当前主任务();
    输出.当前主方法 = 自我对象.获取当前主方法();
    输出.已消亡 = 自我对象.是否已消亡();
    输出.待机状态 = 自我对象.是否待机状态();
    return 输出;
}

} // export
