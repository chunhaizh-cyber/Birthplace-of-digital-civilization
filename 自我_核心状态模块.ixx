module;

#include <string>

#include "需求类.h"
#include "任务类.h"
#include "方法类.h"

export module 自我_核心状态模块;

import 自我模块;
import 自我模块.特征定义;

export {

struct 结构_自我核心状态快照_最小_v0 {
    I64 安全值 = 0;
    I64 服务值 = 0;
    I64 物理安全值 = 0;
    I64 风险安全值 = 0;
    I64 待学习方法数量 = 0;
    I64 可用方法数量 = 0;
    bool 尝试学习状态 = false;
    I64 时序正向步长 = 0;
    I64 时序反向步长 = 0;
    I64 服务时序衰减步长 = 0;
    需求类::节点类* 当前主需求 = nullptr;
    任务类::节点类* 当前主任务 = nullptr;
    方法类::节点类* 当前主方法 = nullptr;
    bool 已消亡 = false;
    bool 待机状态 = false;
};

inline bool 读取自我I64特征_最小_v0(
    const 自我类& 自我对象,
    const 词性节点类* 特征类型,
    I64& 输出值,
    const std::string& 调用点 = "读取自我I64特征_最小_v0") noexcept
{
    return 特征类型
        && 自我对象.读取自我I64特征当前值(特征类型, 输出值, 调用点);
}

inline bool 写入自我I64特征_最小_v0(
    自我类& 自我对象,
    const 词性节点类* 特征类型,
    I64 值,
    时间戳 now = 0,
    const std::string& 调用点 = "写入自我I64特征_最小_v0") noexcept
{
    if (!特征类型) {
        return false;
    }
    if (now == 0) {
        now = 结构体_时间戳::当前_微秒();
    }
    return 自我对象.写入自我I64特征当前值(特征类型, 值, now, 调用点);
}

inline 结构_自我核心状态快照_最小_v0 读取自我核心状态快照_最小_v0(
    const 自我类& 自我对象) noexcept
{
    结构_自我核心状态快照_最小_v0 输出{};
    输出.安全值 = 自我对象.获取安全值();
    输出.服务值 = 自我对象.获取服务值();
    输出.物理安全值 = 自我对象.获取物理安全值();
    输出.风险安全值 = 自我对象.获取风险安全值();
    (void)读取自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_待学习方法数量(),
        输出.待学习方法数量,
        "读取自我核心状态快照_最小_v0/待学习方法数量");
    (void)读取自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_可用方法数量(),
        输出.可用方法数量,
        "读取自我核心状态快照_最小_v0/可用方法数量");

    I64 尝试学习状态值 = 0;
    (void)读取自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_尝试学习状态(),
        尝试学习状态值,
        "读取自我核心状态快照_最小_v0/尝试学习状态");
    输出.尝试学习状态 = 尝试学习状态值 != 0;

    (void)读取自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_时序正向步长(),
        输出.时序正向步长,
        "读取自我核心状态快照_最小_v0/时序正向步长");
    (void)读取自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_时序反向步长(),
        输出.时序反向步长,
        "读取自我核心状态快照_最小_v0/时序反向步长");
    (void)读取自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_服务时序衰减步长(),
        输出.服务时序衰减步长,
        "读取自我核心状态快照_最小_v0/服务时序衰减步长");

    输出.当前主需求 = 自我对象.获取当前主需求();
    输出.当前主任务 = 自我对象.获取当前主任务();
    输出.当前主方法 = 自我对象.获取当前主方法();
    输出.已消亡 = 自我对象.是否已消亡();
    输出.待机状态 = 自我对象.是否待机状态();
    return 输出;
}

inline bool 写入自我核心状态快照_最小_v0(
    自我类& 自我对象,
    const 结构_自我核心状态快照_最小_v0& 快照,
    时间戳 now = 0,
    const std::string& 调用点 = "写入自我核心状态快照_最小_v0") noexcept
{
    if (now == 0) {
        now = 结构体_时间戳::当前_微秒();
    }

    bool 成功 = true;
    成功 = 自我对象.设置物理安全值(
        快照.物理安全值,
        now,
        调用点 + "/物理安全")
        && 成功;
    成功 = 写入自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_安全值(),
        快照.安全值,
        now,
        调用点 + "/安全值")
        && 成功;
    成功 = 写入自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_服务值(),
        快照.服务值,
        now,
        调用点 + "/服务值")
        && 成功;
    成功 = 写入自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_风险安全(),
        快照.风险安全值,
        now,
        调用点 + "/风险安全")
        && 成功;
    成功 = 写入自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_待学习方法数量(),
        快照.待学习方法数量,
        now,
        调用点 + "/待学习方法数量")
        && 成功;
    成功 = 写入自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_可用方法数量(),
        快照.可用方法数量,
        now,
        调用点 + "/可用方法数量")
        && 成功;
    成功 = 写入自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_尝试学习状态(),
        快照.尝试学习状态 ? 1 : 0,
        now,
        调用点 + "/尝试学习状态")
        && 成功;
    成功 = 写入自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_时序正向步长(),
        快照.时序正向步长,
        now,
        调用点 + "/时序正向步长")
        && 成功;
    成功 = 写入自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_时序反向步长(),
        快照.时序反向步长,
        now,
        调用点 + "/时序反向步长")
        && 成功;
    成功 = 写入自我I64特征_最小_v0(
        自我对象,
        自我特征定义类::类型_自我_服务时序衰减步长(),
        快照.服务时序衰减步长,
        now,
        调用点 + "/服务时序衰减步长")
        && 成功;
    成功 = 自我对象.设置当前主需求(
        快照.当前主需求,
        now,
        调用点 + "/当前主需求")
        && 成功;
    成功 = 自我对象.设置当前主任务(
        快照.当前主任务,
        now,
        调用点 + "/当前主任务")
        && 成功;
    成功 = 自我对象.设置当前主方法(
        快照.当前主方法,
        now,
        调用点 + "/当前主方法")
        && 成功;
    return 成功;
}

inline 存在节点类* 确保线程子存在_最小_v0(
    自我类& 自我对象,
    const 结构_线程存在初始化参数& 参数,
    const std::string& 调用点 = "确保线程子存在_最小_v0") noexcept
{
    return 自我对象.确保线程子存在(参数, 调用点);
}

} // export
