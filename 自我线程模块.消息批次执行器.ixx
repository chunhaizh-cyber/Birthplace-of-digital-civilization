module;

#include <deque>
#include <sstream>
#include <string>
#include <variant>
#include <vector>

#include "基础数据类型.h"

export module 自我线程模块.消息批次执行器;

import 自我模块;
import 任务模块.实体;
import 任务模块.工作线程协议;
import 任务管理任务模块;
import 任务模块.管理工作线程;
import 自我线程模块.消息协议;

export namespace 自我线程消息批次执行器 {

struct 结构_治理消息批次 {
    std::vector<自我线程消息协议::结构_治理消息> 全部消息{};
    std::vector<自我线程消息协议::结构_治理消息> 抢占消息{};
    std::vector<自我线程消息协议::结构_治理消息> 普通消息{};
};

struct 结构_线程裁决结果 {
    枚举_任务管理根层重判结果 根层重判结果 = 枚举_任务管理根层重判结果::未定义;
    枚举_任务管理执行前门控结果 执行前门控结果 = 枚举_任务管理执行前门控结果::未定义;
    std::string 上层反馈摘要{};
};

enum class 枚举_批次执行去向 : std::uint8_t {
    继续提交 = 0,
    待机 = 1,
    进入收束 = 2,
    停止 = 3,
};

inline bool 冻结消息批次(
    std::deque<自我线程消息协议::结构_治理消息>* 活邮箱,
    std::deque<自我线程消息协议::结构_治理消息>* 冻结批次) noexcept
{
    if (!活邮箱 || !冻结批次) {
        return false;
    }
    if (!冻结批次->empty() || 活邮箱->empty()) {
        return !冻结批次->empty();
    }
    冻结批次->swap(*活邮箱);
    return !冻结批次->empty();
}

inline void 追加特征值幂等摘要(std::ostringstream* 输出, const 特征值& 值)
{
    if (!输出) {
        return;
    }

    if (std::holds_alternative<std::monostate>(值)) {
        *输出 << "null";
        return;
    }
    if (const auto* 数值 = std::get_if<I64>(&值)) {
        *输出 << "i:" << *数值;
        return;
    }
    if (const auto* 向量句柄 = std::get_if<VecU句柄>(&值)) {
        *输出 << "v:" << 向量句柄->主信息指针;
        return;
    }
    if (const auto* 指针 = std::get_if<指针句柄>(&值)) {
        *输出 << "p:" << 指针->指针;
        return;
    }

    *输出 << "unknown";
}

inline std::string 生成消息幂等键(
    const 自我线程消息协议::结构_治理消息& 消息)
{
    std::ostringstream 输出;
    输出 << static_cast<int>(消息.头.来源链)
        << "|" << static_cast<int>(消息.头.处理类型)
        << "|" << 消息.头.发出者主键
        << "|" << 消息.头.动作主体主键
        << "|" << 消息.头.作用对象主键
        << "|" << 消息.头.来源任务主键
        << "|" << 消息.头.目标任务主键
        << "|" << 消息.头.父任务主键
        << "|" << 消息.头.关联场景主键
        << "|" << 消息.头.路径签名
        << "|" << 消息.语义.动作语义键
        << "|" << 消息.来源.来源主观察特征;

    for (const auto& 变化项 : 消息.变化项集) {
        输出 << "|c:" << static_cast<int>(变化项.变化主体类型)
            << ":" << 变化项.变化主体主键
            << ":" << static_cast<int>(变化项.特征类型)
            << ":" << 变化项.特征主键
            << ":前=";
        追加特征值幂等摘要(&输出, 变化项.变化前值);
        输出 << ":后=";
        追加特征值幂等摘要(&输出, 变化项.变化后值);
        输出
            << ":" << (变化项.已确认生效 ? 1 : 0)
            << ":" << (变化项.是否关键中间状态 ? 1 : 0)
            << ":" << (变化项.已恢复 ? 1 : 0)
            << ":" << 变化项.变化原因键;
    }

    if (消息.附加载荷.需求树更新.has_value()) {
        const auto& 需求树更新 = *消息.附加载荷.需求树更新;
        输出 << "|u:" << static_cast<int>(需求树更新.指令类型)
            << ":" << 需求树更新.父需求主键
            << ":" << 需求树更新.目标需求主键
            << ":" << (需求树更新.标记已满足 ? 1 : 0);
    }

    if (消息.附加载荷.恢复快照.has_value()) {
        输出 << "|恢复快照=1";
    }

    if (const auto* 线程状态变化 = 自我线程消息协议::获取线程状态变化消息段(消息)) {
        输出 << "|线程状态:" << 线程状态变化->线程存在主键
            << ":" << static_cast<int>(线程状态变化->状态特征类型)
            << ":" << 线程状态变化->旧状态
            << "->" << 线程状态变化->新状态
            << ":" << 线程状态变化->决策者主键
            << ":" << 线程状态变化->原因键
            << ":" << 线程状态变化->关联任务主键
            << ":" << (线程状态变化->是否故障触发 ? 1 : 0)
            << ":" << (线程状态变化->是否stop链触发 ? 1 : 0);
    }

    return 输出.str();
}

inline std::string 生成冻结批次摘要(
    const std::deque<自我线程消息协议::结构_治理消息>& 批次)
{
    if (批次.empty()) {
        return "冻结批次=0";
    }

    std::ostringstream 输出;
    输出 << "冻结批次=" << 批次.size()
        << " | 首项处理类型=" << static_cast<int>(批次.front().头.处理类型)
        << " | 最高优先级=" << static_cast<int>(批次.front().头.优先级);
    return 输出.str();
}

inline 结构_治理消息批次 拆分冻结治理邮箱批次(
    const std::deque<自我线程消息协议::结构_治理消息>& 冻结批次)
{
    结构_治理消息批次 批次{};
    批次.全部消息.reserve(冻结批次.size());
    批次.抢占消息.reserve(冻结批次.size());
    批次.普通消息.reserve(冻结批次.size());

    for (const auto& 旧消息 : 冻结批次) {
        auto 消息 = 旧消息;
        批次.全部消息.push_back(消息);
        if (消息.头.可抢占) {
            批次.抢占消息.push_back(std::move(消息));
        } else {
            批次.普通消息.push_back(std::move(消息));
        }
    }

    return 批次;
}

inline bool 存在抢占消息(const 结构_治理消息批次& 批次) noexcept
{
    return !批次.抢占消息.empty();
}

inline 枚举_任务管理根层重判结果 计算根层重判结果(const 自我类& 自我对象) noexcept
{
    if (自我对象.是否已消亡()) {
        return 枚举_任务管理根层重判结果::停止退出边界;
    }

    const auto 安全差额 = 自我对象.安全根方向差值();
    const auto 目标安全值 = 自我对象.根目标安全值();
    if (自我对象.获取物理安全值() <= 0 || 自我对象.获取风险安全值() <= 0) {
        return 枚举_任务管理根层重判结果::收束优先;
    }
    if (目标安全值 > 0 && 安全差额 > (目标安全值 / 5)) {
        return 枚举_任务管理根层重判结果::收束优先;
    }
    if (自我对象.是否待机状态() || 自我对象.获取服务值() <= 0) {
        return 枚举_任务管理根层重判结果::待机保持;
    }
    return 枚举_任务管理根层重判结果::允许普通推进;
}

inline 枚举_任务管理执行前门控结果 计算执行前门控结果(
    const 枚举_任务管理根层重判结果 根层重判结果) noexcept
{
    switch (根层重判结果) {
    case 枚举_任务管理根层重判结果::停止退出边界:
        return 枚举_任务管理执行前门控结果::禁止继续;
    case 枚举_任务管理根层重判结果::收束优先:
        return 枚举_任务管理执行前门控结果::仅允许收束;
    case 枚举_任务管理根层重判结果::待机保持:
        return 枚举_任务管理执行前门控结果::仅允许等待;
    case 枚举_任务管理根层重判结果::允许普通推进:
    default:
        return 枚举_任务管理执行前门控结果::允许普通执行;
    }
}

inline std::string 生成上层反馈摘要(
    const 自我类& 自我对象,
    const 枚举_任务管理根层重判结果 根层重判结果,
    const 枚举_任务管理执行前门控结果 执行前门控结果)
{
    if (自我对象.是否已消亡()
        || 根层重判结果 == 枚举_任务管理根层重判结果::停止退出边界
        || 执行前门控结果 == 枚举_任务管理执行前门控结果::禁止继续) {
        return "停止";
    }
    if (根层重判结果 == 枚举_任务管理根层重判结果::收束优先
        || 执行前门控结果 == 枚举_任务管理执行前门控结果::仅允许收束) {
        return "收束";
    }
    if (根层重判结果 == 枚举_任务管理根层重判结果::待机保持
        || 执行前门控结果 == 枚举_任务管理执行前门控结果::仅允许等待
        || 自我对象.是否待机状态()) {
        return "待机";
    }
    return "推进";
}

inline 结构_线程裁决结果 计算线程裁决结果(const 自我类& 自我对象)
{
    结构_线程裁决结果 结果{};
    结果.根层重判结果 = 计算根层重判结果(自我对象);
    结果.执行前门控结果 = 计算执行前门控结果(结果.根层重判结果);
    结果.上层反馈摘要 =
        生成上层反馈摘要(自我对象, 结果.根层重判结果, 结果.执行前门控结果);
    return 结果;
}

inline 结构_任务根节点 根据主导需求创建任务根节点(
    const 自我类& 自我对象,
    const 时间戳 now,
    const 枚举_任务管理根层重判结果 根层重判结果,
    const std::string& 上层反馈摘要) noexcept
{
    结构_任务根节点 根节点{};
    auto* 当前主需求 = 自我对象.获取当前主需求();
    auto* 当前主任务 = 自我对象.获取当前主任务();

    根节点.任务根ID = 当前主任务
        ? static_cast<std::uint64_t>(reinterpret_cast<std::uintptr_t>(当前主任务))
        : static_cast<std::uint64_t>(now);
    根节点.来源需求指针 = reinterpret_cast<std::uintptr_t>(当前主需求);
    根节点.世界任务根指针 = reinterpret_cast<std::uintptr_t>(当前主任务);
    根节点.父任务指针 = 0;
    根节点.来源需求主键 = 当前主需求 ? 当前主需求->获取主键() : std::string{};
    根节点.方向摘要 = 上层反馈摘要;
    根节点.创建者 = "自我线程";
    switch (根层重判结果) {
    case 枚举_任务管理根层重判结果::待机保持:
        根节点.根约束摘要 = "待机保持";
        break;
    case 枚举_任务管理根层重判结果::收束优先:
        根节点.根约束摘要 = "收束优先";
        break;
    case 枚举_任务管理根层重判结果::停止退出边界:
        根节点.根约束摘要 = "停止退出边界";
        break;
    case 枚举_任务管理根层重判结果::允许普通推进:
    default:
        根节点.根约束摘要 = "允许普通推进";
        break;
    }
    根节点.初始授权等级 =
        根层重判结果 == 枚举_任务管理根层重判结果::允许普通推进 ? 1 : 0;
    根节点.只读 = true;
    return 根节点;
}

inline 结构_任务控制态 初始化任务控制态(
    const 结构_任务根节点& 根节点,
    const 自我线程消息协议::结构_治理消息& 已消费消息,
    const 枚举_任务管理执行前门控结果 执行前门控结果) noexcept
{
    结构_任务控制态 控制态{};
    控制态.任务根ID = 根节点.任务根ID;
    控制态.全局优先级 = static_cast<I64>(已消费消息.头.优先级);
    控制态.时间预算_ms = 250;
    控制态.资源预算 = 1;
    控制态.控制摘要 = 已消费消息.摘要;
    控制态.请求收束 = 执行前门控结果 == 枚举_任务管理执行前门控结果::仅允许收束;
    控制态.请求停止 = 执行前门控结果 == 枚举_任务管理执行前门控结果::禁止继续;
    控制态.队列状态 =
        执行前门控结果 == 枚举_任务管理执行前门控结果::仅允许等待
        ? 枚举_任务队列状态::等待
        : 枚举_任务队列状态::可运行;
    return 控制态;
}

inline 结构_任务控制事件 构造工作线程控制事件(
    const 结构_任务控制态& 控制态) noexcept
{
    结构_任务控制事件 控制事件{};
    控制事件.任务根ID = 控制态.任务根ID;
    控制事件.优先级 = 控制态.全局优先级;
    控制事件.时间预算_ms = 控制态.时间预算_ms;
    控制事件.资源预算 = 控制态.资源预算;
    控制事件.摘要 = 控制态.控制摘要;

    if (控制态.请求停止) {
        控制事件.事件类型 = 枚举_任务控制事件类型::停止;
    } else if (控制态.请求收束) {
        控制事件.事件类型 = 枚举_任务控制事件类型::收束;
    } else {
        控制事件.事件类型 = 枚举_任务控制事件类型::启动;
    }

    return 控制事件;
}

inline 枚举_批次执行去向 裁决批次执行去向(
    const 自我类& 自我对象,
    const 枚举_任务管理根层重判结果 根层重判结果,
    const 枚举_任务管理执行前门控结果 执行前门控结果,
    const 任务管理工作线程::结构_工作线程桥接结果& 桥接结果) noexcept
{
    if (根层重判结果 == 枚举_任务管理根层重判结果::停止退出边界
        || 执行前门控结果 == 枚举_任务管理执行前门控结果::禁止继续
        || 自我对象.是否已消亡()) {
        return 枚举_批次执行去向::停止;
    }

    if (根层重判结果 == 枚举_任务管理根层重判结果::收束优先
        || 执行前门控结果 == 枚举_任务管理执行前门控结果::仅允许收束
        || 桥接结果.最小回写结果.结算包.建议进入收束) {
        return 枚举_批次执行去向::进入收束;
    }

    if (根层重判结果 == 枚举_任务管理根层重判结果::待机保持
        || 执行前门控结果 == 枚举_任务管理执行前门控结果::仅允许等待
        || 自我对象.是否待机状态()) {
        return 枚举_批次执行去向::待机;
    }

    return 枚举_批次执行去向::继续提交;
}

} // namespace 自我线程消息批次执行器

