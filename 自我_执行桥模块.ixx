export module 自我_执行桥模块;

import 自我模块;
import 本能动作管理模块;
import 自我_结果治理模块;

export {

enum class 枚举_任务执行记账结果 : std::uint8_t {
    未定义 = 0,
    成功 = 1,
    失败 = 2,
    转学习 = 3,
};

struct 结构_方法上下文 {
    时间戳 now = 0;
    场景节点类* 输入观测包场景 = nullptr;
    场景节点类* 任务条件场景 = nullptr;
    场景节点类* 调用覆盖场景 = nullptr;
    方法类::节点类* 方法首节点 = nullptr;
    const 场景节点类* 当前场景 = nullptr;
    const 场景节点类* 条件场景 = nullptr;
};

struct 结构_方法执行结果 {
    bool 成功 = false;
    场景节点类* 结果存在集场景 = nullptr;
    场景节点类* 结果事件集场景 = nullptr;
    std::int64_t 成功码 = 0;
    std::int64_t 置信度 = 0;
    std::int64_t 质量_Q10000 = 0;
    std::int64_t 成本_Q10000 = 0;
    std::string 解释{};
};

struct 结构_任务步骤执行结果_最小 {
    bool 有效 = false;
    bool 建议转学习 = false;
    枚举_任务执行记账结果 记账结果 = 枚举_任务执行记账结果::未定义;
    任务类::节点类* 主任务 = nullptr;
    任务类::节点类* 当前步骤节点 = nullptr;
    任务类::节点类* 最近结果节点 = nullptr;
    方法类::节点类* 当前方法 = nullptr;
    场景节点类* 条件场景 = nullptr;
    场景节点类* 结果场景 = nullptr;
    结构_方法执行结果 方法执行结果{};
};

inline 结构_方法执行结果 从本能动作结果转换_最小_v0(
    const 结构_本能动作步骤结果& 输入,
    场景节点类* 默认结果存在集场景 = nullptr,
    场景节点类* 默认结果事件集场景 = nullptr) noexcept
{
    结构_方法执行结果 输出{};
    输出.成功 = 输入.成功码 == 0;
    输出.结果存在集场景 = 输入.结果存在集场景 ? 输入.结果存在集场景 : 默认结果存在集场景;
    输出.结果事件集场景 = 输入.结果事件集场景
        ? 输入.结果事件集场景
        : (默认结果事件集场景 ? 默认结果事件集场景 : 输出.结果存在集场景);
    输出.成功码 = 输入.成功码;
    输出.置信度 = 输出.成功 ? 10000 : 0;
    输出.质量_Q10000 = 输入.质量_Q10000;
    输出.成本_Q10000 = 输入.成本_Q10000;
    输出.解释 = 输入.备注;
    return 输出;
}

inline bool 是否任务筹办本能方法_最小_v0(const 方法类::节点类* 方法首节点) noexcept
{
    return 方法首节点
        && 方法首节点->主信息.动作句柄.类型 == 枚举_动作句柄类型::本能函数ID
        && 方法首节点->主信息.动作句柄.本能ID == static_cast<I64>(枚举_本能方法ID::自我_任务筹办);
}

inline bool 任务筹办要求待重入_最小_v0(
    const 方法类::节点类* 方法首节点,
    const 结构_方法执行结果& 执行结果) noexcept
{
    return 是否任务筹办本能方法_最小_v0(方法首节点)
        && 执行结果.成功码 == 本能方法结果_任务筹办已建立方法头待重入;
}

inline bool 任务筹办已转学习_最小_v0(
    const 方法类::节点类* 方法首节点,
    const 结构_方法执行结果& 执行结果) noexcept
{
    return 是否任务筹办本能方法_最小_v0(方法首节点)
        && 执行结果.成功码 == 本能方法结果_任务筹办已激活学习任务;
}

inline const 词性节点类* 私有_任务执行动态特征词_最小_v0() noexcept
{
    static const 词性节点类* s_词 = 语素集.添加词性词("任务执行动作", "名词");
    return s_词;
}

inline const 词性节点类* 私有_任务当前状态特征词_最小_v0() noexcept
{
    static const 词性节点类* s_词 = 语素集.添加词性词("任务当前状态", "名词");
    return s_词;
}

