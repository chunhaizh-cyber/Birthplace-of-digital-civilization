inline 动态节点类* 私有_记录任务执行动作动态_最小_v0(
    任务类::节点类* 主任务,
    任务类::节点类* 当前步骤,
    方法类::节点类* 当前方法,
    const 结构_方法执行结果& 执行结果,
    时间戳 now,
    const std::string& 调用点) noexcept
{
    if (!主任务) {
        return nullptr;
    }

    auto* 承载场景 = 主任务->主信息.场景.指针
        ? 主任务->主信息.场景.指针
        : (当前步骤 ? 当前步骤->主信息.场景.指针 : nullptr);
    auto* 任务虚拟存在 = 任务类::取或创建_任务虚拟存在(
        主任务,
        承载场景,
        调用点 + "/任务虚拟存在");
    if (!任务虚拟存在) {
        return nullptr;
    }

    auto* 任务内部世界 = 世界树.取或创建存在内部世界(
        任务虚拟存在,
        nullptr);
    auto* 动态特征 = 世界树.取或创建子特征_按类型(
        reinterpret_cast<基础信息节点类*>(任务虚拟存在),
        私有_任务执行动态特征词_最小_v0());
    if (!任务内部世界 || !动态特征) {
        return nullptr;
    }

    auto* 动态节点 = 世界树.动态().创建动作动态(
        任务内部世界,
        reinterpret_cast<基础信息节点类*>(任务虚拟存在),
        动态特征,
        now,
        now);
    if (!动态节点) {
        return nullptr;
    }

    if (auto* 动态主信息 = 世界树.动态().取动态主信息(动态节点)) {
        const auto* 动作名称 =
            当前方法 && 当前方法->主信息.动作名
            ? 当前方法->主信息.动作名
            : 私有_任务执行动态特征词_最小_v0();
        动态主信息->名称 = 动作名称;
        动态主信息->类型 = 动作名称;
        动态主信息->来源执行成功 = 执行结果.成功;
    }

    if (当前方法) {
        (void)世界树.动态().绑定来源方法(
            动态节点,
            reinterpret_cast<方法节点类*>(当前方法),
            当前方法->主信息.动作名
                ? 当前方法->主信息.动作名
                : 私有_任务执行动态特征词_最小_v0(),
            枚举_动作事件相位::完成);
    }
    (void)世界树.动态().绑定来源场景(
        动态节点,
        当前步骤 && 当前步骤->主信息.方法条件节点.指针
            ? 当前步骤->主信息.方法条件节点.指针
            : (当前步骤 ? 当前步骤->主信息.场景.指针 : 承载场景),
        执行结果.结果存在集场景
            ? 执行结果.结果存在集场景
            : 承载场景);
    return 动态节点;
}

inline void 私有_同步任务执行结果到虚拟存在_最小_v0(
    任务类::节点类* 主任务,
    方法类::节点类* 当前方法,
    任务类::节点类* 最近结果节点,
    const 结构_方法执行结果& 执行结果,
    枚举_任务执行记账结果 记账结果,
    时间戳 now,
    const std::string& 调用点) noexcept
{
    if (!主任务) {
        return;
    }

    auto* 承载场景 = 主任务->主信息.场景.指针;
    (void)任务类::初始化任务虚拟存在信息(
        主任务,
        承载场景,
        now,
        调用点 + "/初始化");
    (void)任务类::记录任务虚拟存在特征(
        主任务,
        私有_任务当前状态特征词_最小_v0(),
        特征值{ static_cast<I64>(主任务->主信息.状态) },
        承载场景,
        now,
        调用点 + "/任务当前状态");
    (void)任务类::记录任务虚拟存在特征(
        主任务,
        私有_任务最近执行成功码特征词_最小_v0(),
        特征值{ 执行结果.成功码 },
        承载场景,
        now,
        调用点 + "/成功码");
    (void)任务类::记录任务虚拟存在特征(
        主任务,
        私有_任务最近执行记账结果特征词_最小_v0(),
        特征值{ static_cast<I64>(记账结果) },
        承载场景,
        now,
        调用点 + "/记账结果");
    if (当前方法) {
        (void)任务类::记录任务虚拟存在特征(
            主任务,
            私有_任务最近执行方法特征词_最小_v0(),
            特征值{ 指针句柄{ reinterpret_cast<std::uintptr_t>(当前方法) } },
            承载场景,
            now,
            调用点 + "/执行方法");
    }
    if (最近结果节点) {
        (void)任务类::记录任务虚拟存在特征(
            主任务,
            私有_任务最近结果节点特征词_最小_v0(),
            特征值{ 指针句柄{ reinterpret_cast<std::uintptr_t>(最近结果节点) } },
            承载场景,
            now,
            调用点 + "/结果节点");
    }
}

class 自我_执行桥类 {
public:
    void 启动(std::uint32_t n)
    {
        工作者数量_ = n == 0 ? 1 : n;
        停止请求_ = false;
        取消请求_ = false;
    }

    void 请求停止()
    {
        停止请求_ = true;
    }

    void 等待停止()
    {
    }

    void 取消全部()
    {
        取消请求_ = true;
    }

    结构_方法执行结果 执行方法_同步等待(
        方法类::节点类* 方法首节点,
        场景节点类* 当前场景,
        场景节点类* 条件场景,
        时间戳 timeoutUs)
    {
        return 执行方法_同步等待(
            方法首节点,
            nullptr,
            当前场景,
            条件场景,
            nullptr,
            timeoutUs);
    }

    结构_方法执行结果 执行方法_同步等待(
        方法类::节点类* 方法首节点,
        任务类::节点类* 当前任务节点,
        场景节点类* 当前场景,
        场景节点类* 条件场景,
        场景节点类* 结果场景,
        时间戳 timeoutUs)
    {
        auto* 方法信息 = 方法首节点 ? &方法首节点->主信息 : nullptr;
        if (!方法信息 || 方法信息->节点种类 != 枚举_方法节点种类::方法首节点) {
            结构_方法执行结果 输出{};
            输出.成功码 = -1;
            输出.解释 = "方法首节点无效";
            return 输出;
        }

        auto* 默认结果场景 = 结果场景
            ? 结果场景
            : (方法信息->结果场景.指针
                ? 方法信息->结果场景.指针
                : 方法类::取或创建_方法结果场景(
                    方法首节点,
                    nullptr,
                    结构体_时间戳::当前_微秒(),
                    "自我_执行桥类::执行方法_同步等待/结果场景"));

        if (方法信息->动作句柄.类型 != 枚举_动作句柄类型::本能函数ID) {
            结构_方法执行结果 输出{};
            输出.结果存在集场景 = 默认结果场景;
            输出.结果事件集场景 = 当前场景 ? 当前场景 : 默认结果场景;
            输出.成功码 = -2;
            输出.解释 = "当前执行桥仅支持本能函数ID";
            return 输出;
        }

        auto 执行任务 = [=]() -> 结构_方法执行结果 {
            if (停止请求_ || 取消请求_) {
                结构_方法执行结果 输出{};
                输出.结果存在集场景 = 默认结果场景;
                输出.结果事件集场景 = 当前场景 ? 当前场景 : 默认结果场景;
                输出.成功码 = -4;
                输出.解释 = "执行桥已停止或取消";
                return 输出;
            }

            auto* 输入场景 = 条件场景 ? 条件场景 : 当前场景;
            auto* 输出场景 = 默认结果场景 ? 默认结果场景 : (当前场景 ? 当前场景 : 条件场景);
            auto* 执行场景 = 当前场景 ? 当前场景 : (输入场景 ? 输入场景 : 输出场景);
            结构_本能动作执行上下文 上下文{};
            上下文.世界树 = &世界树;
            上下文.任务 = 当前任务节点;
            上下文.任务节点 = 当前任务节点;
            上下文.场景 = 执行场景 ? 执行场景 : 输出场景;
            上下文.输入场景 = 输入场景 ? 输入场景 : 上下文.场景;
            上下文.输出场景 = 输出场景 ? 输出场景 : 上下文.输入场景;
            上下文.方法根 = 方法首节点;

            结构_本能动作步骤结果 步骤结果{};
            (void)取本能动作集().运行(
                static_cast<枚举_本能动作ID>(方法信息->动作句柄.本能ID),
                上下文,
                &步骤结果);
            return 从本能动作结果转换_最小_v0(
                步骤结果,
                上下文.输出场景,
                上下文.场景);
        };

        if (timeoutUs == 0) {
            return 执行任务();
        }

        auto Future = std::async(std::launch::async, 执行任务);
        const auto 状态 = Future.wait_for(std::chrono::microseconds(timeoutUs));
        if (状态 == std::future_status::ready) {
            return Future.get();
        }

        取消全部();

        结构_方法执行结果 输出{};
        输出.结果存在集场景 = 默认结果场景;
        输出.结果事件集场景 = 当前场景 ? 当前场景 : 默认结果场景;
        输出.成功码 = -3;
        输出.解释 = "timeout";
        return 输出;
    }

    结构_方法执行结果 执行方法_同步等待(
        方法类::节点类* 方法首节点,
        场景节点类* 当前场景,
        场景节点类* 条件场景,
        场景节点类* 结果场景,
        时间戳 timeoutUs)
    {
        return 执行方法_同步等待(
            方法首节点,
            nullptr,
            当前场景,
            条件场景,
            结果场景,
            timeoutUs);
    }

private:
    std::uint32_t 工作者数量_ = 1;
    bool 停止请求_ = false;
    bool 取消请求_ = false;
};

inline 任务类::节点类* 取步骤结果节点_最小_v0(任务类::节点类* 步骤节点) noexcept
{
    if (!步骤节点) {
        return nullptr;
    }

    auto* 后续 = reinterpret_cast<任务类::节点类*>(步骤节点->主信息.后续任务.指针);
    if (后续 && 后续->主信息.节点种类 == 枚举_任务节点种类::结果节点) {
        return 后续;
    }

    任务类::节点类* 最新实际结果 = nullptr;
    时间戳 最新实际时间 = 0;
    任务类::节点类* 最新预测结果 = nullptr;
    时间戳 最新预测时间 = 0;
    任务类::节点类* 首个结果 = nullptr;

    if (!步骤节点->子) {
        return nullptr;
    }

    auto* 起点 = static_cast<任务类::节点类*>(步骤节点->子);
    auto* 当前 = 起点;
    do {
        if (当前->主信息.节点种类 != 枚举_任务节点种类::结果节点) {
            当前 = static_cast<任务类::节点类*>(当前->下);
            continue;
        }

        if (!首个结果) {
            首个结果 = 当前;
        }

        const auto 当前时间 =
            当前->主信息.完成时间 != 0 ? 当前->主信息.完成时间 :
            (当前->主信息.启动时间 != 0 ? 当前->主信息.启动时间 : 当前->主信息.创建时间);
        if (当前->主信息.结果角色 == 枚举_任务结果角色::实际结果) {
            if (!最新实际结果 || 当前时间 >= 最新实际时间) {
                最新实际结果 = 当前;
                最新实际时间 = 当前时间;
            }
        }
        else {
            if (!最新预测结果 || 当前时间 >= 最新预测时间) {
                最新预测结果 = 当前;
                最新预测时间 = 当前时间;
            }
        }
        当前 = static_cast<任务类::节点类*>(当前->下);
    } while (当前 && 当前 != 起点);

    if (最新实际结果) {
        return 最新实际结果;
    }
    if (最新预测结果) {
        return 最新预测结果;
    }
    return 首个结果;
}

inline 任务类::节点类* 取步骤预测结果节点_最小_v0(
    任务类::节点类* 步骤节点,
    方法类::节点类* 当前方法 = nullptr) noexcept
{
    if (!步骤节点 || !步骤节点->子) {
        return nullptr;
    }

    const auto 目标方法主键 = 当前方法 ? 当前方法->获取主键() : std::string{};
    任务类::节点类* 最新预测结果 = nullptr;
    时间戳 最新预测时间 = 0;
    auto* 起点 = static_cast<任务类::节点类*>(步骤节点->子);
    auto* 当前 = 起点;
    do {
        if (当前->主信息.节点种类 != 枚举_任务节点种类::结果节点
            || 当前->主信息.结果角色 != 枚举_任务结果角色::预测结果) {
            当前 = static_cast<任务类::节点类*>(当前->下);
            continue;
        }

        if (!目标方法主键.empty()) {
            const auto 当前来源方法主键 = 当前->主信息.来源方法首节点.主键;
            if (!当前来源方法主键.empty() && 当前来源方法主键 != 目标方法主键) {
                当前 = static_cast<任务类::节点类*>(当前->下);
                continue;
            }
        }

        const auto 当前时间 =
            当前->主信息.完成时间 != 0 ? 当前->主信息.完成时间 :
            (当前->主信息.启动时间 != 0 ? 当前->主信息.启动时间 : 当前->主信息.创建时间);
        if (!最新预测结果 || 当前时间 >= 最新预测时间) {
            最新预测结果 = 当前;
            最新预测时间 = 当前时间;
        }
        当前 = static_cast<任务类::节点类*>(当前->下);
    } while (当前 && 当前 != 起点);

    return 最新预测结果;
}

inline 任务类::节点类* 取结果下一跳步骤节点_最小_v0(任务类::节点类* 结果节点) noexcept
{
    if (!结果节点 || 结果节点->主信息.节点种类 != 枚举_任务节点种类::结果节点) {
        return nullptr;
    }

    auto* 下一跳 = reinterpret_cast<任务类::节点类*>(结果节点->主信息.下一跳步骤节点.指针);
    if (下一跳 && 下一跳->主信息.节点种类 == 枚举_任务节点种类::步骤节点) {
        return 下一跳;
    }

    if (!结果节点->子) {
        return nullptr;
    }

    auto* 起点 = static_cast<任务类::节点类*>(结果节点->子);
    auto* 当前 = 起点;
    do {
        if (当前->主信息.节点种类 == 枚举_任务节点种类::步骤节点) {
            return 当前;
        }
        当前 = static_cast<任务类::节点类*>(当前->下);
    } while (当前 && 当前 != 起点);

    return nullptr;
}

inline bool 任务状态已终结_最小_v0(枚举_任务状态 状态) noexcept
{
    switch (状态) {
    case 枚举_任务状态::完成:
    case 枚举_任务状态::失败:
    case 枚举_任务状态::取消:
    case 枚举_任务状态::超时:
    case 枚举_任务状态::挂起:
        return true;
    default:
        return false;
    }
}

inline bool 结果不符合预期_最小_v0(任务类::节点类* 实际结果节点) noexcept
{
    if (!实际结果节点 || 实际结果节点->主信息.结果角色 != 枚举_任务结果角色::实际结果) {
        return false;
    }

    auto* 命中预测 = reinterpret_cast<任务类::节点类*>(实际结果节点->主信息.命中预测结果节点.指针);
    if (!命中预测) {
        return false;
    }
    auto* 预测状态 = 命中预测->主信息.结果状态信息.指针;
    auto* 实际状态 = 实际结果节点->主信息.结果状态信息.指针;
    return 预测状态 && 实际状态 && 预测状态 != 实际状态;
}

inline 场景节点类* 取步骤条件场景_最小_v0(任务类::节点类* 步骤节点) noexcept
{
    if (!步骤节点) {
        return nullptr;
    }
    return 步骤节点->主信息.方法条件节点.指针
        ? 步骤节点->主信息.方法条件节点.指针
        : 步骤节点->主信息.场景.指针;
}

inline 场景节点类* 取步骤上游结果场景_最小_v0(任务类::节点类* 步骤节点) noexcept
{
    if (!步骤节点 || !步骤节点->父) {
        return nullptr;
    }

    auto* 父节点 = static_cast<任务类::节点类*>(步骤节点->父);
    if (!父节点 || 父节点->主信息.节点种类 != 枚举_任务节点种类::结果节点) {
        return nullptr;
    }

    if (父节点->主信息.方法结果节点.指针) {
        return 父节点->主信息.方法结果节点.指针;
    }
    return 父节点->主信息.场景.指针;
}

inline 场景节点类* 取结果输出场景_最小_v0(
    任务类::节点类* 结果节点,
    任务类::节点类* 步骤节点 = nullptr) noexcept
{
    if (结果节点) {
        if (结果节点->主信息.方法结果节点.指针) {
            return 结果节点->主信息.方法结果节点.指针;
        }
        if (结果节点->主信息.场景.指针) {
            return 结果节点->主信息.场景.指针;
        }
    }
    return 步骤节点 ? 步骤节点->主信息.场景.指针 : nullptr;
}

inline void 同步场景索引_最小_v0(
    场景节点类* 来源场景,
    场景节点类* 目标场景) noexcept
{
    if (!来源场景 || !目标场景 || 来源场景 == 目标场景) {
        return;
    }

    const auto* 来源主信息 = 世界树.场景().取场景主信息(来源场景);
    if (!来源主信息) {
        return;
    }

    for (const auto& 状态引用 : 来源主信息->状态索引) {
        if (状态引用.指针) {
            (void)世界树.场景().追加状态(目标场景, 状态引用.指针);
        }
    }
    for (const auto& 动态引用 : 来源主信息->动态索引) {
        if (动态引用.指针) {
            (void)世界树.场景().追加动态(目标场景, 动态引用.指针);
        }
    }
    for (const auto& 关系引用 : 来源主信息->关系索引) {
        if (关系引用.指针) {
            (void)世界树.场景().追加关系(目标场景, 关系引用.指针);
        }
    }
    for (const auto& 二次特征引用 : 来源主信息->二次特征索引) {
        if (二次特征引用.指针) {
            (void)世界树.场景().追加二次特征(目标场景, 二次特征引用.指针);
        }
    }
    for (const auto& 因果引用 : 来源主信息->实例因果索引) {
        if (因果引用.指针) {
            (void)世界树.场景().追加实例因果(目标场景, 因果引用.指针);
        }
    }
}

inline void 同步任务实例条件场景_最小_v0(
    任务类::节点类* 主任务,
    任务类::节点类* 当前步骤,
    场景节点类* 当前场景,
    场景节点类* 条件场景) noexcept
{
    if (!条件场景) {
        return;
    }

    if (主任务 && 主任务->主信息.场景.指针) {
        同步场景索引_最小_v0(主任务->主信息.场景.指针, 条件场景);
    }
    if (当前场景) {
        同步场景索引_最小_v0(当前场景, 条件场景);
    }
    if (auto* 上游结果场景 = 取步骤上游结果场景_最小_v0(当前步骤)) {
        同步场景索引_最小_v0(上游结果场景, 条件场景);
    }
}

inline void 回并任务执行结果场景_最小_v0(
    任务类::节点类* 主任务,
    const 结构_方法执行结果& 执行结果) noexcept
{
    if (!主任务 || !主任务->主信息.场景.指针) {
        return;
    }

    auto* 任务场景 = 主任务->主信息.场景.指针;
    if (执行结果.结果存在集场景) {
        同步场景索引_最小_v0(执行结果.结果存在集场景, 任务场景);
    }
    if (执行结果.结果事件集场景) {
        同步场景索引_最小_v0(执行结果.结果事件集场景, 任务场景);
    }
}

inline 任务类::节点类* 确保根任务头_最小_v0(
    需求类::节点类* need,
    const 词性节点类* 名称,
    时间戳 now,
    const std::string& 调用点)
{
    (void)名称;
    (void)now;
    (void)调用点;
    auto* 自我对象 = 自我类::当前活动自我();
    if (!自我对象 || !need) {
        return nullptr;
    }
    if (need == 自我对象->获取安全根需求()) {
        return 自我对象->获取安全根任务();
    }
    if (need == 自我对象->获取服务根需求()) {
        return 自我对象->获取服务根任务();
    }
    return nullptr;
}

inline 任务类::节点类* 确保叶子任务头_最小_v0(
    需求类::节点类* need,
    需求类::节点类* 安全需求,
    需求类::节点类* 服务需求,
    任务类::节点类*& 安全任务,
    任务类::节点类*& 服务任务,
    const 词性节点类* 安全根任务名称,
    const 词性节点类* 服务根任务名称,
    时间戳 now,
    const std::string& 调用点)
{
    安全任务 = 确保根任务头_最小_v0(安全需求, 安全根任务名称, now, 调用点 + "/安全根");
    服务任务 = 确保根任务头_最小_v0(服务需求, 服务根任务名称, now, 调用点 + "/服务根");

    if (need == 安全需求) {
        return 安全任务;
    }
    if (need == 服务需求) {
        return 服务任务;
    }

    auto* 自我对象 = 自我类::当前活动自我();
    return 自我对象 ? 自我对象->获取当前主任务() : nullptr;
}

inline 任务类::节点类* 确保执行步骤节点_最小_v0(
    任务类::节点类* 任务头,
    方法类::节点类* 当前方法,
    时间戳 now,
    const std::string& 调用点)
{
    if (!任务头) {
        return nullptr;
    }

    auto* 当前步骤 = reinterpret_cast<任务类::节点类*>(任务头->主信息.当前步骤节点.指针);
    if (当前步骤 && 当前步骤->主信息.节点种类 == 枚举_任务节点种类::步骤节点) {
        auto* 当前执行方法 = reinterpret_cast<方法类::节点类*>(当前步骤->主信息.执行方法.指针);
        auto* 当前可用方法 = reinterpret_cast<方法类::节点类*>(当前步骤->主信息.可用方法首节点.指针);
        if (!当前方法 || 当前执行方法 == 当前方法 || 当前可用方法 == 当前方法) {
            return 当前步骤;
        }
    }

    任务类 临时树{};
    return 临时树.创建任务步骤节点(
        任务头,
        nullptr,
        reinterpret_cast<方法节点类*>(当前方法),
        nullptr,
        now,
        调用点);
}

inline 任务类::节点类* 创建执行结果节点_最小_v0(
    任务类::节点类* 任务头,
    任务类::节点类* 步骤节点,
    方法类::节点类* 当前方法,
    const 结构_方法执行结果& 执行结果,
    枚举_任务执行记账结果 记账结果,
    bool 建议转学习,
    时间戳 now,
    const std::string& 调用点)
{
    (void)调用点;
    if (!步骤节点) {
        return nullptr;
    }

    auto* 结果节点 = 取步骤结果节点_最小_v0(步骤节点);
    if (!结果节点 || 结果节点->主信息.结果角色 != 枚举_任务结果角色::实际结果) {
        return nullptr;
    }

    if (当前方法) {
        结果节点->主信息.执行方法.指针 = reinterpret_cast<方法节点类*>(当前方法);
        结果节点->主信息.执行方法.主键 = 当前方法->获取主键();
        结果节点->主信息.来源方法首节点.指针 = reinterpret_cast<方法节点类*>(当前方法);
        结果节点->主信息.来源方法首节点.主键 = 当前方法->获取主键();
    }
    if (执行结果.结果存在集场景) {
        结果节点->主信息.方法结果节点.指针 = 执行结果.结果存在集场景;
        结果节点->主信息.方法结果节点.主键 = 执行结果.结果存在集场景->获取主键();
    }
    结果节点->主信息.结果角色 = 枚举_任务结果角色::实际结果;
    结果节点->主信息.错误码 = 执行结果.成功码;
    结果节点->主信息.置信度_Q10000 = 执行结果.置信度;
    结果节点->主信息.启动时间 = 步骤节点->主信息.启动时间 != 0 ? 步骤节点->主信息.启动时间 : now;
    结果节点->主信息.完成时间 = now;
    结果节点->主信息.状态 =
        记账结果 == 枚举_任务执行记账结果::成功 ? 枚举_任务状态::完成 :
        (建议转学习 || 记账结果 == 枚举_任务执行记账结果::转学习 ? 枚举_任务状态::挂起 : 枚举_任务状态::失败);
    结果节点->主信息.统计.记录观测(now);

    if (任务头) {
        任务头->主信息.最近实际结果节点.指针 = reinterpret_cast<任务节点类*>(结果节点);
        任务头->主信息.最近实际结果节点.主键 = 结果节点->获取主键();
    }
    步骤节点->主信息.后续任务.指针 = reinterpret_cast<任务节点类*>(结果节点);
    步骤节点->主信息.后续任务.主键 = 结果节点->获取主键();
    return 结果节点;
}

inline void 推进任务执行前状态_最小_v0(
    任务类::节点类* 主任务,
    任务类::节点类* 当前步骤,
    方法类::节点类* 当前方法,
    时间戳 now,
    const std::string& 调用点)
{
    (void)调用点;
    if (主任务) {
        if (主任务->主信息.启动时间 == 0) {
            主任务->主信息.启动时间 = now;
        }
        主任务->主信息.状态 = 枚举_任务状态::运行中;
        主任务->主信息.统计.记录观测(now);
    }
    if (当前步骤) {
        if (当前步骤->主信息.启动时间 == 0) {
            当前步骤->主信息.启动时间 = now;
        }
        当前步骤->主信息.状态 = 枚举_任务状态::执行中;
        当前步骤->主信息.统计.记录观测(now);
    }
    if (当前步骤 && 当前方法 && !当前步骤->主信息.执行方法.指针) {
        当前步骤->主信息.执行方法.指针 = reinterpret_cast<方法节点类*>(当前方法);
        当前步骤->主信息.执行方法.主键 = 当前方法->获取主键();
    }
}

inline void 推进任务执行后状态_最小_v0(
    任务类::节点类* 主任务,
    任务类::节点类* 当前步骤,
    方法类::节点类* 当前方法,
    const 结构_需求结算结果_最小& 结算结果,
    枚举_任务执行记账结果 记账结果,
    const 结构_方法执行结果& 执行结果,
    任务类::节点类* 最近结果节点,
    时间戳 now,
    const std::string& 调用点)
{
    (void)结算结果;
    (void)调用点;
    const auto 默认结束状态 =
        记账结果 == 枚举_任务执行记账结果::成功 ? 枚举_任务状态::完成 :
        (记账结果 == 枚举_任务执行记账结果::转学习 ? 枚举_任务状态::挂起 : 枚举_任务状态::失败);
    const bool 需要回到重筹办 =
        任务筹办要求待重入_最小_v0(当前方法, 执行结果)
        || 结果不符合预期_最小_v0(最近结果节点);
    const auto 结束状态 = 需要回到重筹办
        ? 枚举_任务状态::待重筹办
        : 默认结束状态;

    if (当前步骤) {
        当前步骤->主信息.状态 = 结束状态;
        当前步骤->主信息.完成时间 = now;
        当前步骤->主信息.最近错误码 = 执行结果.成功码;
        当前步骤->主信息.统计.记录观测(now);
        if (当前方法 && !当前步骤->主信息.执行方法.指针) {
            当前步骤->主信息.执行方法.指针 = reinterpret_cast<方法节点类*>(当前方法);
            当前步骤->主信息.执行方法.主键 = 当前方法->获取主键();
        }
    }

    if (最近结果节点) {
        最近结果节点->主信息.状态 = 默认结束状态;
        最近结果节点->主信息.错误码 = 执行结果.成功码;
        最近结果节点->主信息.置信度_Q10000 = 执行结果.置信度;
        if (执行结果.结果存在集场景) {
            最近结果节点->主信息.方法结果节点.指针 = 执行结果.结果存在集场景;
            最近结果节点->主信息.方法结果节点.主键 = 执行结果.结果存在集场景->获取主键();
        }
        最近结果节点->主信息.完成时间 = now;
        最近结果节点->主信息.统计.记录观测(now);
    }

    if (主任务) {
        主任务->主信息.状态 = 结束状态;
        主任务->主信息.完成时间 = now;
        主任务->主信息.最近错误码 = 执行结果.成功码;
        主任务->主信息.统计.记录观测(now);
        if (最近结果节点) {
            主任务->主信息.最近实际结果节点.指针 = reinterpret_cast<任务节点类*>(最近结果节点);
            主任务->主信息.最近实际结果节点.主键 = 最近结果节点->获取主键();
        }
    }

    (void)私有_记录任务执行动作动态_最小_v0(
        主任务,
        当前步骤,
        当前方法,
        执行结果,
        now,
        调用点 + "/动作动态");
    私有_同步任务执行结果到虚拟存在_最小_v0(
        主任务,
        当前方法,
        最近结果节点,
        执行结果,
        记账结果,
        now,
        调用点 + "/任务虚拟存在");
    回并任务执行结果场景_最小_v0(主任务, 执行结果);
}

inline 结构_任务步骤执行结果_最小 执行任务步骤_最小_v0(
    自我_执行桥类& 执行桥,
    任务类::节点类* 主任务,
    方法类::节点类* 当前方法,
    时间戳 now = 结构体_时间戳::当前_微秒(),
    时间戳 timeoutUs = 0,
    bool 建议转学习 = false,
    const std::string& 调用点 = "执行任务步骤_最小_v0")
{
    结构_任务步骤执行结果_最小 输出{};
    输出.主任务 = 主任务;
    输出.当前方法 = 当前方法;
    输出.建议转学习 = 建议转学习;

    if (!主任务 || !当前方法) {
        输出.方法执行结果.成功码 = -10;
        输出.方法执行结果.解释 = "任务头或方法为空";
        输出.记账结果 = 建议转学习
            ? 枚举_任务执行记账结果::转学习
            : 枚举_任务执行记账结果::失败;
        return 输出;
    }

    if (now == 0) {
        now = 结构体_时间戳::当前_微秒();
    }

    auto* 当前步骤 = 确保执行步骤节点_最小_v0(
        主任务,
        当前方法,
        now,
        调用点 + "/确保步骤");
    if (!当前步骤) {
        输出.方法执行结果.成功码 = -11;
        输出.方法执行结果.解释 = "无法创建或获取步骤节点";
        输出.记账结果 = 建议转学习
            ? 枚举_任务执行记账结果::转学习
            : 枚举_任务执行记账结果::失败;
        return 输出;
    }

    auto* 当前结果 = 取步骤结果节点_最小_v0(当前步骤);
    const bool 复用当前实际结果 =
        当前结果
        && 当前结果->主信息.结果角色 == 枚举_任务结果角色::实际结果
        && !任务状态已终结_最小_v0(当前结果->主信息.状态);
    if (!复用当前实际结果) {
        任务类 临时树{};
        当前结果 = 临时树.创建任务结果节点(
            主任务,
            当前步骤,
            reinterpret_cast<方法节点类*>(当前方法),
            枚举_任务结果角色::实际结果,
            nullptr,
            now,
            调用点 + "/创建执行结果");
    }
    auto* 当前场景 = 当前步骤->主信息.场景.指针
        ? 当前步骤->主信息.场景.指针
        : 主任务->主信息.场景.指针;
    auto* 条件场景 = 取步骤条件场景_最小_v0(当前步骤);
    auto* 结果场景 = 取结果输出场景_最小_v0(当前结果, 当前步骤);

    输出.当前步骤节点 = 当前步骤;
    输出.最近结果节点 = 当前结果;
    输出.条件场景 = 条件场景;
    输出.结果场景 = 结果场景;

    同步任务实例条件场景_最小_v0(
        主任务,
        当前步骤,
        当前场景,
        条件场景);

    推进任务执行前状态_最小_v0(
        主任务,
        当前步骤,
        当前方法,
        now,
        调用点 + "/执行前");

    输出.方法执行结果 = 执行桥.执行方法_同步等待(
        当前方法,
        当前步骤,
        当前场景,
        条件场景,
        结果场景,
        timeoutUs);
    if (任务筹办已转学习_最小_v0(当前方法, 输出.方法执行结果)) {
        输出.建议转学习 = true;
        输出.记账结果 = 枚举_任务执行记账结果::转学习;
    } else {
        输出.记账结果 = 输出.方法执行结果.成功
            ? 枚举_任务执行记账结果::成功
            : (建议转学习 ? 枚举_任务执行记账结果::转学习 : 枚举_任务执行记账结果::失败);
    }

    当前结果 = 创建执行结果节点_最小_v0(
        主任务,
        当前步骤,
        当前方法,
        输出.方法执行结果,
        输出.记账结果,
        建议转学习,
        now,
        调用点 + "/结果写回");

    结构_需求结算结果_最小 空结算{};
    推进任务执行后状态_最小_v0(
        主任务,
        当前步骤,
        当前方法,
        空结算,
        输出.记账结果,
        输出.方法执行结果,
        当前结果,
        now,
        调用点 + "/执行后");

    输出.最近结果节点 = 当前结果;
    输出.结果场景 = 取结果输出场景_最小_v0(当前结果, 当前步骤);
    输出.有效 = true;
    return 输出;
}

} // export
