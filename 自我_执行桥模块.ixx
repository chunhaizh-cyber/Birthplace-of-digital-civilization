inline bool 私有_方法允许引导执行_执行桥_最小_v0(const 方法类::节点类* 方法) noexcept
{
    if (!方法
        || 方法->主信息.动作句柄.类型 != 枚举_动作句柄类型::本能函数ID
        || 方法->主信息.动作句柄.本能ID == 0) {
        return false;
    }

    switch (static_cast<枚举_本能方法ID>(方法->主信息.动作句柄.本能ID)) {
    case 枚举_本能方法ID::自我_任务筹办:
    case 枚举_本能方法ID::自我_任务执行一步:
    case 枚举_本能方法ID::自我_学习任务:
    case 枚举_本能方法ID::学习_尝试学习:
    case 枚举_本能方法ID::管理_确保单承载存在:
    case 枚举_本能方法ID::管理_读取单特征当前值:
    case 枚举_本能方法ID::管理_写入单特征当前值:
    case 枚举_本能方法ID::管理_写入单挂点指针:
    case 枚举_本能方法ID::管理_记录动作开始:
    case 枚举_本能方法ID::管理_记录动作结束:
    case 枚举_本能方法ID::管理_增加单特征当前值:
    case 枚举_本能方法ID::管理_减少单特征当前值:
    case 枚举_本能方法ID::管理_改变单特征当前值:
    case 枚举_本能方法ID::管理_形成治理特征面:
    case 枚举_本能方法ID::管理_刷新方法需求位特征:
    case 枚举_本能方法ID::管理_刷新治理二次特征证据:
    case 枚举_本能方法ID::管理_评估本能能力缺口:
    case 枚举_本能方法ID::管理_执行桥接补层裁决:
    case 枚举_本能方法ID::管理_沉淀运行方法证据:
        return true;
    default:
        return false;
    }
}

inline bool 私有_词性相同_执行桥_最小_v0(
    const 词性节点类* 左,
    const 词性节点类* 右) noexcept
{
    if (左 == 右) {
        return true;
    }
    if (!左 || !右) {
        return false;
    }
    return 左->获取主键() == 右->获取主键();
}

inline const 词性节点类* 私有_状态特征类型_执行桥_最小_v0(
    const 状态节点类* 状态节点) noexcept
{
    const auto* 状态主信息 = 状态节点
        ? 世界树.状态().取状态主信息(const_cast<状态节点类*>(状态节点))
        : nullptr;
    if (!状态主信息) {
        return nullptr;
    }

    auto* 特征节点 = 状态主信息->状态特征.指针;
    if (!特征节点 && !状态主信息->状态特征.主键.empty()) {
        特征节点 = dynamic_cast<特征节点类*>(
            世界树.基础信息().查找主键(状态主信息->状态特征.主键));
    }
    const auto* 特征主信息 = 特征节点 ? 世界树.特征().取特征主信息(特征节点) : nullptr;
    return 特征主信息 ? 特征主信息->类型 : nullptr;
}

inline 需求节点类* 私有_任务对应需求_执行桥_最小_v0(任务类::节点类* 任务) noexcept
{
    if (!任务) {
        return nullptr;
    }
    if (任务->主信息.对应需求.指针) {
        return reinterpret_cast<需求节点类*>(任务->主信息.对应需求.指针);
    }
    if (任务->主信息.来源需求.指针) {
        return reinterpret_cast<需求节点类*>(任务->主信息.来源需求.指针);
    }
    if (!任务->主信息.对应需求.主键.empty()) {
        return reinterpret_cast<需求节点类*>(
            世界树.基础信息().查找主键(任务->主信息.对应需求.主键));
    }
    if (!任务->主信息.来源需求.主键.empty()) {
        return reinterpret_cast<需求节点类*>(
            世界树.基础信息().查找主键(任务->主信息.来源需求.主键));
    }
    return nullptr;
}

inline 存在节点类* 私有_需求被需求存在_执行桥_最小_v0(需求节点类* 需求) noexcept
{
    if (!需求) {
        return nullptr;
    }
    if (需求->主信息.被需求存在.指针) {
        return reinterpret_cast<存在节点类*>(需求->主信息.被需求存在.指针);
    }
    if (!需求->主信息.被需求存在.主键.empty()) {
        return reinterpret_cast<存在节点类*>(
            世界树.基础信息().查找主键(需求->主信息.被需求存在.主键));
    }
    return nullptr;
}

inline const 词性节点类* 私有_任务需求目标特征_执行桥_最小_v0(
    任务类::节点类* 任务) noexcept
{
    auto* 需求 = 私有_任务对应需求_执行桥_最小_v0(任务);
    auto* 目标状态 = 需求
        ? (需求->主信息.需求状态.指针
            ? reinterpret_cast<状态节点类*>(需求->主信息.需求状态.指针)
            : (!需求->主信息.需求状态.主键.empty()
                ? reinterpret_cast<状态节点类*>(世界树.基础信息().查找主键(需求->主信息.需求状态.主键))
                : nullptr))
        : nullptr;
    if (const auto* 目标特征类型 = 私有_状态特征类型_执行桥_最小_v0(目标状态)) {
        return 目标特征类型;
    }
    if (任务) {
        if (const auto* 任务目标特征类型 = 私有_状态特征类型_执行桥_最小_v0(
                任务->主信息.目标状态.指针)) {
            return 任务目标特征类型;
        }
    }
    return 私有_任务状态特征类型_执行桥_最小_v0();
}

inline 二次特征节点类* 私有_任务需求方向_执行桥_最小_v0(任务类::节点类* 任务) noexcept
{
    auto* 需求 = reinterpret_cast<需求类::节点类*>(私有_任务对应需求_执行桥_最小_v0(任务));
    if (!需求) {
        return nullptr;
    }
    需求类 需求服务{};
    return 需求服务.获取需求方向(需求);
}

inline bool 私有_二次特征引用命中_执行桥_最小_v0(
    const 可解析引用<二次特征节点类>& 引用,
    const 二次特征节点类* 节点) noexcept
{
    if (!节点) {
        return false;
    }
    if (引用.指针 == 节点) {
        return true;
    }
    const auto 节点主键 = 节点->获取主键();
    return !节点主键.empty() && 引用.主键 == 节点主键;
}

inline bool 私有_方法结果方向命中_执行桥_最小_v0(
    const 方法类::节点类* 方法,
    const 二次特征节点类* 需求方向) noexcept
{
    if (!方法 || !需求方向) {
        return false;
    }
    for (const auto& 方向引用 : 方法->主信息.结果方向索引) {
        if (私有_二次特征引用命中_执行桥_最小_v0(方向引用, 需求方向)) {
            return true;
        }
    }
    return false;
}

inline 方法类::节点类* 私有_查找方法首节点_按结果特征_执行桥_最小_v0(
    方法类::节点类* 方法根节点,
    const 词性节点类* 目标特征类型,
    const 二次特征节点类* 需求方向 = nullptr) noexcept
{
    if (!方法根节点 || !目标特征类型) {
        return nullptr;
    }
    auto* 根节点 = 方法根节点;
    while (根节点->父) {
        根节点 = reinterpret_cast<方法类::节点类*>(根节点->父);
    }

    auto* 首子 = reinterpret_cast<方法类::节点类*>(根节点->子);
    if (!首子) {
        return nullptr;
    }
    auto* 当前 = 首子;
    方法类::节点类* 特征候选 = nullptr;
    std::size_t 保护计数 = 0;
    do {
        if (当前
            && 当前->主信息.节点种类 == 枚举_方法节点种类::方法首节点
            && 私有_词性相同_执行桥_最小_v0(当前->主信息.主结果特征类型, 目标特征类型)) {
            if (需求方向 && 私有_方法结果方向命中_执行桥_最小_v0(当前, 需求方向)) {
                return 当前;
            }
            if (!特征候选 && (!需求方向 || 当前->主信息.结果方向索引.empty())) {
                特征候选 = 当前;
            }
        }
        当前 = 当前 ? reinterpret_cast<方法类::节点类*>(当前->下) : nullptr;
        ++保护计数;
    } while (当前 && 当前 != 首子 && 保护计数 < 4096);
    return 特征候选;
}

inline 方法类::节点类* 私有_按需求查找或建立候选方法_执行桥_最小_v0(
    任务类::节点类* 任务,
    时间戳 now,
    const std::string& 调用点) noexcept
{
    if (!任务) {
        return nullptr;
    }
    const auto* 目标特征类型 = 私有_任务需求目标特征_执行桥_最小_v0(任务);
    if (!目标特征类型) {
        return nullptr;
    }
    auto* 需求方向 = 私有_任务需求方向_执行桥_最小_v0(任务);

    auto* 需求 = 私有_任务对应需求_执行桥_最小_v0(任务);
    auto* 被需求存在 = 私有_需求被需求存在_执行桥_最小_v0(需求);
    auto* 自我存在 = 世界树.自我指针 ? 世界树.自我指针 : 世界树.取或创建自我存在();
    auto* 方法宿主 = 被需求存在 ? 被需求存在 : 自我存在;
    auto* 方法根 = 方法宿主 ? 世界树.存在().获取方法根节点(方法宿主) : nullptr;
    if (!方法根 && 自我存在) {
        方法根 = 世界树.存在().获取方法根节点(自我存在);
    }
    if (!方法根) {
        return nullptr;
    }

    auto* 候选方法 = 私有_查找方法首节点_按结果特征_执行桥_最小_v0(
        方法根,
        目标特征类型,
        需求方向);
    if (!候选方法) {
        候选方法 = 方法类::注册需求方向方法首节点(
            方法根,
            目标特征类型,
            需求方向,
            枚举_方法来源::运行时学习沉淀,
            now,
            调用点 + "/需求位方法头");
    }
    if (!候选方法) {
        return nullptr;
    }

    任务->主信息.候选方法首节点.绑定(reinterpret_cast<方法节点类*>(候选方法));
    if (!任务->主信息.执行方法.有效()) {
        任务->主信息.执行方法.绑定(reinterpret_cast<方法节点类*>(候选方法));
    }
    if (const I64 能力值 = 私有_方法自我能力值_执行桥_最小_v0(候选方法); 能力值 != 0) {
        任务->主信息.选中自我能力值 = 能力值;
    }
    return 候选方法;
}

inline bool 私有_方法当前可用_执行桥_最小_v0(
    方法类::节点类* 方法,
    时间戳 now) noexcept
{
    if (!方法) {
        return false;
    }
    if (私有_方法允许引导执行_执行桥_最小_v0(方法)) {
        return true;
    }
    auto* 方法虚拟存在 = 方法->主信息.方法虚拟存在.指针
        ? 方法->主信息.方法虚拟存在.指针
        : 方法类::取或创建_方法虚拟存在(
            方法,
            nullptr,
            now,
            "执行任务/方法可用判断/虚拟存在");
    I64 可用值 = 0;
    if (方法虚拟存在
        && 世界树.读取特征_I64(
            reinterpret_cast<const 基础信息节点类*>(方法虚拟存在),
            私有_方法是否可用特征类型_执行桥_最小_v0(),
            可用值)) {
        return 可用值 != 0;
    }
    return false;
}

inline I64 私有_方法条件节点数量_执行桥_最小_v0(const 方法类::节点类* 方法) noexcept
{
    if (!方法 || !方法->子) {
        return 0;
    }
    I64 数量 = 0;
    auto* 首节点 = reinterpret_cast<const 方法类::节点类*>(方法->子);
    auto* 当前 = 首节点;
    std::size_t 保护计数 = 0;
    do {
        if (当前 && 当前->主信息.节点种类 == 枚举_方法节点种类::方法条件节点) {
            ++数量;
        }
        当前 = 当前 ? reinterpret_cast<const 方法类::节点类*>(当前->下) : nullptr;
        ++保护计数;
    } while (当前 && 当前 != 首节点 && 保护计数 < 4096);
    return 数量;
}

inline I64 私有_方法动作骨架数量_执行桥_最小_v0(const 方法类::节点类* 方法) noexcept
{
    return 方法 && 方法->主信息.有动作骨架() ? 1 : 0;
}

inline I64 私有_方法结果节点数量_执行桥_最小_v0(const 方法类::节点类* 方法) noexcept
{
    if (!方法 || !方法->子) {
        return 0;
    }
    I64 数量 = 0;
    auto* 首节点 = reinterpret_cast<const 方法类::节点类*>(方法->子);
    auto* 当前 = 首节点;
    std::size_t 保护计数 = 0;
    do {
        if (当前 && 当前->主信息.节点种类 == 枚举_方法节点种类::方法结果节点) {
            ++数量;
        }
        当前 = 当前 ? reinterpret_cast<const 方法类::节点类*>(当前->下) : nullptr;
        ++保护计数;
    } while (当前 && 当前 != 首节点 && 保护计数 < 4096);
    return 数量;
}

inline I64 私有_方法可执行入口数量_执行桥_最小_v0(const 方法类::节点类* 方法) noexcept
{
    return 方法
        && 方法->主信息.动作句柄.类型 == 枚举_动作句柄类型::本能函数ID
        && 方法->主信息.动作句柄.本能ID != 0
        ? 1
        : 0;
}

inline void 私有_填充方法特征需求状态_执行桥_最小_v0(
    方法类::节点类* 方法,
    const 词性节点类* 特征类型,
    I64 当前值,
    I64 目标值,
    场景节点类*& 结果场景,
    时间戳 now,
    const std::string& 调用点) noexcept
{
    if (!方法 || !特征类型) {
        return;
    }
    auto* 方法虚拟存在 = 方法类::取或创建_方法虚拟存在(
            方法,
            nullptr,
            now,
            调用点 + "/方法虚拟存在");
    if (!方法虚拟存在) {
        return;
    }

    auto* 方法存在基础 = reinterpret_cast<基础信息节点类*>(方法虚拟存在);
    auto* 状态特征 = 世界树.确保特征(方法存在基础, 特征类型);
    if (!状态特征) {
        return;
    }
    (void)世界树.写入特征_I64(方法虚拟存在, 特征类型, 当前值, now);

    auto* 状态场景 = 结果场景;
    if (!状态场景) {
        状态场景 = 方法类::取或创建_方法结果场景(
            方法,
            nullptr,
            now,
            调用点 + "/方法结果场景");
    }
    if (!状态场景) {
        状态场景 = 世界树.取或创建自我现实场景();
    }
    if (!状态场景) {
        return;
    }
    结果场景 = 状态场景;

    (void)世界树.状态().创建内部状态(
        状态场景,
        方法存在基础,
        状态特征,
        当前值,
        枚举_存在状态事件::创建,
        false,
        now,
        {},
        调用点 + "/需求当前状态");
    (void)世界树.状态().创建内部状态(
        状态场景,
        方法存在基础,
        状态特征,
        目标值,
        枚举_存在状态事件::变化,
        当前值 != 目标值,
        now,
        {},
        调用点 + "/需求目标状态");
}

inline 特征节点类* 私有_填充方法不可用执行结果_执行桥_最小_v0(
    方法类::节点类* 方法,
    场景节点类*& 结果场景,
    时间戳 now,
    const std::string& 调用点) noexcept
{
    私有_填充方法特征需求状态_执行桥_最小_v0(
        方法,
        私有_方法是否可用特征类型_执行桥_最小_v0(),
        static_cast<I64>(0),
        static_cast<I64>(1),
        结果场景,
        now,
        调用点 + "/方法是否可用");
    return 创建本能动作运行结果实例_按码(
        方法,
        结果场景,
        本能方法结果_任务缺方法需任务管理任务,
        now);
}

