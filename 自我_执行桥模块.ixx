inline bool 私有_方法允许引导执行_执行桥_最小_v0(const 方法类::节点类* 方法) noexcept
{
    if (!方法
        || 方法->主信息.首节点信息().动作句柄.类型 != 枚举_动作句柄类型::本能函数ID
        || 方法->主信息.首节点信息().动作句柄.本能ID == 0) {
        return false;
    }

    switch (static_cast<枚举_本能方法ID>(方法->主信息.首节点信息().动作句柄.本能ID)) {
    case 枚举_本能方法ID::自我_练习:
    case 枚举_本能方法ID::自我_尝试学习:
    case 枚举_本能方法ID::自我_定向学习:
    case 枚举_本能方法ID::自我_查找特征类型:
    case 枚举_本能方法ID::自我_配对参数:
    case 枚举_本能方法ID::自我_改变特征值:
    case 枚举_本能方法ID::自我_检查需求是否满足:
    case 枚举_本能方法ID::管理_确保单承载存在:
    case 枚举_本能方法ID::管理_读取单特征当前值:
    case 枚举_本能方法ID::管理_写入单特征当前值:
    case 枚举_本能方法ID::管理_写入单挂点指针:
    case 枚举_本能方法ID::管理_记录动作开始:
    case 枚举_本能方法ID::管理_记录动作结束:
    case 枚举_本能方法ID::管理_增加单特征当前值:
    case 枚举_本能方法ID::管理_减少单特征当前值:
    case 枚举_本能方法ID::管理_改变单特征当前值:
    case 枚举_本能方法ID::管理_形成治理特征面:
    case 枚举_本能方法ID::管理_刷新方法需求位特征:
    case 枚举_本能方法ID::管理_刷新治理二次特征证据:
    case 枚举_本能方法ID::管理_评估本能能力缺口:
    case 枚举_本能方法ID::管理_执行桥接补层裁决:
    case 枚举_本能方法ID::管理_沉淀运行方法证据:
        return true;
    default:
        return false;
    }
}

inline bool 私有_方法当前可用_执行桥_最小_v0(
    方法类::节点类* 方法,
    时间戳 now) noexcept
{
    if (!方法) {
        return false;
    }
    if (私有_方法允许引导执行_执行桥_最小_v0(方法)) {
        return true;
    }
    auto* 方法虚拟存在 = 方法->主信息.首节点信息().方法虚拟存在.指针
        ? 方法->主信息.首节点信息().方法虚拟存在.指针
        : 方法虚拟存在服务类::取或创建方法虚拟存在(
            方法,
            nullptr,
            now);
    I64 可用值 = 0;
    if (方法虚拟存在
        && 世界树.读取特征_I64(
            reinterpret_cast<const 基础信息节点类*>(方法虚拟存在),
            私有_方法是否可用特征类型_执行桥_最小_v0(),
            可用值)) {
        return 可用值 != 0;
    }
    return false;
}

inline I64 私有_方法条件节点数量_执行桥_最小_v0(const 方法类::节点类* 方法) noexcept
{
    if (!方法 || !方法->子) {
        return 0;
    }
    I64 数量 = 0;
    auto* 首节点 = reinterpret_cast<const 方法类::节点类*>(方法->子);
    auto* 当前 = 首节点;
    std::size_t 保护计数 = 0;
    do {
        if (当前 && 当前->主信息.公共.节点种类 == 枚举_方法节点种类::方法条件节点) {
            ++数量;
        }
        当前 = 当前 ? reinterpret_cast<const 方法类::节点类*>(当前->下) : nullptr;
        ++保护计数;
    } while (当前 && 当前 != 首节点 && 保护计数 < 4096);
    return 数量;
}

inline I64 私有_方法动作骨架数量_执行桥_最小_v0(const 方法类::节点类* 方法) noexcept
{
    return 方法 && 方法->主信息.有动作骨架() ? 1 : 0;
}

inline I64 私有_方法结果节点数量_执行桥_最小_v0(const 方法类::节点类* 方法) noexcept
{
    if (!方法 || !方法->子) {
        return 0;
    }
    I64 数量 = 0;
    auto* 首节点 = reinterpret_cast<const 方法类::节点类*>(方法->子);
    auto* 当前 = 首节点;
    std::size_t 保护计数 = 0;
    do {
        if (当前 && 当前->主信息.公共.节点种类 == 枚举_方法节点种类::方法结果节点) {
            ++数量;
        }
        当前 = 当前 ? reinterpret_cast<const 方法类::节点类*>(当前->下) : nullptr;
        ++保护计数;
    } while (当前 && 当前 != 首节点 && 保护计数 < 4096);
    return 数量;
}

inline I64 私有_方法可执行入口数量_执行桥_最小_v0(const 方法类::节点类* 方法) noexcept
{
    return 方法
        && 方法->主信息.首节点信息().动作句柄.类型 == 枚举_动作句柄类型::本能函数ID
        && 方法->主信息.首节点信息().动作句柄.本能ID != 0
        ? 1
        : 0;
}

inline void 私有_填充方法特征需求状态_执行桥_最小_v0(
    方法类::节点类* 方法,
    const 词性节点类* 特征类型,
    I64 当前值,
    I64 目标值,
    场景节点类*& 结果场景,
    时间戳 now) noexcept
{
    if (!方法 || !特征类型) {
        return;
    }
    auto* 方法虚拟存在 = 方法虚拟存在服务类::取或创建方法虚拟存在(
            方法,
            nullptr,
            now);
    if (!方法虚拟存在) {
        return;
    }

    auto* 方法存在基础 = reinterpret_cast<基础信息节点类*>(方法虚拟存在);
    auto* 状态特征 = 世界树.确保特征(方法存在基础, 特征类型);
    if (!状态特征) {
        return;
    }
    (void)世界树.写入特征_I64(方法虚拟存在, 特征类型, 当前值, now);

    auto* 状态场景 = 结果场景;
    if (!状态场景) {
        状态场景 = 方法类::取或创建_方法结果场景(
            方法,
            nullptr,
            now);
    }
    if (!状态场景) {
        状态场景 = 世界树.取或创建自我现实场景();
    }
    if (!状态场景) {
        return;
    }
    结果场景 = 状态场景;

    (void)世界树.状态().创建内部状态(
        状态场景,
        方法存在基础,
        状态特征,
        当前值,
        枚举_存在状态事件::创建,
        false,
        now);
    (void)世界树.状态().创建内部状态(
        状态场景,
        方法存在基础,
        状态特征,
        目标值,
        枚举_存在状态事件::变化,
        当前值 != 目标值,
        now);
}

inline 特征节点类* 私有_填充方法不可用执行结果_执行桥_最小_v0(
    方法类::节点类* 方法,
    场景节点类*& 结果场景,
    时间戳 now) noexcept
{
    私有_填充方法特征需求状态_执行桥_最小_v0(
        方法,
        私有_方法是否可用特征类型_执行桥_最小_v0(),
        static_cast<I64>(0),
        static_cast<I64>(1),
        结果场景,
        now);
    return 创建本能动作运行结果实例_按码(
        方法,
        结果场景,
        本能方法结果_任务缺条件需自我线程,
        now);
}

inline 特征节点类* 私有_填充方法可用确认执行结果_执行桥_最小_v0(
    方法类::节点类* 方法,
    场景节点类*& 结果场景,
    时间戳 now) noexcept
{
    私有_填充方法特征需求状态_执行桥_最小_v0(
        方法,
        私有_方法是否可用特征类型_执行桥_最小_v0(),
        static_cast<I64>(1),
        static_cast<I64>(1),
        结果场景,
        now);
    return 创建本能动作运行结果实例_按码(
        方法,
        结果场景,
        本能动作运行结果_成功,
        now);
}

inline 特征节点类* 私有_填充方法缺动作骨架执行结果_执行桥_最小_v0(
    方法类::节点类* 方法,
    场景节点类*& 结果场景,
    时间戳 now) noexcept
{
    私有_填充方法特征需求状态_执行桥_最小_v0(
        方法,
        私有_方法动作骨架数量特征类型_执行桥_最小_v0(),
        私有_方法动作骨架数量_执行桥_最小_v0(方法),
        static_cast<I64>(1),
        结果场景,
        now);
    return 创建本能动作运行结果实例_按码(
        方法,
        结果场景,
        本能方法结果_任务缺条件需自我线程,
        now);
}

inline 特征节点类* 私有_填充方法缺可执行入口执行结果_执行桥_最小_v0(
    方法类::节点类* 方法,
    场景节点类*& 结果场景,
    时间戳 now) noexcept
{
    私有_填充方法特征需求状态_执行桥_最小_v0(
        方法,
        私有_方法可执行入口数量特征类型_执行桥_最小_v0(),
        私有_方法可执行入口数量_执行桥_最小_v0(方法),
        static_cast<I64>(1),
        结果场景,
        now);
    return 创建本能动作运行结果实例_按码(
        方法,
        结果场景,
        本能方法结果_任务缺条件需自我线程,
        now);
}

inline 特征节点类* 私有_填充方法缺条件节点执行结果_执行桥_最小_v0(
    方法类::节点类* 方法,
    场景节点类*& 结果场景,
    时间戳 now) noexcept
{
    私有_填充方法特征需求状态_执行桥_最小_v0(
        方法,
        私有_方法条件节点数量特征类型_执行桥_最小_v0(),
        私有_方法条件节点数量_执行桥_最小_v0(方法),
        static_cast<I64>(1),
        结果场景,
        now);
    return 创建本能动作运行结果实例_按码(
        方法,
        结果场景,
        本能方法结果_任务缺条件需自我线程,
        now);
}

inline 特征节点类* 私有_填充方法缺结果节点执行结果_执行桥_最小_v0(
    方法类::节点类* 方法,
    场景节点类*& 结果场景,
    时间戳 now) noexcept
{
    私有_填充方法特征需求状态_执行桥_最小_v0(
        方法,
        私有_方法结果节点数量特征类型_执行桥_最小_v0(),
        私有_方法结果节点数量_执行桥_最小_v0(方法),
        static_cast<I64>(1),
        结果场景,
        now);
    return 创建本能动作运行结果实例_按码(
        方法,
        结果场景,
        本能方法结果_任务缺条件需自我线程,
        now);
}

inline void 私有_记录方法执行条件结果节点_执行桥_最小_v0(
    方法类::节点类* 方法,
    场景节点类* 输入场景,
    场景节点类*& 输出场景,
    时间戳 开始时间,
    时间戳 结束时间) noexcept
{
    if (!方法 || !输入场景) {
        return;
    }

    if (!输出场景) {
        输出场景 = 方法类::取或创建_方法结果场景(
            方法,
            nullptr,
            结束时间);
    }

    auto* 方法条件场景 = 方法类::取或创建_方法条件场景(
            方法,
            nullptr,
            开始时间);
    auto* 方法结果场景 = 方法类::取或创建_方法结果场景(
            方法,
            nullptr,
            结束时间);

    (void)方法类::创建条件节点(
        方法,
        方法条件场景,
        {},
        {},
        开始时间,
        结束时间);

    if (方法结果场景) {
        (void)方法类::创建结果节点(
            方法,
            方法结果场景,
            {});
    }
}

class 自我_执行桥类 {
public:
    void 启动(std::uint32_t n)
    {
        工作者数量_ = n == 0 ? 1 : n;
        停止请求_ = false;
        取消请求_ = false;
    }

    void 请求停止()
    {
        停止请求_ = true;
    }

    void 等待停止()
    {
    }

    void 取消全部()
    {
        取消请求_ = true;
    }

    特征节点类* 执行方法_同步等待(
        方法类::节点类* 方法首节点,
        场景节点类* 当前场景,
        场景节点类* 条件场景,
        时间戳 timeoutUs)
    {
        return 执行方法_同步等待(
            方法首节点,
            nullptr,
            当前场景,
            条件场景,
            nullptr,
            timeoutUs);
    }

    特征节点类* 执行方法_同步等待(
        方法类::节点类* 方法首节点,
        场景节点类* 当前场景,
        场景节点类* 条件场景,
        场景节点类* 结果场景,
        时间戳 timeoutUs)
    {
        return 执行方法_同步等待(
            方法首节点,
            nullptr,
            当前场景,
            条件场景,
            结果场景,
            timeoutUs);
    }

    特征节点类* 执行方法_同步等待(
        方法类::节点类* 方法首节点,
        任务类::节点类* 当前任务节点,
        场景节点类* 当前场景,
        场景节点类* 条件场景,
        场景节点类* 结果场景,
        时间戳 timeoutUs)
    {
        const auto 入口时间 = 结构体_时间戳::当前_微秒();
        if (当前任务节点 && 任务类::读取任务选中自我能力值(当前任务节点) != 0) {
            if (auto* 能力方法 = 私有_解析任务选中自我能力方法_执行桥_最小_v0(
                    当前任务节点,
                    入口时间)) {
                方法首节点 = 能力方法;
            }
            else {
                return 创建本能动作运行结果实例_按码(
                    方法首节点,
                    结果场景 ? 结果场景 : 当前场景,
                    -1,
                    入口时间);
            }
        }

        auto* 方法信息 = 方法首节点 ? &方法首节点->主信息 : nullptr;
        const auto* 首节点信息 = 方法信息 ? 方法信息->取首节点信息() : nullptr;
        if (!方法信息 || !首节点信息) {
            return 创建本能动作运行结果实例_按码(
                方法首节点,
                结果场景 ? 结果场景 : 当前场景,
                -1,
                入口时间);
        }

        auto* 默认结果场景 = 结果场景
            ? 结果场景
            : 方法类::取或创建_方法结果场景(
                方法首节点,
                nullptr,
                结构体_时间戳::当前_微秒());
        auto* 默认方法虚拟存在 = 方法虚拟存在服务类::取或创建方法虚拟存在(
            方法首节点,
            nullptr,
            结构体_时间戳::当前_微秒());

        const auto 当前时间 = 结构体_时间戳::当前_微秒();
        if (!私有_方法当前可用_执行桥_最小_v0(方法首节点, 当前时间)) {
            return 私有_填充方法不可用执行结果_执行桥_最小_v0(
                方法首节点,
                默认结果场景,
                当前时间);
        }

        auto* 执行条件场景 = 条件场景
            ? 条件场景
            : 私有_真实执行条件场景_执行桥_最小_v0(方法首节点, 当前场景);
        const bool 条件类型描述为无输入 =
            私有_方法条件类型描述为无输入_执行桥_最小_v0(默认方法虚拟存在);
        if (!执行条件场景 && !条件类型描述为无输入) {
            return 私有_填充方法缺条件节点执行结果_执行桥_最小_v0(
                方法首节点,
                默认结果场景,
                当前时间);
        }

        if (首节点信息->动作句柄.类型 != 枚举_动作句柄类型::本能函数ID) {
            return 私有_填充方法缺可执行入口执行结果_执行桥_最小_v0(
                方法首节点,
                默认结果场景,
                当前时间);
        }

        auto 执行体 = [=]() -> 特征节点类* {
            if (停止请求_ || 取消请求_) {
                return 创建本能动作运行结果实例_按码(
                    方法首节点,
                    默认结果场景,
                    -4);
            }

            auto* 输入场景 = 执行条件场景 ? 执行条件场景 : 当前场景;
            auto* 输出场景 = 默认结果场景 ? 默认结果场景 : (当前场景 ? 当前场景 : 条件场景);
            auto* 实际输入场景 = 输入场景 ? 输入场景 : (当前场景 ? 当前场景 : 输出场景);
            auto* 实际输出场景 = 输出场景 ? 输出场景 : 实际输入场景;

            const auto 动作开始时间 = 结构体_时间戳::当前_微秒();
            auto* 运行结果 = 取本能动作集().执行功能函数(
                static_cast<枚举_本能动作ID>(首节点信息->动作句柄.本能ID),
                方法首节点,
                实际输入场景,
                实际输出场景);
            const auto 动作结束时间 = 结构体_时间戳::当前_微秒();
            const auto 运行码 = 本能动作运行结果值(运行结果);
            (void)私有_创建方法调用动作动态_执行桥_最小_v0(
                方法首节点,
                实际输入场景,
                实际输出场景,
                动作开始时间,
                动作结束时间,
                运行码 == 0,
                运行码);
            私有_记录方法执行条件结果节点_执行桥_最小_v0(
                方法首节点,
                实际输入场景,
                实际输出场景,
                动作开始时间,
                动作结束时间);
            return 运行结果
                ? 运行结果
                : 创建本能动作运行结果实例_按码(方法首节点, 实际输出场景, 本能动作运行结果_未知);
        };

        if (timeoutUs == 0) {
            return 执行体();
        }

        auto Future = std::async(std::launch::async, 执行体);
        const auto 状态 = Future.wait_for(std::chrono::microseconds(timeoutUs));
        if (状态 == std::future_status::ready) {
            return Future.get();
        }

        取消全部();
        return 创建本能动作运行结果实例(
            方法首节点,
            默认结果场景,
            "执行超时",
            -3);
    }

private:
    std::uint32_t 工作者数量_ = 1;
    bool 停止请求_ = false;
    bool 取消请求_ = false;
};

inline void 私有_同步任务执行记录_最小_v0(
    任务类::节点类* 任务,
    方法类::节点类* 方法,
    const 特征节点类* 方法运行结果,
    枚举_任务执行记账结果 记账结果,
    时间戳 开始时间,
    时间戳 结束时间) noexcept
{
    if (!任务) {
        return;
    }

    const auto 执行后状态 =
        记账结果 == 枚举_任务执行记账结果::成功 ? 枚举_任务状态::完成 : 枚举_任务状态::失败;
    const auto 运行码 = 本能动作运行结果值(方法运行结果);
    (void)任务类::写入任务状态(任务, 执行后状态, nullptr, 结束时间);
    (void)任务类::写入任务最近错误码(任务, 运行码);
    (void)任务类::写入任务运行次数(
        任务,
        任务类::读取任务运行次数(任务) + 1);
    if (运行码 == 0) {
        (void)任务类::写入任务成功次数(
            任务,
            任务类::读取任务成功次数(任务) + 1);
        (void)任务类::写入任务连续失败次数(任务, 0);
    } else {
        (void)任务类::写入任务失败次数(
            任务,
            任务类::读取任务失败次数(任务) + 1);
        (void)任务类::写入任务连续失败次数(
            任务,
            任务类::读取任务连续失败次数(任务) + 1);
    }
    (void)任务类::同步任务运行镜像特征(任务, nullptr, 结束时间);
}

inline 方法类::节点类* 私有_取任务执行方法_最小_v0(任务类::节点类* 任务) noexcept
{
    if (!任务) {
        return nullptr;
    }
    if (任务类::读取任务选中自我能力值(任务) != 0) {
        return 私有_解析任务选中自我能力方法_执行桥_最小_v0(
            任务,
            结构体_时间戳::当前_微秒());
    }
    if (auto* 方法 = reinterpret_cast<方法类::节点类*>(任务类::读取任务执行方法(任务))) {
        return 方法;
    }
    return nullptr;
}

inline 任务类::节点类* 私有_取当前步骤节点_最小_v0(任务类::节点类* 任务或步骤) noexcept
{
    if (!任务或步骤) {
        return nullptr;
    }
    if (任务类::读取任务节点种类(任务或步骤) == 枚举_任务节点种类::步骤节点) {
        return 任务或步骤;
    }

    std::vector<任务类::节点类*> 待查{ 任务或步骤 };
    任务类::节点类* 最新步骤 = nullptr;
    时间戳 最新时间 = 0;
    while (!待查.empty()) {
        auto* 当前 = 待查.back();
        待查.pop_back();
        if (!当前) {
            continue;
        }
        if (当前 != 任务或步骤 && 任务类::读取任务节点种类(当前) == 枚举_任务节点种类::步骤节点) {
            const auto 当前时间 = 当前->主信息.完成时间 != 0
                ? 当前->主信息.完成时间
                : (当前->主信息.启动时间 != 0 ? 当前->主信息.启动时间 : 当前->主信息.创建时间);
            if (!最新步骤 || 当前时间 >= 最新时间) {
                最新步骤 = 当前;
                最新时间 = 当前时间;
            }
        }
        if (!当前->子) {
            continue;
        }
        auto* 首子 = reinterpret_cast<任务类::节点类*>(当前->子);
        auto* 子 = 首子;
        do {
            if (子) {
                待查.push_back(子);
            }
            子 = 子 ? reinterpret_cast<任务类::节点类*>(子->下) : nullptr;
        } while (子 && 子 != 首子);
    }
    return 最新步骤;
}

inline 场景节点类* 私有_任务或步骤场景_最小_v0(
    任务类::节点类* 主任务,
    任务类::节点类* 当前步骤) noexcept
{
    if (当前步骤 && 当前步骤->主信息.场景.指针) {
        return 当前步骤->主信息.场景.指针;
    }
    return 主任务 ? 主任务->主信息.场景.指针 : nullptr;
}

inline 枚举_任务状态 私有_按方法运行结果推导任务状态_最小_v0(
    方法类::节点类* 当前方法,
    const 特征节点类* 方法运行结果,
    枚举_任务执行记账结果 记账结果) noexcept
{
    if (任务结果缺条件_最小_v0(方法运行结果)) {
        return 枚举_任务状态::等待中;
    }
    if (记账结果 == 枚举_任务执行记账结果::成功) {
        return 枚举_任务状态::完成;
    }
    return 枚举_任务状态::失败;
}

inline 结构_执行任务结果 执行任务(
    自我_执行桥类& 执行桥,
    任务类::节点类* 当前任务节点,
    时间戳 now = 结构体_时间戳::当前_微秒(),
    时间戳 timeoutUs = 0)
{
    结构_执行任务结果 输出{};
    auto& 任务执行结果 = 输出.任务执行结果;
    auto* 主任务 = 私有_归一到任务头_执行桥_最小_v0(当前任务节点);
    if (!主任务) {
        主任务 = 当前任务节点;
    }
    任务执行结果.主任务 = 主任务;
    任务执行结果.当前步骤节点 = 主任务;

    if (!当前任务节点) {
        任务执行结果.方法运行结果 = 创建本能动作运行结果实例_按码(nullptr, nullptr, -12, now);
        任务执行结果.方法运行说明 = "当前任务节点为空";
        任务执行结果.记账结果 = 枚举_任务执行记账结果::失败;
        输出.方法运行结果 = 任务执行结果.方法运行结果;
        同步执行桥语义槽(输出);
        return 输出;
    }

    if (now == 0) {
        now = 结构体_时间戳::当前_微秒();
    }

    auto* 当前场景 = 主任务 ? 主任务->主信息.场景.指针 : nullptr;
    场景节点类* 结果场景 = nullptr;
    场景节点类* 本轮条件场景 = nullptr;
    if (主任务 && 主任务->主信息.启动时间 == 0) {
        主任务->主信息.启动时间 = now;
    }

    const auto 完成当前轮 = [&](方法类::节点类* 方法, 枚举_任务状态 结束状态) {
        任务执行结果.当前方法 = 方法;
        if (主任务) {
            (void)任务类::写入任务状态(主任务, 结束状态, nullptr, now);
            主任务->主信息.完成时间 = now;
            (void)任务类::写入任务最近错误码(
                主任务,
                本能动作运行结果值(任务执行结果.方法运行结果));
            if (任务执行结果.记账结果 == 枚举_任务执行记账结果::成功
                && 主任务->主信息.目标状态.有效()) {
                主任务->主信息.结果状态信息 = 主任务->主信息.目标状态;
            }
        }

        私有_同步任务执行记录_最小_v0(
            主任务 ? 主任务 : 当前任务节点,
            方法,
            任务执行结果.方法运行结果,
            任务执行结果.记账结果,
            主任务 && 主任务->主信息.启动时间 != 0 ? 主任务->主信息.启动时间 : now,
            now);
        任务执行结果.条件场景 = 本轮条件场景 ? 本轮条件场景 : 当前场景;
        任务执行结果.结果场景 = 结果场景 ? 结果场景 : 当前场景;
        任务执行结果.有效 = true;
        输出.方法运行结果 = 任务执行结果.方法运行结果;
        输出.有效 = true;
        同步执行桥语义槽(输出);
    };

    auto* 当前方法 = 私有_取任务执行方法_最小_v0(主任务);
    任务执行结果.当前方法 = 当前方法;
    if (!当前方法) {
        结果场景 = 当前场景;
        任务执行结果.方法运行结果 = 创建本能动作运行结果实例_按码(
            nullptr,
            结果场景,
            本能方法结果_任务缺条件需自我线程,
            now);
        任务执行结果.方法运行说明 = "任务尚未完成筹办：缺少任务头绑定执行方法或选中自我能力值";
        任务执行结果.记账结果 = 枚举_任务执行记账结果::失败;
        完成当前轮(nullptr, 枚举_任务状态::等待中);
        return 输出;
    }

    if (主任务) {
        (void)任务类::写入任务状态(主任务, 枚举_任务状态::执行中, nullptr, now);
    }
    本轮条件场景 = 私有_真实执行条件场景_执行桥_最小_v0(当前方法, 当前场景);
    结果场景 = 当前场景;
    任务执行结果.方法运行结果 = 执行桥.执行方法_同步等待(
        当前方法,
        主任务,
        当前场景,
        本轮条件场景,
        结果场景,
        timeoutUs);
    任务执行结果.方法运行说明 = 本能动作运行结果文本(任务执行结果.方法运行结果);

    任务执行结果.记账结果 = 本能动作运行成功(任务执行结果.方法运行结果)
        ? 枚举_任务执行记账结果::成功
        : 枚举_任务执行记账结果::失败;

    const auto 结束状态 = 私有_按方法运行结果推导任务状态_最小_v0(
        当前方法,
        任务执行结果.方法运行结果,
        任务执行结果.记账结果);
    完成当前轮(当前方法, 结束状态);
    return 输出;
}

} // export
