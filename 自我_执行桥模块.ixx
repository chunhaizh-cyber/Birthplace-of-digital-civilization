inline bool 私有_方法条件类型描述为无输入_执行桥_最小_v0(
    const 存在节点类* 方法虚拟存在) noexcept
{
    if (!方法虚拟存在) return false;

    I64 总数 = -1;
    I64 必需数 = -1;
    const bool 有总数 = 世界树.读取特征_I64(
        方法虚拟存在,
        私有_方法条件特征类型数量_执行桥_最小_v0(),
        总数);
    const bool 有必需数 = 世界树.读取特征_I64(
        方法虚拟存在,
        私有_方法必需条件特征类型数量_执行桥_最小_v0(),
        必需数);

    return (有总数 && 总数 == 0)
        || (有必需数 && 必需数 == 0);
}

