{
    私有_填充方法特征需求状态_执行桥_最小_v0(
        方法,
        私有_方法条件节点数量特征类型_执行桥_最小_v0(),
        私有_方法条件节点数量_执行桥_最小_v0(方法),
        static_cast<I64>(1),
        结果场景,
        now,
        调用点 + "/方法条件节点数量");
    return 创建本能动作运行结果实例_按码(
        方法,
        结果场景,
        本能方法结果_任务缺条件需自我线程,
        now);
}

inline 特征节点类* 私有_填充方法缺结果节点执行结果_执行桥_最小_v0(
    方法类::节点类* 方法,
    场景节点类*& 结果场景,
    时间戳 now,
    const std::string& 调用点) noexcept
{
    私有_填充方法特征需求状态_执行桥_最小_v0(
        方法,
        私有_方法结果节点数量特征类型_执行桥_最小_v0(),
        私有_方法结果节点数量_执行桥_最小_v0(方法),
        static_cast<I64>(1),
        结果场景,
        now,
        调用点 + "/方法结果节点数量");
    return 创建本能动作运行结果实例_按码(
        方法,
        结果场景,
        本能方法结果_任务缺条件需自我线程,
        now);
}

inline void 私有_记录方法执行条件结果节点_执行桥_最小_v0(
    方法类::节点类* 方法,
    场景节点类* 输入场景,
    场景节点类*& 输出场景,
    时间戳 开始时间,
    时间戳 结束时间,
    const std::string& 调用点) noexcept
{
    if (!方法 || !输入场景) {
        return;
    }

    if (!输出场景) {
        输出场景 = 方法类::取或创建_方法结果场景(
            方法,
            nullptr,
            结束时间,
            调用点 + "/结果场景");
    }

    auto* 方法条件场景 = 方法->主信息.条件场景.指针
        ? 方法->主信息.条件场景.指针
        : 方法类::取或创建_方法条件场景(
            方法,
            nullptr,
            开始时间,
            调用点 + "/方法条件场景");
    auto* 方法结果场景 = 方法->主信息.结果场景.指针
        ? 方法->主信息.结果场景.指针
        : 方法类::取或创建_方法结果场景(
            方法,
            nullptr,
            结束时间,
            调用点 + "/方法结果场景");

    (void)方法类::创建条件节点(
        方法,
        方法条件场景,
        方法->主信息.条件判定索引,
        方法->主信息.条件场景模板主键,
        开始时间,
        结束时间,
        调用点 + "/条件节点");

    if (方法结果场景) {
        (void)方法类::创建结果节点(
            方法,
            方法结果场景,
            方法->主信息.结果方向索引,
            调用点 + "/结果节点");
    }
}

class 自我_执行桥类 {
public:
    void 启动(std::uint32_t n)
    {
        工作者数量_ = n == 0 ? 1 : n;
        停止请求_ = false;
        取消请求_ = false;
    }

    void 请求停止()
    {
        停止请求_ = true;
    }

    void 等待停止()
    {
    }

    void 取消全部()
    {
        取消请求_ = true;
    }

    特征节点类* 执行方法_同步等待(
        方法类::节点类* 方法首节点,
        场景节点类* 当前场景,
        场景节点类* 条件场景,
        时间戳 timeoutUs)
    {
        return 执行方法_同步等待(
            方法首节点,
            nullptr,
            当前场景,
            条件场景,
            nullptr,
            timeoutUs);
    }

    特征节点类* 执行方法_同步等待(
        方法类::节点类* 方法首节点,
        场景节点类* 当前场景,
        场景节点类* 条件场景,
        场景节点类* 结果场景,
        时间戳 timeoutUs)
    {
        return 执行方法_同步等待(
            方法首节点,
            nullptr,
            当前场景,
            条件场景,
            结果场景,
            timeoutUs);
    }

    特征节点类* 执行方法_同步等待(
        方法类::节点类* 方法首节点,
        任务类::节点类* 当前任务节点,
        场景节点类* 当前场景,
        场景节点类* 条件场景,
        场景节点类* 结果场景,
        时间戳 timeoutUs)
    {
        const auto 入口时间 = 结构体_时间戳::当前_微秒();
        if (当前任务节点 && 当前任务节点->主信息.选中自我能力值 != 0) {
            if (auto* 能力方法 = 私有_解析任务选中自我能力方法_执行桥_最小_v0(
                    当前任务节点,
                    入口时间,
                    "自我_执行桥类::执行方法_同步等待")) {
                方法首节点 = 能力方法;
            }
            else {
                return 创建本能动作运行结果实例_按码(
                    方法首节点,
                    结果场景 ? 结果场景 : 当前场景,
                    -1,
                    入口时间);
            }
        }

        auto* 方法信息 = 方法首节点 ? &方法首节点->主信息 : nullptr;
        if (!方法信息 || 方法信息->节点种类 != 枚举_方法节点种类::方法首节点) {
            return 创建本能动作运行结果实例_按码(
                方法首节点,
                结果场景 ? 结果场景 : 当前场景,
                -1,
                入口时间);
        }

        auto* 默认结果场景 = 结果场景
            ? 结果场景
            : (方法信息->结果场景.指针
                ? 方法信息->结果场景.指针
                : 方法类::取或创建_方法结果场景(
                    方法首节点,
                    nullptr,
                    结构体_时间戳::当前_微秒(),
                    "自我_执行桥类::执行方法_同步等待/结果场景"));
        auto* 默认方法虚拟存在 = 方法类::取或创建_方法虚拟存在(
            方法首节点,
            nullptr,
            结构体_时间戳::当前_微秒(),
            "自我_执行桥类::执行方法_同步等待/方法虚拟存在");

        const auto 当前时间 = 结构体_时间戳::当前_微秒();
        if (!私有_方法当前可用_执行桥_最小_v0(方法首节点, 当前时间)) {
            return 私有_填充方法不可用执行结果_执行桥_最小_v0(
                方法首节点,
                默认结果场景,
                当前时间,
                "自我_执行桥类::执行方法_同步等待/方法不可用");
        }

        auto* 执行条件场景 = 条件场景
            ? 条件场景
            : 私有_真实执行条件场景_执行桥_最小_v0(方法首节点, 当前场景);
        const bool 条件类型描述为无输入 =
            私有_方法条件类型描述为无输入_执行桥_最小_v0(默认方法虚拟存在);
        if (!执行条件场景 && !条件类型描述为无输入) {
            return 私有_填充方法缺条件节点执行结果_执行桥_最小_v0(
                方法首节点,
                默认结果场景,
                当前时间,
                "自我_执行桥类::执行方法_同步等待/缺条件节点");
        }

        if (方法信息->动作句柄.类型 != 枚举_动作句柄类型::本能函数ID) {
            return 私有_填充方法缺可执行入口执行结果_执行桥_最小_v0(
                方法首节点,
                默认结果场景,
                当前时间,
                "自我_执行桥类::执行方法_同步等待/缺可执行入口");
        }

        auto 执行体 = [=]() -> 特征节点类* {
            if (停止请求_ || 取消请求_) {
                return 创建本能动作运行结果实例_按码(
                    方法首节点,
                    默认结果场景,
                    -4);
            }

            auto* 输入场景 = 执行条件场景 ? 执行条件场景 : 当前场景;
            auto* 输出场景 = 默认结果场景 ? 默认结果场景 : (当前场景 ? 当前场景 : 条件场景);
            auto* 实际输入场景 = 输入场景 ? 输入场景 : (当前场景 ? 当前场景 : 输出场景);
            auto* 实际输出场景 = 输出场景 ? 输出场景 : 实际输入场景;

            const auto 动作开始时间 = 结构体_时间戳::当前_微秒();
            auto* 运行结果 = 取本能动作集().执行功能函数(
                static_cast<枚举_本能动作ID>(方法信息->动作句柄.本能ID),
                方法首节点,
                实际输入场景,
                实际输出场景);
            const auto 动作结束时间 = 结构体_时间戳::当前_微秒();
            const auto 运行码 = 本能动作运行结果值(运行结果);
            (void)私有_创建方法调用动作动态_执行桥_最小_v0(
                方法首节点,
                实际输入场景,
                实际输出场景,
                动作开始时间,
                动作结束时间,
                运行码 == 0,
                运行码,
                "自我_执行桥类::执行方法_同步等待/方法调用动作动态");
            私有_记录方法执行条件结果节点_执行桥_最小_v0(
                方法首节点,
                实际输入场景,
                实际输出场景,
                动作开始时间,
                动作结束时间,
                "自我_执行桥类::执行方法_同步等待/方法执行样本");
            return 运行结果
                ? 运行结果
                : 创建本能动作运行结果实例_按码(方法首节点, 实际输出场景, 本能动作运行结果_未知);
        };

        if (timeoutUs == 0) {
            return 执行体();
        }

        auto Future = std::async(std::launch::async, 执行体);
        const auto 状态 = Future.wait_for(std::chrono::microseconds(timeoutUs));
        if (状态 == std::future_status::ready) {
            return Future.get();
        }

        取消全部();
        return 创建本能动作运行结果实例(
            方法首节点,
            默认结果场景,
            "执行超时",
            -3);
    }

private:
    std::uint32_t 工作者数量_ = 1;
    bool 停止请求_ = false;
    bool 取消请求_ = false;
};

inline void 私有_同步任务执行记录_最小_v0(
    任务类::节点类* 任务,
    方法类::节点类* 方法,
    const 特征节点类* 方法运行结果,
    枚举_任务执行记账结果 记账结果,
    时间戳 开始时间,
    时间戳 结束时间) noexcept
{
    if (!任务) {
        return;
    }

    结构_任务执行记录 记录{};
    记录.开始时间 = 开始时间;
    记录.结束时间 = 结束时间;
    记录.执行前状态 = 任务->主信息.最近执行记录.执行后状态 != 枚举_任务状态::未定义
        ? 任务->主信息.最近执行记录.执行后状态
        : 任务->主信息.状态;
    记录.执行后状态 =
        记账结果 == 枚举_任务执行记账结果::成功 ? 枚举_任务状态::完成 :
        (记账结果 == 枚举_任务执行记账结果::转学习 ? 枚举_任务状态::挂起 : 枚举_任务状态::失败);
    if (方法) {
        记录.执行方法.指针 = reinterpret_cast<方法节点类*>(方法);
        记录.执行方法.主键 = 方法->获取主键();
    }
    if (auto* 输入状态 = reinterpret_cast<状态节点类*>(任务->主信息.结果状态信息.指针)) {
        记录.输入状态.指针 = 输入状态;
        记录.输入状态.主键 = 输入状态->获取主键();
    }
    if (auto* 输出状态 = reinterpret_cast<状态节点类*>(任务->主信息.目标状态.指针)) {
        记录.输出状态.指针 = 输出状态;
        记录.输出状态.主键 = 输出状态->获取主键();
    }
    const auto 运行码 = 本能动作运行结果值(方法运行结果);
    记录.错误码 = 运行码;
    任务->主信息.最近执行记录 = 记录;
    任务->主信息.执行记录列表.push_back(记录);
    任务->主信息.最近错误码 = 运行码;
    任务->主信息.运行次数 += 1;
    if (运行码 == 0) {
        任务->主信息.成功次数 += 1;
        任务->主信息.连续失败次数 = 0;
    } else {
        任务->主信息.失败次数 += 1;
        任务->主信息.连续失败次数 += 1;
    }
}

inline 方法类::节点类* 私有_取任务执行方法_最小_v0(任务类::节点类* 任务) noexcept
{
    if (!任务) {
        return nullptr;
    }
    if (任务->主信息.选中自我能力值 != 0) {
        return 私有_解析任务选中自我能力方法_执行桥_最小_v0(
            任务,
            结构体_时间戳::当前_微秒(),
            "自我_执行桥模块::取任务执行方法");
    }
    if (auto* 方法 = reinterpret_cast<方法类::节点类*>(任务->主信息.执行方法.指针)) {
        return 方法;
    }
    if (auto* 方法 = reinterpret_cast<方法类::节点类*>(任务->主信息.候选方法首节点.指针)) {
        return 方法;
    }
    return reinterpret_cast<方法类::节点类*>(任务->主信息.可用方法首节点.指针);
}

inline 任务类::节点类* 私有_取当前步骤节点_最小_v0(任务类::节点类* 任务或步骤) noexcept
{
    if (!任务或步骤) {
        return nullptr;
    }
    if (任务或步骤->主信息.节点种类 == 枚举_任务节点种类::步骤节点) {
        return 任务或步骤;
    }
    auto* 当前步骤 = 私有_从任务引用取任务_执行桥_最小_v0(
        任务或步骤->主信息.当前步骤节点);
    if (当前步骤 && 当前步骤->主信息.节点种类 == 枚举_任务节点种类::步骤节点) {
        return 当前步骤;
    }
    return nullptr;
}

inline 场景节点类* 私有_任务或步骤场景_最小_v0(
    任务类::节点类* 主任务,
    任务类::节点类* 当前步骤) noexcept
{
    if (当前步骤 && 当前步骤->主信息.场景.指针) {
        return 当前步骤->主信息.场景.指针;
    }
    return 主任务 ? 主任务->主信息.场景.指针 : nullptr;
}

inline 枚举_任务状态 私有_按方法运行结果推导任务状态_最小_v0(
    方法类::节点类* 当前方法,
    const 特征节点类* 方法运行结果,
    枚举_任务执行记账结果 记账结果) noexcept
{
    if (任务治理步骤要求待重入_最小_v0(当前方法, 方法运行结果)) {
        return 枚举_任务状态::待重筹办;
    }
    if (任务结果缺条件_最小_v0(方法运行结果)) {
        return 枚举_任务状态::等待中;
    }
    if (记账结果 == 枚举_任务执行记账结果::成功) {
        return 枚举_任务状态::完成;
    }
    if (记账结果 == 枚举_任务执行记账结果::转学习) {
        return 枚举_任务状态::挂起;
    }
    return 枚举_任务状态::失败;
}

inline 结构_执行任务结果 执行任务(
    自我_执行桥类& 执行桥,
    任务类::节点类* 当前任务节点,
    时间戳 now = 结构体_时间戳::当前_微秒(),
    时间戳 timeoutUs = 0,
    bool 建议转学习 = false,
    const std::string& 调用点 = "执行任务")
{
    结构_执行任务结果 输出{};
    auto& 任务执行结果 = 输出.任务执行结果;
    auto* 主任务 = 私有_归一到任务头_执行桥_最小_v0(当前任务节点);
    if (!主任务) {
        主任务 = 当前任务节点;
    }
    auto* 当前步骤 = 私有_取当前步骤节点_最小_v0(当前任务节点);
    任务执行结果.主任务 = 主任务;
    任务执行结果.当前步骤节点 = 当前步骤;
    任务执行结果.建议转学习 = 建议转学习;

    if (!当前任务节点) {
        任务执行结果.方法运行结果 = 创建本能动作运行结果实例_按码(nullptr, nullptr, -12, now);
        任务执行结果.方法运行说明 = "当前任务节点为空";
        任务执行结果.记账结果 = 建议转学习
            ? 枚举_任务执行记账结果::转学习
            : 枚举_任务执行记账结果::失败;
        输出.方法运行结果 = 任务执行结果.方法运行结果;
        return 输出;
    }

    if (now == 0) {
        now = 结构体_时间戳::当前_微秒();
    }

    auto* 当前场景 = 私有_任务或步骤场景_最小_v0(主任务, 当前步骤);
    场景节点类* 结果场景 = nullptr;
    场景节点类* 本轮条件场景 = nullptr;
    const auto 执行前状态 = 主任务 ? 主任务->主信息.状态 : 枚举_任务状态::未定义;
    if (主任务 && 主任务->主信息.启动时间 == 0) {
        主任务->主信息.启动时间 = now;
    }
    if (主任务) {
        主任务->主信息.统计.记录观测(now);
    }
    if (当前步骤) {
        当前步骤->主信息.统计.记录观测(now);
    }

    const auto 完成当前轮 = [&](方法类::节点类* 方法, 枚举_任务状态 结束状态) {
        任务执行结果.当前方法 = 方法;
        if (主任务) {
            主任务->主信息.状态 = 结束状态;
            主任务->主信息.完成时间 = now;
            主任务->主信息.最近错误码 = 本能动作运行结果值(任务执行结果.方法运行结果);
            if (任务执行结果.记账结果 == 枚举_任务执行记账结果::成功
                && 主任务->主信息.目标状态.有效()) {
                主任务->主信息.结果状态信息 = 主任务->主信息.目标状态;
            }
            主任务->主信息.统计.记录观测(now);
        }
        if (当前步骤) {
            当前步骤->主信息.状态 = 结束状态;
            当前步骤->主信息.最近错误码 = 本能动作运行结果值(任务执行结果.方法运行结果);
            当前步骤->主信息.最近执行时间 = now;
            当前步骤->主信息.最近完成时间 = now;
            当前步骤->主信息.统计.记录观测(now);
        }

        私有_同步任务执行记录_最小_v0(
            主任务 ? 主任务 : 当前任务节点,
            方法,
            任务执行结果.方法运行结果,
            任务执行结果.记账结果,
            主任务 && 主任务->主信息.启动时间 != 0 ? 主任务->主信息.启动时间 : now,
            now);
        if (主任务) {
            主任务->主信息.最近执行记录.执行前状态 = 执行前状态;
        }

        任务执行结果.条件场景 = 本轮条件场景 ? 本轮条件场景 : 当前场景;
        任务执行结果.结果场景 = 结果场景 ? 结果场景 : 当前场景;
        任务执行结果.有效 = true;
        输出.方法运行结果 = 任务执行结果.方法运行结果;
        输出.有效 = true;
    };

    if (!当前步骤) {
        结果场景 = 当前场景;
        任务执行结果.方法运行结果 = 创建本能动作运行结果实例_按码(
            nullptr,
            结果场景,
            本能方法结果_任务缺条件需自我线程,
            now);
        任务执行结果.方法运行说明 = "当前任务缺少当前步骤节点，应由自我线程补齐筹办/执行步骤";
        任务执行结果.记账结果 = 枚举_任务执行记账结果::失败;
        完成当前轮(nullptr, 枚举_任务状态::等待中);
        return 输出;
    }

    auto* 当前方法 = 私有_取任务执行方法_最小_v0(当前步骤);
    任务执行结果.当前方法 = 当前方法;
    if (!当前方法) {
        任务执行结果.建议转学习 = true;
        结果场景 = 当前场景;
        任务执行结果.方法运行结果 = 创建本能动作运行结果实例_按码(
            nullptr,
            结果场景,
            本能方法结果_任务缺方法需任务管理任务,
            now);
        任务执行结果.方法运行说明 = "当前步骤节点缺少执行方法，交给任务管理任务补方法";
        任务执行结果.记账结果 = 枚举_任务执行记账结果::转学习;
        完成当前轮(nullptr, 枚举_任务状态::挂起);
        return 输出;
    }

    if (主任务) {
        主任务->主信息.状态 = 枚举_任务状态::执行中;
    }
    当前步骤->主信息.状态 = 枚举_任务状态::执行中;
    本轮条件场景 = 私有_真实执行条件场景_执行桥_最小_v0(当前方法, 当前场景);
    结果场景 = 当前场景;
    任务执行结果.方法运行结果 = 执行桥.执行方法_同步等待(
        当前方法,
        当前步骤,
        当前场景,
        本轮条件场景,
        结果场景,
        timeoutUs);
    任务执行结果.方法运行说明 = 本能动作运行结果文本(任务执行结果.方法运行结果);

    if (任务结果缺方法_最小_v0(任务执行结果.方法运行结果)
        || 任务筹办已转学习_最小_v0(当前方法, 任务执行结果.方法运行结果)) {
        任务执行结果.建议转学习 = true;
        任务执行结果.记账结果 = 枚举_任务执行记账结果::转学习;
    } else {
        任务执行结果.记账结果 = 本能动作运行成功(任务执行结果.方法运行结果)
            ? 枚举_任务执行记账结果::成功
            : (建议转学习 ? 枚举_任务执行记账结果::转学习 : 枚举_任务执行记账结果::失败);
    }

    const auto 结束状态 = 私有_按方法运行结果推导任务状态_最小_v0(
        当前方法,
        任务执行结果.方法运行结果,
        任务执行结果.记账结果);
    完成当前轮(当前方法, 结束状态);
    return 输出;
}

inline 结构_任务步骤执行结果_最小 执行任务步骤_最小_v0(
    自我_执行桥类& 执行桥,
    任务类::节点类* 主任务,
    方法类::节点类* 当前方法,
    时间戳 now = 结构体_时间戳::当前_微秒(),
    时间戳 timeoutUs = 0,
    bool 建议转学习 = false,
    const std::string& 调用点 = "执行任务步骤_最小_v0")
{
    结构_任务步骤执行结果_最小 输出{};
    输出.主任务 = 主任务;
    输出.当前步骤节点 = 私有_取当前步骤节点_最小_v0(主任务);
    输出.当前方法 = 当前方法;
    输出.建议转学习 = 建议转学习;

    if (now == 0) {
        now = 结构体_时间戳::当前_微秒();
    }

    if (!主任务) {
        输出.方法运行结果 = 创建本能动作运行结果实例_按码(nullptr, nullptr, -12, now);
        输出.方法运行说明 = "当前任务节点为空";
        输出.记账结果 = 枚举_任务执行记账结果::失败;
        return 输出;
    }
    if (!当前方法) {
        输出.结果场景 = 主任务->主信息.场景.指针;
        输出.方法运行结果 = 创建本能动作运行结果实例_按码(
            nullptr,
            输出.结果场景,
            本能方法结果_任务缺方法需任务管理任务,
            now);
        输出.方法运行说明 = "当前步骤没有给定可执行方法";
        输出.记账结果 = 枚举_任务执行记账结果::转学习;
        输出.有效 = true;
        return 输出;
    }

    auto* 当前步骤 = 输出.当前步骤节点;
    auto* 当前场景 = 私有_任务或步骤场景_最小_v0(主任务, 当前步骤);
    const auto 执行前状态 = 主任务->主信息.状态;
    if (主任务->主信息.启动时间 == 0) {
        主任务->主信息.启动时间 = now;
    }
    主任务->主信息.状态 = 枚举_任务状态::执行中;
    主任务->主信息.统计.记录观测(now);
    if (当前步骤) {
        当前步骤->主信息.状态 = 枚举_任务状态::执行中;
        当前步骤->主信息.统计.记录观测(now);
    }

    输出.条件场景 = 私有_真实执行条件场景_执行桥_最小_v0(当前方法, 当前场景);
    输出.结果场景 = 当前场景;
    输出.方法运行结果 = 执行桥.执行方法_同步等待(
        当前方法,
        主任务,
        当前场景,
        输出.条件场景,
        输出.结果场景,
        timeoutUs);
    输出.方法运行说明 = 本能动作运行结果文本(输出.方法运行结果);

    if (任务结果缺方法_最小_v0(输出.方法运行结果)
        || 任务筹办已转学习_最小_v0(当前方法, 输出.方法运行结果)) {
        输出.建议转学习 = true;
        输出.记账结果 = 枚举_任务执行记账结果::转学习;
    } else {
        输出.记账结果 = 本能动作运行成功(输出.方法运行结果)
            ? 枚举_任务执行记账结果::成功
            : (建议转学习 ? 枚举_任务执行记账结果::转学习 : 枚举_任务执行记账结果::失败);
    }

    const auto 结束状态 = 私有_按方法运行结果推导任务状态_最小_v0(
        当前方法,
        输出.方法运行结果,
        输出.记账结果);
    主任务->主信息.状态 = 结束状态;
    主任务->主信息.完成时间 = now;
    主任务->主信息.最近错误码 = 本能动作运行结果值(输出.方法运行结果);
    if (输出.记账结果 == 枚举_任务执行记账结果::成功
        && 主任务->主信息.目标状态.有效()) {
        主任务->主信息.结果状态信息 = 主任务->主信息.目标状态;
    }
    主任务->主信息.统计.记录观测(now);
    if (当前步骤) {
        当前步骤->主信息.状态 = 结束状态;
        当前步骤->主信息.最近错误码 = 本能动作运行结果值(输出.方法运行结果);
        当前步骤->主信息.最近执行时间 = now;
        当前步骤->主信息.最近完成时间 = now;
        当前步骤->主信息.统计.记录观测(now);
    }

    私有_同步任务执行记录_最小_v0(
        主任务,
        当前方法,
        输出.方法运行结果,
        输出.记账结果,
        主任务->主信息.启动时间 != 0 ? 主任务->主信息.启动时间 : now,
        now);
    主任务->主信息.最近执行记录.执行前状态 = 执行前状态;
    if (!输出.结果场景) {
        输出.结果场景 = 当前场景;
    }
    输出.有效 = true;
    return 输出;
}

} // export
