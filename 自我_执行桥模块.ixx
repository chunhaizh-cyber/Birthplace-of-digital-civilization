{
    static const 词性节点类* s_词 = 语素集.添加词性词("任务最近执行记账结果", "名词");
    return s_词;
}

inline const 词性节点类* 私有_任务最近执行方法特征词_最小_v0() noexcept
{
    static const 词性节点类* s_词 = 语素集.添加词性词("任务最近执行方法", "名词");
    return s_词;
}

inline const 词性节点类* 私有_任务最近结果节点特征词_最小_v0() noexcept
{
    static const 词性节点类* s_词 = 语素集.添加词性词("任务最近结果节点", "名词");
    return s_词;
