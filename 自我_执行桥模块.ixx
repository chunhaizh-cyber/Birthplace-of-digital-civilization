export module 自我_执行桥模块;

import 本能动作管理模块;
import 自我模块.特征定义;

export {

enum class 枚举_任务执行记账结果 : std::uint8_t {
    未定义 = 0,
    成功 = 1,
    失败 = 2,
};

struct 结构_方法上下文 {
    时间戳 now = 0;
    场景节点类* 输入观测包场景 = nullptr;
    场景节点类* 任务条件场景 = nullptr;
    场景节点类* 调用覆盖场景 = nullptr;
    方法类::节点类* 方法首节点 = nullptr;
    const 场景节点类* 当前场景 = nullptr;
    const 场景节点类* 条件场景 = nullptr;
};

struct 结构_任务步骤执行结果_最小 {
    bool 有效 = false;
    枚举_任务执行记账结果 记账结果 = 枚举_任务执行记账结果::未定义;
    std::uintptr_t 记账结果抽象特征指针 = 0;
    I64 记账结果值 = 0;
    任务类::节点类* 主任务 = nullptr;
    任务类::节点类* 当前步骤节点 = nullptr; // 兼容旧调用者；新逻辑中等同于被执行任务。
    方法类::节点类* 当前方法 = nullptr;
    场景节点类* 条件场景 = nullptr;
    场景节点类* 结果场景 = nullptr;
    特征节点类* 方法运行结果 = nullptr;
    动态节点类* 动作动态 = nullptr;
    std::string 方法运行说明{};
};

struct 结构_执行任务结果 {
    bool 有效 = false;
    结构_任务步骤执行结果_最小 任务执行结果{};
    特征节点类* 方法运行结果 = nullptr;
};

inline void 同步执行桥语义槽(结构_任务步骤执行结果_最小& 结果) noexcept
{
    结果.记账结果抽象特征指针 =
        reinterpret_cast<std::uintptr_t>(自我特征定义类::类型_任务管理_任务执行记账结果());
    结果.记账结果值 = static_cast<I64>(结果.记账结果);
}

inline void 同步执行桥语义槽(结构_执行任务结果& 结果) noexcept
{
    同步执行桥语义槽(结果.任务执行结果);
}

inline const 词性节点类* 私有_方法调用动作动态特征类型_执行桥_最小_v0() noexcept
{
    static const 词性节点类* s_词 = 语素集.添加词性词("方法调用动作动态", "名词");
    return s_词;
}

inline const 词性节点类* 私有_方法动作名_执行桥_最小_v0(const 方法类::节点类* 方法首节点) noexcept
{
    if (方法首节点 && 方法首节点->主信息.首节点信息().动作名) {
        return 方法首节点->主信息.首节点信息().动作名;
    }
    return 语素集.添加词性词("方法调用", "动词");
}

inline 动态节点类* 私有_创建方法调用动作动态_执行桥_最小_v0(
    方法类::节点类* 方法首节点,
    场景节点类* 输入场景,
    场景节点类* 输出场景,
    时间戳 开始时间,
    时间戳 结束时间,
    bool 执行成功,
    std::int64_t 错误码) noexcept
{
    auto* 自我场景 = 世界树.自我所在场景
        ? 世界树.自我所在场景
        : 世界树.取或创建自我现实场景();
    auto* 自我存在 = 世界树.取或创建自我存在();
    if (!自我场景 || !自我存在) {
        return nullptr;
    }

    auto* 动作特征 = 世界树.取或创建子特征_按类型(
        自我存在,
        私有_方法调用动作动态特征类型_执行桥_最小_v0());
    if (!动作特征) {
        return nullptr;
    }

    if (结束时间 == 0) {
        结束时间 = 结构体_时间戳::当前_微秒();
    }
    if (开始时间 == 0) {
        开始时间 = 结束时间;
    }

    const auto* 动作名 = 私有_方法动作名_执行桥_最小_v0(方法首节点);
    auto* 动态节点 = 世界树.动态().创建方法动作动态(
        自我场景,
        自我存在,
        动作特征,
        reinterpret_cast<方法节点类*>(方法首节点),
        动作名,
        开始时间,
        结束时间,
        执行成功,
        static_cast<I64>(错误码),
        执行成功 ? 枚举_动作事件相位::完成 : 枚举_动作事件相位::失败,
        输入场景,
        输出场景);
    if (!动态节点) {
        return nullptr;
    }

    if (auto* 动态主信息 = 世界树.动态().取动态主信息(动态节点)) {
        动态主信息->名称 = 动作名;
        动态主信息->类型 = 动作名;
    }
    return 动态节点;
}

inline bool 任务结果缺条件_最小_v0(const 特征节点类* 运行结果) noexcept
{
    const auto 运行码 = 本能动作运行结果值(运行结果);
    return 运行码 == 本能方法结果_任务缺条件需自我线程
        || 运行码 == 本能动作错误_输入参数不满足;
}

inline 任务类::节点类* 私有_归一到任务头_执行桥_最小_v0(任务类::节点类* 节点) noexcept
{
    auto* 当前 = 节点;
    while (当前) {
        if (任务类::读取任务节点种类(当前) == 枚举_任务节点种类::头结点) {
            return 当前;
        }
        当前 = reinterpret_cast<任务类::节点类*>(当前->父);
    }
    return nullptr;
}

inline I64 私有_方法自我能力值_执行桥_最小_v0(
    const 方法类::节点类* 方法) noexcept
{
    if (!方法
        || 方法->主信息.首节点信息().动作句柄.类型 != 枚举_动作句柄类型::本能函数ID) {
        return 0;
    }
    const I64 能力值 = 方法->主信息.首节点信息().动作句柄.本能ID;
    return 本能方法类::是有效本能方法能力值(能力值) ? 能力值 : 0;
}

inline bool 私有_方法匹配自我能力值_执行桥_最小_v0(
    const 方法类::节点类* 方法,
    I64 自我能力值) noexcept
{
    return 自我能力值 != 0
        && 私有_方法自我能力值_执行桥_最小_v0(方法) == 自我能力值;
}

inline 方法类::节点类* 私有_解析任务选中自我能力方法_执行桥_最小_v0(
    任务类::节点类* 任务,
    时间戳 now) noexcept
{
    const I64 自我能力值 = 任务类::读取任务选中自我能力值(任务);
    if (!任务 || 自我能力值 == 0) {
        return nullptr;
    }

    if (auto* 方法 = reinterpret_cast<方法类::节点类*>(任务类::读取任务执行方法(任务));
        私有_方法匹配自我能力值_执行桥_最小_v0(方法, 自我能力值)) {
        return 方法;
    }
    (void)now;
    return nullptr;
}

inline 场景节点类* 私有_真实执行条件场景_执行桥_最小_v0(
    const 方法类::节点类* 方法,
    场景节点类* 当前场景) noexcept
{
    if (!方法) {
        return nullptr;
    }
    if (方法->子) {
        auto* 首节点 = reinterpret_cast<方法类::节点类*>(方法->子);
        auto* 当前 = 首节点;
        std::size_t 保护计数 = 0;
        do {
            if (当前 && 当前->主信息.公共.节点种类 == 枚举_方法节点种类::方法条件节点) {
                const auto* 条件信息 = 当前->主信息.取条件节点信息();
                return 条件信息 && 条件信息->条件场景.指针
                    ? 条件信息->条件场景.指针
                    : 当前场景;
            }
            当前 = 当前 ? reinterpret_cast<方法类::节点类*>(当前->下) : nullptr;
            ++保护计数;
        } while (当前 && 当前 != 首节点 && 保护计数 < 4096);
    }
    return nullptr;
}

inline const 词性节点类* 私有_方法是否可用特征类型_执行桥_最小_v0() noexcept
{
    static const 词性节点类* s_词 = 语素集.添加词性词("方法是否可用", "名词");
    return s_词;
