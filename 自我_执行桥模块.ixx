module;

#include <chrono>
#include <cstddef>
#include <cstdint>
#include <future>
#include <string>

#include "世界树类.h"
#include "任务类.h"
#include "方法类.h"
#include "方法主信息类.h"
#include "本能方法类.h"
#include "需求类.h"
#include "语素类.h"

export module 自我_执行桥模块;

import 本能动作管理模块;

export {

enum class 枚举_任务执行记账结果 : std::uint8_t {
    未定义 = 0,
    成功 = 1,
    失败 = 2,
    转学习 = 3,
};

struct 结构_方法上下文 {
    时间戳 now = 0;
    场景节点类* 输入观测包场景 = nullptr;
    场景节点类* 任务条件场景 = nullptr;
    场景节点类* 调用覆盖场景 = nullptr;
    方法类::节点类* 方法首节点 = nullptr;
    const 场景节点类* 当前场景 = nullptr;
    const 场景节点类* 条件场景 = nullptr;
};

struct 结构_任务步骤执行结果_最小 {
    bool 有效 = false;
    bool 建议转学习 = false;
    枚举_任务执行记账结果 记账结果 = 枚举_任务执行记账结果::未定义;
    任务类::节点类* 主任务 = nullptr;
    任务类::节点类* 当前步骤节点 = nullptr; // 兼容旧调用者；新逻辑中等同于被执行任务。
    任务类::节点类* 最近结果节点 = nullptr; // 结果节点已废弃，保留为空兼容旧调用者。
    方法类::节点类* 当前方法 = nullptr;
    场景节点类* 条件场景 = nullptr;
    场景节点类* 结果场景 = nullptr;
    特征节点类* 方法运行结果 = nullptr;
    动态节点类* 动作动态 = nullptr;
    std::string 方法运行说明{};
};

struct 结构_执行任务结果 {
    bool 有效 = false;
    结构_任务步骤执行结果_最小 任务执行结果{};
    特征节点类* 方法运行结果 = nullptr;
};

inline const 词性节点类* 私有_方法调用动作动态特征类型_执行桥_最小_v0() noexcept
{
    static const 词性节点类* s_词 = 语素集.添加词性词("方法调用动作动态", "名词");
    return s_词;
}

inline const 词性节点类* 私有_方法动作名_执行桥_最小_v0(const 方法类::节点类* 方法首节点) noexcept
{
    if (方法首节点 && 方法首节点->主信息.动作名) {
        return 方法首节点->主信息.动作名;
    }
    return 语素集.添加词性词("方法调用", "动词");
}

inline 动态节点类* 私有_创建方法调用动作动态_执行桥_最小_v0(
    方法类::节点类* 方法首节点,
    场景节点类* 输入场景,
    场景节点类* 输出场景,
    时间戳 开始时间,
    时间戳 结束时间,
    bool 执行成功,
    std::int64_t 错误码,
    const std::string& 调用点) noexcept
{
    (void)调用点;

    auto* 自我场景 = 世界树.自我所在场景
        ? 世界树.自我所在场景
        : 世界树.取或创建自我现实场景();
    auto* 自我存在 = 世界树.取或创建自我存在();
    if (!自我场景 || !自我存在) {
        return nullptr;
    }

    auto* 动作特征 = 世界树.取或创建子特征_按类型(
        自我存在,
        私有_方法调用动作动态特征类型_执行桥_最小_v0());
    if (!动作特征) {
        return nullptr;
    }

    if (结束时间 == 0) {
        结束时间 = 结构体_时间戳::当前_微秒();
    }
    if (开始时间 == 0) {
        开始时间 = 结束时间;
    }

    const auto* 动作名 = 私有_方法动作名_执行桥_最小_v0(方法首节点);
    auto* 动态节点 = 世界树.动态().创建方法动作动态(
        自我场景,
        自我存在,
        动作特征,
        reinterpret_cast<方法节点类*>(方法首节点),
        动作名,
        开始时间,
        结束时间,
        执行成功,
        static_cast<I64>(错误码),
        执行成功 ? 枚举_动作事件相位::完成 : 枚举_动作事件相位::失败,
        输入场景,
        输出场景);
    if (!动态节点) {
        return nullptr;
    }

    if (auto* 动态主信息 = 世界树.动态().取动态主信息(动态节点)) {
        动态主信息->名称 = 动作名;
        动态主信息->类型 = 动作名;
    }
    return 动态节点;
}

inline bool 是否任务筹办本能方法_最小_v0(const 方法类::节点类* 方法首节点) noexcept
{
    return 方法首节点
        && 方法首节点->主信息.动作句柄.类型 == 枚举_动作句柄类型::本能函数ID
        && 方法首节点->主信息.动作句柄.本能ID == static_cast<I64>(枚举_本能方法ID::自我_任务筹办);
}

inline bool 是否任务执行一步本能方法_最小_v0(const 方法类::节点类* 方法首节点) noexcept
{
    return 方法首节点
        && 方法首节点->主信息.动作句柄.类型 == 枚举_动作句柄类型::本能函数ID
        && 方法首节点->主信息.动作句柄.本能ID == static_cast<I64>(枚举_本能方法ID::自我_任务执行一步);
}

inline bool 任务筹办要求待重入_最小_v0(
    const 方法类::节点类* 方法首节点,
    const 特征节点类* 运行结果) noexcept
{
    return 是否任务筹办本能方法_最小_v0(方法首节点)
        && 本能动作运行结果值(运行结果) == 本能方法结果_任务筹办已建立方法头待重入;
}

inline bool 任务执行一步要求待重入_最小_v0(
    const 方法类::节点类* 方法首节点,
    const 特征节点类* 运行结果) noexcept
{
    return 是否任务执行一步本能方法_最小_v0(方法首节点)
        && 本能动作运行结果值(运行结果) == 本能方法结果_任务执行一步已建立方法头待重入;
}

inline bool 任务治理步骤要求待重入_最小_v0(
    const 方法类::节点类* 方法首节点,
    const 特征节点类* 运行结果) noexcept
{
    return 任务筹办要求待重入_最小_v0(方法首节点, 运行结果)
        || 任务执行一步要求待重入_最小_v0(方法首节点, 运行结果);
}

inline bool 任务筹办已转学习_最小_v0(
    const 方法类::节点类* 方法首节点,
    const 特征节点类* 运行结果) noexcept
{
    const auto 运行码 = 本能动作运行结果值(运行结果);
    if (运行码 == 本能方法结果_任务缺方法需任务管理任务) {
        return true;
    }
    return (是否任务筹办本能方法_最小_v0(方法首节点)
            && 运行码 == 本能方法结果_任务筹办已激活学习任务)
        || (是否任务执行一步本能方法_最小_v0(方法首节点)
            && 运行码 == 本能方法结果_任务执行一步已激活学习任务);
}

inline bool 任务结果缺条件_最小_v0(const 特征节点类* 运行结果) noexcept
{
    return 本能动作运行结果值(运行结果) == 本能方法结果_任务缺条件需自我线程;
}

inline bool 任务结果缺方法_最小_v0(const 特征节点类* 运行结果) noexcept
{
    const auto 运行码 = 本能动作运行结果值(运行结果);
    return 运行码 == 本能方法结果_任务缺方法需任务管理任务
        || 运行码 == 本能方法结果_任务筹办已激活学习任务
        || 运行码 == 本能方法结果_任务执行一步已激活学习任务;
}

inline bool 是否任务治理入口本能方法_最小_v0(const 方法类::节点类* 方法首节点) noexcept
{
    return 是否任务筹办本能方法_最小_v0(方法首节点)
        || 是否任务执行一步本能方法_最小_v0(方法首节点);
}

inline 方法类::节点类* 私有_确保任务筹办本能方法_最小_v0(
    时间戳 now,
    const std::string& 调用点) noexcept
{
    auto* 自我存在 = 世界树.自我指针 ? 世界树.自我指针 : 世界树.取或创建自我存在();
    if (!自我存在) {
        return nullptr;
    }
    return 方法类::查找或创建_本能方法首节点(
        自我存在,
        枚举_本能方法ID::自我_任务筹办,
        now,
        调用点 + "/任务筹办");
}

inline 任务类::节点类* 私有_归一到任务头_执行桥_最小_v0(任务类::节点类* 节点) noexcept
{
    auto* 当前 = 节点;
    while (当前) {
        if (当前->主信息.节点种类 == 枚举_任务节点种类::头结点) {
            return 当前;
        }
        当前 = reinterpret_cast<任务类::节点类*>(当前->父);
    }
    return nullptr;
}

inline 任务类::节点类* 私有_从任务引用取任务_执行桥_最小_v0(
    const 可解析引用<任务节点类>& 引用) noexcept
{
    if (引用.指针) {
        return reinterpret_cast<任务类::节点类*>(引用.指针);
    }
    return !引用.主键.empty()
        ? reinterpret_cast<任务类::节点类*>(世界树.基础信息().查找主键(引用.主键))
        : nullptr;
}

inline 方法类::节点类* 私有_从方法引用取方法_执行桥_最小_v0(
    const 可解析引用<方法节点类>& 引用) noexcept
{
    if (引用.指针) {
        return reinterpret_cast<方法类::节点类*>(引用.指针);
    }
    return !引用.主键.empty()
        ? reinterpret_cast<方法类::节点类*>(世界树.基础信息().查找主键(引用.主键))
        : nullptr;
}

inline bool 私有_任务引用指向任务_执行桥_最小_v0(
    const 可解析引用<任务节点类>& 引用,
    const 任务类::节点类* 任务) noexcept
{
    if (!任务) {
        return false;
    }
    return 引用.指针 == reinterpret_cast<const 任务节点类*>(任务)
        || (!引用.主键.empty() && 引用.主键 == 任务->获取主键());
}

inline 任务类::节点类* 私有_任务管理对象任务或自身_执行桥_最小_v0(
    任务类::节点类* 任务) noexcept
{
    if (!任务 || 任务->主信息.任务角色 != 枚举_任务角色::任务管理任务) {
        return 任务;
    }
    if (auto* 被管理任务 = 私有_从任务引用取任务_执行桥_最小_v0(任务->主信息.管理对象任务)) {
        return 被管理任务;
    }
    return 任务;
}

inline I64 私有_方法自我能力值_执行桥_最小_v0(
    const 方法类::节点类* 方法) noexcept
{
    if (!方法
        || 方法->主信息.动作句柄.类型 != 枚举_动作句柄类型::本能函数ID) {
        return 0;
    }
    const I64 能力值 = 方法->主信息.动作句柄.本能ID;
    return 方法类::是有效本能方法能力值(能力值) ? 能力值 : 0;
}

inline bool 私有_方法匹配自我能力值_执行桥_最小_v0(
    const 方法类::节点类* 方法,
    I64 自我能力值) noexcept
{
    return 自我能力值 != 0
        && 私有_方法自我能力值_执行桥_最小_v0(方法) == 自我能力值;
}

inline 方法类::节点类* 私有_从任务方法缓存取匹配能力方法_执行桥_最小_v0(
    const 可解析引用<方法节点类>& 引用,
    I64 自我能力值) noexcept
{
    auto* 方法 = 私有_从方法引用取方法_执行桥_最小_v0(引用);
    return 私有_方法匹配自我能力值_执行桥_最小_v0(方法, 自我能力值)
        ? 方法
        : nullptr;
}

inline void 私有_同步任务方法缓存_按能力_执行桥_最小_v0(
    任务类::节点类* 任务,
    方法类::节点类* 方法) noexcept
{
    if (!任务 || !方法) {
        return;
    }
    任务->主信息.执行方法.绑定(reinterpret_cast<方法节点类*>(方法));
    任务->主信息.候选方法首节点.绑定(reinterpret_cast<方法节点类*>(方法));
    任务->主信息.可用方法首节点.绑定(reinterpret_cast<方法节点类*>(方法));
}

inline 方法类::节点类* 私有_解析任务选中自我能力方法_执行桥_最小_v0(
    任务类::节点类* 任务,
    时间戳 now,
    const std::string& 调用点) noexcept
{
    if (!任务 || 任务->主信息.选中自我能力值 == 0) {
        return nullptr;
    }

    const I64 自我能力值 = 任务->主信息.选中自我能力值;
    if (auto* 方法 = 私有_从任务方法缓存取匹配能力方法_执行桥_最小_v0(
            任务->主信息.执行方法,
            自我能力值)) {
        return 方法;
    }
    if (auto* 方法 = 私有_从任务方法缓存取匹配能力方法_执行桥_最小_v0(
            任务->主信息.候选方法首节点,
            自我能力值)) {
        私有_同步任务方法缓存_按能力_执行桥_最小_v0(任务, 方法);
        return 方法;
    }
    if (auto* 方法 = 私有_从任务方法缓存取匹配能力方法_执行桥_最小_v0(
            任务->主信息.可用方法首节点,
            自我能力值)) {
        私有_同步任务方法缓存_按能力_执行桥_最小_v0(任务, 方法);
        return 方法;
    }

    auto* 自我存在 = 世界树.自我指针 ? 世界树.自我指针 : 世界树.取或创建自我存在();
    auto* 方法 = 方法类::取或确保本能方法首节点_按能力值(
        自我存在,
        自我能力值,
        now,
        调用点 + "/按能力值解析方法首节点");
    if (方法) {
        私有_同步任务方法缓存_按能力_执行桥_最小_v0(任务, 方法);
    }
    return 方法;
}

inline 方法类::节点类* 私有_任务管理学习对象方法_执行桥_最小_v0(
    任务类::节点类* 管理任务,
    任务类::节点类* 管理对象) noexcept
{
    const auto 取方法 = [](任务类::节点类* 任务) noexcept -> 方法类::节点类* {
        if (!任务) {
            return nullptr;
        }
        if (auto* 方法 = 私有_从方法引用取方法_执行桥_最小_v0(任务->主信息.等待学习方法首节点)) {
            return 方法;
        }
        if (auto* 方法 = 私有_从方法引用取方法_执行桥_最小_v0(任务->主信息.执行方法)) {
            return 方法;
        }
        if (auto* 方法 = 私有_从方法引用取方法_执行桥_最小_v0(任务->主信息.候选方法首节点)) {
            return 方法;
        }
        return 私有_从方法引用取方法_执行桥_最小_v0(任务->主信息.可用方法首节点);
    };

    if (auto* 方法 = 取方法(管理对象)) {
        return 方法;
    }
    return 取方法(管理任务);
}

inline 存在节点类* 私有_解析任务管理方法参数存在_执行桥_最小_v0(
    任务类::节点类* 当前任务节点,
    时间戳 now,
    const std::string& 调用点) noexcept
{
    auto* 当前任务 = 私有_归一到任务头_执行桥_最小_v0(当前任务节点);
    if (!当前任务) {
        return nullptr;
    }

    if (当前任务->主信息.任务角色 == 枚举_任务角色::任务管理任务) {
        auto* 被管理任务 = 私有_从任务引用取任务_执行桥_最小_v0(当前任务->主信息.管理对象任务);
        if (!被管理任务) {
            被管理任务 = 当前任务;
        }

        if (被管理任务 == 当前任务
            || 私有_任务引用指向任务_执行桥_最小_v0(当前任务->主信息.管理对象任务, 当前任务)) {
            return 任务类::取或创建_任务虚拟存在(
                当前任务,
                当前任务->主信息.场景.指针,
                调用点 + "/管理自身");
        }

        if (被管理任务->主信息.任务角色 == 枚举_任务角色::学习任务) {
            if (auto* 学习对象方法 = 私有_任务管理学习对象方法_执行桥_最小_v0(当前任务, 被管理任务)) {
                auto* 自我存在 = 世界树.自我指针 ? 世界树.自我指针 : 世界树.取或创建自我存在();
                return 方法类::取或创建_方法虚拟存在(
                    学习对象方法,
                    自我存在,
                    now,
                    调用点 + "/管理学习");
            }
        }

        return 任务类::取或创建_任务虚拟存在(
            被管理任务,
            被管理任务->主信息.场景.指针,
            调用点 + "/管理任务");
    }

    return 任务类::取或创建_任务虚拟存在(
        当前任务,
        当前任务->主信息.场景.指针,
        调用点 + "/普通任务");
}

inline 场景节点类* 私有_真实执行条件场景_执行桥_最小_v0(
    const 方法类::节点类* 方法,
    场景节点类* 当前场景) noexcept
{
    if (!方法) {
        return nullptr;
    }
    if (方法->子) {
        auto* 首节点 = reinterpret_cast<方法类::节点类*>(方法->子);
        auto* 当前 = 首节点;
        std::size_t 保护计数 = 0;
        do {
            if (当前 && 当前->主信息.节点种类 == 枚举_方法节点种类::方法条件节点) {
                return 当前->主信息.条件场景.指针
                    ? 当前->主信息.条件场景.指针
                    : (方法->主信息.条件场景.指针 ? 方法->主信息.条件场景.指针 : 当前场景);
            }
            当前 = 当前 ? reinterpret_cast<方法类::节点类*>(当前->下) : nullptr;
            ++保护计数;
        } while (当前 && 当前 != 首节点 && 保护计数 < 4096);
    }
    return nullptr;
}

inline const 词性节点类* 私有_方法是否可用特征类型_执行桥_最小_v0() noexcept
{
    static const 词性节点类* s_词 = 语素集.添加词性词("方法是否可用", "名词");
    return s_词;
}

