inline bool 是否线程状态消息表示执行结束(const 结构_任务管理线程状态消息& 消息) noexcept
{
    return 消息.是否执行尝试结束
        || 消息.结束状态 == 枚举_任务管理线程结束状态::正常结束
        || 消息.结束状态 == 枚举_任务管理线程结束状态::收束结束
        || 消息.结束状态 == 枚举_任务管理线程结束状态::中断结束
        || 消息.结束状态 == 枚举_任务管理线程结束状态::故障结束
        || 消息.结束状态 == 枚举_任务管理线程结束状态::超时结束;
}

inline std::string 构造任务管理执行尝试键(const 结构_任务管理消息头& 消息头)
{
    if (!消息头.执行尝试主键.empty()) {
        return 消息头.执行尝试主键;
    }

    std::ostringstream 输出;
    输出 << 消息头.任务管理任务主键
        << "|" << 消息头.任务主键
        << "|" << 消息头.父任务主键
        << "|" << 消息头.步骤主键
        << "|" << 消息头.路径签名
        << "|" << 消息头.执行尝试号;
    return 输出.str();
}

inline std::string 构造任务管理线程状态消息文本(const 结构_任务管理线程状态消息& 消息)
{
    std::ostringstream 输出;
    输出 << "任务管理线程状态"
        << " | 尝试=" << 构造任务管理执行尝试键(消息.消息头)
        << " | 运行状态=" << 任务管理线程运行状态文本(消息.当前运行状态);
    if (消息.消息头.回复目标消息主键 != 0) {
        输出 << " | 回复=#" << 消息.消息头.回复目标消息主键;
    }
    if (是否线程状态消息表示执行结束(消息)) {
        输出 << " | 结束状态=" << 任务管理线程结束状态文本(消息.结束状态);
    }
    if (!消息.消息头.步骤主键.empty()) {
        输出 << " | 步骤=" << 消息.消息头.步骤主键;
    }
    if (消息.是否携带控制请求 || !消息.控制请求主键.empty()) {
        输出 << " | 控制请求=" << (消息.控制请求主键.empty() ? "未命名" : 消息.控制请求主键)
            << " | 控制意图=" << 任务管理控制意图值文本(消息.当前控制意图)
            << " | 响应=" << 任务管理控制响应状态文本(消息.当前控制响应状态)
            << " | 已执行=" << (消息.是否控制已执行完成 ? "是" : "否");
        if (!消息.控制拒绝原因.empty()) {
            输出 << " | 拒绝原因=" << 消息.控制拒绝原因;
        }
    }
    return 输出.str();
}

inline std::string 构造任务管理派生需求消息文本(const 结构_任务管理派生需求消息& 消息)
{
    std::ostringstream 输出;
    输出 << "任务管理派生需求"
        << " | 尝试=" << 构造任务管理执行尝试键(消息.消息头)
        << " | 挂接=" << 需求任务挂接方式文本(消息.任务挂接方式)
        << " | 类型=" << 任务管理派生需求类型文本(消息.派生需求类型)
        << " | 阻塞级别=" << 任务管理阻塞级别文本(消息.阻塞级别)
        << " | 本地不可消化=" << (消息.是否本地不可消化 ? "是" : "否")
        << " | 阻塞当前步骤=" << (消息.是否阻塞当前步骤 ? "是" : "否");
    if (!消息.当前方法主键.empty()) {
        输出 << " | 方法=" << 消息.当前方法主键;
    }
    if (!消息.方法虚拟存在主键.empty()) {
        输出 << " | 方法虚拟存在=" << 消息.方法虚拟存在主键;
    }
    if (!消息.父需求主键.empty()) {
        输出 << " | 父需求=" << 消息.父需求主键;
    }
    if (!消息.方法需求位.empty()) {
        输出 << " | 方法需求位=" << 消息.方法需求位;
    }
    if (!消息.本能能力缺口类型.empty()) {
        输出 << " | 本能缺口=" << 消息.本能能力缺口类型;
    }
    if (!消息.主观察特征.empty()) {
        输出 << " | 主观察=" << 消息.主观察特征;
    }
    if (!消息.需求特征类型主键.empty()) {
        输出 << " | 需求特征=" << 消息.需求特征类型主键;
    }
    if (!消息.需求当前状态主键.empty()) {
        输出 << " | 当前状态=" << 消息.需求当前状态主键;
    }
    if (!消息.需求目标状态主键.empty()) {
        输出 << " | 目标状态=" << 消息.需求目标状态主键;
    }
    if (!消息.当前等待原因.empty()) {
        输出 << " | 等待原因=" << 消息.当前等待原因;
    }
    return 输出.str();
}

inline std::string 构造任务管理结果状态消息文本(const 结构_任务管理结果状态消息& 消息)
{
    std::ostringstream 输出;
    输出 << "任务管理结果状态"
        << " | 尝试=" << 构造任务管理执行尝试键(消息.消息头)
        << " | 结果=" << 任务管理结果状态文本(消息.结果状态)
        << " | 成功=" << (消息.是否成功 ? "是" : "否")
        << " | 完成度=" << 消息.完成度
        << " | 错误码=" << 消息.错误码;
    if (!消息.结果节点主键.empty()) {
        输出 << " | 结果节点=" << 消息.结果节点主键;
    }
    if (!消息.结果节点场景主键.empty()) {
        输出 << " | 结果场景=" << 消息.结果节点场景主键;
    }
    if (!消息.方法虚拟存在主键.empty()) {
        输出 << " | 方法虚拟存在=" << 消息.方法虚拟存在主键;
    }
    return 输出.str();
}

} // export
