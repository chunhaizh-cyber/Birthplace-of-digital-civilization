module;

#include <cstdint>
#include <sstream>
#include <string>
#include <variant>
#include <vector>

#include "基础数据类型.h"
#include "需求任务挂接方式.h"
#include "语素信息类型.h"

export module 任务模块.工作线程消息协议;

import 自我模块.特征定义;

export {

enum class 枚举_任务管理上行消息类型 : std::uint8_t {
    未定义 = 0,
    线程状态消息 = 1,
    派生需求消息 = 2,
    结果状态消息 = 3,
};

enum class 枚举_任务管理结果状态 : std::uint8_t {
    未定义 = 0,
    成功 = 1,
    失败 = 2,
    部分完成 = 3,
    中断 = 4,
    收束完成 = 5,
    异常结束 = 6,
};

enum class 枚举_任务管理线程运行状态 : std::uint8_t {
    未定义 = 0,
    已启动 = 1,
    推进中 = 2,
    等待中 = 3,
    阻塞 = 4,
    故障 = 5,
    收束中 = 6,
    已停止 = 7,
};

enum class 枚举_任务管理线程结束状态 : std::uint8_t {
    未定义 = 0,
    未结束 = 1,
    正常结束 = 2,
    收束结束 = 3,
    中断结束 = 4,
    故障结束 = 5,
    超时结束 = 6,
};

enum class 枚举_任务管理控制意图值 : std::uint8_t {
    未定义 = 0,
    请求启动 = 1,
    请求暂停 = 2,
    请求继续 = 3,
    请求打断 = 4,
    请求收束 = 5,
    请求停止 = 6,
    请求恢复重建 = 7,
    请求刷新预算 = 8,
    请求刷新优先级 = 9,
};

enum class 枚举_任务管理控制响应状态 : std::uint8_t {
    未定义 = 0,
    待承接 = 1,
    已承接 = 2,
    已响应 = 3,
    已执行完成 = 4,
    已拒绝 = 5,
    已超时 = 6,
};

enum class 枚举_任务管理派生需求类型 : std::uint8_t {
    未定义 = 0,
    缺资源 = 1,
    缺确认 = 2,
    缺信息 = 3,
    缺方法 = 4,
    风险处置 = 5,
    异常恢复 = 6,
    补偿动作 = 7,
    任务步骤 = 8,
    缺条件 = 9,
};

enum class 枚举_任务管理阻塞级别 : std::uint8_t {
    未定义 = 0,
    轻微 = 1,
    中等 = 2,
    严重 = 3,
    致命 = 4,
};

enum class 枚举_任务管理线程补充特征类型 : std::uint8_t {
    未定义 = 0,
    当前步骤主键 = 1,
    当前步骤前沿 = 2,
    当前等待原因 = 3,
    是否可继续推进 = 4,
    是否已响应控制意图 = 5,
    当前预算消耗 = 6,
    当前时间消耗 = 7,
    是否超时 = 8,
    是否触发异常 = 9,
    当前局部风险等级 = 10,
    建议自我线程重判 = 11,
    建议收束 = 12,
    建议恢复重建 = 13,
    当前控制请求主键 = 14,
    当前控制意图值 = 15,
    当前控制响应状态 = 16,
    控制拒绝原因 = 17,
};

struct 结构_任务管理消息头 {
    std::string 发出者主键{};
    std::string 任务管理任务主键{};
    std::string 任务主键{};
    std::string 父任务主键{};
    std::string 步骤主键{};
    std::string 关联场景主键{};
    时间戳 产生时间 = 0;
    std::uint64_t 回复目标消息主键 = 0;
    std::uint64_t 执行尝试号 = 0;
    std::string 执行尝试主键{};
    std::uint64_t 路径签名 = 0;
    std::string 幂等键{};
    std::string 影子验证状态{};
    bool 允许正式资产提交 = false;
};

struct 结构_任务管理状态变化项 {
    std::string 变化主体主键{};
    std::string 变化主体类型文本{};
    std::string 特征类型文本{};
    std::string 特征标签{};
    特征值 变化前值{};
    特征值 变化后值{};
    bool 已确认生效 = false;
    bool 是否关键中间状态 = false;
    bool 已恢复 = false;
    std::string 变化原因键{};
};

struct 结构_任务管理关键中间状态变化项 {
    std::string 动作主体主键{};
    std::string 动作主体类型文本{};
    std::string 动作语义键{};
    std::string 输入场景主键{};
    std::string 输出场景主键{};
    std::string 变化主体主键{};
    std::string 变化主体类型文本{};
    std::string 特征类型文本{};
    特征值 变化前值{};
    特征值 变化后值{};
    时间戳 发生时间 = 0;
    bool 执行成功 = false;
    I64 错误码 = 0;
    std::uint64_t 路径签名 = 0;
    bool 已确认生效 = false;
    bool 已恢复 = false;
};

struct 结构_任务管理未满足项 {
    std::string 未满足项类型{};
    std::string 作用主体主键{};
    bool 是否关键阻塞 = false;
    bool 是否建议线程重判 = false;
};

struct 结构_任务管理线程补充特征 {
    枚举_任务管理线程补充特征类型 特征类型 = 枚举_任务管理线程补充特征类型::未定义;
    std::string 文本值{};
    I64 数值 = 0;
    bool 布尔值 = false;
    std::uintptr_t 指针值 = 0;
    std::uintptr_t 特征类型抽象特征指针 = 0;
    I64 特征类型值 = 0;
};

struct 结构_任务管理控制请求 {
    std::string 请求主键{};
    std::string 目标线程主键{};
    std::string 目标任务管理任务主键{};
    std::string 目标任务主键{};
    std::uint64_t 回复目标消息主键 = 0;
    枚举_任务管理控制意图值 控制意图值 = 枚举_任务管理控制意图值::未定义;
    std::string 发起者主键{};
    std::string 发起者类型文本{};
    时间戳 发生时间 = 0;
    std::string 请求原因{};
    bool 是否需要确认 = false;
    I64 请求预算 = 0;
    I64 请求优先级 = 0;
    std::string 请求说明{};
    std::uintptr_t 控制意图抽象特征指针 = 0;
    I64 控制意图当前值 = 0;
};

struct 结构_任务管理控制响应记录 {
    std::string 请求主键{};
    std::string 执行尝试主键{};
    枚举_任务管理控制意图值 控制意图值 = 枚举_任务管理控制意图值::未定义;
    枚举_任务管理控制响应状态 响应状态 = 枚举_任务管理控制响应状态::未定义;
    bool 是否已下发 = false;
    bool 是否已响应 = false;
    bool 是否已执行完成 = false;
    bool 是否超时 = false;
    时间戳 最近回报时间 = 0;
    std::string 拒绝原因{};
    std::string 响应说明{};
    std::uintptr_t 控制意图抽象特征指针 = 0;
    I64 控制意图当前值 = 0;
    std::uintptr_t 响应状态抽象特征指针 = 0;
    I64 响应状态当前值 = 0;
};

struct 结构_任务管理线程状态消息 {
    结构_任务管理消息头 消息头{};
    枚举_任务管理线程运行状态 当前运行状态 = 枚举_任务管理线程运行状态::未定义;
    bool 是否执行尝试结束 = false;
    枚举_任务管理线程结束状态 结束状态 = 枚举_任务管理线程结束状态::未定义;
    时间戳 开始时间 = 0;
    时间戳 结束时间 = 0;
    bool 是否携带控制请求 = false;
    std::string 控制请求主键{};
    枚举_任务管理控制意图值 当前控制意图 = 枚举_任务管理控制意图值::未定义;
    枚举_任务管理控制响应状态 当前控制响应状态 = 枚举_任务管理控制响应状态::未定义;
    bool 是否控制已执行完成 = false;
    std::string 控制拒绝原因{};
    std::vector<结构_任务管理线程补充特征> 补充特征集{};
    std::uintptr_t 当前运行状态抽象特征指针 = 0;
    I64 当前运行状态值 = 0;
    std::uintptr_t 结束状态抽象特征指针 = 0;
    I64 结束状态值 = 0;
    std::uintptr_t 当前控制意图抽象特征指针 = 0;
    I64 当前控制意图值 = 0;
    std::uintptr_t 当前控制响应状态抽象特征指针 = 0;
    I64 当前控制响应状态值 = 0;
};

struct 结构_任务管理派生需求消息 {
    结构_任务管理消息头 消息头{};
    std::string 当前方法主键{};
    std::uintptr_t 方法虚拟存在指针 = 0;
    std::string 方法虚拟存在主键{};
    std::uintptr_t 父需求指针 = 0;
    std::string 父需求主键{};
    std::string 方法需求位{};
    std::string 本能能力缺口类型{};
    std::string 主观察特征{};
    枚举_需求任务挂接方式 任务挂接方式 = 枚举_需求任务挂接方式::未定义;
    枚举_任务管理派生需求类型 派生需求类型 = 枚举_任务管理派生需求类型::未定义;
    枚举_任务管理阻塞级别 阻塞级别 = 枚举_任务管理阻塞级别::未定义;
    bool 是否本地不可消化 = false;
    bool 是否阻塞当前步骤 = false;
    bool 是否影响父任务推进 = false;
    bool 是否需要外部支撑 = false;
    bool 是否可能影响服务 = false;
    bool 是否可能影响安全 = false;
    bool 是否建议线程重判 = false;
    bool 是否疑似需要新任务入口 = false;
    std::string 触发动作主体主键{};
    std::string 触发动作主体类型文本{};
    std::string 触发动作语义键{};
    std::uintptr_t 需求特征类型指针 = 0;
    std::string 需求特征类型主键{};
    std::uintptr_t 需求当前状态指针 = 0;
    std::string 需求当前状态主键{};
    std::uintptr_t 需求目标状态指针 = 0;
    std::string 需求目标状态主键{};
    std::string 当前等待原因{};
    std::vector<结构_任务管理状态变化项> 局部状态变化集{};
    std::vector<结构_任务管理未满足项> 缺口项集{};
    std::uintptr_t 任务挂接方式抽象特征指针 = 0;
    I64 任务挂接方式值 = 0;
    std::uintptr_t 派生需求类型抽象特征指针 = 0;
    I64 派生需求类型值 = 0;
    std::uintptr_t 阻塞级别抽象特征指针 = 0;
    I64 阻塞级别值 = 0;
};

struct 结构_任务管理结果状态消息 {
    结构_任务管理消息头 消息头{};

    std::string 结果节点主键{};
    std::uintptr_t 结果节点指针 = 0;
    std::string 结果节点场景主键{};
    std::uintptr_t 方法虚拟存在指针 = 0;
    std::string 方法虚拟存在主键{};
    bool 是否已正式写入结果节点 = false;
    时间戳 执行开始时间 = 0;
    时间戳 执行结束时间 = 0;

    枚举_任务管理结果状态 结果状态 = 枚举_任务管理结果状态::未定义;
    double 完成度 = 0.0;
    特征值 结果值{};
    bool 是否成功 = false;
    I64 错误码 = 0;
    时间戳 完成时间 = 0;

    bool 是否存在关键中间状态 = false;
    bool 是否仍有未满足项 = false;
    std::string 未满足项类型文本{};
    bool 是否需要外部支撑 = false;
    bool 是否需要父任务处理 = false;
    bool 是否需要自我线程重判 = false;
    bool 是否疑似需要新任务入口 = false;
    bool 可能影响父任务 = false;

    std::vector<结构_任务管理状态变化项> 服务对象状态变化集{};
    std::vector<结构_任务管理关键中间状态变化项> 关键中间状态变化集{};
    std::vector<结构_任务管理未满足项> 未满足项集{};
    std::uintptr_t 结果状态抽象特征指针 = 0;
    I64 结果状态值 = 0;
};

using 任务管理上行消息载荷 =
    std::variant<std::monostate, 结构_任务管理线程状态消息, 结构_任务管理派生需求消息, 结构_任务管理结果状态消息>;

struct 结构_任务管理上行消息 {
    枚举_任务管理上行消息类型 类型 = 枚举_任务管理上行消息类型::未定义;
    任务管理上行消息载荷 载荷{};
    std::uintptr_t 类型抽象特征指针 = 0;
    I64 类型值 = 0;
};

inline std::uintptr_t 任务管理抽象特征指针(const 词性节点类* 特征类型) noexcept
{
    return reinterpret_cast<std::uintptr_t>(特征类型);
}

inline void 同步任务管理线程补充特征语义槽(结构_任务管理线程补充特征& 特征) noexcept
{
    特征.特征类型抽象特征指针 =
        任务管理抽象特征指针(自我特征定义类::类型_任务管理_线程补充特征类型());
    特征.特征类型值 = static_cast<I64>(特征.特征类型);
}

inline void 同步任务管理控制请求语义槽(结构_任务管理控制请求& 请求) noexcept
{
    请求.控制意图抽象特征指针 =
        任务管理抽象特征指针(自我特征定义类::类型_任务管理_控制意图());
    请求.控制意图当前值 = static_cast<I64>(请求.控制意图值);
}

inline void 同步任务管理控制响应语义槽(结构_任务管理控制响应记录& 响应) noexcept
{
    响应.控制意图抽象特征指针 =
        任务管理抽象特征指针(自我特征定义类::类型_任务管理_控制意图());
    响应.控制意图当前值 = static_cast<I64>(响应.控制意图值);
    响应.响应状态抽象特征指针 =
        任务管理抽象特征指针(自我特征定义类::类型_任务管理_控制响应状态());
    响应.响应状态当前值 = static_cast<I64>(响应.响应状态);
}

inline void 同步任务管理线程状态消息语义槽(结构_任务管理线程状态消息& 消息) noexcept
{
    消息.当前运行状态抽象特征指针 =
        任务管理抽象特征指针(自我特征定义类::类型_任务管理_线程运行状态());
    消息.当前运行状态值 = static_cast<I64>(消息.当前运行状态);
    消息.结束状态抽象特征指针 =
        任务管理抽象特征指针(自我特征定义类::类型_任务管理_线程结束状态());
    消息.结束状态值 = static_cast<I64>(消息.结束状态);
    消息.当前控制意图抽象特征指针 =
        任务管理抽象特征指针(自我特征定义类::类型_任务管理_控制意图());
    消息.当前控制意图值 = static_cast<I64>(消息.当前控制意图);
    消息.当前控制响应状态抽象特征指针 =
        任务管理抽象特征指针(自我特征定义类::类型_任务管理_控制响应状态());
    消息.当前控制响应状态值 = static_cast<I64>(消息.当前控制响应状态);
    for (auto& 特征 : 消息.补充特征集) {
        同步任务管理线程补充特征语义槽(特征);
    }
}

inline void 同步任务管理派生需求消息语义槽(结构_任务管理派生需求消息& 消息) noexcept
{
    消息.任务挂接方式抽象特征指针 =
        任务管理抽象特征指针(自我特征定义类::类型_任务管理_任务挂接方式());
    消息.任务挂接方式值 = static_cast<I64>(消息.任务挂接方式);
    消息.派生需求类型抽象特征指针 =
        任务管理抽象特征指针(自我特征定义类::类型_任务管理_派生需求类型());
    消息.派生需求类型值 = static_cast<I64>(消息.派生需求类型);
    消息.阻塞级别抽象特征指针 =
        任务管理抽象特征指针(自我特征定义类::类型_任务管理_阻塞级别());
    消息.阻塞级别值 = static_cast<I64>(消息.阻塞级别);
}

inline void 同步任务管理结果状态消息语义槽(结构_任务管理结果状态消息& 消息) noexcept
{
    消息.结果状态抽象特征指针 =
        任务管理抽象特征指针(自我特征定义类::类型_任务管理_结果状态());
    消息.结果状态值 = static_cast<I64>(消息.结果状态);
}

inline void 同步任务管理上行消息语义槽(结构_任务管理上行消息& 消息) noexcept
{
    消息.类型抽象特征指针 =
        任务管理抽象特征指针(自我特征定义类::类型_任务管理_上行消息类型());
    消息.类型值 = static_cast<I64>(消息.类型);

    if (auto* 线程状态 = std::get_if<结构_任务管理线程状态消息>(&消息.载荷)) {
        同步任务管理线程状态消息语义槽(*线程状态);
    }
    if (auto* 派生需求 = std::get_if<结构_任务管理派生需求消息>(&消息.载荷)) {
        同步任务管理派生需求消息语义槽(*派生需求);
    }
    if (auto* 结果状态 = std::get_if<结构_任务管理结果状态消息>(&消息.载荷)) {
        同步任务管理结果状态消息语义槽(*结果状态);
    }
}

inline const char* 任务管理上行消息类型文本(枚举_任务管理上行消息类型 类型) noexcept
{
    switch (类型) {
    case 枚举_任务管理上行消息类型::线程状态消息: return "线程状态消息";
    case 枚举_任务管理上行消息类型::派生需求消息: return "派生需求消息";
    case 枚举_任务管理上行消息类型::结果状态消息: return "结果状态消息";
    default: return "未定义";
    }
}

inline const char* 任务管理结果状态文本(枚举_任务管理结果状态 状态) noexcept
{
    switch (状态) {
    case 枚举_任务管理结果状态::成功: return "成功";
    case 枚举_任务管理结果状态::失败: return "失败";
    case 枚举_任务管理结果状态::部分完成: return "部分完成";
    case 枚举_任务管理结果状态::中断: return "中断";
    case 枚举_任务管理结果状态::收束完成: return "收束完成";
    case 枚举_任务管理结果状态::异常结束: return "异常结束";
    case 枚举_任务管理结果状态::未定义:
    default:
        return "未定义";
    }
}

inline const char* 任务管理线程运行状态文本(枚举_任务管理线程运行状态 状态) noexcept
{
    switch (状态) {
    case 枚举_任务管理线程运行状态::已启动: return "已启动";
    case 枚举_任务管理线程运行状态::推进中: return "推进中";
    case 枚举_任务管理线程运行状态::等待中: return "等待中";
    case 枚举_任务管理线程运行状态::阻塞: return "阻塞";
    case 枚举_任务管理线程运行状态::故障: return "故障";
    case 枚举_任务管理线程运行状态::收束中: return "收束中";
    case 枚举_任务管理线程运行状态::已停止: return "已停止";
    case 枚举_任务管理线程运行状态::未定义:
    default:
        return "未定义";
    }
}

