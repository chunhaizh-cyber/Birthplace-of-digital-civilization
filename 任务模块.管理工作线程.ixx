namespace {

using 任务节点 = 任务类::节点类;
using 需求节点 = 需求类::节点类;

struct 结构_工作线程壳状态 {
    std::mutex 锁{};
    任务管理工作线程::结构_工作线程实例快照 快照{};
    std::deque<任务管理工作线程::结构_工作线程界面回报记录> 界面回报列表{};
    std::deque<结构_任务管理上行消息> 上行消息直达队列{};
    std::uint64_t 下一个请求ID = 1;
    bool 界面线程壳已启动 = false;
    bool 工作线程壳已启动 = false;
};

enum class 枚举_界面线程工作调度动作 : std::uint8_t {
    挂起等待 = 0,
    开启下一轮 = 1,
    结束调度 = 2,
};

struct 结构_界面线程工作调度决策 {
    枚举_界面线程工作调度动作 动作 = 枚举_界面线程工作调度动作::挂起等待;
    std::string 原因{};
};

结构_工作线程壳状态& 私有_壳状态() noexcept
{
    static 结构_工作线程壳状态 状态{};
    return 状态;
}

时间戳 私有_时间(时间戳 now) noexcept
{
    return now != 0 ? now : 结构体_时间戳::当前_微秒();
}

std::string 私有_任务主键(const 任务节点* 节点) noexcept
{
    return 节点 ? 节点->获取主键() : std::string{};
}

std::string 私有_需求主键(const 需求节点* 节点) noexcept
{
    return 节点 ? 节点->获取主键() : std::string{};
}

bool 私有_任务状态已终结(枚举_任务状态 状态) noexcept
{
    return 状态 == 枚举_任务状态::完成
        || 状态 == 枚举_任务状态::失败
        || 状态 == 枚举_任务状态::取消
        || 状态 == 枚举_任务状态::超时;
}

bool 私有_词性同一(const 词性节点类* 左, const 词性节点类* 右) noexcept
{
    if (!左 || !右) {
        return false;
    }
    if (左 == 右) {
        return true;
    }
    const auto 左主键 = 左->获取主键();
    return !左主键.empty() && 左主键 == 右->获取主键();
}

任务节点* 私有_按主键解析任务节点(const std::string& 主键) noexcept
{
    if (主键.empty()) {
        return nullptr;
    }
    return reinterpret_cast<任务节点*>(世界树.基础信息().查找主键(主键));
}

任务节点* 私有_解析任务引用(const 可解析引用<任务节点类>& 引用) noexcept
{
    if (引用.指针) {
        return reinterpret_cast<任务节点*>(引用.指针);
    }
    return 私有_按主键解析任务节点(引用.主键);
}

bool 私有_任务节点归属任务头(
    const 任务节点* 节点,
    const 任务节点* 任务头) noexcept
{
    if (!节点 || !任务头) {
        return false;
    }
    const auto* 所属任务 = reinterpret_cast<const 任务节点*>(节点->主信息.所属任务头结点.指针);
    if (所属任务 == 任务头) {
        return true;
    }
    const auto& 所属主键 = 节点->主信息.所属任务头结点.主键;
    return !所属主键.empty() && 所属主键 == 任务头->获取主键();
}

bool 私有_方法是任务治理本能方法(
    const 方法类::节点类* 方法,
    const 枚举_本能方法ID 本能ID) noexcept
{
    return 方法
        && 方法->主信息.动作句柄.类型 == 枚举_动作句柄类型::本能函数ID
        && static_cast<枚举_本能方法ID>(方法->主信息.动作句柄.本能ID) == 本能ID;
}

任务节点* 私有_任务根节点取任务(const 结构_任务根节点& 根节点) noexcept
{
    if (根节点.世界任务根指针 != 0) {
        return reinterpret_cast<任务节点*>(根节点.世界任务根指针);
    }
    if (根节点.父任务指针 != 0) {
        return reinterpret_cast<任务节点*>(根节点.父任务指针);
    }
    return nullptr;
}

任务节点* 私有_任务根节点取管理对象任务(const 结构_任务根节点& 根节点) noexcept
{
    return 根节点.管理对象任务指针 != 0
        ? reinterpret_cast<任务节点*>(根节点.管理对象任务指针)
        : nullptr;
}

需求节点* 私有_任务根节点取需求(const 结构_任务根节点& 根节点) noexcept
{
    return 根节点.来源需求指针 != 0
        ? reinterpret_cast<需求节点*>(根节点.来源需求指针)
        : nullptr;
}

bool 私有_任务已在需求列表(const 需求节点* 需求, const 任务节点* 任务) noexcept
{
    if (!需求 || !任务) {
        return false;
    }
    const auto 主键 = 私有_任务主键(任务);
    for (const auto& 项 : 需求->主信息.任务列表) {
        if (项.指针 == reinterpret_cast<const 任务节点类*>(任务)
            || (!主键.empty() && 项.主键 == 主键)) {
            return true;
        }
    }
    return false;
}

void 私有_绑定任务需求关系(任务节点* 任务, 需求节点* 需求) noexcept
{
    if (!任务 || !需求) {
        return;
    }

    任务->主信息.对应需求.指针 = reinterpret_cast<需求节点类*>(需求);
    任务->主信息.对应需求.主键 = 私有_需求主键(需求);
    任务->主信息.目标状态.指针 = 需求->主信息.需求状态.指针;
    任务->主信息.目标状态.主键 = 需求->主信息.需求状态.主键;
    任务->主信息.基准优先级 = 需求->主信息.安全权重 + 需求->主信息.服务权重;
    任务->主信息.调度优先级 = 任务->主信息.基准优先级 + 任务->主信息.局部优先级偏移;

    if (任务->主信息.状态 == 枚举_任务状态::未定义) {
        任务->主信息.状态 = 枚举_任务状态::未启动;
    }
    if (任务->主信息.任务角色 == 枚举_任务角色::未定义) {
        任务->主信息.任务角色 = 需求->子节点数量 > 0
            ? 枚举_任务角色::需求管理任务
            : 枚举_任务角色::需求执行任务;
    }
    if (任务->主信息.完成口径 == 枚举_任务完成口径::未定义) {
        任务->主信息.完成口径 = 需求->子节点数量 > 0
            ? 枚举_任务完成口径::子需求全部完成
            : 枚举_任务完成口径::需求状态达成;
    }

    if (!私有_任务已在需求列表(需求, 任务)) {
        可解析引用<任务节点类> 引用{};
        引用.指针 = reinterpret_cast<任务节点类*>(任务);
        引用.主键 = 私有_任务主键(任务);
        需求->主信息.任务列表.push_back(引用);
    }
}

任务节点* 私有_从需求任务列表取任务(const 需求节点* 需求) noexcept
{
    if (!需求) {
        return nullptr;
    }
    for (const auto& 引用 : 需求->主信息.任务列表) {
        if (auto* 任务 = reinterpret_cast<任务节点*>(引用.指针)) {
            return 任务;
        }
    }
    return nullptr;
}

任务节点* 私有_消息取任务(const 任务管理工作线程::结构_任务信息消息& 消息) noexcept
{
    if (消息.新任务) {
        return 消息.新任务;
    }
    return 私有_从需求任务列表取任务(消息.任务目标);
}

void 私有_写入任务节点引用(
    可解析引用<任务节点类>& 输出,
    任务节点* 节点) noexcept
{
    输出.指针 = reinterpret_cast<任务节点类*>(节点);
    输出.主键 = 节点 ? 节点->获取主键() : std::string{};
}

bool 私有_任务引用指向(
    const 可解析引用<任务节点类>& 引用,
    const 任务节点* 节点) noexcept
{
    if (!节点) {
        return false;
    }
    return 引用.指针 == reinterpret_cast<const 任务节点类*>(节点)
        || (!引用.主键.empty() && 引用.主键 == 节点->获取主键());
}

方法类::节点类* 私有_确保任务管理本能方法(
    自我类& 自我对象,
    枚举_本能方法ID 本能ID,
    时间戳 now,
    const std::string& 调用点) noexcept
{
    auto* 自我存在 = 自我对象.获取自我存在();
    if (!自我存在) {
        return nullptr;
    }
    auto* 方法 = 方法类::查找或创建_本能方法首节点(
        自我存在,
        本能ID,
        now,
        调用点 + "/本能方法");
    if (方法) {
        (void)方法类::初始化方法虚拟存在信息(
            方法,
            自我存在,
            now,
            调用点 + "/初始化本能方法虚拟存在");
        (void)方法类::记录方法虚拟存在特征(
            方法,
            语素集.添加词性词("方法是否可用", "名词"),
            特征值{ static_cast<I64>(1) },
            自我存在,
            now,
            调用点 + "/本能方法可用");
    }
    return 方法;
}

const 词性节点类* 私有_任务管理本体步骤类型词(const char* 名称) noexcept
{
    return 语素集.添加词性词(名称 ? 名称 : "步骤", "名词");
}

bool 私有_任务管理本体步骤有效(
    const 任务节点* 步骤,
    const 任务节点* 管理任务,
    const char* 步骤名称,
    const 枚举_本能方法ID 本能ID) noexcept
{
    if (!步骤
        || !管理任务
        || 步骤->主信息.节点种类 != 枚举_任务节点种类::步骤节点
        || !私有_任务节点归属任务头(步骤, 管理任务)
        || !私有_词性同一(步骤->主信息.类型, 私有_任务管理本体步骤类型词(步骤名称))
        || 私有_任务状态已终结(步骤->主信息.状态)) {
        return false;
    }

    const auto* 方法 = reinterpret_cast<const 方法类::节点类*>(步骤->主信息.执行方法.指针);
    return 私有_方法是任务治理本能方法(方法, 本能ID);
}

bool 私有_当前步骤是任务两步壳(
    const 任务节点* 步骤,
    const 任务节点* 管理任务) noexcept
{
    return 私有_任务管理本体步骤有效(
            步骤,
            管理任务,
            "筹办",
            枚举_本能方法ID::自我_任务筹办)
        || 私有_任务管理本体步骤有效(
            步骤,
            管理任务,
            "执行",
            枚举_本能方法ID::自我_任务执行一步);
}

任务节点* 私有_查找任务管理本体步骤(
    任务节点* 管理任务,
    const char* 步骤名称) noexcept
{
    if (!管理任务) {
        return nullptr;
    }
    const auto* 类型词 = 私有_任务管理本体步骤类型词(步骤名称);
    std::vector<任务节点*> 待查{ 管理任务 };
    std::size_t 保护计数 = 0;
    while (!待查.empty() && ++保护计数 < 2048) {
        auto* 当前 = 待查.back();
        待查.pop_back();
        if (!当前) {
            continue;
        }
        if (当前 != 管理任务
            && 当前->主信息.节点种类 == 枚举_任务节点种类::步骤节点
            && 私有_词性同一(当前->主信息.类型, 类型词)
            && 私有_任务节点归属任务头(当前, 管理任务)) {
            return 当前;
        }
        if (!当前->子) {
            continue;
        }
        auto* 首子 = reinterpret_cast<任务节点*>(当前->子);
        auto* 子 = 首子;
        std::size_t 子保护 = 0;
        do {
            if (子) {
                待查.push_back(子);
            }
            子 = 子 ? reinterpret_cast<任务节点*>(子->下) : nullptr;
            ++子保护;
        } while (子 && 子 != 首子 && 子保护 < 512);
    }
    return nullptr;
}

任务节点* 私有_绑定任务管理实例当前步骤(
    任务节点* 管理任务,
    const char* 步骤名称) noexcept
{
    if (auto* 步骤 = 私有_查找任务管理本体步骤(管理任务, 步骤名称)) {
        私有_写入任务节点引用(管理任务->主信息.当前步骤节点, 步骤);
        return 步骤;
    }
    return nullptr;
}

void 私有_绑定任务管理实例步骤方法(
    自我类& 自我对象,
    任务节点* 管理任务,
    const char* 步骤名称,
    枚举_本能方法ID 本能ID,
    时间戳 now,
    const std::string& 调用点,
    bool 设为当前步骤 = false) noexcept
{
    auto* 步骤 = 设为当前步骤
        ? 私有_绑定任务管理实例当前步骤(管理任务, 步骤名称)
        : 私有_查找任务管理本体步骤(管理任务, 步骤名称);
    if (!步骤) {
        return;
    }
    auto* 方法 = 私有_确保任务管理本能方法(
        自我对象,
        本能ID,
        now,
        调用点 + "/步骤方法");
    if (!方法) {
        return;
    }
    步骤->主信息.执行方法.绑定(reinterpret_cast<方法节点类*>(方法));
    步骤->主信息.候选方法首节点.绑定(reinterpret_cast<方法节点类*>(方法));
    步骤->主信息.可用方法首节点.绑定(reinterpret_cast<方法节点类*>(方法));
    步骤->主信息.动作句柄 = 方法->主信息.动作句柄;
    步骤->主信息.状态 = 枚举_任务状态::就绪;
}

bool 私有_准备任务管理任务实例(
    自我类& 自我对象,
    任务节点* 管理任务,
    任务节点* 被管理任务,
    时间戳 now,
    const std::string& 调用点) noexcept
{
    if (!管理任务) {
        return false;
    }
    if (!被管理任务) {
        被管理任务 = 管理任务;
    }

    const bool 管理对象已变化 =
        !私有_任务引用指向(管理任务->主信息.管理对象任务, 被管理任务);
    私有_写入任务节点引用(管理任务->主信息.管理对象任务, 被管理任务);
    管理任务->主信息.任务角色 = 枚举_任务角色::任务管理任务;
    管理任务->主信息.完成口径 = 枚举_任务完成口径::治理状态完成;
    管理任务->主信息.目标状态 = 被管理任务->主信息.目标状态;
    管理任务->主信息.结果状态信息 = 被管理任务->主信息.结果状态信息;
    管理任务->主信息.基准优先级 = 被管理任务->主信息.基准优先级;
    管理任务->主信息.局部优先级偏移 =
        (std::max<std::int64_t>)(管理任务->主信息.局部优先级偏移, 被管理任务->主信息.局部优先级偏移 + 100);
    管理任务->主信息.调度优先级 = 管理任务->主信息.基准优先级 + 管理任务->主信息.局部优先级偏移;

    auto* 当前步骤 = 私有_解析任务引用(管理任务->主信息.当前步骤节点);
    const bool 当前步骤有效 = 私有_当前步骤是任务两步壳(当前步骤, 管理任务);
    const bool 需要回到筹办 =
        管理对象已变化
        || !当前步骤有效
        || 私有_任务状态已终结(管理任务->主信息.状态);
    {
        auto* 当前方法 = 当前步骤
            ? reinterpret_cast<方法类::节点类*>(当前步骤->主信息.执行方法.指针)
            : nullptr;
        std::ostringstream 输出;
        输出 << "任务管理界面线程/准备管理实例"
            << " | 管理任务=" << 私有_任务主键(管理任务)
            << " | 被管理任务=" << 私有_任务主键(被管理任务)
            << " | 当前步骤=" << 私有_任务主键(当前步骤)
            << " | 当前方法=" << (当前方法 ? 当前方法->获取主键() : std::string("空"))
            << " | 当前本能ID=" << (当前方法 ? 当前方法->主信息.动作句柄.本能ID : -1)
            << " | 步骤有效=" << (当前步骤有效 ? "是" : "否")
            << " | 管理对象变化=" << (管理对象已变化 ? "是" : "否")
            << " | 回筹办=" << (需要回到筹办 ? "是" : "否");
        项目运行日志(输出.str());
    }
    if (需要回到筹办) {
        if (auto* 筹办步骤 = 私有_绑定任务管理实例当前步骤(管理任务, "筹办")) {
            auto* 筹办方法 = 私有_确保任务管理本能方法(
                自我对象,
                枚举_本能方法ID::自我_任务筹办,
                now,
                调用点 + "/筹办");
            if (筹办方法) {
                筹办步骤->主信息.执行方法.绑定(reinterpret_cast<方法节点类*>(筹办方法));
                筹办步骤->主信息.候选方法首节点.绑定(reinterpret_cast<方法节点类*>(筹办方法));
                筹办步骤->主信息.可用方法首节点.绑定(reinterpret_cast<方法节点类*>(筹办方法));
                筹办步骤->主信息.动作句柄 = 筹办方法->主信息.动作句柄;
                筹办步骤->主信息.状态 = 枚举_任务状态::就绪;
            }
        }
        管理任务->主信息.状态 = 枚举_任务状态::待重筹办;
        管理任务->主信息.完成时间 = 0;
    }
    私有_绑定任务管理实例步骤方法(
        自我对象,
        管理任务,
        "执行",
        枚举_本能方法ID::自我_任务执行一步,
        now,
        调用点 + "/执行步骤",
        false);
    return true;
}

结构_任务根节点 私有_构造任务根节点(
    const 任务管理工作线程::结构_任务信息消息& 消息,
    任务节点* 管理任务,
    任务节点* 被管理任务,
    const std::uint64_t 请求ID) noexcept
{
    结构_任务根节点 根节点{};
    根节点.任务根ID = 管理任务
        ? static_cast<std::uint64_t>(reinterpret_cast<std::uintptr_t>(管理任务))
        : 请求ID;
    根节点.来源需求指针 = reinterpret_cast<std::uintptr_t>(消息.任务目标);
    根节点.世界任务根指针 = reinterpret_cast<std::uintptr_t>(管理任务);
    根节点.父任务指针 = 0;
    根节点.管理对象任务指针 = reinterpret_cast<std::uintptr_t>(被管理任务);
    根节点.来源需求主键 = 私有_需求主键(消息.任务目标);
    根节点.管理对象任务主键 = 私有_任务主键(被管理任务);
    根节点.方向说明 = "任务管理任务实例治理任务参数";
    根节点.创建者 = "任务管理界面线程";
    根节点.根约束说明 = "界面线程承接任务参数并派发任务管理任务实例";
    根节点.初始授权等级 = 1;
    根节点.只读 = false;
    return 根节点;
}

结构_任务控制态 私有_构造任务控制态(
    const 结构_任务根节点& 根节点,
    const 任务节点* 任务) noexcept
{
    结构_任务控制态 控制态{};
    控制态.任务根ID = 根节点.任务根ID;
    控制态.队列状态 = !任务
        ? 枚举_任务队列状态::等待
        : (私有_任务状态已终结(任务->主信息.状态)
            ? 枚举_任务队列状态::已结算
            : 枚举_任务队列状态::可运行);
    控制态.全局优先级 = 任务 ? 任务->主信息.调度优先级 : 0;
    控制态.绑定工作线程ID = 1;
    控制态.控制说明 = "界面线程承接任务控制态";
    return 控制态;
}

结构_任务局部运行态 私有_构造任务局部运行态(
    const 结构_任务根节点& 根节点,
    const 任务节点* 任务) noexcept
{
    结构_任务局部运行态 运行态{};
    运行态.任务根ID = 根节点.任务根ID;
    运行态.当前状态 = !任务
        ? 枚举_任务局部运行状态::等待条件
        : (私有_任务状态已终结(任务->主信息.状态)
            ? 枚举_任务局部运行状态::局部完成
            : 枚举_任务局部运行状态::已受理);
    运行态.当前步骤前沿 = reinterpret_cast<std::uintptr_t>(任务);
    运行态.当前等待原因 = 任务 ? std::string{} : std::string("缺少任务节点");
    运行态.局部运行说明 = "界面线程承接任务运行态";
    return 运行态;
}

void 私有_界面线程标记任务已承接(任务节点* 任务, const 时间戳 now) noexcept
{
    if (!任务 || 私有_任务状态已终结(任务->主信息.状态)) {
        return;
    }
    if (任务->主信息.状态 == 枚举_任务状态::未定义
        || 任务->主信息.状态 == 枚举_任务状态::未启动
        || 任务->主信息.状态 == 枚举_任务状态::就绪
        || 任务->主信息.状态 == 枚举_任务状态::待重筹办) {
        任务->主信息.状态 = 枚举_任务状态::排队中;
        任务->主信息.统计.记录观测(now);
    }
}

void 私有_界面线程标记任务已派发(任务节点* 任务, const 时间戳 now) noexcept
{
    if (!任务 || 私有_任务状态已终结(任务->主信息.状态)) {
        return;
    }
    任务->主信息.状态 = 枚举_任务状态::执行中;
    任务->主信息.最近调度时间 = now;
    if (任务->主信息.启动时间 == 0) {
        任务->主信息.启动时间 = now;
    }
    任务->主信息.统计.记录观测(now);
}

枚举_任务状态 私有_从执行结果推导界面任务状态(
    const 结构_任务步骤执行结果_最小& 任务数据,
    const 结构_本能动作步骤结果& 方法数据) noexcept
{
    if (任务结果缺条件_最小_v0(方法数据)) {
        return 枚举_任务状态::等待中;
    }
    if (任务结果缺方法_最小_v0(方法数据)) {
        return 枚举_任务状态::挂起;
    }
    if (任务治理步骤要求待重入_最小_v0(任务数据.当前方法, 方法数据)) {
        return 枚举_任务状态::待重筹办;
    }
    if (任务数据.记账结果 == 枚举_任务执行记账结果::转学习) {
        return 枚举_任务状态::挂起;
    }
    if (方法数据.成功) {
        return 枚举_任务状态::完成;
    }
    return 任务数据.当前方法 ? 枚举_任务状态::待重筹办 : 枚举_任务状态::等待中;
}

bool 私有_本轮禁止工作线程执行(
    const 结构_任务控制事件& 控制事件,
    枚举_任务管理根层重判结果 根层重判结果,
    枚举_任务管理执行前门控结果 执行前门控结果) noexcept
{
    return 根层重判结果 == 枚举_任务管理根层重判结果::停止退出边界
        || 执行前门控结果 == 枚举_任务管理执行前门控结果::禁止继续
        || 控制事件.事件类型 == 枚举_任务控制事件类型::停止;
}

结构_执行任务结果 私有_构造未执行任务结果(
    任务节点* 任务,
    const I64 错误码,
    const std::string& 解释) noexcept
{
    结构_执行任务结果 输出{};
    输出.任务执行结果.主任务 = 任务;
    输出.任务执行结果.当前步骤节点 = 任务;
    输出.任务执行结果.记账结果 = 枚举_任务执行记账结果::失败;
    输出.任务执行结果.方法执行结果.成功 = false;
    输出.任务执行结果.方法执行结果.成功码 = 错误码;
    输出.任务执行结果.方法执行结果.备注 = 解释;
    输出.方法执行结果 = 输出.任务执行结果.方法执行结果;
    return 输出;
}

std::string 私有_执行结果等待原因(
    const 结构_任务步骤执行结果_最小& 任务数据,
    const 结构_本能动作步骤结果& 方法数据)
{
    if (任务结果缺条件_最小_v0(方法数据)) {
        return !方法数据.备注.empty()
            ? 方法数据.备注
            : std::string("执行缺少方法执行条件，已上报自我线程补条件");
    }
    if (任务结果缺方法_最小_v0(方法数据)) {
        return !方法数据.备注.empty()
            ? 方法数据.备注
            : std::string("筹办缺少执行方法，交给任务管理任务补方法");
    }
    return 任务数据.当前方法
        ? std::string("方法执行未完成")
        : std::string("缺少执行方法");
}

bool 私有_回报包含派生需求消息(
    const 任务管理工作线程::结构_工作线程推进响应& 响应) noexcept
{
    return std::any_of(
        响应.桥接结果.上行消息集.begin(),
        响应.桥接结果.上行消息集.end(),
        [](const auto& 消息) noexcept {
            return 消息.类型 == 枚举_任务管理上行消息类型::派生需求消息;
        });
}

结构_界面线程工作调度决策 私有_界面线程裁决工作线程下一步(
    const 任务管理工作线程::结构_工作线程推进响应& 响应) noexcept
{
    结构_界面线程工作调度决策 决策{};
    const auto& 任务数据 = 响应.桥接结果.当前步骤方法执行数据;
    const auto& 方法数据 = 响应.桥接结果.当前步骤方法实际数据;

    if (!响应.推进成功) {
        决策.动作 = 枚举_界面线程工作调度动作::挂起等待;
        决策.原因 = "工作线程本轮未成功回报，界面线程挂起等待";
        return 决策;
    }

    if (响应.最新任务控制态.队列状态 == 枚举_任务队列状态::已结算
        || 响应.桥接结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::进入收束) {
        决策.动作 = 枚举_界面线程工作调度动作::结束调度;
        决策.原因 = "工作线程回报任务已进入收束或结算";
        return 决策;
    }

    if (私有_回报包含派生需求消息(响应)
        || 任务结果缺条件_最小_v0(方法数据)
        || 任务结果缺方法_最小_v0(方法数据)) {
        决策.动作 = 枚举_界面线程工作调度动作::挂起等待;
        决策.原因 = "工作线程已上报派生需求，等待自我线程处理后再唤醒";
        return 决策;
    }

    if (任务治理步骤要求待重入_最小_v0(任务数据.当前方法, 方法数据)
        || 响应.桥接结果.治理结果.宿主任务新状态 == 枚举_任务状态::待重筹办
        || 响应.桥接结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::进入运行
        || 响应.桥接结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::保持运行
        || 响应.桥接结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::回到重筹办
        || 响应.桥接结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::绑定方法) {
        决策.动作 = 枚举_界面线程工作调度动作::开启下一轮;
        决策.原因 = "工作线程完成一步且无外部缺口，界面线程排队下一轮";
        return 决策;
    }

    决策.动作 = 枚举_界面线程工作调度动作::挂起等待;
    决策.原因 = "工作线程本轮未形成可继续推进条件，界面线程挂起等待";
    return 决策;
}

void 私有_界面线程应用调度决策到回报(
    任务管理工作线程::结构_工作线程推进响应& 响应,
    任务节点* 任务,
    const 结构_界面线程工作调度决策& 决策,
    时间戳 now) noexcept
{
    if (!任务) {
        return;
    }

    switch (决策.动作) {
    case 枚举_界面线程工作调度动作::开启下一轮:
        if (!私有_任务状态已终结(任务->主信息.状态)) {
            响应.桥接结果.治理结果.宿主任务新状态 = 枚举_任务状态::排队中;
            响应.最新任务控制态.队列状态 = 枚举_任务队列状态::可运行;
            响应.最新任务控制态.已派发 = false;
            响应.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::当前步骤可执行;
            响应.最新任务局部运行态.当前等待原因.clear();
            响应.桥接结果.治理结果.当前下一步去向 = 枚举_任务管理下一步去向::进入运行;
            响应.桥接结果.治理结果.最近总控结果 = 枚举_任务管理总控结果::宿主已进入运行;
        }
        break;
    case 枚举_界面线程工作调度动作::结束调度:
        响应.最新任务控制态.队列状态 = 枚举_任务队列状态::已结算;
        响应.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::局部完成;
        响应.桥接结果.治理结果.当前下一步去向 = 枚举_任务管理下一步去向::进入收束;
        响应.桥接结果.治理结果.最近总控结果 = 枚举_任务管理总控结果::宿主进入收束;
        break;
    case 枚举_界面线程工作调度动作::挂起等待:
    default:
        响应.最新任务控制态.队列状态 = 枚举_任务队列状态::等待;
        响应.最新任务控制态.已派发 = false;
        响应.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::等待条件;
        if (响应.最新任务局部运行态.当前等待原因.empty()) {
            响应.最新任务局部运行态.当前等待原因 = 决策.原因;
        }
        响应.桥接结果.治理结果.当前下一步去向 = 枚举_任务管理下一步去向::保持等待;
        响应.桥接结果.治理结果.最近总控结果 = 枚举_任务管理总控结果::宿主保持等待;
        break;
    }

    响应.最新任务局部运行态.局部运行说明 = 决策.原因;
    if (now != 0) {
        任务->主信息.统计.记录观测(now);
    }
}

bool 私有_界面线程任务允许派发(const 任务节点* 任务) noexcept
{
    if (!任务 || 私有_任务状态已终结(任务->主信息.状态)) {
        return false;
    }
    switch (任务->主信息.状态) {
    case 枚举_任务状态::等待中:
    case 枚举_任务状态::挂起:
    case 枚举_任务状态::无法执行:
        return false;
    default:
        return true;
    }
}

const 词性节点类* 私有_状态特征类型词(const 状态节点类* 状态节点) noexcept
{
    const auto* 状态主信息 = 状态节点
        ? 世界树.状态().取状态主信息(const_cast<状态节点类*>(状态节点))
        : nullptr;
    if (!状态主信息) {
        return nullptr;
    }

    auto* 特征节点 = 状态主信息->状态特征.指针;
    if (!特征节点 && !状态主信息->状态特征.主键.empty()) {
        特征节点 = dynamic_cast<特征节点类*>(
            世界树.基础信息().查找主键(状态主信息->状态特征.主键));
    }
    const auto* 特征主信息 = 特征节点 ? 世界树.特征().取特征主信息(特征节点) : nullptr;
    return 特征主信息 ? 特征主信息->类型 : nullptr;
}

void 私有_填充派生需求状态字段(
    结构_任务管理派生需求消息& 消息,
    const 结构_本能动作步骤结果& 方法结果) noexcept
{
    if (方法结果.需求当前状态) {
        消息.需求当前状态指针 =
            reinterpret_cast<std::uintptr_t>(方法结果.需求当前状态);
        消息.需求当前状态主键 = 方法结果.需求当前状态->获取主键();
    }
    if (方法结果.需求目标状态) {
        消息.需求目标状态指针 =
            reinterpret_cast<std::uintptr_t>(方法结果.需求目标状态);
        消息.需求目标状态主键 = 方法结果.需求目标状态->获取主键();
    }

    const auto* 需求特征类型 = 私有_状态特征类型词(
        方法结果.需求目标状态 ? 方法结果.需求目标状态 : 方法结果.需求当前状态);
    if (!需求特征类型) {
        return;
    }
    消息.需求特征类型指针 = reinterpret_cast<std::uintptr_t>(需求特征类型);
    消息.需求特征类型主键 = 需求特征类型->获取主键();
    if (消息.主观察特征.empty()) {
        消息.主观察特征 = 语素集.获取词(需求特征类型);
    }
}

结构_任务管理上行消息 私有_构造补条件派生需求消息(
    const 任务节点* 任务,
    const 结构_执行任务结果& 执行结果,
    const 时间戳 now) noexcept
{
    结构_任务管理派生需求消息 消息{};
    const auto 任务主键 = 私有_任务主键(任务);
    const auto 步骤主键 = 私有_任务主键(执行结果.任务执行结果.当前步骤节点);
    消息.消息头.发出者主键 = "任务管理界面线程";
    消息.消息头.任务主键 = 任务主键;
    消息.消息头.步骤主键 = 步骤主键.empty() ? 任务主键 : 步骤主键;
    消息.消息头.产生时间 = now;
    消息.消息头.执行尝试主键 = 任务主键 + "|补条件";
    消息.当前方法主键 = 执行结果.任务执行结果.当前方法
        ? 执行结果.任务执行结果.当前方法->获取主键()
        : std::string{};
    消息.派生需求类型 = 枚举_任务管理派生需求类型::缺条件;
    消息.方法需求位 = "补条件";
    消息.阻塞级别 = 枚举_任务管理阻塞级别::严重;
    消息.是否阻塞当前步骤 = true;
    消息.是否影响父任务推进 = true;
    消息.是否建议线程重判 = true;
    消息.当前等待原因 = !执行结果.方法执行结果.备注.empty()
        ? 执行结果.方法执行结果.备注
        : std::string("缺少方法执行条件");
    if (auto* 方法虚拟存在 = 执行结果.方法执行结果.方法虚拟存在) {
        消息.方法虚拟存在指针 = reinterpret_cast<std::uintptr_t>(方法虚拟存在);
        消息.方法虚拟存在主键 = 方法虚拟存在->获取主键();
    }
    私有_填充派生需求状态字段(消息, 执行结果.方法执行结果);

    结构_任务管理上行消息 上行{};
    上行.类型 = 枚举_任务管理上行消息类型::派生需求消息;
    上行.载荷 = 消息;
    return 上行;
}

结构_任务管理上行消息 私有_构造补方法派生需求消息(
    const 任务节点* 任务,
    const 结构_执行任务结果& 执行结果,
    const 时间戳 now) noexcept
{
    结构_任务管理派生需求消息 消息{};
    const auto 任务主键 = 私有_任务主键(任务);
    const auto 步骤主键 = 私有_任务主键(执行结果.任务执行结果.当前步骤节点);
    auto* 方法 = 执行结果.任务执行结果.当前方法;

    消息.消息头.发出者主键 = "任务管理界面线程";
    消息.消息头.任务主键 = 任务主键;
    消息.消息头.步骤主键 = 步骤主键.empty() ? 任务主键 : 步骤主键;
    消息.消息头.产生时间 = now;
    消息.消息头.执行尝试主键 = 任务主键 + "|补方法";
    消息.当前方法主键 = 方法 ? 方法->获取主键() : std::string{};
    消息.派生需求类型 = 枚举_任务管理派生需求类型::缺方法;
    消息.方法需求位 = "补结构";
    消息.本能能力缺口类型 = "需学习补齐";
    消息.阻塞级别 = 枚举_任务管理阻塞级别::严重;
    消息.是否本地不可消化 = true;
    消息.是否阻塞当前步骤 = true;
    消息.是否影响父任务推进 = true;
    消息.是否需要外部支撑 = true;
    消息.是否可能影响服务 = true;
    消息.是否建议线程重判 = true;
    消息.是否疑似需要新任务入口 = true;
    消息.当前等待原因 = !执行结果.方法执行结果.备注.empty()
        ? 执行结果.方法执行结果.备注
        : std::string("方法结构不可用，等待学习任务补齐");
    if (auto* 方法虚拟存在 = 执行结果.方法执行结果.方法虚拟存在) {
        消息.方法虚拟存在指针 = reinterpret_cast<std::uintptr_t>(方法虚拟存在);
        消息.方法虚拟存在主键 = 方法虚拟存在->获取主键();
    }
    私有_填充派生需求状态字段(消息, 执行结果.方法执行结果);

    结构_任务管理上行消息 上行{};
    上行.类型 = 枚举_任务管理上行消息类型::派生需求消息;
    上行.载荷 = 消息;
    return 上行;
}

void 私有_推入界面回报_已加锁(
    结构_工作线程壳状态& 状态,
    const 任务管理工作线程::结构_工作线程推进响应& 响应,
    const 时间戳 now) noexcept
{
    任务管理工作线程::结构_工作线程界面回报记录 记录{};
    记录.回报时间 = now;
    记录.请求ID = 状态.快照.最近请求ID;
    记录.任务根ID = 状态.快照.最近任务根ID;
    记录.宿主任务主键 = 状态.快照.最近宿主任务主键;
    记录.步骤主键 = 状态.快照.最近步骤主键;
    记录.方法主键 = 状态.快照.最近方法主键;
    记录.结果主键 = 状态.快照.最近结果主键;
    记录.下一步去向 = 状态.快照.最近下一步去向;
    记录.总控结果 = 状态.快照.最近总控结果;
    记录.缺口归类 = 状态.快照.最近缺口归类;
    记录.筹办承接 = 状态.快照.最近筹办承接;
    记录.等待原因 = 状态.快照.最近等待原因;
    记录.推进事件数 = static_cast<std::uint64_t>(响应.桥接结果.推进事件列表.size());
    记录.上行消息数 = static_cast<std::uint64_t>(响应.桥接结果.上行消息集.size());
    状态.界面回报列表.push_front(记录);
    while (状态.界面回报列表.size() > 32) {
        状态.界面回报列表.pop_back();
    }
}

结构_任务管理上行消息 私有_构造结果状态上行消息(
    const 任务节点* 任务,
    const 结构_执行任务结果& 执行结果,
    const 时间戳 now) noexcept
{
    结构_任务管理结果状态消息 消息{};
    const auto 任务主键 = 私有_任务主键(任务);
    const auto 步骤主键 = 私有_任务主键(执行结果.任务执行结果.当前步骤节点);
    消息.消息头.发出者主键 = "任务管理界面线程";
    消息.消息头.任务主键 = 任务主键;
    消息.消息头.步骤主键 = 步骤主键.empty() ? 任务主键 : 步骤主键;
    消息.消息头.产生时间 = now;
    消息.消息头.执行尝试主键 = 任务主键 + "|执行任务";
    消息.执行结束时间 = now;
    if (auto* 结果场景 = 执行结果.方法执行结果.结果存在集场景) {
        消息.结果节点场景主键 = 结果场景->获取主键();
    }
    if (auto* 方法虚拟存在 = 执行结果.方法执行结果.方法虚拟存在) {
        消息.方法虚拟存在指针 = reinterpret_cast<std::uintptr_t>(方法虚拟存在);
        消息.方法虚拟存在主键 = 方法虚拟存在->获取主键();
    }
    消息.结果状态 = 执行结果.方法执行结果.成功
        ? 枚举_任务管理结果状态::成功
        : 枚举_任务管理结果状态::失败;
    消息.完成度 = 执行结果.方法执行结果.成功 ? 1.0 : 0.0;
    消息.是否成功 = 执行结果.方法执行结果.成功;
    消息.错误码 = 执行结果.方法执行结果.成功码;
    消息.完成时间 = now;
    消息.是否仍有未满足项 =
        任务结果缺条件_最小_v0(执行结果.方法执行结果)
        || 任务结果缺方法_最小_v0(执行结果.方法执行结果);
    消息.未满足项类型文本 =
        任务结果缺条件_最小_v0(执行结果.方法执行结果)
            ? "缺条件"
            : (任务结果缺方法_最小_v0(执行结果.方法执行结果) ? "缺方法" : std::string{});
    消息.是否需要父任务处理 = 任务结果缺方法_最小_v0(执行结果.方法执行结果);
    消息.是否需要自我线程重判 =
        执行结果.方法执行结果.成功
        || 任务结果缺条件_最小_v0(执行结果.方法执行结果);
    if (消息.是否仍有未满足项) {
        结构_任务管理未满足项 未满足项{};
        未满足项.未满足项类型 = 消息.未满足项类型文本;
        未满足项.作用主体主键 = 任务主键;
        未满足项.是否关键阻塞 = true;
        未满足项.是否建议线程重判 = 消息.是否需要自我线程重判;
        消息.未满足项集.push_back(未满足项);
    }

    结构_任务管理上行消息 上行{};
    上行.类型 = 枚举_任务管理上行消息类型::结果状态消息;
    上行.载荷 = 消息;
    return 上行;
}

任务管理工作线程::结构_工作线程推进响应 私有_工作线程执行当前任务方法(
    自我类& 自我对象,
    const 结构_任务根节点& 任务根节点,
    结构_任务控制态* 任务控制态,
    结构_任务局部运行态* 任务局部运行态,
    时间戳 now,
    const 结构_任务控制事件& 控制事件,
    枚举_任务管理根层重判结果 根层重判结果,
    枚举_任务管理执行前门控结果 执行前门控结果,
    const std::string& 上层反馈特征键,
    const std::string& 调用点,
    const 结构_任务管理请求* 提交请求) noexcept
{
    (void)上层反馈特征键;
    (void)调用点;
    (void)提交请求;

    now = 私有_时间(now);
    auto* 任务 = 私有_任务根节点取任务(任务根节点);

    任务管理工作线程::结构_工作线程推进响应 响应{};
    响应.最新任务控制态 = 任务控制态 ? *任务控制态 : 私有_构造任务控制态(任务根节点, 任务);
    响应.最新任务局部运行态 = 任务局部运行态 ? *任务局部运行态 : 私有_构造任务局部运行态(任务根节点, 任务);
    响应.桥接结果.根层重判结果 = 根层重判结果;
    响应.桥接结果.执行前门控结果 = 执行前门控结果;

    结构_执行任务结果 执行结果{};
    const bool 禁止执行 = 私有_本轮禁止工作线程执行(控制事件, 根层重判结果, 执行前门控结果);
    if (!任务) {
        执行结果 = 私有_构造未执行任务结果(nullptr, -12, "当前任务节点为空");
    } else if (禁止执行) {
        执行结果 = 私有_构造未执行任务结果(任务, -15, "界面线程禁止本轮执行");
    } else {
        try {
            auto* 当前步骤 = reinterpret_cast<任务节点*>(任务->主信息.当前步骤节点.指针);
            auto* 当前方法 = 当前步骤
                ? reinterpret_cast<方法类::节点类*>(当前步骤->主信息.执行方法.指针)
                : nullptr;
            auto* 管理对象任务 = reinterpret_cast<任务节点*>(任务->主信息.管理对象任务.指针);
            std::ostringstream 输出;
            输出 << "任务管理工作线程/执行任务入口"
                << " | 管理任务=" << 私有_任务主键(任务)
                << " | 管理对象=" << 私有_任务主键(管理对象任务)
                << " | 当前步骤=" << 私有_任务主键(当前步骤)
                << " | 当前方法=" << (当前方法 ? 当前方法->获取主键() : std::string("空"))
                << " | 当前本能ID=" << (当前方法 ? 当前方法->主信息.动作句柄.本能ID : -1)
                << " | 管理任务角色=" << static_cast<int>(任务->主信息.任务角色)
                << " | 管理对象角色=" << (管理对象任务 ? static_cast<int>(管理对象任务->主信息.任务角色) : -1);
            项目运行日志(输出.str());
            自我_执行桥类 执行桥{};
            执行结果 = 执行任务(执行桥, 任务, now, 0, false, "任务管理工作线程::执行当前任务方法");
        } catch (...) {
            执行结果.方法执行结果.成功 = false;
            执行结果.方法执行结果.成功码 = -9001;
            执行结果.方法执行结果.备注 = "执行任务异常";
        }
    }

    响应.桥接结果.已执行当前步骤方法 = 任务 != nullptr && !禁止执行;
    响应.桥接结果.存在当前步骤方法执行数据 = true;
    响应.桥接结果.当前步骤方法执行数据 = 执行结果.任务执行结果;
    响应.桥接结果.当前步骤方法实际数据 = 执行结果.方法执行结果;
    响应.推进成功 = true;
    return 响应;
}

void 私有_刷新快照_已加锁(
    结构_工作线程壳状态& 状态,
    const 任务管理工作线程::结构_工作线程推进响应& 响应,
    const 任务节点* 任务,
    const 时间戳 now) noexcept
{
    状态.快照.已启动 = 状态.工作线程壳已启动 || 状态.界面线程壳已启动;
    状态.快照.正在执行 = false;
    状态.快照.已收到请求 = true;
    状态.快照.最近任务根ID = 响应.最新任务控制态.任务根ID;
    状态.快照.累计推进次数 += 1;
    状态.快照.最近推进时间 = now;
    状态.快照.最近宿主任务主键 = 私有_任务主键(任务);
    状态.快照.最近步骤主键 = 私有_任务主键(
        响应.桥接结果.当前步骤方法执行数据.当前步骤节点);
    if (状态.快照.最近步骤主键.empty()) {
        状态.快照.最近步骤主键 = 状态.快照.最近宿主任务主键;
    }
    状态.快照.最近方法主键 = 响应.桥接结果.当前步骤方法执行数据.当前方法
        ? 响应.桥接结果.当前步骤方法执行数据.当前方法->获取主键()
        : std::string{};
    状态.快照.最近结果主键.clear();
    状态.快照.最近下一步去向 = 响应.桥接结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::进入收束
        ? "进入收束"
        : (响应.桥接结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::保持等待
            ? "保持等待"
            : "进入运行");
    状态.快照.最近总控结果 = 响应.桥接结果.治理结果.最近总控结果 == 枚举_任务管理总控结果::宿主进入收束
        ? "宿主进入收束"
        : (响应.桥接结果.治理结果.最近总控结果 == 枚举_任务管理总控结果::宿主保持等待
            ? "宿主保持等待"
            : "宿主已进入运行");
    状态.快照.最近缺口归类 = 响应.桥接结果.治理结果.当前缺口类型 == 枚举_任务管理缺口类型::方法挂点缺失
        ? "方法挂点缺失"
        : (响应.桥接结果.治理结果.当前缺口类型 == 枚举_任务管理缺口类型::无缺口
            ? "无缺口"
            : "界面线程按任务回报归类");
    状态.快照.最近筹办承接 = "界面线程已收取工作线程回报";
    状态.快照.最近等待原因 = 响应.最新任务局部运行态.当前等待原因;
    状态.快照.最近一次上行消息数 = static_cast<std::uint64_t>(响应.桥接结果.上行消息集.size());
    状态.快照.累计发送上行消息数 += 状态.快照.最近一次上行消息数;
}

void 私有_界面线程补齐工作线程回报(
    任务管理工作线程::结构_工作线程推进响应& 响应,
    任务节点* 任务,
    任务节点* 管理对象任务,
    需求节点* 需求,
    const 结构_任务根节点& 任务根节点,
    const 结构_任务控制事件& 控制事件,
    const 枚举_任务管理根层重判结果 根层重判结果,
    const 枚举_任务管理执行前门控结果 执行前门控结果,
    const 时间戳 now) noexcept
{
    auto& 桥接 = 响应.桥接结果;
    桥接.已消费控制事件 = 控制事件;
    桥接.根层重判结果 = 根层重判结果;
    桥接.执行前门控结果 = 执行前门控结果;
    桥接.任务管理治理触发 = true;
    桥接.任务管理上位输入已刷新 = true;
    桥接.治理结果.最近根层重判结果 = 根层重判结果;
    桥接.治理结果.最近执行前门控结果 = 执行前门控结果;
    桥接.治理结果.当前主需求 = 需求;
    桥接.治理结果.当前管理任务 = 任务;
    桥接.治理结果.当前宿主任务 = 管理对象任务 ? 管理对象任务 : 任务;
    桥接.治理结果.当前步骤节点 =
        桥接.当前步骤方法执行数据.当前步骤节点
            ? 桥接.当前步骤方法执行数据.当前步骤节点
            : 任务;
    桥接.治理结果.已选中宿主任务 = 任务 != nullptr;

    const bool 禁止执行 = 私有_本轮禁止工作线程执行(
        控制事件,
        根层重判结果,
        执行前门控结果);
    if (!任务) {
        响应.最新任务控制态.队列状态 = 枚举_任务队列状态::等待;
        响应.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::等待条件;
        响应.最新任务局部运行态.当前等待原因 = "缺少任务节点";
        桥接.治理结果.当前缺口类型 = 枚举_任务管理缺口类型::宿主任务缺失;
        桥接.治理结果.当前下一步去向 = 枚举_任务管理下一步去向::保持等待;
        桥接.治理结果.最近总控结果 = 枚举_任务管理总控结果::宿主保持等待;
        return;
    }

    if (禁止执行) {
        响应.最新任务控制态.队列状态 = 枚举_任务队列状态::已停止;
        响应.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::已停止;
        响应.最新任务局部运行态.当前等待原因 = "根层或门控禁止继续";
        桥接.治理结果.宿主任务旧状态 = 任务->主信息.状态;
        桥接.治理结果.宿主任务新状态 = 枚举_任务状态::挂起;
        桥接.治理结果.当前缺口类型 =
            根层重判结果 == 枚举_任务管理根层重判结果::停止退出边界
                ? 枚举_任务管理缺口类型::上位停止约束
                : 枚举_任务管理缺口类型::上位等待约束;
        桥接.治理结果.当前下一步去向 = 枚举_任务管理下一步去向::保持等待;
        桥接.治理结果.最近总控结果 = 枚举_任务管理总控结果::宿主保持等待;
        return;
    }

    const auto 推导状态 = 私有_从执行结果推导界面任务状态(
        桥接.当前步骤方法执行数据,
        桥接.当前步骤方法实际数据);
    桥接.治理结果.宿主任务旧状态 = 任务->主信息.最近执行记录.执行前状态;
    if (桥接.治理结果.宿主任务旧状态 == 枚举_任务状态::未定义) {
        桥接.治理结果.宿主任务旧状态 = 枚举_任务状态::执行中;
    }
    桥接.治理结果.宿主任务新状态 = 推导状态;
    桥接.治理结果.当前方法 = 桥接.当前步骤方法执行数据.当前方法;

    if (推导状态 == 枚举_任务状态::完成) {
        响应.最新任务控制态.队列状态 = 枚举_任务队列状态::已结算;
        响应.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::局部完成;
        响应.最新任务局部运行态.局部完成度 = 10000;
        桥接.治理结果.已推进任务状态 = true;
        桥接.治理结果.当前缺口类型 = 枚举_任务管理缺口类型::无缺口;
        桥接.治理结果.当前下一步去向 = 枚举_任务管理下一步去向::进入收束;
        桥接.治理结果.最近总控结果 = 枚举_任务管理总控结果::宿主进入收束;
    } else {
        响应.最新任务控制态.队列状态 = 枚举_任务队列状态::等待;
        响应.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::等待条件;
        响应.最新任务局部运行态.当前等待原因 = 私有_执行结果等待原因(
            桥接.当前步骤方法执行数据,
            桥接.当前步骤方法实际数据);
        桥接.治理结果.当前缺口类型 =
            任务结果缺方法_最小_v0(桥接.当前步骤方法实际数据)
                ? 枚举_任务管理缺口类型::方法挂点缺失
                : (桥接.当前步骤方法执行数据.当前方法
                    ? 枚举_任务管理缺口类型::任务运行中
                    : 枚举_任务管理缺口类型::方法挂点缺失);
        桥接.治理结果.当前下一步去向 = 枚举_任务管理下一步去向::保持等待;
        桥接.治理结果.最近总控结果 = 枚举_任务管理总控结果::宿主保持等待;
    }

    结构_执行任务结果 执行结果{};
    执行结果.任务执行结果 = 桥接.当前步骤方法执行数据;
    执行结果.方法执行结果 = 桥接.当前步骤方法实际数据;
    auto* 上行任务 = 管理对象任务 ? 管理对象任务 : 任务;
    const bool 仅任务管理内部换步 = 任务治理步骤要求待重入_最小_v0(
        桥接.当前步骤方法执行数据.当前方法,
        桥接.当前步骤方法实际数据);
    if (!仅任务管理内部换步) {
        if (任务结果缺条件_最小_v0(执行结果.方法执行结果)) {
            桥接.上行消息集.push_back(私有_构造补条件派生需求消息(上行任务, 执行结果, now));
        }
        if (任务结果缺方法_最小_v0(执行结果.方法执行结果)) {
            桥接.上行消息集.push_back(私有_构造补方法派生需求消息(上行任务, 执行结果, now));
        }
        auto 上行消息 = 私有_构造结果状态上行消息(上行任务, 执行结果, now);
        桥接.上行消息集.push_back(上行消息);
        桥接.上行消息已直达自我线程 = true;
    }
    const bool 已上报派生需求 =
        任务结果缺条件_最小_v0(执行结果.方法执行结果)
        || 任务结果缺方法_最小_v0(执行结果.方法执行结果);
    桥接.推进事件列表.push_back(结构_任务推进事件{
        任务根节点.任务根ID,
        推导状态 == 枚举_任务状态::完成
            ? 枚举_任务推进事件类型::最终结果返回
            : (已上报派生需求
                ? 枚举_任务推进事件类型::派生需求上报
                : 枚举_任务推进事件类型::当前步骤阻塞),
        reinterpret_cast<std::uintptr_t>(任务),
        0,
        响应.最新任务局部运行态.当前等待原因,
        桥接.当前步骤方法实际数据.备注
    });
}

void 私有_界面线程应用工作线程回报到任务(
    任务节点* 任务,
    const 任务管理工作线程::结构_工作线程推进响应& 响应,
    const 时间戳 now) noexcept
{
    if (!任务) {
        return;
    }
    if (响应.桥接结果.治理结果.宿主任务新状态 != 枚举_任务状态::未定义) {
        任务->主信息.状态 = 响应.桥接结果.治理结果.宿主任务新状态;
    }
    if (任务->主信息.状态 == 枚举_任务状态::完成
        && 任务->主信息.完成时间 == 0) {
        任务->主信息.完成时间 = now;
    }
    任务->主信息.等待学习唤醒 =
        任务结果缺方法_最小_v0(响应.桥接结果.当前步骤方法实际数据)
        || (任务->主信息.状态 == 枚举_任务状态::等待中
            && 响应.桥接结果.当前步骤方法执行数据.当前方法 == nullptr);
    任务->主信息.统计.记录观测(now);
}

void 私有_界面线程收取工作线程回报(
    结构_工作线程壳状态& 状态,
    const 任务管理工作线程::结构_工作线程推进响应& 响应,
    任务节点* 任务,
    const 时间戳 now) noexcept
{
    私有_界面线程应用工作线程回报到任务(任务, 响应, now);
    std::lock_guard<std::mutex> 锁(状态.锁);
    状态.快照.正在执行 = false;
    状态.快照.当前排队数 = 0;
    私有_刷新快照_已加锁(状态, 响应, 任务, now);
    for (const auto& 消息 : 响应.桥接结果.上行消息集) {
        状态.上行消息直达队列.push_back(消息);
    }
    私有_推入界面回报_已加锁(状态, 响应, now);
}

} // namespace

namespace 任务管理工作线程 {

bool 提取任务管理上行消息直达桥(
    std::vector<结构_任务管理上行消息>* 输出,
    std::size_t 最大数量) noexcept
{
    if (!输出) {
        return false;
    }
    auto& 状态 = 私有_壳状态();
    std::lock_guard<std::mutex> 锁(状态.锁);
    const auto 数量上限 = 最大数量 == 0 ? 状态.上行消息直达队列.size() : 最大数量;
    std::size_t 已取 = 0;
    while (!状态.上行消息直达队列.empty() && 已取 < 数量上限) {
        输出->push_back(状态.上行消息直达队列.front());
        状态.上行消息直达队列.pop_front();
        ++已取;
    }
    return 已取 > 0;
}

bool 确保任务管理工作线程壳已启动() noexcept
{
    auto& 状态 = 私有_壳状态();
    std::lock_guard<std::mutex> 锁(状态.锁);
    状态.工作线程壳已启动 = true;
    状态.快照.已启动 = true;
    return true;
}

bool 确保任务管理界面线程壳已启动() noexcept
{
    auto& 状态 = 私有_壳状态();
    std::lock_guard<std::mutex> 锁(状态.锁);
    状态.界面线程壳已启动 = true;
    状态.快照.已启动 = true;
    return true;
}

bool 接收任务信息并启动任务管理任务(
    自我类& 自我对象,
    const 结构_任务信息消息& 消息,
    const std::string& 调用点,
    结构_任务信息承接结果* 输出) noexcept
{
    (void)调用点;
    确保任务管理界面线程壳已启动();

    const auto now = 私有_时间(消息.当前时间);
    auto* 被管理任务 = 私有_消息取任务(消息);
    auto* 管理任务 = 消息.任务管理任务实例
        ? reinterpret_cast<任务节点*>(消息.任务管理任务实例)
        : reinterpret_cast<任务节点*>(自我对象.获取任务管理任务());
    if (!被管理任务) {
        被管理任务 = 管理任务;
    }
    私有_绑定任务需求关系(被管理任务, 消息.任务目标);
    const bool 已准备管理实例 = 私有_准备任务管理任务实例(
        自我对象,
        管理任务,
        被管理任务,
        now,
        "任务管理界面线程::接收任务信息并启动任务管理任务");
    私有_界面线程标记任务已承接(管理任务, now);

    auto& 状态 = 私有_壳状态();
    std::uint64_t 请求ID = 0;
    {
        std::lock_guard<std::mutex> 锁(状态.锁);
        请求ID = 状态.下一个请求ID++;
        状态.快照.最近请求ID = 请求ID;
        状态.快照.累计收到请求数 += 1;
        状态.快照.已收到请求 = true;
        状态.快照.最近推进时间 = now;
        状态.快照.最近宿主任务主键 = 私有_任务主键(管理任务);
        状态.快照.最近步骤主键 = 状态.快照.最近宿主任务主键;
        状态.快照.最近等待原因 = 已准备管理实例 ? std::string{} : std::string("缺少任务管理任务实例或任务参数");
        状态.快照.最近筹办承接 = "界面线程已接收任务信息";
        状态.快照.当前排队数 = 管理任务 && !私有_任务状态已终结(管理任务->主信息.状态) ? 1 : 0;
    }

    结构_任务信息承接结果 承接{};
    承接.已接收任务信息 = 被管理任务 != nullptr || 消息.任务目标 != nullptr;
    承接.已确认根链挂接 = 管理任务 != nullptr && 被管理任务 != nullptr;
    承接.已登记步骤前置任务 = false;
    承接.已写入任务管理任务 = 已准备管理实例;
    承接.已通过任务管理界面线程承接 = true;
    承接.已启动任务管理工作线程 = false;
    承接.提交ID = 请求ID;
    承接.任务根节点 = 私有_构造任务根节点(消息, 管理任务, 被管理任务, 请求ID);
    承接.最新任务控制态 = 私有_构造任务控制态(承接.任务根节点, 管理任务);
    承接.最新任务局部运行态 = 私有_构造任务局部运行态(承接.任务根节点, 管理任务);
    承接.说明 = 已准备管理实例
        ? "任务参数已由任务管理界面线程写入任务管理任务实例并排队"
        : "任务管理任务实例缺失或任务参数缺失";

    结构_任务控制事件 控制事件{};
    控制事件.任务根ID = 承接.任务根节点.任务根ID;
    控制事件.事件类型 = 枚举_任务控制事件类型::启动;
    控制事件.说明 = "任务信息承接后同步推进一轮";

    if (私有_界面线程任务允许派发(管理任务)) {
        承接.已启动任务管理工作线程 = 通过工作线程壳推进任务管理工作线程(
            自我对象,
            承接.任务根节点,
            &承接.最新任务控制态,
            &承接.最新任务局部运行态,
            now,
            控制事件,
            枚举_任务管理根层重判结果::允许普通推进,
            枚举_任务管理执行前门控结果::允许普通执行,
            {},
            "任务管理界面线程::接收任务信息并启动任务管理任务",
            &承接.桥接结果,
            nullptr);
    } else if (管理任务 && !私有_任务状态已终结(管理任务->主信息.状态)) {
        承接.最新任务控制态.队列状态 = 枚举_任务队列状态::等待;
        承接.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::等待条件;
        承接.最新任务局部运行态.当前等待原因 = "任务管理界面线程保持挂起，等待自我线程处理派生需求后唤醒";
        承接.说明 = "任务管理任务已挂起或等待，本轮不派发工作线程";
    }

    if (输出) {
        *输出 = 承接;
    }
    return 承接.已接收任务信息;
}

bool 通过工作线程壳推进任务管理工作线程(
    自我类& 自我对象,
    const 结构_任务根节点& 任务根节点,
    结构_任务控制态* 任务控制态,
    结构_任务局部运行态* 任务局部运行态,
    时间戳 now,
    const 结构_任务控制事件& 控制事件,
    枚举_任务管理根层重判结果 根层重判结果,
    枚举_任务管理执行前门控结果 执行前门控结果,
    const std::string& 上层反馈特征键,
    const std::string& 调用点,
    结构_工作线程桥接结果* 输出,
    const 结构_任务管理请求* 提交请求) noexcept
{
    (void)确保任务管理界面线程壳已启动();
    (void)确保任务管理工作线程壳已启动();
    now = 私有_时间(now);
    auto* 任务 = 私有_任务根节点取任务(任务根节点);
    私有_界面线程标记任务已派发(任务, now);
    auto& 状态 = 私有_壳状态();
    {
        std::lock_guard<std::mutex> 锁(状态.锁);
        状态.工作线程壳已启动 = true;
        状态.快照.已启动 = true;
        状态.快照.正在执行 = true;
        状态.快照.当前排队数 = 0;
        状态.快照.最近任务根ID = 任务根节点.任务根ID;
        状态.快照.最近宿主任务主键 = 私有_任务主键(任务);
        状态.快照.最近步骤主键 = 状态.快照.最近宿主任务主键;
        if (控制事件.事件类型 != 枚举_任务控制事件类型::未定义) {
            状态.快照.累计收到控制请求数 += 1;
        }
    }

    auto 响应 = 私有_工作线程执行当前任务方法(
        自我对象,
        任务根节点,
        任务控制态,
        任务局部运行态,
        now,
        控制事件,
        根层重判结果,
        执行前门控结果,
        上层反馈特征键,
        调用点,
        提交请求);
    私有_界面线程补齐工作线程回报(
        响应,
        任务,
        私有_任务根节点取管理对象任务(任务根节点),
        私有_任务根节点取需求(任务根节点),
        任务根节点,
        控制事件,
        根层重判结果,
        执行前门控结果,
        now);
    const auto 调度决策 = 私有_界面线程裁决工作线程下一步(响应);
    私有_界面线程应用调度决策到回报(
        响应,
        任务,
        调度决策,
        now);
    if (任务控制态) {
        *任务控制态 = 响应.最新任务控制态;
    }
    if (任务局部运行态) {
        *任务局部运行态 = 响应.最新任务局部运行态;
    }
    if (输出) {
        *输出 = 响应.桥接结果;
    }
    私有_界面线程收取工作线程回报(状态, 响应, 任务, now);
    return 响应.推进成功;
}

bool 读取任务管理工作线程快照(结构_工作线程实例快照* 输出) noexcept
{
    if (!输出) {
        return false;
    }
    auto& 状态 = 私有_壳状态();
    std::lock_guard<std::mutex> 锁(状态.锁);
    *输出 = 状态.快照;
    return true;
}

bool 读取任务管理工作线程界面回报列表(
    std::vector<结构_工作线程界面回报记录>* 输出,
    std::size_t 最大数量) noexcept
{
    if (!输出) {
        return false;
    }
    auto& 状态 = 私有_壳状态();
    std::lock_guard<std::mutex> 锁(状态.锁);
    const auto 数量 = std::min<std::size_t>(最大数量, 状态.界面回报列表.size());
    for (std::size_t i = 0; i < 数量; ++i) {
        输出->push_back(状态.界面回报列表[i]);
    }
    return 数量 > 0;
}

bool 计算任务管理界面优先级结果(
    const 自我类& 自我对象,
    结构_界面优先级结果* 输出,
    const std::string& 调用点) noexcept
{
    (void)调用点;
    if (!输出) {
        return false;
    }
    auto* 任务 = 自我对象.获取当前主任务();
    if (!任务) {
        任务 = 自我对象.获取任务管理任务();
    }

    *输出 = {};
    输出->当前最高优先级任务 = 任务;
    if (!任务) {
        return false;
    }
    输出->调度优先级 = 任务->主信息.调度优先级 != 0
        ? 任务->主信息.调度优先级
        : (任务->主信息.基准优先级 + 任务->主信息.局部优先级偏移);
    输出->是否可执行 =
        任务->主信息.状态 != 枚举_任务状态::完成
        && 任务->主信息.状态 != 枚举_任务状态::取消
        && 任务->主信息.状态 != 枚举_任务状态::失败;

    if (auto* 需求 = reinterpret_cast<需求节点*>(任务->主信息.对应需求.指针)) {
        输出->是否安全方向任务 = 需求->主信息.安全权重 >= 需求->主信息.服务权重;
        输出->是否服务方向任务 = 需求->主信息.服务权重 > 需求->主信息.安全权重;
    }
    return true;
}

void 停止任务管理界面线程壳() noexcept
{
    auto& 状态 = 私有_壳状态();
    std::lock_guard<std::mutex> 锁(状态.锁);
    状态.界面线程壳已启动 = false;
    状态.快照.已启动 = 状态.工作线程壳已启动;
}

void 停止任务管理工作线程壳() noexcept
{
    auto& 状态 = 私有_壳状态();
    std::lock_guard<std::mutex> 锁(状态.锁);
    状态.工作线程壳已启动 = false;
    状态.快照.已启动 = 状态.界面线程壳已启动;
    状态.快照.正在执行 = false;
}

bool 推进任务管理工作线程(
    自我类& 自我对象,
    const 结构_任务根节点& 任务根节点,
    结构_任务控制态* 任务控制态,
    结构_任务局部运行态* 任务局部运行态,
    时间戳 now,
    const 结构_任务控制事件& 控制事件,
    枚举_任务管理根层重判结果 根层重判结果,
    枚举_任务管理执行前门控结果 执行前门控结果,
    const std::string& 上层反馈特征键,
    const std::string& 调用点,
    结构_工作线程桥接结果* 输出,
    const 结构_任务管理请求* 提交请求) noexcept
{
    auto 响应 = 私有_工作线程执行当前任务方法(
        自我对象,
        任务根节点,
        任务控制态,
        任务局部运行态,
        now,
        控制事件,
        根层重判结果,
        执行前门控结果,
        上层反馈特征键,
        调用点,
        提交请求);
    私有_界面线程补齐工作线程回报(
        响应,
        私有_任务根节点取任务(任务根节点),
        私有_任务根节点取管理对象任务(任务根节点),
        私有_任务根节点取需求(任务根节点),
        任务根节点,
        控制事件,
        根层重判结果,
        执行前门控结果,
        私有_时间(now));
    if (任务控制态) {
        *任务控制态 = 响应.最新任务控制态;
    }
    if (任务局部运行态) {
        *任务局部运行态 = 响应.最新任务局部运行态;
    }
    if (输出) {
        *输出 = 响应.桥接结果;
    }
    return 响应.推进成功;
}

} // namespace 任务管理工作线程
