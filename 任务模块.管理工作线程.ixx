    消息.消息头.产生时间 = now;
    消息.消息头.执行尝试主键 = 任务主键 + "|补条件";
    消息.当前方法主键 = 执行结果.任务执行结果.当前方法
        ? 执行结果.任务执行结果.当前方法->获取主键()
        : std::string{};
    消息.派生需求类型 = 枚举_任务管理派生需求类型::缺条件;
    消息.方法需求位 = "补条件";
    消息.阻塞级别 = 枚举_任务管理阻塞级别::严重;
    消息.是否阻塞当前步骤 = true;
    消息.是否影响父任务推进 = true;
    消息.是否建议线程重判 = true;
    消息.当前等待原因 = !执行结果.任务执行结果.方法运行说明.empty()
        ? 执行结果.任务执行结果.方法运行说明
        : std::string("缺少方法执行条件");
    auto* 当前方法 = 执行结果.任务执行结果.当前方法;
    if (auto* 方法虚拟存在 = 当前方法 ? 当前方法->主信息.方法虚拟存在.指针 : nullptr) {
        消息.方法虚拟存在指针 = reinterpret_cast<std::uintptr_t>(方法虚拟存在);
        消息.方法虚拟存在主键 = 方法虚拟存在->获取主键();
    }
    私有_填充派生需求父需求字段(消息, 任务);
    私有_填充派生需求状态字段(消息, 任务);

    结构_任务管理上行消息 上行{};
    上行.类型 = 枚举_任务管理上行消息类型::派生需求消息;
    上行.载荷 = 消息;
    同步任务管理上行消息语义槽(上行);
    return 上行;
}

void 私有_推入界面回报_已加锁(
    结构_工作线程壳状态& 状态,
    const 任务管理工作线程::结构_工作线程推进响应& 响应,
    const 时间戳 now) noexcept
{
    任务管理工作线程::结构_工作线程界面回报记录 记录{};
    记录.回报时间 = now;
    记录.请求ID = 状态.快照.最近请求ID;
    记录.任务根ID = 状态.快照.最近任务根ID;
    记录.宿主任务主键 = 状态.快照.最近宿主任务主键;
    记录.步骤主键 = 状态.快照.最近步骤主键;
    记录.方法主键 = 状态.快照.最近方法主键;
    记录.结果主键 = 状态.快照.最近结果主键;
    记录.下一步去向 = 状态.快照.最近下一步去向;
    记录.总控结果 = 状态.快照.最近总控结果;
    记录.缺口归类 = 状态.快照.最近缺口归类;
    记录.筹办承接 = 状态.快照.最近筹办承接;
    记录.等待原因 = 状态.快照.最近等待原因;
    记录.推进事件数 = static_cast<std::uint64_t>(响应.桥接结果.推进事件列表.size());
    记录.上行消息数 = static_cast<std::uint64_t>(响应.桥接结果.上行消息集.size());
    状态.界面回报列表.push_front(记录);
    while (状态.界面回报列表.size() > 32) {
        状态.界面回报列表.pop_back();
    }
}

结构_任务管理上行消息 私有_构造结果状态上行消息(
    const 任务节点* 任务,
    const 结构_执行任务结果& 执行结果,
    const 时间戳 now) noexcept
{
    结构_任务管理结果状态消息 消息{};
    const auto 任务主键 = 私有_任务主键(任务);
    const auto 步骤主键 = 私有_任务主键(执行结果.任务执行结果.当前步骤节点);
    消息.消息头.发出者主键 = "任务管理界面线程";
    消息.消息头.任务主键 = 任务主键;
    消息.消息头.步骤主键 = 步骤主键.empty() ? 任务主键 : 步骤主键;
    消息.消息头.产生时间 = now;
    消息.消息头.执行尝试主键 = 任务主键 + "|执行任务";
    消息.执行结束时间 = now;
    if (auto* 结果场景 = 执行结果.任务执行结果.结果场景) {
        消息.结果节点场景主键 = 结果场景->获取主键();
    }
    auto* 当前方法 = 执行结果.任务执行结果.当前方法;
    if (auto* 方法虚拟存在 = 当前方法 ? 当前方法->主信息.方法虚拟存在.指针 : nullptr) {
        消息.方法虚拟存在指针 = reinterpret_cast<std::uintptr_t>(方法虚拟存在);
        消息.方法虚拟存在主键 = 方法虚拟存在->获取主键();
    }
    const bool 方法成功 = 本能动作运行成功(执行结果.方法运行结果);
    const auto 运行码 = 本能动作运行结果值(执行结果.方法运行结果);
    消息.结果状态 = 方法成功
        ? 枚举_任务管理结果状态::成功
        : 枚举_任务管理结果状态::失败;
    消息.完成度 = 方法成功 ? 1.0 : 0.0;
    消息.是否成功 = 方法成功;
    消息.错误码 = 运行码;
    消息.完成时间 = now;
    消息.是否仍有未满足项 =
        任务结果缺条件_最小_v0(执行结果.方法运行结果)
        || 任务结果缺方法_最小_v0(执行结果.方法运行结果);
    消息.未满足项类型文本 =
        任务结果缺条件_最小_v0(执行结果.方法运行结果)
            ? "缺条件"
            : (任务结果缺方法_最小_v0(执行结果.方法运行结果) ? "缺方法" : std::string{});
    消息.是否需要父任务处理 = 任务结果缺方法_最小_v0(执行结果.方法运行结果);
    消息.是否需要自我线程重判 =
        方法成功
        || 任务结果缺条件_最小_v0(执行结果.方法运行结果);
    if (消息.是否仍有未满足项) {
        结构_任务管理未满足项 未满足项{};
        未满足项.未满足项类型 = 消息.未满足项类型文本;
        未满足项.作用主体主键 = 任务主键;
        未满足项.是否关键阻塞 = true;
        未满足项.是否建议线程重判 = 消息.是否需要自我线程重判;
        消息.未满足项集.push_back(未满足项);
    }

    结构_任务管理上行消息 上行{};
    上行.类型 = 枚举_任务管理上行消息类型::结果状态消息;
    上行.载荷 = 消息;
    同步任务管理上行消息语义槽(上行);
    return 上行;
}

结构_任务管理上行消息 私有_构造线程状态上行消息(
    const 任务节点* 任务,
    const 结构_执行任务结果& 执行结果,
    const 结构_任务控制事件& 控制事件,
    枚举_任务管理线程运行状态 运行状态,
    枚举_任务管理线程结束状态 结束状态,
    bool 是否结束,
    时间戳 now,
    const std::string& 阶段) noexcept
{
    结构_任务管理线程状态消息 消息{};
    const auto 任务主键 = 私有_任务主键(任务);
    const auto 步骤主键 = 私有_任务主键(执行结果.任务执行结果.当前步骤节点);
    消息.消息头.发出者主键 = "任务管理界面线程";
    消息.消息头.任务主键 = 任务主键;
    消息.消息头.步骤主键 = 步骤主键.empty() ? 任务主键 : 步骤主键;
    消息.消息头.产生时间 = now;
    消息.消息头.执行尝试主键 = 任务主键 + "|线程状态|" + 阶段;
    消息.消息头.幂等键 = 消息.消息头.执行尝试主键;
    消息.当前运行状态 = 运行状态;
    消息.是否执行尝试结束 = 是否结束;
    消息.结束状态 = 结束状态;
    消息.开始时间 = 任务 ? 任务->主信息.启动时间 : 0;
    消息.结束时间 = 是否结束 ? now : 0;

    if (控制事件.事件类型 != 枚举_任务控制事件类型::未定义) {
        消息.是否携带控制请求 = true;
        消息.控制请求主键 = std::to_string(控制事件.任务根ID)
            + "|" + std::to_string(static_cast<int>(控制事件.事件类型));
        消息.当前控制意图 = 私有_控制事件映射控制意图(控制事件.事件类型);
        消息.当前控制响应状态 = 是否结束
            ? 枚举_任务管理控制响应状态::已执行完成
            : 枚举_任务管理控制响应状态::已响应;
        消息.是否控制已执行完成 = 是否结束;
        消息.补充特征集.push_back(结构_任务管理线程补充特征{
            枚举_任务管理线程补充特征类型::当前控制请求主键,
            消息.控制请求主键,
            0,
            false,
            0
        });
        消息.补充特征集.push_back(结构_任务管理线程补充特征{
            枚举_任务管理线程补充特征类型::当前控制意图值,
            {},
            static_cast<I64>(消息.当前控制意图),
            false,
            0
        });
        消息.补充特征集.push_back(结构_任务管理线程补充特征{
            枚举_任务管理线程补充特征类型::当前控制响应状态,
            {},
            static_cast<I64>(消息.当前控制响应状态),
            消息.是否控制已执行完成,
            0
        });
    }

    if (!步骤主键.empty()) {
        消息.补充特征集.push_back(结构_任务管理线程补充特征{
            枚举_任务管理线程补充特征类型::当前步骤主键,
            步骤主键,
            0,
            false,
            reinterpret_cast<std::uintptr_t>(执行结果.任务执行结果.当前步骤节点)
        });
    }
    if (!执行结果.任务执行结果.方法运行说明.empty()) {
        消息.补充特征集.push_back(结构_任务管理线程补充特征{
            枚举_任务管理线程补充特征类型::当前等待原因,
            执行结果.任务执行结果.方法运行说明,
            0,
            false,
            0
        });
    }

    结构_任务管理上行消息 上行{};
    上行.类型 = 枚举_任务管理上行消息类型::线程状态消息;
    上行.载荷 = 消息;
    同步任务管理上行消息语义槽(上行);
    return 上行;
}

任务管理工作线程::结构_工作线程推进响应 私有_工作线程执行当前任务方法(
    自我类& 自我对象,
    const 结构_任务根节点& 任务根节点,
    结构_任务控制态* 任务控制态,
    结构_任务局部运行态* 任务局部运行态,
    时间戳 now,
    const 结构_任务控制事件& 控制事件,
    枚举_任务管理根层重判结果 根层重判结果,
    枚举_任务管理执行前门控结果 执行前门控结果,
    const std::string& 上层反馈特征键,
    const std::string& 调用点,
    const 结构_任务管理请求* 提交请求) noexcept
{
    (void)上层反馈特征键;
    (void)调用点;
    (void)提交请求;

    now = 私有_时间(now);
    auto* 任务 = 私有_任务根节点取任务(任务根节点);

    任务管理工作线程::结构_工作线程推进响应 响应{};
    响应.最新任务控制态 = 任务控制态 ? *任务控制态 : 私有_构造任务控制态(任务根节点, 任务);
    响应.最新任务局部运行态 = 任务局部运行态 ? *任务局部运行态 : 私有_构造任务局部运行态(任务根节点, 任务);
    响应.桥接结果.根层重判结果 = 根层重判结果;
    响应.桥接结果.执行前门控结果 = 执行前门控结果;

    结构_执行任务结果 执行结果{};
    const bool 禁止执行 = 私有_本轮禁止工作线程执行(控制事件, 根层重判结果, 执行前门控结果);
    if (!任务) {
        执行结果 = 私有_构造未执行任务结果(nullptr, -12, "当前任务节点为空");
    } else if (禁止执行) {
        执行结果 = 私有_构造未执行任务结果(任务, -15, "界面线程禁止本轮执行");
    } else {
        try {
            auto* 当前步骤 = reinterpret_cast<任务节点*>(任务->主信息.当前步骤节点.指针);
            auto* 当前方法 = 当前步骤
                ? reinterpret_cast<方法类::节点类*>(当前步骤->主信息.执行方法.指针)
                : nullptr;
            auto* 管理对象任务 = reinterpret_cast<任务节点*>(任务->主信息.管理对象任务.指针);
            std::ostringstream 输出;
            输出 << "任务管理工作线程/执行任务入口"
                << " | 管理任务=" << 私有_任务主键(任务)
                << " | 管理对象=" << 私有_任务主键(管理对象任务)
                << " | 当前步骤=" << 私有_任务主键(当前步骤)
                << " | 当前方法=" << (当前方法 ? 当前方法->获取主键() : std::string("空"))
                << " | 当前本能ID=" << (当前方法 ? 当前方法->主信息.动作句柄.本能ID : -1)
                << " | 管理任务角色=" << static_cast<int>(任务->主信息.任务角色)
                << " | 管理对象角色=" << (管理对象任务 ? static_cast<int>(管理对象任务->主信息.任务角色) : -1);
            项目运行日志(输出.str());
            自我_执行桥类 执行桥{};
            执行结果 = 执行任务(执行桥, 任务, now, 0, false, "任务管理工作线程::执行当前任务方法");
        } catch (...) {
            执行结果.任务执行结果.结果场景 = 任务 ? 任务->主信息.场景.指针 : nullptr;
            执行结果.任务执行结果.方法运行结果 = 创建本能动作运行结果实例_按码(
                nullptr,
                执行结果.任务执行结果.结果场景,
                -9001,
                now);
            执行结果.任务执行结果.方法运行说明 = "执行任务异常";
            执行结果.方法运行结果 = 执行结果.任务执行结果.方法运行结果;
        }
    }

    响应.桥接结果.已执行当前步骤方法 = 任务 != nullptr && !禁止执行;
    响应.桥接结果.存在当前步骤方法执行数据 = true;
    响应.桥接结果.当前步骤方法执行数据 = 执行结果.任务执行结果;
    响应.桥接结果.当前步骤方法运行结果 = 执行结果.方法运行结果;
    响应.推进成功 = true;
    私有_同步任务态语义槽(响应.最新任务控制态, 响应.最新任务局部运行态);
    return 响应;
}

void 私有_刷新快照_已加锁(
    结构_工作线程壳状态& 状态,
    const 任务管理工作线程::结构_工作线程推进响应& 响应,
    const 任务节点* 任务,
    const 时间戳 now) noexcept
{
    状态.快照.已启动 = 状态.工作线程壳已启动 || 状态.界面线程壳已启动;
    状态.快照.正在执行 = false;
    状态.快照.已收到请求 = true;
    状态.快照.最近任务根ID = 响应.最新任务控制态.任务根ID;
    状态.快照.累计推进次数 += 1;
    状态.快照.最近推进时间 = now;
    状态.快照.最近宿主任务主键 = 私有_任务主键(任务);
    状态.快照.最近步骤主键 = 私有_任务主键(
        响应.桥接结果.当前步骤方法执行数据.当前步骤节点);
    if (状态.快照.最近步骤主键.empty()) {
        状态.快照.最近步骤主键 = 状态.快照.最近宿主任务主键;
    }
    状态.快照.最近方法主键 = 响应.桥接结果.当前步骤方法执行数据.当前方法
        ? 响应.桥接结果.当前步骤方法执行数据.当前方法->获取主键()
        : std::string{};
    状态.快照.最近结果主键 = 私有_任务主键(
        reinterpret_cast<任务节点*>(响应.桥接结果.当前步骤方法执行数据.最近结果节点));
    状态.快照.最近下一步去向 = 响应.桥接结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::进入收束
        ? "进入收束"
        : (响应.桥接结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::保持等待
            ? "保持等待"
            : "进入运行");
    状态.快照.最近总控结果 = 响应.桥接结果.治理结果.最近总控结果 == 枚举_任务管理总控结果::宿主进入收束
        ? "宿主进入收束"
        : (响应.桥接结果.治理结果.最近总控结果 == 枚举_任务管理总控结果::宿主保持等待
            ? "宿主保持等待"
            : "宿主已进入运行");
    状态.快照.最近缺口归类 = 响应.桥接结果.治理结果.当前缺口类型 == 枚举_任务管理缺口类型::方法挂点缺失
        ? "方法挂点缺失"
        : (响应.桥接结果.治理结果.当前缺口类型 == 枚举_任务管理缺口类型::无缺口
            ? "无缺口"
            : "界面线程按任务回报归类");
    状态.快照.最近筹办承接 = "界面线程已收取工作线程回报";
    状态.快照.最近等待原因 = 响应.最新任务局部运行态.当前等待原因;
    状态.快照.最近一次上行消息数 = static_cast<std::uint64_t>(响应.桥接结果.上行消息集.size());
    状态.快照.累计发送上行消息数 += 状态.快照.最近一次上行消息数;
}

void 私有_界面线程补齐工作线程回报(
    任务管理工作线程::结构_工作线程推进响应& 响应,
    任务节点* 任务,
    任务节点* 管理对象任务,
    需求节点* 需求,
    const 结构_任务根节点& 任务根节点,
    const 结构_任务控制事件& 控制事件,
    const 枚举_任务管理根层重判结果 根层重判结果,
    const 枚举_任务管理执行前门控结果 执行前门控结果,
    const 时间戳 now) noexcept
{
    auto& 桥接 = 响应.桥接结果;
    桥接.已消费控制事件 = 控制事件;
    桥接.根层重判结果 = 根层重判结果;
    桥接.执行前门控结果 = 执行前门控结果;
    桥接.任务管理治理触发 = true;
    桥接.任务管理上位输入已刷新 = true;
    桥接.治理结果.最近根层重判结果 = 根层重判结果;
    桥接.治理结果.最近执行前门控结果 = 执行前门控结果;
    桥接.治理结果.当前主需求 = 需求;
    桥接.治理结果.当前管理任务 = 任务;
    桥接.治理结果.当前宿主任务 = 管理对象任务 ? 管理对象任务 : 任务;
    桥接.治理结果.当前步骤节点 =
        桥接.当前步骤方法执行数据.当前步骤节点
            ? 桥接.当前步骤方法执行数据.当前步骤节点
            : 任务;
    桥接.治理结果.已选中宿主任务 = 任务 != nullptr;

    const bool 禁止执行 = 私有_本轮禁止工作线程执行(
        控制事件,
        根层重判结果,
        执行前门控结果);
    if (!任务) {
        响应.最新任务控制态.队列状态 = 枚举_任务队列状态::等待;
        响应.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::等待条件;
        响应.最新任务局部运行态.当前等待原因 = "缺少任务节点";
        桥接.治理结果.当前缺口类型 = 枚举_任务管理缺口类型::宿主任务缺失;
        桥接.治理结果.当前下一步去向 = 枚举_任务管理下一步去向::保持等待;
        桥接.治理结果.最近总控结果 = 枚举_任务管理总控结果::宿主保持等待;
        结构_执行任务结果 空执行结果{};
        空执行结果.任务执行结果 = 桥接.当前步骤方法执行数据;
        空执行结果.方法运行结果 = 桥接.当前步骤方法运行结果;
        桥接.上行消息集.push_back(私有_构造线程状态上行消息(
            nullptr,
            空执行结果,
            控制事件,
            枚举_任务管理线程运行状态::故障,
            枚举_任务管理线程结束状态::故障结束,
            true,
            now,
            "缺少任务"));
        私有_同步任务态语义槽(响应.最新任务控制态, 响应.最新任务局部运行态);
        return;
    }

    if (禁止执行) {
        响应.最新任务控制态.队列状态 = 枚举_任务队列状态::已停止;
        响应.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::已停止;
        响应.最新任务局部运行态.当前等待原因 = "根层或门控禁止继续";
        桥接.治理结果.宿主任务旧状态 = 任务->主信息.状态;
        桥接.治理结果.宿主任务新状态 = 枚举_任务状态::挂起;
        桥接.治理结果.当前缺口类型 =
            根层重判结果 == 枚举_任务管理根层重判结果::停止退出边界
                ? 枚举_任务管理缺口类型::上位停止约束
                : 枚举_任务管理缺口类型::上位等待约束;
        桥接.治理结果.当前下一步去向 = 枚举_任务管理下一步去向::保持等待;
        桥接.治理结果.最近总控结果 = 枚举_任务管理总控结果::宿主保持等待;
        结构_执行任务结果 禁止执行结果{};
        禁止执行结果.任务执行结果 = 桥接.当前步骤方法执行数据;
        禁止执行结果.方法运行结果 = 桥接.当前步骤方法运行结果;
        桥接.上行消息集.push_back(私有_构造线程状态上行消息(
            任务,
            禁止执行结果,
            控制事件,
            控制事件.事件类型 == 枚举_任务控制事件类型::停止
                ? 枚举_任务管理线程运行状态::已停止
                : 枚举_任务管理线程运行状态::阻塞,
            控制事件.事件类型 == 枚举_任务控制事件类型::停止
                ? 枚举_任务管理线程结束状态::中断结束
                : 枚举_任务管理线程结束状态::未结束,
            控制事件.事件类型 == 枚举_任务控制事件类型::停止,
            now,
            "禁止执行"));
        私有_同步任务态语义槽(响应.最新任务控制态, 响应.最新任务局部运行态);
        return;
    }

    结构_执行任务结果 执行结果{};
    执行结果.任务执行结果 = 桥接.当前步骤方法执行数据;
    执行结果.方法运行结果 = 桥接.当前步骤方法运行结果;
    auto* 上行任务 = 管理对象任务 ? 管理对象任务 : 任务;
    const bool 仅任务管理内部换步 = 任务治理步骤要求待重入_最小_v0(
        桥接.当前步骤方法执行数据.当前方法,
        桥接.当前步骤方法运行结果);
    const bool 本轮缺方法 = 任务结果缺方法_最小_v0(执行结果.方法运行结果);
    const bool 缺方法应派生需求 =
        本轮缺方法 && 私有_缺方法应派生需求(上行任务, 执行结果);
    方法节点* 直建方法头 = nullptr;
    if (!仅任务管理内部换步 && 本轮缺方法 && !缺方法应派生需求) {
        直建方法头 = 私有_缺方法直接生成方法头(上行任务, 执行结果, now);
    }

    auto 推导状态 = 私有_从执行结果推导界面任务状态(
        桥接.当前步骤方法执行数据,
        桥接.当前步骤方法运行结果);
    if (本轮缺方法 && 直建方法头) {
        推导状态 = 枚举_任务状态::待重筹办;
    }
    桥接.治理结果.宿主任务旧状态 = 任务->主信息.最近执行记录.执行前状态;
    if (桥接.治理结果.宿主任务旧状态 == 枚举_任务状态::未定义) {
        桥接.治理结果.宿主任务旧状态 = 枚举_任务状态::执行中;
    }
    桥接.治理结果.宿主任务新状态 = 推导状态;
    桥接.治理结果.当前方法 = 桥接.当前步骤方法执行数据.当前方法;
    if (auto* 最新结果节点 = 私有_同步工作线程执行结果到结果节点(
            任务,
            桥接.当前步骤方法执行数据,
            桥接.当前步骤方法运行结果,
            推导状态,
            now)) {
        桥接.治理结果.最新结果节点 = 最新结果节点;
    }

    if (推导状态 == 枚举_任务状态::完成) {
        响应.最新任务控制态.队列状态 = 枚举_任务队列状态::已结算;
        响应.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::局部完成;
        响应.最新任务局部运行态.局部完成度 = 10000;
        桥接.治理结果.已推进任务状态 = true;
        桥接.治理结果.当前缺口类型 = 枚举_任务管理缺口类型::无缺口;
        桥接.治理结果.当前下一步去向 = 枚举_任务管理下一步去向::进入收束;
        桥接.治理结果.最近总控结果 = 枚举_任务管理总控结果::宿主进入收束;
    } else {
        响应.最新任务控制态.队列状态 = 枚举_任务队列状态::等待;
        响应.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::等待条件;
        响应.最新任务局部运行态.当前等待原因 = 私有_执行结果等待原因(
            桥接.当前步骤方法执行数据,
            桥接.当前步骤方法运行结果);
        桥接.治理结果.当前缺口类型 =
            任务结果缺方法_最小_v0(桥接.当前步骤方法运行结果)
                ? 枚举_任务管理缺口类型::方法挂点缺失
                : (桥接.当前步骤方法执行数据.当前方法
                    ? 枚举_任务管理缺口类型::任务运行中
                    : 枚举_任务管理缺口类型::方法挂点缺失);
        桥接.治理结果.当前下一步去向 = 枚举_任务管理下一步去向::保持等待;
        桥接.治理结果.最近总控结果 = 枚举_任务管理总控结果::宿主保持等待;
    }

    桥接.上行消息集.push_back(私有_构造线程状态上行消息(
        任务,
        执行结果,
        控制事件,
        枚举_任务管理线程运行状态::推进中,
        枚举_任务管理线程结束状态::未结束,
        false,
        now,
        "推进中"));

    if (!仅任务管理内部换步) {
        if (任务结果缺条件_最小_v0(执行结果.方法运行结果)) {
            桥接.上行消息集.push_back(私有_构造补条件派生需求消息(上行任务, 执行结果, now));
        }
        if (缺方法应派生需求) {
            桥接.上行消息集.push_back(私有_构造补方法派生需求消息(上行任务, 执行结果, now));
        }
        auto 上行消息 = 私有_构造结果状态上行消息(上行任务, 执行结果, now);
        桥接.上行消息集.push_back(上行消息);
        桥接.上行消息已直达自我线程 = true;
    }
    const auto 最终运行状态 =
        推导状态 == 枚举_任务状态::完成
            ? 枚举_任务管理线程运行状态::已停止
            : (推导状态 == 枚举_任务状态::等待中 || 推导状态 == 枚举_任务状态::挂起
                ? 枚举_任务管理线程运行状态::等待中
                : 枚举_任务管理线程运行状态::推进中);
    const auto 最终结束状态 =
        推导状态 == 枚举_任务状态::完成
            ? 枚举_任务管理线程结束状态::正常结束
            : 枚举_任务管理线程结束状态::未结束;
    桥接.上行消息集.push_back(私有_构造线程状态上行消息(
        任务,
        执行结果,
        控制事件,
        最终运行状态,
        最终结束状态,
        推导状态 == 枚举_任务状态::完成,
        now,
        "回报"));
    const bool 已上报派生需求 =
        任务结果缺条件_最小_v0(执行结果.方法运行结果)
        || (任务结果缺方法_最小_v0(执行结果.方法运行结果) && !直建方法头);
    结构_任务推进事件 推进事件{};
    推进事件.任务根ID = 任务根节点.任务根ID;
    推进事件.事件类型 =
        推导状态 == 枚举_任务状态::完成
            ? 枚举_任务推进事件类型::最终结果返回
            : (已上报派生需求
                ? 枚举_任务推进事件类型::派生需求上报
                : 枚举_任务推进事件类型::当前步骤阻塞);
    推进事件.当前步骤指针 = reinterpret_cast<std::uintptr_t>(任务);
    推进事件.结果指针 = 0;
    推进事件.等待原因 = 响应.最新任务局部运行态.当前等待原因;
    推进事件.说明 = 桥接.当前步骤方法执行数据.方法运行说明;
    同步工作线程事件语义槽(推进事件);
    桥接.推进事件列表.push_back(推进事件);
    私有_同步任务态语义槽(响应.最新任务控制态, 响应.最新任务局部运行态);
}

void 私有_界面线程应用工作线程回报到任务(
    任务节点* 任务,
    const 任务管理工作线程::结构_工作线程推进响应& 响应,
    const 时间戳 now) noexcept
{
    if (!任务) {
        return;
    }
    if (响应.桥接结果.治理结果.宿主任务新状态 != 枚举_任务状态::未定义) {
        任务->主信息.状态 = 响应.桥接结果.治理结果.宿主任务新状态;
    }
    if (任务->主信息.状态 == 枚举_任务状态::完成
        && 任务->主信息.完成时间 == 0) {
        任务->主信息.完成时间 = now;
    }
    任务->主信息.等待学习唤醒 =
        任务结果缺方法_最小_v0(响应.桥接结果.当前步骤方法运行结果)
        || (任务->主信息.状态 == 枚举_任务状态::等待中
            && 响应.桥接结果.当前步骤方法执行数据.当前方法 == nullptr);
    任务->主信息.统计.记录观测(now);
}

void 私有_界面线程收取工作线程回报(
    结构_工作线程壳状态& 状态,
    const 任务管理工作线程::结构_工作线程推进响应& 响应,
    任务节点* 任务,
    const 时间戳 now) noexcept
{
    私有_界面线程应用工作线程回报到任务(任务, 响应, now);
    std::lock_guard<std::mutex> 锁(状态.锁);
    状态.快照.正在执行 = false;
    状态.快照.当前排队数 = 0;
    私有_刷新快照_已加锁(状态, 响应, 任务, now);
    for (const auto& 消息 : 响应.桥接结果.上行消息集) {
        状态.上行消息直达队列.push_back(消息);
    }
    私有_推入界面回报_已加锁(状态, 响应, now);
}

bool 私有_界面线程恢复一个负载等待任务(
    自我类& 自我对象,
    时间戳 now) noexcept
{
    结构_任务根节点 根节点{};
    if (!私有_取一个负载等待任务(&根节点)) {
        return false;
    }

    now = 私有_时间(now);
    auto* 管理任务 = 私有_任务根节点取任务(根节点);
    auto* 被管理任务 = 私有_任务根节点取管理对象任务(根节点);
    auto* 来源需求 = 私有_任务根节点取需求(根节点);
    bool 已恢复 = false;

    if (私有_界面线程任务允许派发(管理任务)
        && 私有_准备任务管理任务实例(
            自我对象,
            管理任务,
            被管理任务,
            now,
            "任务管理界面线程::恢复负载等待任务")) {
        结构_任务控制态 控制态 = 私有_构造任务控制态(根节点, 管理任务);
        结构_任务局部运行态 运行态 = 私有_构造任务局部运行态(根节点, 管理任务);
        结构_任务控制事件 控制事件{};
        控制事件.任务根ID = 根节点.任务根ID;
        控制事件.事件类型 = 枚举_任务控制事件类型::启动;
        控制事件.说明 = "工作线程负载恢复后重建排队任务";
        同步工作线程事件语义槽(控制事件);

        已恢复 = 任务管理工作线程::通过工作线程壳推进任务管理工作线程(
            自我对象,
            根节点,
            &控制态,
            &运行态,
            now,
            控制事件,
            枚举_任务管理根层重判结果::允许普通推进,
            枚举_任务管理执行前门控结果::允许普通执行,
            {},
            "任务管理界面线程::恢复负载等待任务",
            nullptr,
            nullptr);
    } else {
        if (管理任务 && !私有_任务状态已终结(管理任务->主信息.状态)) {
            管理任务->主信息.状态 = 枚举_任务状态::等待中;
            管理任务->主信息.统计.记录观测(now);
        }
        if (被管理任务 && !私有_任务状态已终结(被管理任务->主信息.状态)) {
            被管理任务->主信息.状态 = 枚举_任务状态::等待中;
            被管理任务->主信息.统计.记录观测(now);
        }
        (void)来源需求;
    }

    私有_结束负载等待任务恢复();
    return 已恢复;
}

} // namespace

namespace 任务管理工作线程 {

bool 提取任务管理上行消息直达桥(
    std::vector<结构_任务管理上行消息>* 输出,
    std::size_t 最大数量) noexcept
{
    if (!输出) {
        return false;
    }
    auto& 状态 = 私有_壳状态();
    std::lock_guard<std::mutex> 锁(状态.锁);
    const auto 数量上限 = 最大数量 == 0 ? 状态.上行消息直达队列.size() : 最大数量;
    std::size_t 已取 = 0;
    while (!状态.上行消息直达队列.empty() && 已取 < 数量上限) {
        输出->push_back(状态.上行消息直达队列.front());
        状态.上行消息直达队列.pop_front();
        ++已取;
    }
    return 已取 > 0;
}

bool 确保任务管理工作线程壳已启动() noexcept
{
    auto& 状态 = 私有_壳状态();
    std::lock_guard<std::mutex> 锁(状态.锁);
    状态.工作线程壳已启动 = true;
    状态.快照.已启动 = true;
    return true;
}

bool 确保任务管理界面线程壳已启动() noexcept
{
    auto& 状态 = 私有_壳状态();
    std::lock_guard<std::mutex> 锁(状态.锁);
    状态.界面线程壳已启动 = true;
    状态.快照.已启动 = true;
    return true;
}

bool 接收任务信息并启动任务管理任务(
    自我类& 自我对象,
    const 结构_任务信息消息& 消息,
    const std::string& 调用点,
    结构_任务信息承接结果* 输出) noexcept
{
    (void)调用点;
    确保任务管理界面线程壳已启动();

    const auto now = 私有_时间(消息.当前时间);
    auto* 被管理任务 = 私有_消息取任务(消息);
    if (!被管理任务) {
        被管理任务 = reinterpret_cast<任务节点*>(消息.任务管理任务实例);
    }
    auto* 管理任务 = 被管理任务;
    私有_绑定任务需求关系(被管理任务, 消息.任务目标);

    auto& 状态 = 私有_壳状态();
    std::uint64_t 请求ID = 0;
    {
        std::lock_guard<std::mutex> 锁(状态.锁);
        请求ID = 状态.下一个请求ID++;
        状态.快照.最近请求ID = 请求ID;
        状态.快照.累计收到请求数 += 1;
        状态.快照.已收到请求 = true;
        状态.快照.最近推进时间 = now;
        状态.快照.最近宿主任务主键 = 私有_任务主键(被管理任务);
        状态.快照.最近步骤主键 = 状态.快照.最近宿主任务主键;
        状态.快照.最近筹办承接 = "界面线程已接收任务信息";
        私有_刷新负载等待排队数_已加锁(状态);
    }

    结构_任务信息承接结果 承接{};
    承接.已接收任务信息 = 被管理任务 != nullptr || 消息.任务目标 != nullptr;
    承接.已确认根链挂接 = 管理任务 != nullptr && 被管理任务 != nullptr;
    承接.已登记步骤前置任务 = false;
    承接.已写入任务管理任务 = false;
    承接.已通过任务管理界面线程承接 = true;
    承接.已启动任务管理工作线程 = false;
    承接.提交ID = 请求ID;
    承接.任务根节点 = 私有_构造任务根节点(消息, 管理任务, 被管理任务, 请求ID);
    承接.最新任务控制态 = 私有_构造任务控制态(承接.任务根节点, 管理任务);
    承接.最新任务局部运行态 = 私有_构造任务局部运行态(承接.任务根节点, 管理任务);
    承接.说明 = "任务信息已由任务管理界面线程接收";

    结构_任务控制事件 控制事件{};
    控制事件.任务根ID = 承接.任务根节点.任务根ID;
    控制事件.事件类型 = 枚举_任务控制事件类型::启动;
    控制事件.说明 = "任务信息承接后同步推进一轮";
    同步工作线程事件语义槽(控制事件);

    bool 有空余负载 = false;
    {
        std::lock_guard<std::mutex> 锁(状态.锁);
        有空余负载 = 私有_当前工作线程有空余负载_已加锁(状态)
            && 状态.负载等待任务队列.empty();
    }

    if (私有_界面线程任务允许派发(管理任务) && 有空余负载) {
        const bool 已准备管理实例 = 私有_准备任务管理任务实例(
            自我对象,
            管理任务,
            被管理任务,
            now,
            "任务管理界面线程::接收任务信息并启动任务管理任务");
        私有_界面线程标记任务已承接(管理任务, now);
        承接.已写入任务管理任务 = 已准备管理实例;
        承接.说明 = 已准备管理实例
            ? "任务参数已由任务管理界面线程写入普通任务并准备派发"
            : "任务节点缺失或任务参数缺失";
        承接.已启动任务管理工作线程 = 通过工作线程壳推进任务管理工作线程(
            自我对象,
            承接.任务根节点,
            &承接.最新任务控制态,
            &承接.最新任务局部运行态,
            now,
            控制事件,
            枚举_任务管理根层重判结果::允许普通推进,
            枚举_任务管理执行前门控结果::允许普通执行,
            {},
            "任务管理界面线程::接收任务信息并启动任务管理任务",
            &承接.桥接结果,
            nullptr);
        (void)私有_界面线程恢复一个负载等待任务(自我对象, now);
    } else if (私有_界面线程任务允许派发(管理任务)) {
        (void)私有_登记负载等待任务(
            承接.任务根节点,
            管理任务,
            被管理任务,
            now);
        承接.最新任务控制态.队列状态 = 枚举_任务队列状态::等待;
        承接.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::已受理;
        承接.最新任务局部运行态.当前等待原因 = "工作线程负载已满，任务进入负载等待队列";
        承接.说明 = "任务因工作线程负载不足排队，等待容量恢复后重建";
    } else if (管理任务 && !私有_任务状态已终结(管理任务->主信息.状态)) {
        承接.最新任务控制态.队列状态 = 枚举_任务队列状态::等待;
        承接.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::等待条件;
        承接.最新任务局部运行态.当前等待原因 = "任务管理界面线程保持挂起，等待自我线程处理派生需求后唤醒";
        承接.说明 = "任务管理任务已挂起或等待，本轮不派发工作线程";
    }

    私有_同步任务态语义槽(承接.最新任务控制态, 承接.最新任务局部运行态);
    if (输出) {
        *输出 = 承接;
    }
    return 承接.已接收任务信息;
}

bool 通过工作线程壳推进任务管理工作线程(
    自我类& 自我对象,
    const 结构_任务根节点& 任务根节点,
    结构_任务控制态* 任务控制态,
    结构_任务局部运行态* 任务局部运行态,
    时间戳 now,
    const 结构_任务控制事件& 控制事件,
    枚举_任务管理根层重判结果 根层重判结果,
    枚举_任务管理执行前门控结果 执行前门控结果,
    const std::string& 上层反馈特征键,
    const std::string& 调用点,
    结构_工作线程桥接结果* 输出,
    const 结构_任务管理请求* 提交请求) noexcept
{
    (void)确保任务管理界面线程壳已启动();
    (void)确保任务管理工作线程壳已启动();
    now = 私有_时间(now);
    auto* 任务 = 私有_任务根节点取任务(任务根节点);
    私有_界面线程标记任务已派发(任务, now);
    auto& 状态 = 私有_壳状态();
    {
        std::lock_guard<std::mutex> 锁(状态.锁);
        状态.工作线程壳已启动 = true;
        状态.快照.已启动 = true;
        状态.快照.正在执行 = true;
        状态.快照.当前排队数 = 0;
        状态.快照.最近任务根ID = 任务根节点.任务根ID;
        状态.快照.最近宿主任务主键 = 私有_任务主键(任务);
        状态.快照.最近步骤主键 = 状态.快照.最近宿主任务主键;
        if (控制事件.事件类型 != 枚举_任务控制事件类型::未定义) {
            状态.快照.累计收到控制请求数 += 1;
        }
    }

    任务管理工作线程::结构_工作线程推进响应 响应{};
    std::vector<结构_任务管理上行消息> 累计上行消息{};
    std::vector<结构_任务推进事件> 累计推进事件{};
    constexpr int 最大连续推进轮次 = 8;
    for (int 轮次 = 0; 轮次 < 最大连续推进轮次; ++轮次) {
        响应 = 私有_工作线程执行当前任务方法(
            自我对象,
            任务根节点,
            任务控制态,
            任务局部运行态,
            now,
            控制事件,
            根层重判结果,
            执行前门控结果,
            上层反馈特征键,
            调用点,
            提交请求);
        私有_界面线程补齐工作线程回报(
            响应,
            任务,
            私有_任务根节点取管理对象任务(任务根节点),
            私有_任务根节点取需求(任务根节点),
            任务根节点,
            控制事件,
            根层重判结果,
            执行前门控结果,
            now);
        const auto 调度决策 = 私有_界面线程裁决工作线程下一步(响应);
        私有_界面线程应用调度决策到回报(
            响应,
            任务,
            调度决策,
            now);
        私有_同步任务态语义槽(响应.最新任务控制态, 响应.最新任务局部运行态);
        累计上行消息.insert(
            累计上行消息.end(),
            响应.桥接结果.上行消息集.begin(),
            响应.桥接结果.上行消息集.end());
        累计推进事件.insert(
            累计推进事件.end(),
            响应.桥接结果.推进事件列表.begin(),
            响应.桥接结果.推进事件列表.end());
        if (任务控制态) {
            *任务控制态 = 响应.最新任务控制态;
        }
        if (任务局部运行态) {
            *任务局部运行态 = 响应.最新任务局部运行态;
        }
        if (调度决策.动作 != 枚举_界面线程工作调度动作::开启下一轮) {
            break;
        }
    }
    响应.桥接结果.上行消息集 = std::move(累计上行消息);
    响应.桥接结果.推进事件列表 = std::move(累计推进事件);
    私有_同步任务态语义槽(响应.最新任务控制态, 响应.最新任务局部运行态);
    if (任务控制态) {
        *任务控制态 = 响应.最新任务控制态;
    }
    if (任务局部运行态) {
        *任务局部运行态 = 响应.最新任务局部运行态;
    }
    if (输出) {
        *输出 = 响应.桥接结果;
    }
    私有_界面线程收取工作线程回报(状态, 响应, 任务, now);
    (void)私有_界面线程恢复一个负载等待任务(自我对象, now);
    return 响应.推进成功;
}

bool 读取任务管理工作线程快照(结构_工作线程实例快照* 输出) noexcept
{
    if (!输出) {
        return false;
    }
    auto& 状态 = 私有_壳状态();
    std::lock_guard<std::mutex> 锁(状态.锁);
    *输出 = 状态.快照;
    return true;
}

bool 读取任务管理工作线程界面回报列表(
    std::vector<结构_工作线程界面回报记录>* 输出,
    std::size_t 最大数量) noexcept
{
    if (!输出) {
        return false;
    }
    auto& 状态 = 私有_壳状态();
    std::lock_guard<std::mutex> 锁(状态.锁);
    const auto 数量 = std::min<std::size_t>(最大数量, 状态.界面回报列表.size());
    for (std::size_t i = 0; i < 数量; ++i) {
        输出->push_back(状态.界面回报列表[i]);
    }
    return 数量 > 0;
}

bool 计算任务管理界面优先级结果(
    const 自我类& 自我对象,
    结构_界面优先级结果* 输出,
    const std::string& 调用点) noexcept
{
    (void)调用点;
    if (!输出) {
        return false;
    }
    auto* 任务 = 自我对象.获取当前主任务();
    if (!任务) {
        任务 = 自我对象.获取任务管理任务();
    }

    *输出 = {};
    输出->当前最高优先级任务 = 任务;
    if (!任务) {
        return false;
    }
    输出->调度优先级 = 任务->主信息.调度优先级 != 0
        ? 任务->主信息.调度优先级
        : (任务->主信息.基准优先级 + 任务->主信息.局部优先级偏移);
    输出->是否可执行 =
        任务->主信息.状态 != 枚举_任务状态::完成
        && 任务->主信息.状态 != 枚举_任务状态::取消
        && 任务->主信息.状态 != 枚举_任务状态::失败;

    if (auto* 需求 = reinterpret_cast<需求节点*>(任务->主信息.对应需求.指针)) {
        输出->是否安全方向任务 = 需求->主信息.安全权重 >= 需求->主信息.服务权重;
        输出->是否服务方向任务 = 需求->主信息.服务权重 > 需求->主信息.安全权重;
    }
    return true;
}

void 停止任务管理界面线程壳() noexcept
{
    auto& 状态 = 私有_壳状态();
    std::lock_guard<std::mutex> 锁(状态.锁);
    状态.界面线程壳已启动 = false;
    状态.快照.已启动 = 状态.工作线程壳已启动;
}

void 停止任务管理工作线程壳() noexcept
{
    auto& 状态 = 私有_壳状态();
    std::lock_guard<std::mutex> 锁(状态.锁);
    状态.工作线程壳已启动 = false;
    状态.快照.已启动 = 状态.界面线程壳已启动;
    状态.快照.正在执行 = false;
}

bool 推进任务管理工作线程(
    自我类& 自我对象,
    const 结构_任务根节点& 任务根节点,
    结构_任务控制态* 任务控制态,
    结构_任务局部运行态* 任务局部运行态,
    时间戳 now,
    const 结构_任务控制事件& 控制事件,
    枚举_任务管理根层重判结果 根层重判结果,
    枚举_任务管理执行前门控结果 执行前门控结果,
    const std::string& 上层反馈特征键,
    const std::string& 调用点,
    结构_工作线程桥接结果* 输出,
    const 结构_任务管理请求* 提交请求) noexcept
{
    auto 响应 = 私有_工作线程执行当前任务方法(
        自我对象,
        任务根节点,
        任务控制态,
        任务局部运行态,
        now,
        控制事件,
        根层重判结果,
        执行前门控结果,
        上层反馈特征键,
        调用点,
        提交请求);
    私有_界面线程补齐工作线程回报(
        响应,
        私有_任务根节点取任务(任务根节点),
        私有_任务根节点取管理对象任务(任务根节点),
        私有_任务根节点取需求(任务根节点),
        任务根节点,
        控制事件,
        根层重判结果,
        执行前门控结果,
        私有_时间(now));
    私有_同步任务态语义槽(响应.最新任务控制态, 响应.最新任务局部运行态);
    if (任务控制态) {
        *任务控制态 = 响应.最新任务控制态;
    }
    if (任务局部运行态) {
        *任务局部运行态 = 响应.最新任务局部运行态;
    }
    if (输出) {
        *输出 = 响应.桥接结果;
    }
    return 响应.推进成功;
}

} // namespace 任务管理工作线程
