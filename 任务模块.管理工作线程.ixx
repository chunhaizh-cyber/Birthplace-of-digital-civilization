const 语素入口节点类* 私有_值_筹办缺口_任务信息缺失() noexcept { return 私有_任务语义状态词("筹办缺口_任务信息缺失"); }
const 语素入口节点类* 私有_值_筹办缺口_需求目标不可解析() noexcept { return 私有_任务语义状态词("筹办缺口_需求目标不可解析"); }
const 语素入口节点类* 私有_值_筹办缺口_无确定候选方法() noexcept { return 私有_任务语义状态词("筹办缺口_无确定候选方法"); }
const 语素入口节点类* 私有_值_筹办缺口_候选方法不可用() noexcept { return 私有_任务语义状态词("筹办缺口_候选方法不可用"); }
const 语素入口节点类* 私有_值_筹办缺口_候选方法缺执行入口() noexcept { return 私有_任务语义状态词("筹办缺口_候选方法缺执行入口"); }
const 语素入口节点类* 私有_值_筹办缺口_候选方法条件不满足() noexcept { return 私有_任务语义状态词("筹办缺口_候选方法条件不满足"); }
const 语素入口节点类* 私有_值_筹办缺口_参数配对失败() noexcept { return 私有_任务语义状态词("筹办缺口_参数配对失败"); }
const 语素入口节点类* 私有_值_无执行缺口() noexcept { return 私有_任务语义状态词("无执行缺口"); }
