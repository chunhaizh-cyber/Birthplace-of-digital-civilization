export namespace 任务管理工作线程 {

struct 结构_工作线程一步结果 {
    std::vector<结构_任务推进事件> 推进事件列表{};
    std::vector<结构_任务管理上行消息> 上行消息集{};
    bool 任务管理上位输入已刷新 = false;
    bool 任务管理治理触发 = false;
    bool 已执行当前步骤方法 = false;
    bool 存在当前步骤方法执行数据 = false;
    结构_任务步骤执行结果_最小 当前步骤方法执行数据{};
    特征节点类* 当前步骤方法运行结果 = nullptr;
    bool 存在任务推进回执 = false;
    任务模块::筹办::结构_任务推进回执 当前任务推进回执{};
    结构_任务管理结果 治理结果{};
};

struct 结构_工作线程一步响应 {
    bool 推进成功 = false;
    结构_任务控制态 最新任务控制态{};
    结构_任务局部运行态 最新任务局部运行态{};
    结构_工作线程一步结果 一步结果{};
};

struct 结构_工作线程实例快照 {
    bool 已启动 = false;
    bool 正在执行 = false;
    bool 已收到请求 = false;
    bool 停止请求 = false;
    bool 故障 = false;
    std::uint64_t 工作线程ID = 1;
    std::uint64_t 最近任务根ID = 0;
    std::uint64_t 最近请求ID = 0;
    std::uint64_t 最近工作包ID = 0;
    std::uint64_t 累计推进次数 = 0;
    std::uint64_t 累计收到请求数 = 0;
    std::uint64_t 累计收到工作包数 = 0;
    std::uint64_t 累计处理工作包数 = 0;
    std::uint64_t 累计成功推进数 = 0;
    std::uint64_t 累计失败数 = 0;
    std::uint64_t 累计派生需求数 = 0;
    std::uint64_t 累计收到控制请求数 = 0;
    std::uint64_t 累计发送上行消息数 = 0;
    std::uint64_t 最近一次上行消息数 = 0;
    std::uint64_t 当前排队数 = 0;
    时间戳 最近开始时间 = 0;
    时间戳 最近结束时间 = 0;
    时间戳 最近推进时间 = 0;
    std::string 最近宿主任务主键{};
    std::string 最近任务虚拟存在主键{};
    std::string 最近需求主键{};
    std::string 最近步骤主键{};
    std::string 最近方法主键{};
    std::string 最近下一步去向{};
    std::string 最近总控结果{};
    std::string 最近因果链状态{};
    std::string 最近缺口归类{};
    std::string 最近推进阶段{};
    std::string 最近推进状况{};
    std::string 最近筹办承接{};
    std::string 最近等待原因{};
    std::string 最近错误说明{};
    std::uint64_t 最近特征变化数 = 0;
};

struct 结构_界面优先级结果 {
    任务类::节点类* 当前最高优先级任务 = nullptr;
    std::int64_t 调度优先级 = 0;
    bool 是否硬中断任务 = false;
    bool 是否可执行 = false;
    bool 是否安全方向任务 = false;
    bool 是否服务方向任务 = false;
    std::int32_t 来源步骤序号 = 0;
    bool 来源于前置步骤 = false;
};

bool 确保任务管理工作线程壳已启动() noexcept;

bool 提交任务工作包(
    自我类& 自我对象,
    const 任务管理线程协议::结构_任务工作包& 工作包,
    任务管理线程协议::结构_任务工作结果* 输出 = nullptr) noexcept;

bool 读取任务管理工作线程快照(结构_工作线程实例快照* 输出) noexcept;

bool 计算任务管理界面优先级结果(
    const 自我类& 自我对象,
    结构_界面优先级结果* 输出) noexcept;

void 停止任务管理工作线程壳() noexcept;

