namespace {

using 任务节点 = 任务类::节点类;
using 需求节点 = 需求类::节点类;
using 方法节点 = 方法类::节点类;

struct 结构_工作线程壳状态 {
    std::mutex 锁{};
    任务管理工作线程::结构_工作线程实例快照 快照{};
    std::deque<任务管理工作线程::结构_工作线程界面回报记录> 界面回报列表{};
    std::deque<结构_任务管理上行消息> 上行消息直达队列{};
    std::deque<结构_任务根节点> 负载等待任务队列{};
    std::uint64_t 下一个请求ID = 1;
    bool 界面线程壳已启动 = false;
    bool 工作线程壳已启动 = false;
    bool 正在恢复负载等待任务 = false;
};

enum class 枚举_界面线程工作调度动作 : std::uint8_t {
    挂起等待 = 0,
    开启下一轮 = 1,
    结束调度 = 2,
};

struct 结构_界面线程工作调度决策 {
    枚举_界面线程工作调度动作 动作 = 枚举_界面线程工作调度动作::挂起等待;
    std::string 原因{};
};

结构_工作线程壳状态& 私有_壳状态() noexcept
{
    static 结构_工作线程壳状态 状态{};
    return 状态;
}

时间戳 私有_时间(时间戳 now) noexcept
{
    return now != 0 ? now : 结构体_时间戳::当前_微秒();
}

std::string 私有_任务主键(const 任务节点* 节点) noexcept
{
    return 节点 ? 节点->获取主键() : std::string{};
}

std::string 私有_需求主键(const 需求节点* 节点) noexcept
{
    return 节点 ? 节点->获取主键() : std::string{};
}

bool 私有_任务状态已终结(枚举_任务状态 状态) noexcept
{
    return 状态 == 枚举_任务状态::完成
        || 状态 == 枚举_任务状态::失败
        || 状态 == 枚举_任务状态::取消
        || 状态 == 枚举_任务状态::超时;
}

constexpr std::size_t 私有_工作线程并发限额() noexcept
{
    return 1;
}

void 私有_刷新负载等待排队数_已加锁(结构_工作线程壳状态& 状态) noexcept
{
    状态.快照.当前排队数 = static_cast<std::uint64_t>(状态.负载等待任务队列.size());
}

bool 私有_词性同一(const 词性节点类* 左, const 词性节点类* 右) noexcept
{
    if (!左 || !右) {
        return false;
    }
    if (左 == 右) {
        return true;
    }
    const auto 左主键 = 左->获取主键();
    return !左主键.empty() && 左主键 == 右->获取主键();
}

任务节点* 私有_按主键解析任务节点(const std::string& 主键) noexcept
{
    if (主键.empty()) {
        return nullptr;
    }
    return reinterpret_cast<任务节点*>(世界树.基础信息().查找主键(主键));
}

任务节点* 私有_解析任务引用(const 可解析引用<任务节点类>& 引用) noexcept
{
    if (引用.指针) {
        return reinterpret_cast<任务节点*>(引用.指针);
    }
    return 私有_按主键解析任务节点(引用.主键);
}

bool 私有_任务节点归属任务头(
    const 任务节点* 节点,
    const 任务节点* 任务头) noexcept
{
    if (!节点 || !任务头) {
        return false;
    }
    const auto* 所属任务 = reinterpret_cast<const 任务节点*>(节点->主信息.所属任务头结点.指针);
    if (所属任务 == 任务头) {
        return true;
    }
    const auto& 所属主键 = 节点->主信息.所属任务头结点.主键;
    return !所属主键.empty() && 所属主键 == 任务头->获取主键();
}

bool 私有_方法是任务治理本能方法(
    const 方法类::节点类* 方法,
    const 枚举_本能方法ID 本能ID) noexcept
{
    return 方法
        && 方法->主信息.动作句柄.类型 == 枚举_动作句柄类型::本能函数ID
        && static_cast<枚举_本能方法ID>(方法->主信息.动作句柄.本能ID) == 本能ID;
}

任务节点* 私有_任务根节点取任务(const 结构_任务根节点& 根节点) noexcept
{
    if (根节点.世界任务根指针 != 0) {
        return reinterpret_cast<任务节点*>(根节点.世界任务根指针);
    }
    if (根节点.父任务指针 != 0) {
        return reinterpret_cast<任务节点*>(根节点.父任务指针);
    }
    return nullptr;
}

任务节点* 私有_任务根节点取管理对象任务(const 结构_任务根节点& 根节点) noexcept
{
    return 根节点.管理对象任务指针 != 0
        ? reinterpret_cast<任务节点*>(根节点.管理对象任务指针)
        : nullptr;
}

需求节点* 私有_任务根节点取需求(const 结构_任务根节点& 根节点) noexcept
{
    return 根节点.来源需求指针 != 0
        ? reinterpret_cast<需求节点*>(根节点.来源需求指针)
        : nullptr;
}

bool 私有_任务已在需求列表(const 需求节点* 需求, const 任务节点* 任务) noexcept
{
    if (!需求 || !任务) {
        return false;
    }
    const auto 主键 = 私有_任务主键(任务);
    for (const auto& 项 : 需求->主信息.任务列表) {
        if (项.指针 == reinterpret_cast<const 任务节点类*>(任务)
            || (!主键.empty() && 项.主键 == 主键)) {
            return true;
        }
    }
    return false;
}

void 私有_绑定任务需求关系(任务节点* 任务, 需求节点* 需求) noexcept
{
    if (!任务 || !需求) {
        return;
    }

    任务->主信息.对应需求.指针 = reinterpret_cast<需求节点类*>(需求);
    任务->主信息.对应需求.主键 = 私有_需求主键(需求);
    任务->主信息.目标状态.指针 = 需求->主信息.需求状态.指针;
    任务->主信息.目标状态.主键 = 需求->主信息.需求状态.主键;
    任务->主信息.基准优先级 = 需求->主信息.安全权重 + 需求->主信息.服务权重;
    任务->主信息.调度优先级 = 任务->主信息.基准优先级 + 任务->主信息.局部优先级偏移;

    if (任务->主信息.状态 == 枚举_任务状态::未定义) {
        任务->主信息.状态 = 枚举_任务状态::未启动;
    }
    if (任务->主信息.当前阶段 == 枚举_任务阶段::未定义) {
        任务->主信息.当前阶段 = 枚举_任务阶段::筹办;
    }
    if (任务->主信息.任务角色 == 枚举_任务角色::未定义) {
        任务->主信息.任务角色 = 需求->子节点数量 > 0
            ? 枚举_任务角色::需求管理任务
            : 枚举_任务角色::需求执行任务;
    }
    if (任务->主信息.完成口径 == 枚举_任务完成口径::未定义) {
        任务->主信息.完成口径 = 需求->子节点数量 > 0
            ? 枚举_任务完成口径::子需求全部完成
            : 枚举_任务完成口径::需求状态达成;
    }

    if (!私有_任务已在需求列表(需求, 任务)) {
        可解析引用<任务节点类> 引用{};
        引用.指针 = reinterpret_cast<任务节点类*>(任务);
        引用.主键 = 私有_任务主键(任务);
        需求->主信息.任务列表.push_back(引用);
    }
    if (!需求->主信息.对应任务.有效()) {
        需求->主信息.对应任务.指针 = reinterpret_cast<任务节点类*>(任务);
        需求->主信息.对应任务.主键 = 私有_任务主键(任务);
    }
}

任务节点* 私有_从需求任务列表取任务(const 需求节点* 需求) noexcept
{
    if (!需求) {
        return nullptr;
    }
    if (auto* 任务 = reinterpret_cast<任务节点*>(需求->主信息.对应任务.指针)) {
        return 任务;
    }
    for (const auto& 引用 : 需求->主信息.任务列表) {
        if (auto* 任务 = reinterpret_cast<任务节点*>(引用.指针)) {
            return 任务;
        }
    }
    return nullptr;
}

任务节点* 私有_消息取任务(const 任务管理工作线程::结构_任务信息消息& 消息) noexcept
{
    if (消息.新任务) {
        return 消息.新任务;
    }
    return 私有_从需求任务列表取任务(消息.任务目标);
}

void 私有_写入任务节点引用(
    可解析引用<任务节点类>& 输出,
    任务节点* 节点) noexcept
{
    输出.指针 = reinterpret_cast<任务节点类*>(节点);
    输出.主键 = 节点 ? 节点->获取主键() : std::string{};
}

void 私有_写入方法节点引用(
    可解析引用<方法节点类>& 输出,
    方法类::节点类* 节点) noexcept
{
    输出.指针 = reinterpret_cast<方法节点类*>(节点);
    输出.主键 = 节点 ? 节点->获取主键() : std::string{};
}

void 私有_写入状态节点引用(
    可解析引用<状态节点类>& 输出,
    状态节点类* 节点) noexcept
{
    输出.指针 = 节点;
    输出.主键 = 节点 ? 节点->获取主键() : std::string{};
}

void 私有_写入场景节点引用(
    可解析引用<场景节点类>& 输出,
    场景节点类* 节点) noexcept
{
    输出.指针 = 节点;
    输出.主键 = 节点 ? 节点->获取主键() : std::string{};
}

bool 私有_任务引用指向(
    const 可解析引用<任务节点类>& 引用,
    const 任务节点* 节点) noexcept
{
    if (!节点) {
        return false;
    }
    return 引用.指针 == reinterpret_cast<const 任务节点类*>(节点)
        || (!引用.主键.empty() && 引用.主键 == 节点->获取主键());
}

方法类::节点类* 私有_确保任务管理本能方法(
    自我类& 自我对象,
    枚举_本能方法ID 本能ID,
    时间戳 now,
    const std::string& 调用点) noexcept
{
    auto* 自我存在 = 自我对象.获取自我存在();
    if (!自我存在) {
        return nullptr;
    }
    auto* 方法 = 方法类::查找或创建_本能方法首节点(
        自我存在,
        本能ID,
        now,
        调用点 + "/本能方法");
    if (方法) {
        (void)方法类::初始化方法虚拟存在信息(
            方法,
            自我存在,
            now,
            调用点 + "/初始化本能方法虚拟存在");
        (void)方法类::记录方法虚拟存在特征(
            方法,
            语素集.添加词性词("方法是否可用", "名词"),
            特征值{ static_cast<I64>(1) },
            自我存在,
            now,
            调用点 + "/本能方法可用");
    }
    return 方法;
}

const 词性节点类* 私有_任务管理本体步骤类型词(const char* 名称) noexcept
{
    return 语素集.添加词性词(名称 ? 名称 : "步骤", "名词");
}

bool 私有_任务管理本体步骤有效(
    const 任务节点* 步骤,
    const 任务节点* 管理任务,
    const char* 步骤名称,
    const 枚举_本能方法ID 本能ID) noexcept
{
    if (!步骤
        || !管理任务
        || 步骤->主信息.节点种类 != 枚举_任务节点种类::步骤节点
        || !私有_任务节点归属任务头(步骤, 管理任务)
        || !私有_词性同一(步骤->主信息.类型, 私有_任务管理本体步骤类型词(步骤名称))
        || 私有_任务状态已终结(步骤->主信息.状态)) {
        return false;
    }

    const auto* 方法 = reinterpret_cast<const 方法类::节点类*>(步骤->主信息.执行方法.指针);
    return 私有_方法是任务治理本能方法(方法, 本能ID);
}

bool 私有_当前步骤是任务两步壳(
    const 任务节点* 步骤,
    const 任务节点* 管理任务) noexcept
{
    return 私有_任务管理本体步骤有效(
            步骤,
            管理任务,
            "筹办",
            枚举_本能方法ID::自我_任务筹办)
        || 私有_任务管理本体步骤有效(
            步骤,
            管理任务,
            "执行",
            枚举_本能方法ID::自我_任务执行一步);
}

任务节点* 私有_查找任务管理本体步骤(
    任务节点* 管理任务,
    const char* 步骤名称) noexcept
{
    if (!管理任务) {
        return nullptr;
    }
    const auto* 类型词 = 私有_任务管理本体步骤类型词(步骤名称);
    std::vector<任务节点*> 待查{ 管理任务 };
    std::size_t 保护计数 = 0;
    while (!待查.empty() && ++保护计数 < 2048) {
        auto* 当前 = 待查.back();
        待查.pop_back();
        if (!当前) {
            continue;
        }
        if (当前 != 管理任务
            && 当前->主信息.节点种类 == 枚举_任务节点种类::步骤节点
            && 私有_词性同一(当前->主信息.类型, 类型词)
            && 私有_任务节点归属任务头(当前, 管理任务)) {
            return 当前;
        }
        if (!当前->子) {
            continue;
        }
        auto* 首子 = reinterpret_cast<任务节点*>(当前->子);
        auto* 子 = 首子;
        std::size_t 子保护 = 0;
        do {
            if (子) {
                待查.push_back(子);
            }
            子 = 子 ? reinterpret_cast<任务节点*>(子->下) : nullptr;
            ++子保护;
        } while (子 && 子 != 首子 && 子保护 < 512);
    }
    return nullptr;
}

任务节点* 私有_绑定任务管理实例当前步骤(
    任务节点* 管理任务,
    const char* 步骤名称) noexcept
{
    if (auto* 步骤 = 私有_查找任务管理本体步骤(管理任务, 步骤名称)) {
        私有_写入任务节点引用(管理任务->主信息.当前步骤节点, 步骤);
        return 步骤;
    }
    return nullptr;
}

void 私有_绑定任务管理实例步骤方法(
    自我类& 自我对象,
    任务节点* 管理任务,
    const char* 步骤名称,
    枚举_本能方法ID 本能ID,
    时间戳 now,
    const std::string& 调用点,
    bool 设为当前步骤 = false) noexcept
{
    auto* 步骤 = 设为当前步骤
        ? 私有_绑定任务管理实例当前步骤(管理任务, 步骤名称)
        : 私有_查找任务管理本体步骤(管理任务, 步骤名称);
    if (!步骤) {
        return;
    }
    auto* 方法 = 私有_确保任务管理本能方法(
        自我对象,
        本能ID,
        now,
        调用点 + "/步骤方法");
    if (!方法) {
        return;
    }
    步骤->主信息.执行方法.绑定(reinterpret_cast<方法节点类*>(方法));
    步骤->主信息.候选方法首节点.绑定(reinterpret_cast<方法节点类*>(方法));
    步骤->主信息.可用方法首节点.绑定(reinterpret_cast<方法节点类*>(方法));
    步骤->主信息.动作句柄 = 方法->主信息.动作句柄;
    步骤->主信息.状态 = 枚举_任务状态::就绪;
}

bool 私有_准备任务管理任务实例(
    自我类& 自我对象,
    任务节点* 管理任务,
    任务节点* 被管理任务,
    时间戳 now,
    const std::string& 调用点) noexcept
{
    if (!管理任务) {
        return false;
    }
    if (!被管理任务) {
        被管理任务 = 管理任务;
    }

    const bool 管理对象已变化 =
        !私有_任务引用指向(管理任务->主信息.管理对象任务, 被管理任务);
    私有_写入任务节点引用(管理任务->主信息.管理对象任务, 被管理任务);
    if (管理任务 != 被管理任务) {
        管理任务->主信息.任务角色 = 枚举_任务角色::任务管理任务;
        管理任务->主信息.完成口径 = 枚举_任务完成口径::治理状态完成;
    }
    管理任务->主信息.目标状态 = 被管理任务->主信息.目标状态;
    管理任务->主信息.结果状态信息 = 被管理任务->主信息.结果状态信息;
    管理任务->主信息.基准优先级 = 被管理任务->主信息.基准优先级;
    if (管理任务 != 被管理任务) {
        管理任务->主信息.局部优先级偏移 =
            (std::max<std::int64_t>)(管理任务->主信息.局部优先级偏移, 被管理任务->主信息.局部优先级偏移 + 100);
    }
    管理任务->主信息.调度优先级 = 管理任务->主信息.基准优先级 + 管理任务->主信息.局部优先级偏移;

    auto* 当前步骤 = 私有_解析任务引用(管理任务->主信息.当前步骤节点);
    const bool 当前步骤有效 = 私有_当前步骤是任务两步壳(当前步骤, 管理任务);
    const bool 需要回到筹办 =
        管理对象已变化
        || !当前步骤有效
        || 私有_任务状态已终结(管理任务->主信息.状态);
    if (需要回到筹办) {
        if (auto* 筹办步骤 = 私有_绑定任务管理实例当前步骤(管理任务, "筹办")) {
            auto* 筹办方法 = 私有_确保任务管理本能方法(
                自我对象,
                枚举_本能方法ID::自我_任务筹办,
                now,
                调用点 + "/筹办");
            if (筹办方法) {
                筹办步骤->主信息.执行方法.绑定(reinterpret_cast<方法节点类*>(筹办方法));
                筹办步骤->主信息.候选方法首节点.绑定(reinterpret_cast<方法节点类*>(筹办方法));
                筹办步骤->主信息.可用方法首节点.绑定(reinterpret_cast<方法节点类*>(筹办方法));
                筹办步骤->主信息.动作句柄 = 筹办方法->主信息.动作句柄;
                筹办步骤->主信息.状态 = 枚举_任务状态::就绪;
            }
        }
        管理任务->主信息.状态 = 枚举_任务状态::待重筹办;
        管理任务->主信息.完成时间 = 0;
    }
    私有_绑定任务管理实例步骤方法(
        自我对象,
        管理任务,
        "执行",
        枚举_本能方法ID::自我_任务执行一步,
        now,
        调用点 + "/执行步骤",
        false);
    return true;
}

结构_任务根节点 私有_构造任务根节点(
    const 任务管理工作线程::结构_任务信息消息& 消息,
    任务节点* 管理任务,
    任务节点* 被管理任务,
    const std::uint64_t 请求ID) noexcept
{
    结构_任务根节点 根节点{};
    根节点.任务根ID = 管理任务
        ? static_cast<std::uint64_t>(reinterpret_cast<std::uintptr_t>(管理任务))
        : 请求ID;
    根节点.来源需求指针 = reinterpret_cast<std::uintptr_t>(消息.任务目标);
    根节点.世界任务根指针 = reinterpret_cast<std::uintptr_t>(管理任务);
    根节点.父任务指针 = 0;
    根节点.管理对象任务指针 = reinterpret_cast<std::uintptr_t>(被管理任务);
    根节点.来源需求主键 = 私有_需求主键(消息.任务目标);
    根节点.管理对象任务主键 = 私有_任务主键(被管理任务);
    根节点.方向说明 = "任务管理界面线程治理任务参数";
    根节点.创建者 = "任务管理界面线程";
    根节点.根约束说明 = "界面线程承接任务参数并派发工作线程单步执行";
    根节点.初始授权等级 = 1;
    根节点.只读 = false;
    return 根节点;
}

结构_任务控制态 私有_构造任务控制态(
    const 结构_任务根节点& 根节点,
    const 任务节点* 任务) noexcept
{
    结构_任务控制态 控制态{};
    控制态.任务根ID = 根节点.任务根ID;
    控制态.队列状态 = !任务
        ? 枚举_任务队列状态::等待
        : (私有_任务状态已终结(任务->主信息.状态)
            ? 枚举_任务队列状态::已结算
            : 枚举_任务队列状态::可运行);
    控制态.全局优先级 = 任务 ? 任务->主信息.调度优先级 : 0;
    控制态.绑定工作线程ID = 1;
    控制态.控制说明 = "界面线程承接任务控制态";
    同步任务实体语义槽(控制态);
    return 控制态;
}

结构_任务局部运行态 私有_构造任务局部运行态(
    const 结构_任务根节点& 根节点,
    const 任务节点* 任务) noexcept
{
    结构_任务局部运行态 运行态{};
    运行态.任务根ID = 根节点.任务根ID;
    运行态.当前状态 = !任务
        ? 枚举_任务局部运行状态::等待条件
        : (私有_任务状态已终结(任务->主信息.状态)
            ? 枚举_任务局部运行状态::局部完成
            : 枚举_任务局部运行状态::已受理);
    运行态.当前步骤前沿 = reinterpret_cast<std::uintptr_t>(任务);
    运行态.当前等待原因 = 任务 ? std::string{} : std::string("缺少任务节点");
    运行态.局部运行说明 = "界面线程承接任务运行态";
    同步任务实体语义槽(运行态);
    return 运行态;
}

void 私有_界面线程标记任务已承接(任务节点* 任务, const 时间戳 now) noexcept
{
    if (!任务 || 私有_任务状态已终结(任务->主信息.状态)) {
        return;
    }
    if (任务->主信息.状态 == 枚举_任务状态::未定义
        || 任务->主信息.状态 == 枚举_任务状态::未启动
        || 任务->主信息.状态 == 枚举_任务状态::就绪
        || 任务->主信息.状态 == 枚举_任务状态::待重筹办) {
        任务->主信息.状态 = 枚举_任务状态::排队中;
        任务->主信息.统计.记录观测(now);
    }
}

void 私有_界面线程标记任务已派发(任务节点* 任务, const 时间戳 now) noexcept
{
    if (!任务 || 私有_任务状态已终结(任务->主信息.状态)) {
        return;
    }
    任务->主信息.状态 = 枚举_任务状态::执行中;
    任务->主信息.最近调度时间 = now;
    if (任务->主信息.启动时间 == 0) {
        任务->主信息.启动时间 = now;
    }
    任务->主信息.统计.记录观测(now);
}

void 私有_界面线程标记任务负载等待(任务节点* 任务, const 时间戳 now) noexcept
{
    if (!任务 || 私有_任务状态已终结(任务->主信息.状态)) {
        return;
    }
    if (任务->主信息.状态 == 枚举_任务状态::等待中
        || 任务->主信息.状态 == 枚举_任务状态::挂起
        || 任务->主信息.状态 == 枚举_任务状态::无法执行) {
        return;
    }
    任务->主信息.状态 = 枚举_任务状态::排队中;
    任务->主信息.统计.记录观测(now);
}

bool 私有_任务根节点相同(
    const 结构_任务根节点& 左,
    const 结构_任务根节点& 右) noexcept
{
    if (左.任务根ID != 0 && 左.任务根ID == 右.任务根ID) {
        return true;
    }
    return 左.世界任务根指针 != 0
        && 左.世界任务根指针 == 右.世界任务根指针
        && 左.管理对象任务指针 == 右.管理对象任务指针;
}

void 私有_同步任务态语义槽(
    结构_任务控制态& 控制态,
    结构_任务局部运行态& 运行态) noexcept
{
    同步任务实体语义槽(控制态);
    同步任务实体语义槽(运行态);
}

bool 私有_负载等待队列已有任务_已加锁(
    const 结构_工作线程壳状态& 状态,
    const 结构_任务根节点& 根节点) noexcept
{
    return std::any_of(
        状态.负载等待任务队列.begin(),
        状态.负载等待任务队列.end(),
        [&根节点](const 结构_任务根节点& 已有) noexcept {
            return 私有_任务根节点相同(已有, 根节点);
        });
}

bool 私有_登记负载等待任务(
    const 结构_任务根节点& 根节点,
    任务节点* 管理任务,
    任务节点* 被管理任务,
    const 时间戳 now) noexcept
{
    auto& 状态 = 私有_壳状态();
    std::lock_guard<std::mutex> 锁(状态.锁);
    if (私有_负载等待队列已有任务_已加锁(状态, 根节点)) {
        私有_刷新负载等待排队数_已加锁(状态);
        return false;
    }
    状态.负载等待任务队列.push_back(根节点);
    私有_刷新负载等待排队数_已加锁(状态);
    状态.快照.最近等待原因 = "工作线程负载已满，任务进入负载等待队列";
    私有_界面线程标记任务负载等待(管理任务, now);
    私有_界面线程标记任务负载等待(被管理任务, now);
    return true;
}

bool 私有_当前工作线程有空余负载_已加锁(const 结构_工作线程壳状态& 状态) noexcept
{
    return !状态.快照.正在执行
        && 私有_工作线程并发限额() > 0;
}

bool 私有_取一个负载等待任务(
    结构_任务根节点* 输出) noexcept
{
    if (!输出) {
        return false;
    }
    auto& 状态 = 私有_壳状态();
    std::lock_guard<std::mutex> 锁(状态.锁);
    if (状态.正在恢复负载等待任务
        || !私有_当前工作线程有空余负载_已加锁(状态)
        || 状态.负载等待任务队列.empty()) {
        私有_刷新负载等待排队数_已加锁(状态);
        return false;
    }
    *输出 = 状态.负载等待任务队列.front();
    状态.负载等待任务队列.pop_front();
    状态.正在恢复负载等待任务 = true;
    私有_刷新负载等待排队数_已加锁(状态);
    return true;
}

void 私有_结束负载等待任务恢复() noexcept
{
    auto& 状态 = 私有_壳状态();
    std::lock_guard<std::mutex> 锁(状态.锁);
    状态.正在恢复负载等待任务 = false;
    私有_刷新负载等待排队数_已加锁(状态);
}

枚举_任务状态 私有_从执行结果推导界面任务状态(
    const 结构_任务步骤执行结果_最小& 任务数据,
    const 特征节点类* 方法运行结果) noexcept
{
    if (任务结果缺条件_最小_v0(方法运行结果)) {
        return 枚举_任务状态::等待中;
    }
    if (任务结果缺方法_最小_v0(方法运行结果)) {
        return 枚举_任务状态::挂起;
    }
    if (任务治理步骤要求待重入_最小_v0(任务数据.当前方法, 方法运行结果)) {
        return 枚举_任务状态::待重筹办;
    }
    if (任务数据.记账结果 == 枚举_任务执行记账结果::转学习) {
        return 枚举_任务状态::挂起;
    }
    if (本能动作运行成功(方法运行结果)) {
        return 枚举_任务状态::完成;
    }
    return 任务数据.当前方法 ? 枚举_任务状态::待重筹办 : 枚举_任务状态::等待中;
}

枚举_任务管理控制意图值 私有_控制事件映射控制意图(
    const 枚举_任务控制事件类型 事件类型) noexcept
{
    switch (事件类型) {
    case 枚举_任务控制事件类型::启动:
        return 枚举_任务管理控制意图值::请求启动;
    case 枚举_任务控制事件类型::打断:
        return 枚举_任务管理控制意图值::请求打断;
    case 枚举_任务控制事件类型::收束:
        return 枚举_任务管理控制意图值::请求收束;
    case 枚举_任务控制事件类型::停止:
        return 枚举_任务管理控制意图值::请求停止;
    case 枚举_任务控制事件类型::优先级刷新:
        return 枚举_任务管理控制意图值::请求刷新优先级;
    case 枚举_任务控制事件类型::预算刷新:
        return 枚举_任务管理控制意图值::请求刷新预算;
    default:
        return 枚举_任务管理控制意图值::未定义;
    }
}

bool 私有_本轮禁止工作线程执行(
    const 结构_任务控制事件& 控制事件,
    枚举_任务管理根层重判结果 根层重判结果,
    枚举_任务管理执行前门控结果 执行前门控结果) noexcept
{
    return 根层重判结果 == 枚举_任务管理根层重判结果::停止退出边界
        || 执行前门控结果 == 枚举_任务管理执行前门控结果::禁止继续
        || 控制事件.事件类型 == 枚举_任务控制事件类型::停止;
}

结构_执行任务结果 私有_构造未执行任务结果(
    任务节点* 任务,
    const I64 错误码,
    const std::string& 解释) noexcept
{
    结构_执行任务结果 输出{};
    输出.任务执行结果.主任务 = 任务;
    输出.任务执行结果.当前步骤节点 = 任务;
    输出.任务执行结果.记账结果 = 枚举_任务执行记账结果::失败;
    输出.任务执行结果.结果场景 = 任务 ? 任务->主信息.场景.指针 : nullptr;
    输出.任务执行结果.方法运行结果 = 创建本能动作运行结果实例_按码(
        nullptr,
        输出.任务执行结果.结果场景,
        错误码);
    输出.任务执行结果.方法运行说明 = 解释;
    输出.方法运行结果 = 输出.任务执行结果.方法运行结果;
    return 输出;
}

std::string 私有_执行结果等待原因(
    const 结构_任务步骤执行结果_最小& 任务数据,
    const 特征节点类* 方法运行结果)
{
    if (任务结果缺条件_最小_v0(方法运行结果)) {
        return !任务数据.方法运行说明.empty()
            ? 任务数据.方法运行说明
            : std::string("执行缺少方法执行条件，已上报自我线程补条件");
    }
    if (任务结果缺方法_最小_v0(方法运行结果)) {
        return !任务数据.方法运行说明.empty()
            ? 任务数据.方法运行说明
            : std::string("筹办缺少执行方法，交给任务管理任务补方法");
    }
    return 任务数据.当前方法
        ? std::string("方法执行未完成")
        : std::string("缺少执行方法");
}

任务节点* 私有_查找步骤结果节点_按当前步骤(任务节点* 当前步骤) noexcept
{
    if (!当前步骤 || 当前步骤->主信息.节点种类 != 枚举_任务节点种类::步骤节点) {
        return nullptr;
    }

    if (auto* 后续结果 = 私有_解析任务引用(当前步骤->主信息.后续任务)) {
        if (后续结果->主信息.节点种类 == 枚举_任务节点种类::结果节点
            && (后续结果->父 == 当前步骤
                || 私有_任务引用指向(后续结果->主信息.来源步骤节点, 当前步骤))) {
            return 后续结果;
        }
    }

    if (!当前步骤->子) {
        return nullptr;
    }
    auto* 首子 = reinterpret_cast<任务节点*>(当前步骤->子);
    auto* 子 = 首子;
    std::size_t 保护计数 = 0;
    do {
        if (子
            && 子->主信息.节点种类 == 枚举_任务节点种类::结果节点
            && (子->父 == 当前步骤 || 私有_任务引用指向(子->主信息.来源步骤节点, 当前步骤))) {
            return 子;
        }
        子 = 子 ? reinterpret_cast<任务节点*>(子->下) : nullptr;
        ++保护计数;
    } while (子 && 子 != 首子 && 保护计数 < 512);
    return nullptr;
}

任务节点* 私有_同步工作线程执行结果到结果节点(
    任务节点* 任务,
    结构_任务步骤执行结果_最小& 任务数据,
    const 特征节点类* 方法运行结果,
    const 枚举_任务状态 推导状态,
    const 时间戳 now) noexcept
{
    if (!任务) {
        return nullptr;
    }

    auto* 当前步骤 = reinterpret_cast<任务节点*>(任务数据.当前步骤节点);
    if (!当前步骤 || 当前步骤->主信息.节点种类 != 枚举_任务节点种类::步骤节点) {
        return nullptr;
    }

    auto* 推导结果状态 = reinterpret_cast<状态节点类*>(
        任务->主信息.目标状态.指针
            ? 任务->主信息.目标状态.指针
            : 任务->主信息.结果状态信息.指针);

    auto* 结果节点 = 私有_查找步骤结果节点_按当前步骤(当前步骤);
    if (!结果节点) {
        任务类 临时任务树{};
        结果节点 = 临时任务树.创建任务结果节点(
            任务,
            当前步骤,
            reinterpret_cast<方法节点类*>(任务数据.当前方法),
            枚举_任务结果角色::实际结果,
            推导结果状态,
            now,
            "任务管理工作线程::同步执行结果/创建实际结果");
    }
    if (!结果节点) {
        return nullptr;
    }

    const bool 本轮成功 =
        推导状态 == 枚举_任务状态::完成
        || 任务数据.记账结果 == 枚举_任务执行记账结果::成功
        || 本能动作运行成功(方法运行结果);
    const bool 本轮转学习 =
        任务数据.记账结果 == 枚举_任务执行记账结果::转学习
        || 任务结果缺方法_最小_v0(方法运行结果);

    auto& 结果主信息 = 结果节点->主信息;
    结果主信息.节点种类 = 枚举_任务节点种类::结果节点;
    结果主信息.结果角色 = 枚举_任务结果角色::实际结果;
    结果主信息.状态 = 推导状态 != 枚举_任务状态::未定义 ? 推导状态 : 枚举_任务状态::失败;
    if (结果主信息.启动时间 == 0) {
        结果主信息.启动时间 = 当前步骤->主信息.启动时间 != 0
            ? 当前步骤->主信息.启动时间
            : now;
    }
    结果主信息.完成时间 = now;
    结果主信息.最近执行时间 = 结果主信息.启动时间;
    结果主信息.最近完成时间 = now;
    ++结果主信息.运行次数;
    if (本轮成功) {
        ++结果主信息.成功次数;
        结果主信息.连续失败次数 = 0;
    }
    else {
        ++结果主信息.失败次数;
        ++结果主信息.连续失败次数;
    }
    if (本轮转学习) {
        ++结果主信息.转入学习次数;
    }
    const auto 运行码 = 本能动作运行结果值(方法运行结果);
    结果主信息.最近错误码 = 运行码;
    结果主信息.错误码 = 运行码;
    结果主信息.置信度_Q10000 = 本轮成功 ? 10000 : 0;
    结果主信息.统计.记录观测(now);
    私有_写入任务节点引用(结果主信息.父任务, 当前步骤);
    私有_写入任务节点引用(结果主信息.来源步骤节点, 当前步骤);
    私有_写入任务节点引用(结果主信息.所属任务头结点, 任务);
    私有_写入任务节点引用(当前步骤->主信息.后续任务, 结果节点);
    私有_写入任务节点引用(任务->主信息.最近实际结果节点, 结果节点);
    私有_写入方法节点引用(结果主信息.执行方法, 任务数据.当前方法);
    私有_写入方法节点引用(结果主信息.来源方法首节点, 任务数据.当前方法);
    if (任务数据.当前方法) {
        结果主信息.动作句柄 = 任务数据.当前方法->主信息.动作句柄;
    }
    if (推导结果状态) {
        私有_写入状态节点引用(结果主信息.结果状态信息, 推导结果状态);
    }
    if (任务->主信息.目标状态.有效()) {
        结果主信息.目标状态 = 任务->主信息.目标状态;
    }
    if (任务数据.结果场景) {
        私有_写入场景节点引用(结果主信息.场景, 任务数据.结果场景);
    }
    else if (当前步骤->主信息.场景.指针) {
        私有_写入场景节点引用(结果主信息.场景, 当前步骤->主信息.场景.指针);
    }
    else {
        结果主信息.场景 = 任务->主信息.场景;
    }

    当前步骤->主信息.状态 = 结果主信息.状态;
    if (当前步骤->主信息.启动时间 == 0) {
        当前步骤->主信息.启动时间 = 结果主信息.启动时间;
    }
    当前步骤->主信息.完成时间 = now;
    当前步骤->主信息.最近执行时间 = 结果主信息.启动时间;
    当前步骤->主信息.最近完成时间 = now;
    当前步骤->主信息.最近错误码 = 运行码;
    当前步骤->主信息.统计.记录观测(now);

    任务数据.最近结果节点 = 结果节点;
    return 结果节点;
}

bool 私有_回报包含派生需求消息(
    const 任务管理工作线程::结构_工作线程推进响应& 响应) noexcept
{
    return std::any_of(
        响应.桥接结果.上行消息集.begin(),
        响应.桥接结果.上行消息集.end(),
        [](const auto& 消息) noexcept {
            return 消息.类型 == 枚举_任务管理上行消息类型::派生需求消息;
        });
}

结构_界面线程工作调度决策 私有_界面线程裁决工作线程下一步(
    const 任务管理工作线程::结构_工作线程推进响应& 响应) noexcept
{
    结构_界面线程工作调度决策 决策{};
    const auto& 任务数据 = 响应.桥接结果.当前步骤方法执行数据;
    const auto* 方法运行结果 = 响应.桥接结果.当前步骤方法运行结果;

    if (!响应.推进成功) {
        决策.动作 = 枚举_界面线程工作调度动作::挂起等待;
        决策.原因 = "工作线程本轮未成功回报，界面线程挂起等待";
        return 决策;
    }

    if (响应.最新任务控制态.队列状态 == 枚举_任务队列状态::已结算
        || 响应.桥接结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::进入收束) {
        决策.动作 = 枚举_界面线程工作调度动作::结束调度;
        决策.原因 = "工作线程回报任务已进入收束或结算";
        return 决策;
    }

    if (任务治理步骤要求待重入_最小_v0(任务数据.当前方法, 方法运行结果)
        || 响应.桥接结果.治理结果.宿主任务新状态 == 枚举_任务状态::待重筹办
        || 响应.桥接结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::进入运行
        || 响应.桥接结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::保持运行
        || 响应.桥接结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::回到重筹办
        || 响应.桥接结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::绑定方法) {
        决策.动作 = 枚举_界面线程工作调度动作::开启下一轮;
        决策.原因 = "工作线程完成一步且无外部缺口，界面线程排队下一轮";
        return 决策;
    }

    if (私有_回报包含派生需求消息(响应)
        || 任务结果缺条件_最小_v0(方法运行结果)
        || 任务结果缺方法_最小_v0(方法运行结果)) {
        决策.动作 = 枚举_界面线程工作调度动作::挂起等待;
        决策.原因 = "工作线程已上报派生需求或仍有缺口，等待自我线程处理后再唤醒";
        return 决策;
    }

    决策.动作 = 枚举_界面线程工作调度动作::挂起等待;
    决策.原因 = "工作线程本轮未形成可继续推进条件，界面线程挂起等待";
    return 决策;
}

void 私有_界面线程应用调度决策到回报(
    任务管理工作线程::结构_工作线程推进响应& 响应,
    任务节点* 任务,
    const 结构_界面线程工作调度决策& 决策,
    时间戳 now) noexcept
{
    if (!任务) {
        return;
    }

    switch (决策.动作) {
    case 枚举_界面线程工作调度动作::开启下一轮:
        if (!私有_任务状态已终结(任务->主信息.状态)) {
            响应.桥接结果.治理结果.宿主任务新状态 = 枚举_任务状态::排队中;
            响应.最新任务控制态.队列状态 = 枚举_任务队列状态::可运行;
            响应.最新任务控制态.已派发 = false;
            响应.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::当前步骤可执行;
            响应.最新任务局部运行态.当前等待原因.clear();
            响应.桥接结果.治理结果.当前下一步去向 = 枚举_任务管理下一步去向::进入运行;
            响应.桥接结果.治理结果.最近总控结果 = 枚举_任务管理总控结果::宿主已进入运行;
        }
        break;
    case 枚举_界面线程工作调度动作::结束调度:
        响应.最新任务控制态.队列状态 = 枚举_任务队列状态::已结算;
        响应.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::局部完成;
        响应.桥接结果.治理结果.当前下一步去向 = 枚举_任务管理下一步去向::进入收束;
        响应.桥接结果.治理结果.最近总控结果 = 枚举_任务管理总控结果::宿主进入收束;
        break;
    case 枚举_界面线程工作调度动作::挂起等待:
    default:
        响应.最新任务控制态.队列状态 = 枚举_任务队列状态::等待;
        响应.最新任务控制态.已派发 = false;
        响应.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::等待条件;
        if (响应.最新任务局部运行态.当前等待原因.empty()) {
            响应.最新任务局部运行态.当前等待原因 = 决策.原因;
        }
        响应.桥接结果.治理结果.当前下一步去向 = 枚举_任务管理下一步去向::保持等待;
        响应.桥接结果.治理结果.最近总控结果 = 枚举_任务管理总控结果::宿主保持等待;
        break;
    }

    响应.最新任务局部运行态.局部运行说明 = 决策.原因;
    if (now != 0) {
        任务->主信息.统计.记录观测(now);
    }
}

bool 私有_界面线程任务允许派发(const 任务节点* 任务) noexcept
{
    if (!任务 || 私有_任务状态已终结(任务->主信息.状态)) {
        return false;
    }
    switch (任务->主信息.状态) {
    case 枚举_任务状态::等待中:
    case 枚举_任务状态::挂起:
    case 枚举_任务状态::无法执行:
        return false;
    default:
        return true;
    }
}

const 词性节点类* 私有_状态特征类型词(const 状态节点类* 状态节点) noexcept
{
    const auto* 状态主信息 = 状态节点
        ? 世界树.状态().取状态主信息(const_cast<状态节点类*>(状态节点))
        : nullptr;
    if (!状态主信息) {
        return nullptr;
    }

    auto* 特征节点 = 状态主信息->状态特征.指针;
    if (!特征节点 && !状态主信息->状态特征.主键.empty()) {
        特征节点 = dynamic_cast<特征节点类*>(
            世界树.基础信息().查找主键(状态主信息->状态特征.主键));
    }
    const auto* 特征主信息 = 特征节点 ? 世界树.特征().取特征主信息(特征节点) : nullptr;
    return 特征主信息 ? 特征主信息->类型 : nullptr;
}

void 私有_填充派生需求状态字段(
    结构_任务管理派生需求消息& 消息,
    const 任务节点* 任务) noexcept
{
    auto* 来源需求 = 任务
        ? reinterpret_cast<需求节点*>(任务->主信息.对应需求.指针)
        : nullptr;
    if (!来源需求 && 任务) {
        来源需求 = reinterpret_cast<需求节点*>(任务->主信息.来源需求.指针);
    }

    auto* 当前状态 = 来源需求
        ? 来源需求->主信息.被需求当前状态.指针
        : nullptr;
    auto* 目标状态 = 来源需求
        ? 来源需求->主信息.需求状态.指针
        : nullptr;
    if (!当前状态 && 任务) {
        当前状态 = reinterpret_cast<状态节点类*>(任务->主信息.结果状态信息.指针);
    }
    if (!目标状态 && 任务) {
        目标状态 = reinterpret_cast<状态节点类*>(任务->主信息.目标状态.指针);
    }

    if (当前状态) {
        消息.需求当前状态指针 =
            reinterpret_cast<std::uintptr_t>(当前状态);
        消息.需求当前状态主键 = 当前状态->获取主键();
    }
    if (目标状态) {
        消息.需求目标状态指针 =
            reinterpret_cast<std::uintptr_t>(目标状态);
        消息.需求目标状态主键 = 目标状态->获取主键();
    }

    const auto* 需求特征类型 = 私有_状态特征类型词(
        目标状态 ? 目标状态 : 当前状态);
    if (!需求特征类型) {
        return;
    }
    消息.需求特征类型指针 = reinterpret_cast<std::uintptr_t>(需求特征类型);
    消息.需求特征类型主键 = 需求特征类型->获取主键();
    if (消息.主观察特征.empty()) {
        消息.主观察特征 = 语素集.获取词(需求特征类型);
    }
}

void 私有_填充派生需求父需求字段(
    结构_任务管理派生需求消息& 消息,
    const 任务节点* 任务) noexcept
{
    auto* 父需求 = 任务
        ? reinterpret_cast<需求节点*>(任务->主信息.对应需求.指针)
        : nullptr;
    auto* 来源需求 = 任务
        ? reinterpret_cast<需求节点*>(任务->主信息.来源需求.指针)
        : nullptr;
    if ((!父需求 || 父需求->父 == nullptr)
        && 来源需求
        && 来源需求->父 != nullptr) {
        父需求 = 来源需求;
    }
    if (!父需求) {
        return;
    }
    消息.父需求指针 = reinterpret_cast<std::uintptr_t>(父需求);
    消息.父需求主键 = 私有_需求主键(父需求);
}

bool 私有_状态特征类型文本是(
    const 状态节点类* 状态,
    const char* 文本) noexcept
{
    if (!状态 || !文本) {
        return false;
    }
    const auto* 特征类型 = 私有_状态特征类型词(状态);
    return 特征类型 && 语素集.获取词(特征类型) == 文本;
}

bool 私有_缺方法应派生需求(
    const 任务节点* 任务,
    const 结构_执行任务结果& 执行结果) noexcept
{
    (void)执行结果;
    auto* 来源需求 = 任务
        ? reinterpret_cast<需求节点*>(任务->主信息.对应需求.指针)
        : nullptr;
    if (!来源需求 && 任务) {
        来源需求 = reinterpret_cast<需求节点*>(任务->主信息.来源需求.指针);
    }
    auto* 目标状态 = 任务
        ? reinterpret_cast<状态节点类*>(任务->主信息.目标状态.指针)
        : nullptr;
    if ((!目标状态 || 私有_状态特征类型文本是(目标状态, "目标方法数量"))
        && 来源需求) {
        目标状态 = 来源需求->主信息.需求状态.指针;
    }
    return 私有_状态特征类型文本是(目标状态, "方法是否可用")
        || 私有_状态特征类型文本是(目标状态, "方法结构是否完整")
        || 私有_状态特征类型文本是(目标状态, "方法结果节点数量");
}

方法节点* 私有_缺方法直接生成方法头(
    任务节点* 任务,
    const 结构_执行任务结果& 执行结果,
    const 时间戳 now) noexcept
{
    auto* 自我存在 = 世界树.自我指针 ? 世界树.自我指针 : 世界树.取或创建自我存在();
    auto* 方法根节点 = 自我存在
        ? reinterpret_cast<方法节点*>(世界树.存在().获取方法根节点(自我存在))
        : nullptr;
    if (!方法根节点) {
        return nullptr;
    }

    auto* 来源需求 = 任务
        ? reinterpret_cast<需求节点*>(任务->主信息.对应需求.指针)
        : nullptr;
    if (!来源需求 && 任务) {
        来源需求 = reinterpret_cast<需求节点*>(任务->主信息.来源需求.指针);
    }

    auto* 目标状态 = 任务
        ? reinterpret_cast<状态节点类*>(任务->主信息.目标状态.指针)
        : nullptr;
    if ((!目标状态 || 私有_状态特征类型文本是(目标状态, "目标方法数量"))
        && 来源需求) {
        目标状态 = 来源需求->主信息.需求状态.指针;
    }
    const auto* 目标特征类型 = 私有_状态特征类型词(目标状态);
    if (!目标特征类型) {
        return nullptr;
    }

    二次特征节点类* 需求方向 = nullptr;
    if (来源需求 && 来源需求->父 != nullptr) {
        需求类 需求服务{};
        需求方向 = 需求服务.获取需求方向(来源需求);
    }
    if (!需求方向) {
        return nullptr;
    }

    auto* 方法头 = 方法类::注册需求方向方法首节点(
        方法根节点,
        目标特征类型,
        需求方向,
        枚举_方法来源::运行时学习沉淀,
        now,
        "任务管理工作线程::缺方法直接生成方法头");
    if (方法头 && 任务) {
        私有_写入方法节点引用(任务->主信息.候选方法首节点, 方法头);
        if (!任务->主信息.执行方法.有效()) {
            私有_写入方法节点引用(任务->主信息.执行方法, 方法头);
        }
        私有_写入任务节点引用(方法头->主信息.来源任务, 任务);
    }
    return 方法头;
}

结构_任务管理上行消息 私有_构造补方法派生需求消息(
    const 任务节点* 任务,
    const 结构_执行任务结果& 执行结果,
    const 时间戳 now) noexcept
{
    结构_任务管理派生需求消息 消息{};
    const auto 任务主键 = 私有_任务主键(任务);
    const auto 步骤主键 = 私有_任务主键(执行结果.任务执行结果.当前步骤节点);
    消息.消息头.发出者主键 = "任务管理界面线程";
    消息.消息头.任务主键 = 任务主键;
    消息.消息头.步骤主键 = 步骤主键.empty() ? 任务主键 : 步骤主键;
    消息.消息头.产生时间 = now;
    消息.消息头.执行尝试主键 = 任务主键 + "|补方法";
    消息.当前方法主键 = 执行结果.任务执行结果.当前方法
        ? 执行结果.任务执行结果.当前方法->获取主键()
        : std::string{};
    消息.派生需求类型 = 枚举_任务管理派生需求类型::缺方法;
    消息.方法需求位 = "补方法";
    消息.阻塞级别 = 枚举_任务管理阻塞级别::严重;
    消息.是否阻塞当前步骤 = true;
    消息.是否影响父任务推进 = true;
    消息.是否建议线程重判 = true;
    消息.当前等待原因 = !执行结果.任务执行结果.方法运行说明.empty()
        ? 执行结果.任务执行结果.方法运行说明
        : std::string("方法不可用，需要派生补方法需求");
    auto* 当前方法 = 执行结果.任务执行结果.当前方法;
    if (auto* 方法虚拟存在 = 当前方法 ? 当前方法->主信息.方法虚拟存在.指针 : nullptr) {
        消息.方法虚拟存在指针 = reinterpret_cast<std::uintptr_t>(方法虚拟存在);
        消息.方法虚拟存在主键 = 方法虚拟存在->获取主键();
    }
    私有_填充派生需求父需求字段(消息, 任务);
    私有_填充派生需求状态字段(消息, 任务);

    结构_任务管理上行消息 上行{};
    上行.类型 = 枚举_任务管理上行消息类型::派生需求消息;
    上行.载荷 = 消息;
    同步任务管理上行消息语义槽(上行);
    return 上行;
}

结构_任务管理上行消息 私有_构造补条件派生需求消息(
    const 任务节点* 任务,
    const 结构_执行任务结果& 执行结果,
    const 时间戳 now) noexcept
{
