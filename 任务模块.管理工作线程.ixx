namespace {

using 任务节点 = 任务类::节点类;
using 方法节点 = 方法类::节点类;
using 需求节点 = 需求类::节点类;

template<class T节点>
bool 私有_节点属于独立树_工作线程(const T节点* 根节点, const T节点* 候选节点) noexcept
{
    if (!根节点 || !候选节点) {
        return false;
    }
    if (根节点 == 候选节点) {
        return true;
    }
    for (auto* 当前节点 = reinterpret_cast<const T节点*>(根节点->链下);
         当前节点 && 当前节点 != 根节点;
         当前节点 = reinterpret_cast<const T节点*>(当前节点->链下)) {
        if (当前节点 == 候选节点) {
            return true;
        }
    }
    return false;
}

inline std::string 私有_安全词_工作线程(const 词性节点类* 词) noexcept
{
    if (!词) {
        return {};
    }
    const auto* 语素根 = reinterpret_cast<const 词性节点类*>(语素集.根指针);
    if (!私有_节点属于独立树_工作线程(语素根, 词)) {
        return {};
    }
    try {
        return 语素集.获取词(词);
    }
    catch (...) {
        return {};
    }
}

inline 任务节点* 私有_按主键解析任务节点_工作线程(const std::string& 主键) noexcept
{
    if (主键.empty()) {
        return nullptr;
    }
    return reinterpret_cast<任务节点*>(世界树.基础信息().查找主键(主键));
}

inline 任务节点* 私有_从任务引用解析任务节点_工作线程(
    可解析引用<任务节点类>& 引用) noexcept
{
    if (!引用.主键.empty()) {
        if (auto* 节点 = 私有_按主键解析任务节点_工作线程(引用.主键)) {
            引用.指针 = reinterpret_cast<任务节点类*>(节点);
            return 节点;
        }
        引用.指针 = nullptr;
        return nullptr;
    }
    return reinterpret_cast<任务节点*>(引用.指针);
}

inline 任务节点* 私有_从任务引用解析任务节点_工作线程(
    const 可解析引用<任务节点类>& 引用) noexcept
{
    return !引用.主键.empty()
        ? 私有_按主键解析任务节点_工作线程(引用.主键)
        : reinterpret_cast<任务节点*>(引用.指针);
}

inline 需求节点* 私有_按主键解析需求节点_工作线程(const std::string& 主键) noexcept
{
    if (主键.empty()) {
        return nullptr;
    }
    return reinterpret_cast<需求节点*>(世界树.基础信息().查找主键(主键));
}

inline 需求节点* 私有_从需求引用解析需求节点_工作线程(
    可解析引用<需求节点类>& 引用) noexcept
{
    if (!引用.主键.empty()) {
        if (auto* 节点 = 私有_按主键解析需求节点_工作线程(引用.主键)) {
            引用.指针 = reinterpret_cast<需求节点类*>(节点);
            return 节点;
        }
        引用.指针 = nullptr;
        return nullptr;
    }
    return reinterpret_cast<需求节点*>(引用.指针);
}

inline 需求节点* 私有_从需求引用解析需求节点_工作线程(
    const 可解析引用<需求节点类>& 引用) noexcept
{
    return !引用.主键.empty()
        ? 私有_按主键解析需求节点_工作线程(引用.主键)
        : reinterpret_cast<需求节点*>(引用.指针);
}

template<class T节点>
bool 私有_节点位于父链_工作线程(const T节点* 祖先, const T节点* 节点) noexcept
{
    auto* 当前 = 节点;
    while (当前) {
        if (当前 == 祖先) {
            return true;
        }
        当前 = reinterpret_cast<const T节点*>(当前->父);
    }
    return false;
}

template<class T节点, class T谓词>
T节点* 私有_查找直接子节点_按谓词(T节点* 父节点, T谓词&& 谓词) noexcept
{
    if (!父节点 || !父节点->子) {
        return nullptr;
    }

    auto* 首节点 = reinterpret_cast<T节点*>(父节点->子);
    auto* 当前 = 首节点;
    do {
        if (当前 && 谓词(当前)) {
            return 当前;
        }
        当前 = reinterpret_cast<T节点*>(当前->下);
    } while (当前 && 当前 != 首节点);
    return nullptr;
}

inline 任务节点* 私有_归一到任务头结点_工作线程(任务节点* 节点) noexcept
{
    auto* 当前 = 节点;
    while (当前) {
        if (当前->主信息.节点种类 == 枚举_任务节点种类::头结点) {
            return 当前;
        }
        当前 = reinterpret_cast<任务节点*>(当前->父);
    }
    return nullptr;
}

inline bool 私有_任务状态已终结_工作线程(枚举_任务状态 状态) noexcept;

inline void 私有_写入任务节点引用_工作线程(
    可解析引用<任务节点类>& 输出,
    任务节点* 节点) noexcept
{
    输出.指针 = reinterpret_cast<任务节点类*>(节点);
    输出.主键 = 节点 ? 节点->获取主键() : std::string{};
}

inline bool 私有_任务节点引用已存在_工作线程(
    const std::vector<可解析引用<任务节点类>>& 列表,
    const 任务节点* 节点) noexcept
{
    if (!节点) {
        return false;
    }

    const auto 节点主键 = 节点->获取主键();
    return std::ranges::any_of(列表, [&](const auto& 项) {
        return 项.指针 == reinterpret_cast<const 任务节点类*>(节点)
            || (!项.主键.empty() && 项.主键 == 节点主键);
    });
}

inline void 私有_登记步骤前置任务_工作线程(
    任务节点* 步骤节点,
    任务节点* 前置任务头) noexcept
{
    if (!步骤节点
        || !前置任务头
        || 步骤节点->主信息.节点种类 != 枚举_任务节点种类::步骤节点) {
        return;
    }

    if (!私有_任务节点引用已存在_工作线程(步骤节点->主信息.并发前置任务头结点列表, 前置任务头)) {
        可解析引用<任务节点类> 引用{};
        私有_写入任务节点引用_工作线程(引用, 前置任务头);
        步骤节点->主信息.并发前置任务头结点列表.push_back(引用);
    }
    if (!步骤节点->主信息.当前前置任务头结点.有效()) {
        私有_写入任务节点引用_工作线程(步骤节点->主信息.当前前置任务头结点, 前置任务头);
    }
}

inline 任务节点* 私有_获取世界任务根_工作线程(const 自我类& 自我对象) noexcept
{
    auto* 自我存在 = 自我对象.获取自我存在();
    return 自我存在
        ? reinterpret_cast<任务节点*>(世界树.存在().获取任务根节点(自我存在))
        : nullptr;
}

inline bool 私有_任务头已直接挂到根链_工作线程(
    const 任务节点* 世界任务根,
    const 任务节点* 任务头) noexcept
{
    if (!世界任务根 || !任务头) {
        return false;
    }
    return 任务头 == 世界任务根
        || reinterpret_cast<const 任务节点*>(任务头->父) == 世界任务根;
}

inline void 私有_登记直属子任务_工作线程(
    任务节点* 父任务头,
    任务节点* 子任务头) noexcept
{
    if (!父任务头 || !子任务头) {
        return;
    }

    私有_写入任务节点引用_工作线程(子任务头->主信息.父任务, 父任务头);
    私有_写入任务节点引用_工作线程(子任务头->主信息.父任务头结点, 父任务头);
    if (!私有_任务节点引用已存在_工作线程(父任务头->主信息.直属子任务头结点列表, 子任务头)) {
        可解析引用<任务节点类> 引用{};
        私有_写入任务节点引用_工作线程(引用, 子任务头);
        父任务头->主信息.直属子任务头结点列表.push_back(引用);
    }
    if (!父任务头->主信息.当前子任务头结点.有效()) {
        私有_写入任务节点引用_工作线程(父任务头->主信息.当前子任务头结点, 子任务头);
    }
    子任务头->主信息.是否真根任务 = false;
}

inline 结构_任务根节点 私有_构造任务根节点_任务信息消息_工作线程(
    任务节点* 任务头,
    需求节点* 任务目标,
    const 时间戳 now) noexcept
{
    结构_任务根节点 结果{};
    结果.任务根ID = 任务头
        ? static_cast<std::uint64_t>(reinterpret_cast<std::uintptr_t>(任务头))
        : static_cast<std::uint64_t>(now);
    结果.来源需求指针 = reinterpret_cast<std::uintptr_t>(任务目标);
    结果.世界任务根指针 = reinterpret_cast<std::uintptr_t>(任务头);
    结果.父任务指针 = 0;
    结果.来源需求主键 = 任务目标 ? 任务目标->获取主键() : std::string{};
    结果.方向摘要 = "任务管理任务收到任务信息";
    结果.创建者 = "任务管理任务界面线程";
    结果.根约束摘要 = "允许普通推进";
    结果.初始授权等级 = 1;
    结果.只读 = true;
    return 结果;
}

inline 结构_任务控制态 私有_构造任务控制态_任务信息消息_工作线程(
    const 结构_任务根节点& 任务根节点,
    任务节点* 任务头) noexcept
{
    结构_任务控制态 结果{};
    结果.任务根ID = 任务根节点.任务根ID;
    结果.全局优先级 = 任务头 ? 任务头->主信息.调度优先级 : 0;
    if (结果.全局优先级 == 0 && 任务头) {
        结果.全局优先级 = 任务头->主信息.基准优先级 + 任务头->主信息.局部优先级偏移;
    }
    结果.时间预算_ms = 250;
    结果.资源预算 = 1;
    结果.控制摘要 = "任务管理任务收到任务信息，进入筹办再执行";
    结果.请求停止 = 任务头 && 私有_任务状态已终结_工作线程(任务头->主信息.状态);
    结果.队列状态 = 结果.请求停止
        ? 枚举_任务队列状态::已停止
        : 枚举_任务队列状态::可运行;
    return 结果;
}

inline 结构_任务局部运行态 私有_构造任务局部运行态_任务信息消息_工作线程(
    const 结构_任务根节点& 任务根节点,
    任务节点* 任务头) noexcept
{
    结构_任务局部运行态 结果{};
    结果.任务根ID = 任务根节点.任务根ID;
    结果.当前状态 = 任务头 && 私有_任务状态已终结_工作线程(任务头->主信息.状态)
        ? 枚举_任务局部运行状态::已停止
        : 枚举_任务局部运行状态::已受理;
    结果.当前等待原因.clear();
    结果.最近局部结果 = 0;
    结果.局部完成度 = 0;
    结果.局部运行摘要 = "任务管理任务已接收任务信息";
    return 结果;
}

inline 结构_任务控制事件 私有_构造控制事件_任务信息消息_工作线程(
    const 结构_任务控制态& 任务控制态) noexcept
{
    结构_任务控制事件 结果{};
    结果.任务根ID = 任务控制态.任务根ID;
    结果.优先级 = 任务控制态.全局优先级;
    结果.时间预算_ms = 任务控制态.时间预算_ms;
    结果.资源预算 = 任务控制态.资源预算;
    结果.摘要 = 任务控制态.控制摘要;
    结果.事件类型 = 任务控制态.请求停止
        ? 枚举_任务控制事件类型::停止
        : 枚举_任务控制事件类型::启动;
    return 结果;
}

inline bool 私有_任务状态已终结_工作线程(枚举_任务状态 状态) noexcept
{
    switch (状态) {
    case 枚举_任务状态::完成:
    case 枚举_任务状态::失败:
    case 枚举_任务状态::取消:
        return true;
    default:
        return false;
    }
}

inline bool 私有_任务状态可直接推进_工作线程(const 枚举_任务状态 状态) noexcept
{
    switch (状态) {
    case 枚举_任务状态::未启动:
    case 枚举_任务状态::就绪:
    case 枚举_任务状态::执行中:
    case 枚举_任务状态::运行中:
    case 枚举_任务状态::筹办中:
    case 枚举_任务状态::排队中:
    case 枚举_任务状态::待重筹办:
        return true;
    default:
        return false;
    }
}

enum class 枚举_任务来源根方向_工作线程 : std::uint8_t {
    未定义 = 0,
    安全 = 1,
    服务 = 2,
};

enum class 枚举_任务来源挂点层级_工作线程 : std::uint8_t {
    前置步骤 = 0,
    后续结果 = 1,
    未定义 = 2,
};

inline 需求节点* 私有_任务来源需求_工作线程(任务节点* 任务头) noexcept
{
    return 任务头 ? 私有_从需求引用解析需求节点_工作线程(任务头->主信息.来源需求) : nullptr;
}

inline 任务节点* 私有_任务来源步骤节点_工作线程(任务节点* 任务头) noexcept
{
    if (!任务头) {
        return nullptr;
    }

    if (auto* 来源步骤 = 私有_从任务引用解析任务节点_工作线程(任务头->主信息.来源父步骤节点);
        来源步骤 && 来源步骤->主信息.节点种类 == 枚举_任务节点种类::步骤节点) {
        return 来源步骤;
    }

    auto* 来源结果 = 私有_从任务引用解析任务节点_工作线程(任务头->主信息.来源父结果节点);
    if (!来源结果 || 来源结果->主信息.节点种类 != 枚举_任务节点种类::结果节点) {
        return nullptr;
    }

    auto* 来源步骤 = 私有_从任务引用解析任务节点_工作线程(来源结果->主信息.来源步骤节点);
    return 来源步骤 && 来源步骤->主信息.节点种类 == 枚举_任务节点种类::步骤节点
        ? 来源步骤
        : nullptr;
}

inline std::int32_t 私有_任务来源步骤序号_工作线程(任务节点* 任务头) noexcept
{
    auto* 来源步骤 = 私有_任务来源步骤节点_工作线程(任务头);
    return 来源步骤 && 来源步骤->主信息.步骤序号 > 0
        ? 来源步骤->主信息.步骤序号
        : (std::numeric_limits<std::int32_t>::max)();
}

inline 枚举_任务来源挂点层级_工作线程 私有_任务来源挂点层级_工作线程(任务节点* 任务头) noexcept
{
    if (!任务头) {
        return 枚举_任务来源挂点层级_工作线程::未定义;
    }
    if (auto* 来源步骤 = 私有_从任务引用解析任务节点_工作线程(任务头->主信息.来源父步骤节点);
        来源步骤 && 来源步骤->主信息.节点种类 == 枚举_任务节点种类::步骤节点) {
        return 枚举_任务来源挂点层级_工作线程::前置步骤;
    }
    if (auto* 来源结果 = 私有_从任务引用解析任务节点_工作线程(任务头->主信息.来源父结果节点);
        来源结果 && 来源结果->主信息.节点种类 == 枚举_任务节点种类::结果节点) {
        return 枚举_任务来源挂点层级_工作线程::后续结果;
    }
    return 枚举_任务来源挂点层级_工作线程::未定义;
}

inline 枚举_任务来源根方向_工作线程 私有_任务来源根方向_工作线程(
    const 自我类& 自我对象,
    任务节点* 任务头) noexcept
{
    auto* 来源需求 = 私有_任务来源需求_工作线程(任务头);
    if (!来源需求) {
        return 枚举_任务来源根方向_工作线程::未定义;
    }
    if (auto* 安全根需求 = 自我对象.获取安全根需求();
        安全根需求 && 私有_节点位于父链_工作线程(安全根需求, 来源需求)) {
        return 枚举_任务来源根方向_工作线程::安全;
    }
    if (auto* 服务根需求 = 自我对象.获取服务根需求();
        服务根需求 && 私有_节点位于父链_工作线程(服务根需求, 来源需求)) {
        return 枚举_任务来源根方向_工作线程::服务;
    }
    return 枚举_任务来源根方向_工作线程::未定义;
}

inline bool 私有_文本带硬中断语义_工作线程(const std::string& 文本) noexcept
{
    return !文本.empty()
        && (文本.find("硬中断") != std::string::npos
            || 文本.find("请求打断") != std::string::npos
            || 文本.find("请求停止") != std::string::npos);
}

inline bool 私有_任务属于硬中断任务_工作线程(任务节点* 任务头) noexcept
{
    if (!任务头) {
        return false;
    }
    if (私有_文本带硬中断语义_工作线程(私有_安全词_工作线程(任务头->主信息.名称))
        || 私有_文本带硬中断语义_工作线程(私有_安全词_工作线程(任务头->主信息.类型))) {
        return true;
    }
    auto* 来源需求 = 私有_任务来源需求_工作线程(任务头);
    return 来源需求
        && 私有_文本带硬中断语义_工作线程(私有_安全词_工作线程(来源需求->主信息.类型));
}

inline bool 私有_任务当前可执行_工作线程(任务节点* 任务头) noexcept
{
    if (!任务头 || 任务头->主信息.节点种类 != 枚举_任务节点种类::头结点) {
        return false;
    }
    if (私有_任务状态已终结_工作线程(任务头->主信息.状态)) {
        return false;
    }
    if (auto* 当前步骤 = 私有_从任务引用解析任务节点_工作线程(任务头->主信息.当前步骤节点);
        当前步骤 && 当前步骤->主信息.节点种类 == 枚举_任务节点种类::步骤节点) {
        if (!私有_任务状态已终结_工作线程(当前步骤->主信息.状态)) {
            return 私有_任务状态可直接推进_工作线程(当前步骤->主信息.状态);
        }
    }
    return 私有_任务状态可直接推进_工作线程(任务头->主信息.状态);
}

inline bool 私有_任务头结点位于父任务链_工作线程(const 任务节点* 祖先任务头, const 任务节点* 任务头) noexcept
{
    auto* 当前 = 任务头;
    while (当前) {
        if (当前 == 祖先任务头) {
            return true;
        }
        当前 = 私有_从任务引用解析任务节点_工作线程(当前->主信息.父任务头结点);
    }
    return false;
}

inline std::int64_t 私有_任务基础调度优先级_工作线程(任务节点* 任务头) noexcept
{
    if (!任务头) {
        return (std::numeric_limits<std::int64_t>::min)();
    }
    auto* 来源需求 = 私有_任务来源需求_工作线程(任务头);
    const std::int64_t 来源需求优先级 =
        来源需求
        ? (来源需求->主信息.服务权重 != 0
            ? 来源需求->主信息.服务权重
            : 来源需求->主信息.安全权重)
        : 0;
    const std::int64_t 基准优先级 =
        来源需求优先级 != 0
        ? 来源需求优先级
        : 任务头->主信息.基准优先级;
    任务头->主信息.基准优先级 = 基准优先级;
    任务头->主信息.调度优先级 = 基准优先级 + 任务头->主信息.局部优先级偏移;
    return 任务头->主信息.调度优先级;
}

inline bool 私有_任务界面优先级更高_工作线程(
    const 自我类& 自我对象,
    任务节点* 候选,
    任务节点* 当前最佳,
    任务节点* 当前主任务) noexcept
{
    if (!候选) {
        return false;
    }
    if (!当前最佳) {
        return true;
    }

    const bool 候选为硬中断任务 = 私有_任务属于硬中断任务_工作线程(候选);
    const bool 当前最佳为硬中断任务 = 私有_任务属于硬中断任务_工作线程(当前最佳);
    if (候选为硬中断任务 != 当前最佳为硬中断任务) {
        return 候选为硬中断任务;
    }

    const bool 候选可执行 = 私有_任务当前可执行_工作线程(候选);
    const bool 当前最佳可执行 = 私有_任务当前可执行_工作线程(当前最佳);
    if (候选可执行 != 当前最佳可执行) {
        return 候选可执行;
    }

    const bool 候选是当前最佳子任务 = 私有_任务头结点位于父任务链_工作线程(当前最佳, 候选);
    const bool 当前最佳是候选子任务 = 私有_任务头结点位于父任务链_工作线程(候选, 当前最佳);
    if (候选是当前最佳子任务 != 当前最佳是候选子任务) {
        return 候选是当前最佳子任务;
    }

    const auto 候选来源步骤序号 = 私有_任务来源步骤序号_工作线程(候选);
    const auto 当前最佳来源步骤序号 = 私有_任务来源步骤序号_工作线程(当前最佳);
    const bool 两侧都有步骤来源 =
        候选来源步骤序号 != (std::numeric_limits<std::int32_t>::max)()
        && 当前最佳来源步骤序号 != (std::numeric_limits<std::int32_t>::max)();
    if (两侧都有步骤来源 && 候选来源步骤序号 != 当前最佳来源步骤序号) {
        return 候选来源步骤序号 < 当前最佳来源步骤序号;
    }

    if (两侧都有步骤来源) {
        const auto 候选挂点层级 = 私有_任务来源挂点层级_工作线程(候选);
        const auto 当前最佳挂点层级 = 私有_任务来源挂点层级_工作线程(当前最佳);
        if (候选挂点层级 != 当前最佳挂点层级) {
            return 候选挂点层级 < 当前最佳挂点层级;
        }
    }

    const auto 候选来源根方向 = 私有_任务来源根方向_工作线程(自我对象, 候选);
    const auto 当前最佳来源根方向 = 私有_任务来源根方向_工作线程(自我对象, 当前最佳);
    const bool 一侧安全一侧服务 =
        (候选来源根方向 == 枚举_任务来源根方向_工作线程::安全
            && 当前最佳来源根方向 == 枚举_任务来源根方向_工作线程::服务)
        || (候选来源根方向 == 枚举_任务来源根方向_工作线程::服务
            && 当前最佳来源根方向 == 枚举_任务来源根方向_工作线程::安全);
    if (一侧安全一侧服务) {
        return 候选来源根方向 == 枚举_任务来源根方向_工作线程::安全;
    }

    const auto 候选优先级 = 私有_任务基础调度优先级_工作线程(候选);
    const auto 当前最佳优先级 = 私有_任务基础调度优先级_工作线程(当前最佳);
    if (候选优先级 != 当前最佳优先级) {
        return 候选优先级 > 当前最佳优先级;
    }

    if (候选 == 当前主任务 && 当前最佳 != 当前主任务) {
        return true;
    }
    if (当前最佳 == 当前主任务 && 候选 != 当前主任务) {
        return false;
    }
    if (候选->主信息.创建时间 != 当前最佳->主信息.创建时间) {
        return 候选->主信息.创建时间 < 当前最佳->主信息.创建时间;
    }
    return 候选->获取主键() < 当前最佳->获取主键();
}

inline 任务节点* 私有_取步骤结果节点_工作线程(任务节点* 步骤节点) noexcept
{
    if (!步骤节点 || 步骤节点->主信息.节点种类 != 枚举_任务节点种类::步骤节点) {
        return nullptr;
    }

    if (auto* 结果节点 = reinterpret_cast<任务节点*>(步骤节点->主信息.后续任务.指针);
        结果节点 && 结果节点->主信息.节点种类 == 枚举_任务节点种类::结果节点) {
        return 结果节点;
    }

    return 私有_查找直接子节点_按谓词<任务节点>(步骤节点, [](const 任务节点* 节点) noexcept {
        return 节点 && 节点->主信息.节点种类 == 枚举_任务节点种类::结果节点;
    });
}

inline 任务节点* 私有_取结果下一跳步骤_工作线程(任务节点* 结果节点) noexcept
{
    if (!结果节点 || 结果节点->主信息.节点种类 != 枚举_任务节点种类::结果节点) {
        return nullptr;
    }

    if (auto* 下一跳步骤 = reinterpret_cast<任务节点*>(结果节点->主信息.下一跳步骤节点.指针);
        下一跳步骤 && 下一跳步骤->主信息.节点种类 == 枚举_任务节点种类::步骤节点) {
        return 下一跳步骤;
    }

    return 私有_查找直接子节点_按谓词<任务节点>(结果节点, [](const 任务节点* 节点) noexcept {
        return 节点 && 节点->主信息.节点种类 == 枚举_任务节点种类::步骤节点;
    });
}

inline std::uint32_t 私有_读取方法本能ID_工作线程(const 方法节点* 方法) noexcept
{
    if (!方法 || 方法->主信息.动作句柄.类型 != 枚举_动作句柄类型::本能函数ID) {
        return 0;
    }
    return static_cast<std::uint32_t>(方法->主信息.动作句柄.本能ID);
}

inline bool 私有_方法已有结果节点_工作线程(const 方法节点* 方法) noexcept
{
    if (!方法 || !方法->子) {
        return false;
    }
    auto* 首节点 = reinterpret_cast<方法节点*>(方法->子);
    auto* 当前 = 首节点;
    do {
        if (当前 && 当前->主信息.节点种类 == 枚举_方法节点种类::方法结果节点) {
            return true;
        }
        当前 = reinterpret_cast<方法节点*>(当前->下);
    } while (当前 && 当前 != 首节点);
    return false;
}

inline 方法节点* 私有_等待学习目标方法_工作线程(任务节点* 宿主任务) noexcept
{
    if (!宿主任务) {
        return nullptr;
    }
    if (auto* 目标方法 = reinterpret_cast<方法节点*>(宿主任务->主信息.等待学习方法首节点.指针)) {
        return 目标方法;
    }
    if (auto* 当前步骤 = reinterpret_cast<任务节点*>(宿主任务->主信息.当前步骤节点.指针)) {
        if (auto* 方法 = reinterpret_cast<方法节点*>(当前步骤->主信息.执行方法.指针)) {
            return 方法;
        }
        return reinterpret_cast<方法节点*>(当前步骤->主信息.可用方法首节点.指针);
    }
    return nullptr;
}

inline bool 私有_学习对象已可用_工作线程(任务节点* 宿主任务) noexcept
{
    return 私有_方法已有结果节点_工作线程(私有_等待学习目标方法_工作线程(宿主任务));
}

inline 方法节点* 私有_确保本能方法头_工作线程(
    自我类& 自我对象,
    const std::uint32_t 本能ID,
    const 时间戳 now,
    const std::string& 调用点) noexcept
{
    auto* 自我存在 = 自我对象.确保自我存在(调用点 + "/自我存在");
    if (!自我存在) {
        return nullptr;
    }
    return 方法类::查找或创建_本能方法首节点(
        自我存在,
        static_cast<枚举_本能方法ID>(本能ID),
        now,
        调用点 + "/本能方法头");
}

inline std::uint32_t 私有_推导下一本能ID_工作线程(
    任务节点* 宿主任务,
    任务节点* 当前步骤,
    const 结构_任务步骤执行结果_最小* 执行结果 = nullptr) noexcept
{
    if (!宿主任务 || 宿主任务->主信息.状态 == 枚举_任务状态::完成) {
        return 0;
    }

    const auto 当前本能ID = 私有_读取方法本能ID_工作线程(
        当前步骤
            ? reinterpret_cast<方法节点*>(当前步骤->主信息.执行方法.指针)
            : nullptr);
    const auto 成功码 = 执行结果 ? 执行结果->方法执行结果.成功码 : 0;

    if (!当前步骤) {
        return 6037U;
    }

    switch (当前本能ID) {
    case 6037U:
        if (成功码 == 本能方法结果_任务筹办已激活学习任务) {
            return 6039U;
        }
        if (成功码 == 本能方法结果_任务筹办已建立方法头待重入) {
            return 6037U;
        }
        return 6038U;
    case 6038U:
        if (成功码 == 本能方法结果_任务执行一步已激活学习任务) {
            return 6039U;
        }
        if (成功码 == 本能方法结果_任务执行一步已建立方法头待重入) {
            return 6038U;
        }
        return 宿主任务->主信息.状态 == 枚举_任务状态::完成 ? 0U : 6037U;
    case 6039U:
        if (!私有_学习对象已可用_工作线程(宿主任务)) {
            return 6039U;
        }
        if (const auto* 目标方法 = 私有_等待学习目标方法_工作线程(宿主任务)) {
            const auto 目标本能ID = 私有_读取方法本能ID_工作线程(目标方法);
            if (目标本能ID == 6037U) {
                return 6037U;
            }
            if (目标本能ID == 6038U) {
                return 6038U;
            }
        }
        return 6037U;
    default:
        return 6037U;
    }
}

inline void 私有_规范本能执行后的状态_工作线程(
    任务节点* 宿主任务,
    任务节点* 当前步骤,
    任务节点* 当前结果,
    const std::uint32_t 当前本能ID,
    const 结构_任务步骤执行结果_最小& 执行结果,
    const 时间戳 now) noexcept
{
    if (!宿主任务 || !当前步骤) {
        return;
    }

    const auto 成功码 = 执行结果.方法执行结果.成功码;
    const bool 学习对象可用 =
        当前本能ID == 6039U
        && 执行结果.方法执行结果.质量_Q10000 >= 10000
        && 私有_学习对象已可用_工作线程(宿主任务);
    const bool 学习仍未可用 =
        当前本能ID == 6039U && !学习对象可用;

    if (成功码 == 本能方法结果_任务筹办已建立方法头待重入
        || 成功码 == 本能方法结果_任务执行一步已建立方法头待重入) {
        宿主任务->主信息.状态 = 枚举_任务状态::筹办中;
        当前步骤->主信息.状态 = 枚举_任务状态::完成;
        if (当前结果) {
            当前结果->主信息.状态 = 枚举_任务状态::完成;
            当前结果->主信息.完成时间 = now;
        }
        宿主任务->主信息.完成时间 = 0;
        return;
    }

    if (成功码 == 本能方法结果_任务筹办已激活学习任务
        || 成功码 == 本能方法结果_任务执行一步已激活学习任务
        || 成功码 == 本能方法结果_学习任务已建立任务头待重入
        || 学习仍未可用) {
        宿主任务->主信息.状态 = 枚举_任务状态::等待中;
        当前步骤->主信息.状态 = 枚举_任务状态::挂起;
        if (当前结果) {
            当前结果->主信息.状态 = 枚举_任务状态::挂起;
            当前结果->主信息.完成时间 = now;
        }
        宿主任务->主信息.完成时间 = 0;
        return;
    }

    if (学习对象可用) {
        当前步骤->主信息.状态 = 枚举_任务状态::完成;
        if (当前结果) {
            当前结果->主信息.状态 = 枚举_任务状态::完成;
            当前结果->主信息.完成时间 = now;
        }
        if (宿主任务->主信息.状态 != 枚举_任务状态::完成) {
            宿主任务->主信息.状态 = 枚举_任务状态::筹办中;
            宿主任务->主信息.完成时间 = 0;
        }
    }
}

struct 结构_工作线程壳请求 {
    自我类* 自我对象 = nullptr;
    结构_任务根节点 任务根节点{};
    结构_任务控制态 任务控制态{};
    结构_任务局部运行态 任务局部运行态{};
    时间戳 now = 0;
    结构_任务控制事件 控制事件{};
    枚举_任务管理根层重判结果 根层重判结果 = 枚举_任务管理根层重判结果::未定义;
    枚举_任务管理执行前门控结果 执行前门控结果 = 枚举_任务管理执行前门控结果::未定义;
    std::string 上层反馈特征键{};
    std::string 调用点{};
    bool 存在正式任务管理请求 = false;
    结构_任务管理请求 正式任务管理请求{};
    std::promise<任务管理工作线程::结构_工作线程推进响应> 完成承诺{};
};

struct 结构_工作线程壳状态 {
    std::mutex 锁{};
    std::condition_variable 条件{};
    bool 已启动 = false;
    bool 停止请求 = false;
    bool 正在执行 = false;
    std::deque<std::unique_ptr<结构_工作线程壳请求>> 队列{};
    std::deque<任务管理工作线程::结构_工作线程界面回报记录> 界面回报列表{};
    std::thread 线程{};
    任务管理工作线程::结构_工作线程实例快照 快照{};
};

inline 结构_工作线程壳状态& 私有_任务管理工作线程壳() noexcept
{
    static 结构_工作线程壳状态 壳{};
    return 壳;
}

inline std::string 私有_工作线程请求宿主主键(const 结构_任务管理请求& 请求) noexcept
{
    if (请求.宿主任务) {
        return 请求.宿主任务->获取主键();
    }
    if (请求.上下文.当前宿主任务) {
        return 请求.上下文.当前宿主任务->获取主键();
    }
    return {};
}

inline const char* 私有_工作线程下一步去向文本(枚举_任务管理下一步去向 去向) noexcept
{
    switch (去向) {
    case 枚举_任务管理下一步去向::回到重筹办: return "回到重筹办";
    case 枚举_任务管理下一步去向::绑定方法: return "绑定方法";
    case 枚举_任务管理下一步去向::进入运行: return "进入运行";
    case 枚举_任务管理下一步去向::保持运行: return "保持运行";
    case 枚举_任务管理下一步去向::保持等待: return "保持等待";
    case 枚举_任务管理下一步去向::进入收束: return "进入收束";
    default: return "未定义";
    }
}

inline const char* 私有_工作线程总控结果文本(枚举_任务管理总控结果 结果) noexcept
{
    switch (结果) {
    case 枚举_任务管理总控结果::治理任务已补齐: return "治理任务已补齐";
    case 枚举_任务管理总控结果::宿主待重筹办: return "宿主待重筹办";
    case 枚举_任务管理总控结果::宿主已挂起: return "宿主已挂起";
    case 枚举_任务管理总控结果::宿主已进入运行: return "宿主已进入运行";
    case 枚举_任务管理总控结果::宿主保持运行: return "宿主保持运行";
    case 枚举_任务管理总控结果::宿主保持等待: return "宿主保持等待";
    case 枚举_任务管理总控结果::宿主进入收束: return "宿主进入收束";
    default: return "未定义";
    }
}

inline const char* 私有_工作线程特征值类型文本(const 特征值& 值) noexcept
{
    if (std::holds_alternative<std::monostate>(值)) {
        return "空";
    }
    if (std::holds_alternative<I64>(值)) {
        return "i64";
    }
    if (std::holds_alternative<VecU句柄>(值)) {
        return "VecU句柄";
    }
    if (std::holds_alternative<指针句柄>(值)) {
        return "指针句柄";
    }
    return "未定义";
}

inline std::string 私有_工作线程特征值文本(const 特征值& 值) noexcept
{
    if (std::holds_alternative<std::monostate>(值)) {
        return "空";
    }
    if (const auto* 标量 = std::get_if<I64>(&值)) {
        return std::to_string(*标量);
    }
    if (const auto* 向量句柄 = std::get_if<VecU句柄>(&值)) {
        return std::to_string(static_cast<std::uint64_t>(向量句柄->主信息指针));
    }
    if (const auto* 指针 = std::get_if<指针句柄>(&值)) {
        return std::to_string(static_cast<std::uint64_t>(指针->指针));
    }
    return "未定义";
}

inline std::string 私有_工作线程特征值差值文本(
    const 特征值& 前值,
    const 特征值& 后值) noexcept
{
    if (const auto* 前标量 = std::get_if<I64>(&前值)) {
        if (const auto* 后标量 = std::get_if<I64>(&后值)) {
            return std::to_string(*后标量 - *前标量);
        }
        if (std::holds_alternative<std::monostate>(后值)) {
            return std::to_string(-(*前标量));
        }
    }
    if (std::holds_alternative<std::monostate>(前值)) {
        if (const auto* 后标量 = std::get_if<I64>(&后值)) {
            return std::to_string(*后标量);
        }
        if (!std::holds_alternative<std::monostate>(后值)) {
            return "新增";
        }
    }
    if (!std::holds_alternative<std::monostate>(前值)
        && std::holds_alternative<std::monostate>(后值)) {
        return "清空";
    }
    if (前值 == 后值) {
        return "0";
    }
    return "不可计算";
}

inline void 私有_追加工作线程状态变化记录(
    std::vector<任务管理工作线程::结构_工作线程特征变化记录>* 输出,
    const std::string& 来源,
    const 结构_任务管理状态变化项& 变化项) noexcept
{
    if (!输出) {
        return;
    }
    任务管理工作线程::结构_工作线程特征变化记录 记录{};
    记录.来源 = 来源;
    记录.变化主体主键 = 变化项.变化主体主键;
    记录.变化主体类型摘要 = 变化项.变化主体类型摘要;
    记录.特征类型摘要 = 变化项.特征类型摘要;
    记录.特征标签 = 变化项.特征标签;
    记录.变化前值类型 = 私有_工作线程特征值类型文本(变化项.变化前值);
    记录.变化前值 = 私有_工作线程特征值文本(变化项.变化前值);
    记录.变化后值类型 = 私有_工作线程特征值类型文本(变化项.变化后值);
    记录.变化后值 = 私有_工作线程特征值文本(变化项.变化后值);
    记录.差值 = 私有_工作线程特征值差值文本(变化项.变化前值, 变化项.变化后值);
    记录.变化原因键 = 变化项.变化原因键;
    记录.已确认生效 = 变化项.已确认生效;
    记录.是否关键中间状态 = 变化项.是否关键中间状态;
    输出->push_back(std::move(记录));
}

inline void 私有_追加工作线程关键中间状态变化记录(
    std::vector<任务管理工作线程::结构_工作线程特征变化记录>* 输出,
    const 结构_任务管理关键中间状态变化项& 变化项) noexcept
{
    if (!输出) {
        return;
    }
    任务管理工作线程::结构_工作线程特征变化记录 记录{};
    记录.来源 = "关键中间状态";
    记录.变化主体主键 = 变化项.变化主体主键;
    记录.变化主体类型摘要 = 变化项.变化主体类型摘要;
    记录.特征类型摘要 = 变化项.特征类型摘要;
    记录.变化前值类型 = 私有_工作线程特征值类型文本(变化项.变化前值);
    记录.变化前值 = 私有_工作线程特征值文本(变化项.变化前值);
    记录.变化后值类型 = 私有_工作线程特征值类型文本(变化项.变化后值);
    记录.变化后值 = 私有_工作线程特征值文本(变化项.变化后值);
    记录.差值 = 私有_工作线程特征值差值文本(变化项.变化前值, 变化项.变化后值);
    记录.变化原因键 = 变化项.动作语义键;
    记录.已确认生效 = 变化项.已确认生效;
    记录.是否关键中间状态 = true;
    输出->push_back(std::move(记录));
}

inline void 私有_工作线程收集特征变化记录(
    const 任务管理工作线程::结构_工作线程推进响应& 响应,
    std::vector<任务管理工作线程::结构_工作线程特征变化记录>* 输出) noexcept
{
    if (!输出) {
        return;
    }
    输出->clear();
    constexpr std::size_t 私有_特征变化上限 = 24;
    for (const auto& 上行消息 : 响应.桥接结果.上行消息集) {
        if (const auto* 派生需求 =
                std::get_if<结构_任务管理派生需求消息>(&上行消息.载荷)) {
            for (const auto& 变化项 : 派生需求->局部状态变化集) {
                私有_追加工作线程状态变化记录(输出, "局部状态", 变化项);
                if (输出->size() >= 私有_特征变化上限) {
                    return;
                }
            }
            continue;
        }
        if (const auto* 结果状态 =
                std::get_if<结构_任务管理结果状态消息>(&上行消息.载荷)) {
            for (const auto& 变化项 : 结果状态->服务对象状态变化集) {
                私有_追加工作线程状态变化记录(输出, "服务对象状态", 变化项);
                if (输出->size() >= 私有_特征变化上限) {
                    return;
                }
            }
            for (const auto& 变化项 : 结果状态->关键中间状态变化集) {
                私有_追加工作线程关键中间状态变化记录(输出, 变化项);
                if (输出->size() >= 私有_特征变化上限) {
                    return;
                }
            }
        }
    }
}

inline bool 私有_工作线程存在现实世界因果缺口(
    const 任务管理工作线程::结构_工作线程桥接结果& 桥接结果) noexcept
{
    for (const auto& 上行消息 : 桥接结果.上行消息集) {
        if (const auto* 派生需求 =
                std::get_if<结构_任务管理派生需求消息>(&上行消息.载荷)) {
            if (派生需求->是否需要外部支撑) {
                return true;
            }
            if (派生需求->是否本地不可消化) {
                switch (派生需求->派生需求类型) {
                case 枚举_任务管理派生需求类型::缺资源:
                case 枚举_任务管理派生需求类型::缺确认:
                case 枚举_任务管理派生需求类型::缺信息:
                case 枚举_任务管理派生需求类型::风险处置:
                case 枚举_任务管理派生需求类型::异常恢复:
                case 枚举_任务管理派生需求类型::补偿动作:
                    return true;
                case 枚举_任务管理派生需求类型::缺方法:
                case 枚举_任务管理派生需求类型::未定义:
                default:
                    break;
                }
            }
        }
        if (const auto* 结果状态 =
                std::get_if<结构_任务管理结果状态消息>(&上行消息.载荷);
            结果状态 && 结果状态->是否需要外部支撑) {
            return true;
        }
    }
    return false;
}

inline bool 私有_工作线程存在虚拟存在因果缺口(
    const 任务管理工作线程::结构_工作线程推进响应& 响应) noexcept
{
    if (!响应.桥接结果.任务管理治理触发) {
        return true;
    }

    const auto& 治理结果 = 响应.桥接结果.治理结果;
    if (治理结果.当前下一步去向 == 枚举_任务管理下一步去向::保持等待
        || 治理结果.已上报学习需求
        || 治理结果.当前缺口类型 != 枚举_任务管理缺口类型::无缺口
        || 治理结果.当前步骤节点 == nullptr
        || 治理结果.当前一步结果.当前方法节点 == nullptr) {
        return true;
    }

    return 响应.最新任务局部运行态.当前状态 == 枚举_任务局部运行状态::等待条件;
}

inline std::string 私有_工作线程因果链状态文本(
    const 任务管理工作线程::结构_工作线程推进响应& 响应) noexcept
{
    const auto& 治理结果 = 响应.桥接结果.治理结果;
    if (治理结果.当前下一步去向 == 枚举_任务管理下一步去向::进入收束
        || 治理结果.最近总控结果 == 枚举_任务管理总控结果::宿主进入收束) {
        return "因果链已闭合";
    }
    if (私有_工作线程存在现实世界因果缺口(响应.桥接结果)) {
        return "因果链未成: 缺现实支撑";
    }
    if (私有_工作线程存在虚拟存在因果缺口(响应)) {
        return "因果链未成: 待筹办补链";
    }
    if (治理结果.当前步骤节点 != nullptr
        && 治理结果.当前一步结果.当前方法节点 != nullptr) {
        return "因果链已形成";
    }
    return "因果链待判定";
}

inline std::string 私有_工作线程缺口归类文本(
    const 任务管理工作线程::结构_工作线程推进响应& 响应) noexcept
{
    if (私有_工作线程存在现实世界因果缺口(响应.桥接结果)) {
        return "现实世界缺口";
    }
    if (私有_工作线程存在虚拟存在因果缺口(响应)) {
        return "虚拟存在缺口";
    }
    return "无显式缺口";
}

inline std::string 私有_工作线程筹办承接文本(
    const 任务管理工作线程::结构_工作线程推进响应& 响应) noexcept
{
    const auto& 治理结果 = 响应.桥接结果.治理结果;
    if (私有_工作线程存在现实世界因果缺口(响应.桥接结果)) {
        return "筹办外化现实支撑并上报自我线程";
    }
    if (私有_工作线程存在虚拟存在因果缺口(响应)) {
        return "筹办直接补齐因果链";
    }
    if (治理结果.当前下一步去向 == 枚举_任务管理下一步去向::进入收束) {
        return "无需筹办，进入收束";
    }
    return "继续执行当前链";
}

inline std::string 私有_工作线程等待原因文本(
    const 任务管理工作线程::结构_工作线程推进响应& 响应) noexcept
{
    const auto& 治理结果 = 响应.桥接结果.治理结果;
    if (!响应.桥接结果.任务管理治理触发) {
        return "当前无宿主任务";
    }
    if (治理结果.当前步骤节点 == nullptr) {
        return "当前无步骤";
    }
    if (治理结果.当前一步结果.当前方法节点 == nullptr) {
        return "当前无方法";
    }
    if (!响应.最新任务局部运行态.当前等待原因.empty()) {
        return 响应.最新任务局部运行态.当前等待原因;
    }
    return {};
}

inline void 私有_写入工作线程界面回报_已加锁(
    const 任务管理工作线程::结构_工作线程推进响应& 响应,
    const 结构_工作线程壳请求* 当前请求) noexcept
{
    auto& 壳 = 私有_任务管理工作线程壳();
    任务管理工作线程::结构_工作线程界面回报记录 记录{};
    记录.回报时间 = 当前请求 ? 当前请求->now : 0;
    记录.任务根ID = 当前请求 ? 当前请求->任务根节点.任务根ID : 0;
    if (当前请求 && 当前请求->存在正式任务管理请求) {
        记录.请求ID = 当前请求->正式任务管理请求.请求ID;
        记录.宿主任务主键 = 私有_工作线程请求宿主主键(当前请求->正式任务管理请求);
    }
    记录.步骤主键 =
        响应.桥接结果.治理结果.当前步骤节点
        ? 响应.桥接结果.治理结果.当前步骤节点->获取主键()
        : std::string{};
    记录.方法主键 =
        响应.桥接结果.治理结果.当前一步结果.当前方法节点
        ? reinterpret_cast<方法节点*>(响应.桥接结果.治理结果.当前一步结果.当前方法节点)->获取主键()
        : std::string{};
    记录.结果主键 =
        响应.桥接结果.治理结果.最新结果节点
        ? 响应.桥接结果.治理结果.最新结果节点->获取主键()
        : std::string{};
    记录.下一步去向 =
        私有_工作线程下一步去向文本(响应.桥接结果.治理结果.当前下一步去向);
    记录.总控结果 =
        私有_工作线程总控结果文本(响应.桥接结果.治理结果.最近总控结果);
    记录.因果链状态 = 私有_工作线程因果链状态文本(响应);
    记录.缺口归类 = 私有_工作线程缺口归类文本(响应);
    记录.筹办承接 = 私有_工作线程筹办承接文本(响应);
    记录.等待原因 = 私有_工作线程等待原因文本(响应);
    记录.推进事件数 = static_cast<std::uint64_t>(响应.桥接结果.推进事件列表.size());
    记录.上行消息数 = static_cast<std::uint64_t>(响应.桥接结果.上行消息集.size());
    私有_工作线程收集特征变化记录(响应, &记录.特征变化列表);

    壳.界面回报列表.push_front(std::move(记录));
    constexpr std::size_t 私有_界面回报上限 = 24;
    while (壳.界面回报列表.size() > 私有_界面回报上限) {
        壳.界面回报列表.pop_back();
    }
}

inline void 私有_更新工作线程壳快照_已加锁(
    const bool 已收到请求,
    const bool 正在执行,
    const std::uint64_t 最近任务根ID,
    const 时间戳 最近推进时间,
    const std::uint64_t 最近请求ID = 0,
    const std::string& 最近宿主任务主键 = {})
{
    auto& 壳 = 私有_任务管理工作线程壳();
    auto& 快照 = 壳.快照;
    快照.已启动 = 壳.已启动;
    快照.正在执行 = 正在执行;
    快照.已收到请求 = 已收到请求;
    快照.最近任务根ID = 最近任务根ID;
    快照.最近推进时间 = 最近推进时间;
    if (最近请求ID != 0) {
        快照.最近请求ID = 最近请求ID;
    }
    if (!最近宿主任务主键.empty()) {
        快照.最近宿主任务主键 = 最近宿主任务主键;
    }
    快照.当前排队数 = static_cast<std::uint64_t>(壳.队列.size());
}

inline void 私有_任务管理工作线程壳线程主体() noexcept
{
    auto& 壳 = 私有_任务管理工作线程壳();
    for (;;) {
        std::unique_ptr<结构_工作线程壳请求> 当前请求{};
        {
            std::unique_lock 锁(壳.锁);
            壳.条件.wait(
                锁,
                [&壳] { return 壳.停止请求 || !壳.队列.empty(); });
            if (壳.停止请求 && 壳.队列.empty()) {
                壳.正在执行 = false;
                私有_更新工作线程壳快照_已加锁(
                    false,
                    false,
                    壳.快照.最近任务根ID,
                    壳.快照.最近推进时间);
                return;
            }

            当前请求 = std::move(壳.队列.front());
            壳.队列.pop_front();
            壳.正在执行 = true;
            const auto 最近请求ID =
                当前请求 && 当前请求->存在正式任务管理请求
                ? 当前请求->正式任务管理请求.请求ID
                : 0;
            const auto 最近宿主任务主键 =
                当前请求 && 当前请求->存在正式任务管理请求
                ? 私有_工作线程请求宿主主键(当前请求->正式任务管理请求)
                : std::string{};
            私有_更新工作线程壳快照_已加锁(
                true,
                true,
                当前请求 ? 当前请求->任务根节点.任务根ID : 0,
                当前请求 ? 当前请求->now : 0,
                最近请求ID,
                最近宿主任务主键);
        }

        任务管理工作线程::结构_工作线程推进响应 响应{};
        if (当前请求 && 当前请求->自我对象) {
            响应.最新任务控制态 = 当前请求->任务控制态;
            响应.最新任务局部运行态 = 当前请求->任务局部运行态;
            响应.推进成功 = 任务管理工作线程::推进任务管理工作线程(
                *当前请求->自我对象,
                当前请求->任务根节点,
                &响应.最新任务控制态,
                &响应.最新任务局部运行态,
                当前请求->now,
                当前请求->控制事件,
                当前请求->根层重判结果,
                当前请求->执行前门控结果,
                当前请求->上层反馈特征键,
                当前请求->调用点,
                &响应.桥接结果,
                当前请求->存在正式任务管理请求 ? &当前请求->正式任务管理请求 : nullptr);
        }

        {
            std::lock_guard 锁(壳.锁);
            壳.正在执行 = false;
            ++壳.快照.累计推进次数;
            壳.快照.最近一次上行消息数 =
                static_cast<std::uint64_t>(响应.桥接结果.上行消息集.size());
            壳.快照.累计发送上行消息数 += 壳.快照.最近一次上行消息数;
            if (响应.桥接结果.已执行学习任务) {
                ++壳.快照.累计学习执行次数;
            }
            私有_写入工作线程界面回报_已加锁(响应, 当前请求.get());
            壳.快照.最近步骤主键 =
                响应.桥接结果.治理结果.当前步骤节点
                ? 响应.桥接结果.治理结果.当前步骤节点->获取主键()
                : std::string{};
            壳.快照.最近方法主键 =
                响应.桥接结果.治理结果.当前一步结果.当前方法节点
                ? reinterpret_cast<方法节点*>(响应.桥接结果.治理结果.当前一步结果.当前方法节点)->获取主键()
                : std::string{};
            壳.快照.最近结果主键 =
                响应.桥接结果.治理结果.最新结果节点
                ? 响应.桥接结果.治理结果.最新结果节点->获取主键()
                : std::string{};
            壳.快照.最近下一步去向 =
                私有_工作线程下一步去向文本(响应.桥接结果.治理结果.当前下一步去向);
            壳.快照.最近总控结果 =
                私有_工作线程总控结果文本(响应.桥接结果.治理结果.最近总控结果);
            壳.快照.最近因果链状态 = 私有_工作线程因果链状态文本(响应);
            壳.快照.最近缺口归类 = 私有_工作线程缺口归类文本(响应);
            壳.快照.最近筹办承接 = 私有_工作线程筹办承接文本(响应);
            壳.快照.最近等待原因 = 私有_工作线程等待原因文本(响应);
            壳.快照.最近特征变化数 =
                壳.界面回报列表.empty()
                ? 0
                : static_cast<std::uint64_t>(壳.界面回报列表.front().特征变化列表.size());
            const auto 最近请求ID =
                当前请求 && 当前请求->存在正式任务管理请求
                ? 当前请求->正式任务管理请求.请求ID
                : 0;
            const auto 最近宿主任务主键 =
                当前请求 && 当前请求->存在正式任务管理请求
                ? 私有_工作线程请求宿主主键(当前请求->正式任务管理请求)
                : std::string{};
            私有_更新工作线程壳快照_已加锁(
                true,
                false,
                当前请求 ? 当前请求->任务根节点.任务根ID : 0,
                当前请求 ? 当前请求->now : 0,
                最近请求ID,
                最近宿主任务主键);
        }

        if (当前请求) {
            当前请求->完成承诺.set_value(std::move(响应));
        }
    }
}

inline bool 私有_确保任务管理工作线程壳已启动() noexcept
{
    auto& 壳 = 私有_任务管理工作线程壳();
    std::lock_guard 锁(壳.锁);
    if (壳.已启动) {
        return true;
    }

    try {
        壳.停止请求 = false;
        壳.正在执行 = false;
        壳.线程 = std::thread(私有_任务管理工作线程壳线程主体);
        壳.已启动 = true;
        私有_更新工作线程壳快照_已加锁(
            false,
            false,
            0,
            0);
        return true;
    } catch (...) {
        壳.已启动 = false;
        私有_更新工作线程壳快照_已加锁(
            false,
            false,
            0,
            0);
        return false;
    }
}

} // namespace

namespace 任务管理工作线程 {

inline bool 计算任务管理界面优先级结果(
    const 自我类& 自我对象,
    结构_界面优先级结果* 输出,
    const std::string& 调用点) noexcept
{
    (void)调用点;
    if (!输出) {
        return false;
    }

    *输出 = {};
    auto* 自我存在 = 自我对象.获取自我存在();
    auto* 任务根节点 = 自我存在
        ? reinterpret_cast<任务节点*>(世界树.存在().获取任务根节点(自我存在))
        : nullptr;
    if (!任务根节点) {
        return false;
    }

    auto* 当前主任务 = 私有_归一到任务头结点_工作线程(自我对象.获取当前主任务());
    任务节点* 最佳任务 = nullptr;
    for (auto* 当前节点 = reinterpret_cast<任务节点*>(任务根节点->链下);
         当前节点 && 当前节点 != 任务根节点;
         当前节点 = reinterpret_cast<任务节点*>(当前节点->链下)) {
        if (当前节点->主信息.节点种类 != 枚举_任务节点种类::头结点) {
            continue;
        }
        if (私有_任务状态已终结_工作线程(当前节点->主信息.状态)) {
            continue;
        }
        if (私有_任务界面优先级更高_工作线程(自我对象, 当前节点, 最佳任务, 当前主任务)) {
            最佳任务 = 当前节点;
        }
    }

    输出->当前最高优先级任务 = 最佳任务;
    if (!最佳任务) {
        return true;
    }

    输出->调度优先级 = 私有_任务基础调度优先级_工作线程(最佳任务);
    输出->是否硬中断任务 = 私有_任务属于硬中断任务_工作线程(最佳任务);
    输出->是否可执行 = 私有_任务当前可执行_工作线程(最佳任务);
    const auto 根方向 = 私有_任务来源根方向_工作线程(自我对象, 最佳任务);
    输出->是否安全方向任务 = 根方向 == 枚举_任务来源根方向_工作线程::安全;
    输出->是否服务方向任务 = 根方向 == 枚举_任务来源根方向_工作线程::服务;
    const auto 来源步骤序号 = 私有_任务来源步骤序号_工作线程(最佳任务);
    输出->来源步骤序号 =
        来源步骤序号 == (std::numeric_limits<std::int32_t>::max)() ? 0 : 来源步骤序号;
    输出->来源于前置步骤 =
        私有_任务来源挂点层级_工作线程(最佳任务)
        == 枚举_任务来源挂点层级_工作线程::前置步骤;
    return true;
}

inline bool 推进任务管理工作线程(
    自我类& 自我对象,
    const 结构_任务根节点& 任务根节点,
    结构_任务控制态* 任务控制态,
    结构_任务局部运行态* 任务局部运行态,
    时间戳 now,
    const 结构_任务控制事件& 控制事件,
    const 枚举_任务管理根层重判结果 根层重判结果,
    const 枚举_任务管理执行前门控结果 执行前门控结果,
    const std::string& 上层反馈特征键,
    const std::string& 调用点,
    结构_工作线程桥接结果* 输出,
    const 结构_任务管理请求* 提交请求) noexcept
{
    if (!输出 || !任务控制态 || !任务局部运行态) {
        return false;
    }

    const auto 安全任务主键 = [](auto* 节点) -> std::string {
        return 节点 ? 节点->获取主键() : std::string{};
    };
    const auto 安全方法主键 = [](auto* 节点) -> std::string {
        return 节点 ? 节点->获取主键() : std::string{};
    };
    const auto 构造推进事件 = [](
        const std::uint64_t 任务根ID,
        const 枚举_任务推进事件类型 类型,
        const std::uintptr_t 当前步骤指针,
        const std::uintptr_t 结果指针,
        const std::string& 摘要,
        const std::string& 等待原因 = std::string{},
        const std::string& 派生需求摘要 = std::string{}) {
            结构_任务推进事件 事件{};
            事件.任务根ID = 任务根ID;
            事件.事件类型 = 类型;
            事件.当前步骤指针 = 当前步骤指针;
            事件.结果指针 = 结果指针;
            事件.等待原因 = 等待原因;
            (void)摘要;
            (void)派生需求摘要;
            事件.派生需求摘要.clear();
            事件.摘要.clear();
            return 事件;
        };
    const auto 映射线程运行状态 = [](
        const 结构_任务控制态& 控制态,
        const 结构_任务局部运行态& 局部运行态) noexcept {
            if (控制态.请求停止 || 局部运行态.当前状态 == 枚举_任务局部运行状态::已停止) {
                return 枚举_任务管理线程运行状态::已停止;
            }
            if (局部运行态.当前状态 == 枚举_任务局部运行状态::已收束) {
                return 枚举_任务管理线程运行状态::收束中;
            }
            if (局部运行态.当前状态 == 枚举_任务局部运行状态::局部失败
                || 局部运行态.当前状态 == 枚举_任务局部运行状态::已中断) {
                return 枚举_任务管理线程运行状态::故障;
            }
            if (局部运行态.当前状态 == 枚举_任务局部运行状态::等待条件
                || 局部运行态.当前状态 == 枚举_任务局部运行状态::等待前序步骤
                || 局部运行态.当前状态 == 枚举_任务局部运行状态::等待子结果) {
                return 枚举_任务管理线程运行状态::等待中;
            }
            if (局部运行态.当前状态 == 枚举_任务局部运行状态::当前步骤可执行
                || 局部运行态.当前状态 == 枚举_任务局部运行状态::已受理
                || 局部运行态.当前状态 == 枚举_任务局部运行状态::展开步骤中) {
                return 枚举_任务管理线程运行状态::推进中;
            }
            return 枚举_任务管理线程运行状态::已启动;
        };
    const auto 追加线程补充特征 = [](
        std::vector<结构_任务管理线程补充特征>& 补充特征集,
        const 枚举_任务管理线程补充特征类型 特征类型,
        const std::string& 文本值,
        const I64 数值,
        const bool 布尔值) {
            结构_任务管理线程补充特征 特征{};
            特征.特征类型 = 特征类型;
            特征.文本值 = 文本值;
            特征.数值 = 数值;
            特征.布尔值 = 布尔值;
            补充特征集.push_back(std::move(特征));
        };
    const auto 构造线程状态消息 = [&](
        const 结构_工作线程桥接结果& 桥接结果) {
            结构_任务管理线程状态消息 消息{};
            消息.消息头.发出者主键 = std::to_string(任务根节点.任务根ID);
            消息.消息头.任务管理任务主键 = 安全任务主键(桥接结果.治理结果.上下文.当前管理任务);
            消息.消息头.任务主键 = 安全任务主键(桥接结果.治理结果.上下文.当前宿主任务);
            消息.消息头.父任务主键 = 安全任务主键(桥接结果.治理结果.上下文.当前管理任务);
            消息.消息头.步骤主键 = 安全任务主键(桥接结果.治理结果.当前步骤节点);
            消息.消息头.产生时间 = now;
            消息.消息头.执行尝试号 = 任务根节点.任务根ID;
            消息.消息头.执行尝试主键 =
                std::to_string(任务根节点.任务根ID)
                + "|"
                + (消息.消息头.步骤主键.empty() ? std::string("step") : 消息.消息头.步骤主键);
            消息.消息头.路径签名 = 任务根节点.任务根ID;
            消息.消息头.幂等键 = 消息.消息头.执行尝试主键 + "|" + std::to_string(now);
            消息.消息头.影子验证状态 = 桥接结果.治理结果.当前影子验证状态;
            消息.消息头.允许正式资产提交 = 桥接结果.治理结果.允许正式资产提交;
            消息.当前运行状态 = 映射线程运行状态(*任务控制态, *任务局部运行态);
            消息.开始时间 = now;
            消息.结束时间 = 0;
            消息.是否执行尝试结束 =
                任务控制态->请求停止
                || 任务局部运行态->当前状态 == 枚举_任务局部运行状态::已收束
                || 任务局部运行态->当前状态 == 枚举_任务局部运行状态::已停止;
            消息.结束状态 =
                任务控制态->请求停止
                ? 枚举_任务管理线程结束状态::中断结束
                : (任务局部运行态->当前状态 == 枚举_任务局部运行状态::已收束
                    ? 枚举_任务管理线程结束状态::收束结束
                    : 枚举_任务管理线程结束状态::未结束);

            追加线程补充特征(
                消息.补充特征集,
                枚举_任务管理线程补充特征类型::当前步骤前沿,
                std::to_string(任务局部运行态->当前步骤前沿),
                static_cast<I64>(任务局部运行态->当前步骤前沿),
                false);
            追加线程补充特征(
                消息.补充特征集,
                枚举_任务管理线程补充特征类型::当前等待原因,
                任务局部运行态->当前等待原因,
                0,
                false);
            追加线程补充特征(
                消息.补充特征集,
                枚举_任务管理线程补充特征类型::是否可继续推进,
                std::string{},
                0,
                消息.当前运行状态 != 枚举_任务管理线程运行状态::等待中
                    && 消息.当前运行状态 != 枚举_任务管理线程运行状态::阻塞
                    && 消息.当前运行状态 != 枚举_任务管理线程运行状态::已停止);
            return 消息;
        };
    auto& 结果 = *输出;
    结果 = {};
    const auto 填充任务管理消息头 = [&](
        结构_任务管理消息头& 消息头,
        const 结构_工作线程桥接结果& 桥接结果) {
            消息头.发出者主键 = std::to_string(任务根节点.任务根ID);
            消息头.任务管理任务主键 = 安全任务主键(桥接结果.治理结果.上下文.当前管理任务);
            消息头.任务主键 = 安全任务主键(桥接结果.治理结果.上下文.当前宿主任务);
            消息头.父任务主键 = 安全任务主键(桥接结果.治理结果.上下文.当前管理任务);
            消息头.步骤主键 = 安全任务主键(桥接结果.治理结果.当前步骤节点);
            消息头.产生时间 = now;
            消息头.执行尝试号 = 任务根节点.任务根ID;
            消息头.执行尝试主键 =
                std::to_string(任务根节点.任务根ID)
                + "|"
                + (消息头.步骤主键.empty() ? std::string("step") : 消息头.步骤主键);
            消息头.路径签名 = 任务根节点.任务根ID;
            消息头.幂等键 = 消息头.执行尝试主键 + "|" + std::to_string(now);
            消息头.影子验证状态 = 桥接结果.治理结果.当前影子验证状态;
            消息头.允许正式资产提交 = 桥接结果.治理结果.允许正式资产提交;
        };
    const auto 追加派生需求消息 = [&](
        const 枚举_任务管理派生需求类型 派生需求类型,
        const 枚举_任务管理阻塞级别 阻塞级别,
        const bool 是否本地不可消化,
        const bool 是否阻塞当前步骤,
        const bool 是否影响父任务推进,
        const bool 是否需要外部支撑,
        const bool 是否可能影响服务,
        const bool 是否可能影响安全,
        const bool 是否建议线程重判,
        const bool 是否疑似需要新任务入口,
        const std::string& 当前方法主键,
        const std::string& 当前等待原因,
        const std::string& 摘要) {
            结构_任务管理派生需求消息 消息{};
            填充任务管理消息头(消息.消息头, 结果);
            消息.当前方法主键 = 当前方法主键;
            消息.派生需求类型 = 派生需求类型;
            消息.阻塞级别 = 阻塞级别;
            消息.是否本地不可消化 = 是否本地不可消化;
            消息.是否阻塞当前步骤 = 是否阻塞当前步骤;
            消息.是否影响父任务推进 = 是否影响父任务推进;
            消息.是否需要外部支撑 = 是否需要外部支撑;
            消息.是否可能影响服务 = 是否可能影响服务;
            消息.是否可能影响安全 = 是否可能影响安全;
            消息.是否建议线程重判 = 是否建议线程重判;
            消息.是否疑似需要新任务入口 = 是否疑似需要新任务入口;
            消息.当前等待原因 = 当前等待原因;
            消息.摘要 = 摘要;

            结构_任务管理上行消息 上行消息{};
            上行消息.类型 = 枚举_任务管理上行消息类型::派生需求消息;
            上行消息.载荷 = 消息;
            结果.上行消息集.push_back(std::move(上行消息));

            const auto 派生摘要 = 构造任务管理派生需求消息摘要(消息);
            任务局部运行态->派生需求缓存.push_back(派生摘要);
            结果.推进事件列表.push_back(构造推进事件(
                任务根节点.任务根ID,
                枚举_任务推进事件类型::派生需求上报,
                任务局部运行态->当前步骤前沿,
                任务局部运行态->最近局部结果,
                "工作线程上报派生需求",
                {},
                派生摘要));
        };
    const auto 构造结果状态消息 = [&](
        const 结构_工作线程桥接结果& 桥接结果,
        任务节点* 当前宿主任务,
        const std::optional<结构_任务步骤执行结果_最小>& 最近执行结果) {
            结构_任务管理结果状态消息 消息{};
            填充任务管理消息头(消息.消息头, 桥接结果);
            auto* 最新结果节点 = 桥接结果.治理结果.最新结果节点;
            消息.结果节点主键 = 安全任务主键(最新结果节点);
            消息.结果节点指针 = reinterpret_cast<std::uintptr_t>(最新结果节点);
            消息.结果节点场景主键 =
                最新结果节点 && 最新结果节点->主信息.场景.指针
                ? 最新结果节点->主信息.场景.指针->获取主键()
                : std::string{};
            消息.是否已正式写入结果节点 = 最新结果节点 != nullptr;
            消息.执行开始时间 =
                桥接结果.治理结果.当前步骤节点
                ? 桥接结果.治理结果.当前步骤节点->主信息.启动时间
                : 0;
            消息.执行结束时间 =
                最新结果节点 && 最新结果节点->主信息.完成时间 != 0
                ? 最新结果节点->主信息.完成时间
                : now;

            if (当前宿主任务 && 当前宿主任务->主信息.状态 == 枚举_任务状态::完成) {
                消息.结果状态 = 枚举_任务管理结果状态::收束完成;
                消息.完成度 = 1.0;
            } else if (最近执行结果.has_value() && 最近执行结果->方法执行结果.成功) {
                消息.结果状态 =
                    桥接结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::保持等待
                    ? 枚举_任务管理结果状态::部分完成
                    : 枚举_任务管理结果状态::成功;
                消息.完成度 =
                    桥接结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::保持等待
                    ? 0.5
                    : 0.8;
            } else if (任务局部运行态->当前状态 == 枚举_任务局部运行状态::已收束) {
                消息.结果状态 = 枚举_任务管理结果状态::收束完成;
                消息.完成度 = 1.0;
            } else if (任务局部运行态->当前状态 == 枚举_任务局部运行状态::已停止
                || 任务局部运行态->当前状态 == 枚举_任务局部运行状态::已中断) {
                消息.结果状态 = 枚举_任务管理结果状态::中断;
            } else if (任务局部运行态->当前状态 == 枚举_任务局部运行状态::局部失败) {
                消息.结果状态 = 枚举_任务管理结果状态::失败;
            } else {
                消息.结果状态 = 枚举_任务管理结果状态::部分完成;
                消息.完成度 = 0.2;
            }

            if (最近执行结果.has_value()) {
                消息.是否成功 = 最近执行结果->方法执行结果.成功;
                消息.错误码 = 最近执行结果->方法执行结果.成功码;
                消息.结果值 = 特征值{ static_cast<I64>(最近执行结果->记账结果) };
            } else {
                消息.是否成功 = 消息.结果状态 == 枚举_任务管理结果状态::成功
                    || 消息.结果状态 == 枚举_任务管理结果状态::收束完成;
                消息.错误码 = 当前宿主任务 ? 当前宿主任务->主信息.最近错误码 : 0;
                消息.结果值 = 特征值{
                    static_cast<I64>(
                        当前宿主任务
                            ? static_cast<I64>(当前宿主任务->主信息.状态)
                            : static_cast<I64>(枚举_任务状态::未定义))
                };
            }

            消息.完成时间 = 消息.执行结束时间;
            消息.是否存在关键中间状态 = false;
            消息.是否仍有未满足项 =
                桥接结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::保持等待;
            消息.未满足项类型摘要 =
                消息.是否仍有未满足项 ? "等待学习或前置条件" : std::string{};
            消息.是否需要外部支撑 = false;
            消息.是否需要父任务处理 = false;
            消息.是否需要自我线程重判 = false;
            消息.是否疑似需要新任务入口 =
                桥接结果.治理结果.已上报学习需求;
            消息.可能影响父任务 = false;

            if (当前宿主任务) {
                结构_任务管理状态变化项 宿主状态变化{};
                宿主状态变化.变化主体主键 = 安全任务主键(当前宿主任务);
                宿主状态变化.变化主体类型摘要 = "任务";
                宿主状态变化.特征类型摘要 = "任务状态";
                宿主状态变化.特征标签 = "宿主状态";
                宿主状态变化.变化前值 = 特征值{ static_cast<I64>(桥接结果.治理结果.宿主任务旧状态) };
                宿主状态变化.变化后值 = 特征值{ static_cast<I64>(桥接结果.治理结果.宿主任务新状态) };
                宿主状态变化.已确认生效 = true;
                宿主状态变化.变化原因键 = "工作线程步骤执行";
                消息.服务对象状态变化集.push_back(std::move(宿主状态变化));
            }
            if (桥接结果.治理结果.当前步骤节点) {
                结构_任务管理状态变化项 步骤状态变化{};
                步骤状态变化.变化主体主键 = 安全任务主键(桥接结果.治理结果.当前步骤节点);
                步骤状态变化.变化主体类型摘要 = "步骤";
                步骤状态变化.特征类型摘要 = "步骤状态";
                步骤状态变化.特征标签 = "当前步骤";
                步骤状态变化.变化后值 = 特征值{
                    static_cast<I64>(桥接结果.治理结果.当前步骤节点->主信息.状态)
                };
                步骤状态变化.已确认生效 = true;
                步骤状态变化.变化原因键 = "工作线程步骤执行";
                消息.服务对象状态变化集.push_back(std::move(步骤状态变化));
            }

            消息.摘要 = 构造任务管理结果状态消息摘要(消息);
            return 消息;
    };
    结果.当前消息合同.消息输入.控制事件 = 控制事件;
    if (提交请求) {
        结果.当前消息合同.消息输入.存在控制请求 = 提交请求->存在控制请求;
        结果.当前消息合同.消息输入.控制请求 = 提交请求->当前控制请求;
    }
    结果.当前消息合同.消息输入.当前时间 = now;
    结果.当前消息合同.消息输入.调用点 = 调用点;
    结果.已消费控制事件 = 控制事件;
    结果.根层重判结果 = 根层重判结果;
    结果.执行前门控结果 = 执行前门控结果;
    任务控制态->任务根ID = 任务根节点.任务根ID;
    任务局部运行态->任务根ID = 任务根节点.任务根ID;
    任务控制态->已派发 = true;
    任务控制态->绑定工作线程ID = 任务根节点.任务根ID;
    任务控制态->控制摘要.clear();
    任务控制态->队列状态 = 枚举_任务队列状态::已派发;
    任务局部运行态->当前状态 = 枚举_任务局部运行状态::已受理;

    结果.任务管理上位输入已刷新 = true;

    auto& 治理结果 = 结果.治理结果;
    auto* 自我存在 = 自我对象.获取自我存在();
    auto* 当前任务树根 = 自我存在
        ? reinterpret_cast<任务节点*>(世界树.存在().获取任务根节点(自我存在))
        : nullptr;
    const auto 校验任务节点 = [&](任务节点* 节点) noexcept -> 任务节点* {
        if (!当前任务树根 || !节点) {
            return nullptr;
        }
        return 私有_节点属于独立树_工作线程(当前任务树根, 节点) ? 节点 : nullptr;
    };
    const auto 归一任务头并校验 = [&](任务节点* 节点) noexcept -> 任务节点* {
        auto* 当前 = 校验任务节点(节点);
        while (当前) {
            if (当前->主信息.节点种类 == 枚举_任务节点种类::头结点) {
                return 当前;
            }
            当前 = 校验任务节点(reinterpret_cast<任务节点*>(当前->父));
        }
        return nullptr;
    };
    const auto 校验宿主子树节点 = [&](任务节点* 节点, 任务节点* 宿主头) noexcept -> 任务节点* {
        auto* 已校验节点 = 校验任务节点(节点);
        if (!已校验节点 || !宿主头) {
            return nullptr;
        }
        return 归一任务头并校验(已校验节点) == 宿主头 ? 已校验节点 : nullptr;
    };

    auto* 当前管理任务 = 归一任务头并校验(自我对象.获取任务管理任务());
    auto* 宿主任务 = 归一任务头并校验(
        reinterpret_cast<任务节点*>(任务根节点.世界任务根指针));
    if (!宿主任务) {
        宿主任务 = 归一任务头并校验(自我对象.获取当前主任务());
    }
    if (!宿主任务) {
        宿主任务 = 归一任务头并校验(自我对象.获取安全根任务());
    }
    if (!宿主任务) {
        宿主任务 = 归一任务头并校验(自我对象.获取服务根任务());
    }

    治理结果.已补齐治理任务 = 当前管理任务 != nullptr;
    治理结果.已选中宿主任务 = 宿主任务 != nullptr;
    治理结果.当前请求 = 提交请求 ? *提交请求 : 结构_任务管理请求{};
    if (治理结果.当前请求.提交时间 == 0) {
        治理结果.当前请求.提交时间 = now;
    }
    if (治理结果.当前请求.宿主任务 == nullptr) {
        治理结果.当前请求.宿主任务 = 宿主任务;
    }
    治理结果.当前请求.上下文.当前时间 = now;
    if (治理结果.当前请求.上下文.当前主需求 == nullptr) {
        治理结果.当前请求.上下文.当前主需求 =
            reinterpret_cast<需求类::节点类*>(任务根节点.来源需求指针);
    }
    if (治理结果.当前请求.上下文.当前管理任务 == nullptr) {
        治理结果.当前请求.上下文.当前管理任务 = 当前管理任务;
    }
    if (治理结果.当前请求.上下文.当前宿主任务 == nullptr) {
        治理结果.当前请求.上下文.当前宿主任务 = 宿主任务;
    }
    治理结果.当前请求.上下文.最近根层重判结果 = 根层重判结果;
    治理结果.当前请求.上下文.最近执行前门控结果 = 执行前门控结果;
    治理结果.当前请求.上下文.最近上层反馈摘要 = 上层反馈特征键;
    治理结果.上下文 = 治理结果.当前请求.上下文;
    治理结果.最近根层重判结果 = 根层重判结果;
    治理结果.最近执行前门控结果 = 执行前门控结果;
    治理结果.最近上层反馈摘要 = 上层反馈特征键;
    治理结果.当前触发来源 = 治理结果.当前请求.触发来源;
    治理结果.来源最小原语位图 = 治理结果.当前请求.来源最小原语位图;
    治理结果.当前治理二次特征证据 = 治理结果.当前请求.当前治理二次特征证据;
    治理结果.当前原语判定汇总 = 治理结果.当前请求.当前原语判定汇总;
    治理结果.当前高阶排序请求 = 治理结果.当前请求.当前高阶排序请求;
    治理结果.当前高阶胜出绑定 = 治理结果.当前请求.当前高阶胜出绑定;
    治理结果.当前控制承接 = 治理结果.当前请求.当前控制承接;
    治理结果.来源主观察特征 = 治理结果.当前请求.来源主观察特征;
    治理结果.当前影子验证状态 = 治理结果.当前请求.影子验证状态;
    治理结果.允许正式资产提交 = 治理结果.当前请求.允许正式资产提交;
    治理结果.当前功能域 = 枚举_任务管理功能域::筹办;
    治理结果.当前缺口类型 = 宿主任务
        ? 枚举_任务管理缺口类型::无缺口
        : 枚举_任务管理缺口类型::宿主任务缺失;

    bool 控制阻断执行 =
        任务控制态->请求停止
        || 任务控制态->请求收束
        || 执行前门控结果 == 枚举_任务管理执行前门控结果::禁止继续;

    const auto 绑定步骤方法 = [](任务节点* 步骤节点, 方法节点* 方法头) noexcept {
        if (!步骤节点 || !方法头) {
            return;
        }
        步骤节点->主信息.执行方法.指针 = reinterpret_cast<方法节点类*>(方法头);
        步骤节点->主信息.执行方法.主键 = 方法头->获取主键();
        步骤节点->主信息.可用方法首节点.指针 = reinterpret_cast<方法节点类*>(方法头);
        步骤节点->主信息.可用方法首节点.主键 = 方法头->获取主键();
    };
    const auto 写入当前步骤引用 = [](任务节点* 宿主, 任务节点* 步骤节点) noexcept {
        if (!宿主) {
            return;
        }
        宿主->主信息.当前步骤节点.指针 = reinterpret_cast<任务节点类*>(步骤节点);
        宿主->主信息.当前步骤节点.主键 = 步骤节点 ? 步骤节点->获取主键() : std::string{};
    };
    const auto 映射步骤语义 = [](const std::uint32_t 本能ID) noexcept {
        switch (本能ID) {
        case 6038U: return 枚举_任务管理步骤语义类型::业务推进步骤;
        case 6039U: return 枚举_任务管理步骤语义类型::补结构步骤;
        case 6037U:
        default: return 枚举_任务管理步骤语义类型::补结构步骤;
        }
    };
    const auto 映射步骤位 = [](const std::uint32_t 本能ID) noexcept {
        switch (本能ID) {
        case 6038U: return 枚举_任务管理步骤位类型::执行位;
        case 6039U: return 枚举_任务管理步骤位类型::补结构位;
        case 6037U:
        default: return 枚举_任务管理步骤位类型::补结构位;
        }
    };
    const auto 映射方法需求位 = [](const std::uint32_t 本能ID) noexcept {
        switch (本能ID) {
        case 6038U: return 枚举_任务管理方法需求位::选择推进;
        case 6039U: return 枚举_任务管理方法需求位::补结构;
        case 6037U:
        default: return 枚举_任务管理方法需求位::补结构;
        }
    };

    任务类 任务服务{};
    const auto 确保当前步骤 = [&](const 结构_任务步骤执行结果_最小* 上一步执行结果,
                                bool* 输出已创建步骤,
                                bool* 输出已创建结果) -> 任务节点* {
        if (输出已创建步骤) {
            *输出已创建步骤 = false;
        }
        if (输出已创建结果) {
            *输出已创建结果 = false;
        }
        if (!宿主任务) {
            return nullptr;
        }

        auto* 当前步骤 = 校验宿主子树节点(
            reinterpret_cast<任务节点*>(宿主任务->主信息.当前步骤节点.指针),
            宿主任务);
        if (当前步骤 && !私有_任务状态已终结_工作线程(当前步骤->主信息.状态)) {
            return 当前步骤;
        }

        auto* 当前结果 = 校验宿主子树节点(
            私有_取步骤结果节点_工作线程(当前步骤),
            宿主任务);
        if (当前结果) {
            if (auto* 下一跳步骤 = 校验宿主子树节点(
                    私有_取结果下一跳步骤_工作线程(当前结果),
                    宿主任务)) {
                写入当前步骤引用(宿主任务, 下一跳步骤);
                return 下一跳步骤;
            }
        }

        const auto 下一本能ID = 私有_推导下一本能ID_工作线程(
            宿主任务,
            当前步骤,
            上一步执行结果);
        if (下一本能ID == 0) {
            return nullptr;
        }

        auto* 下一方法 = 私有_确保本能方法头_工作线程(
            自我对象,
            下一本能ID,
            now,
            调用点 + "/下一方法");
        if (!下一方法) {
            return nullptr;
        }

        auto* 新步骤 = 任务服务.创建任务步骤节点(
            宿主任务,
            当前结果 ? 当前结果 : 宿主任务,
            reinterpret_cast<方法节点类*>(下一方法),
            nullptr,
            now,
            调用点 + "/创建步骤");
        if (!新步骤) {
            return nullptr;
        }

        绑定步骤方法(新步骤, 下一方法);
        写入当前步骤引用(宿主任务, 新步骤);
        if (输出已创建步骤) {
            *输出已创建步骤 = true;
        }
        if (输出已创建结果) {
            *输出已创建结果 = 私有_取步骤结果节点_工作线程(新步骤) != nullptr;
        }
        return 新步骤;
    };

    结果.任务管理治理触发 = 宿主任务 != nullptr;
    if (!结果.任务管理治理触发) {
        任务局部运行态->当前状态 = 枚举_任务局部运行状态::等待条件;
        任务局部运行态->当前等待原因 = "当前无宿主任务";
        任务控制态->队列状态 = 枚举_任务队列状态::等待;
        结果.推进事件列表.push_back(构造推进事件(
            任务根节点.任务根ID,
            枚举_任务推进事件类型::当前步骤阻塞,
            0,
            0,
            "工作线程未命中宿主任务",
            任务局部运行态->当前等待原因));
        return true;
    }

    const auto 宿主旧状态 = 宿主任务->主信息.状态;
    治理结果.宿主任务旧状态 = 宿主旧状态;
    std::optional<结构_任务步骤执行结果_最小> 最近执行结果{};

    bool 已创建步骤 = false;
    bool 已创建结果 = false;
    auto* 当前步骤 = 确保当前步骤(nullptr, &已创建步骤, &已创建结果);
    治理结果.已创建步骤节点 = 已创建步骤;
    治理结果.已创建结果节点 = 已创建结果;

    if (当前步骤) {
        auto* 当前方法 = reinterpret_cast<方法节点*>(当前步骤->主信息.执行方法.指针);
        if (!当前方法) {
            当前方法 = reinterpret_cast<方法节点*>(当前步骤->主信息.可用方法首节点.指针);
        }
        const auto 当前本能ID = 私有_读取方法本能ID_工作线程(当前方法);
        治理结果.当前步骤位类型 = 映射步骤位(当前本能ID);
        治理结果.当前步骤语义类型 = 映射步骤语义(当前本能ID);
        治理结果.当前主方法需求位 = 映射方法需求位(当前本能ID);
        治理结果.当前步骤节点 = 当前步骤;
        治理结果.上下文.当前步骤 = 当前步骤;
        治理结果.当前方法来源 = 枚举_任务管理方法来源::已挂方法复用;
        治理结果.上下文.当前方法 = 当前方法;
        治理结果.当前一步结果.当前方法节点 = 当前方法;

        if (!控制阻断执行 && 当前方法) {
            自我_执行桥类 执行桥{};
            auto 执行结果 = 执行任务步骤_最小_v0(
                执行桥,
                宿主任务,
                当前方法,
                now,
                0,
                false,
                调用点 + "/执行本能步骤");
            最近执行结果 = 执行结果;

            auto* 当前结果 = 执行结果.最近结果节点;
            私有_规范本能执行后的状态_工作线程(
                宿主任务,
                当前步骤,
                当前结果,
                当前本能ID,
                执行结果,
                now);

            const auto 下一本能ID = 私有_推导下一本能ID_工作线程(
                宿主任务,
                当前步骤,
                &执行结果);
            if (当前结果 && 下一本能ID != 0 && !私有_取结果下一跳步骤_工作线程(当前结果)) {
                bool 新建步骤 = false;
                bool 新建结果 = false;
                (void)确保当前步骤(&执行结果, &新建步骤, &新建结果);
                治理结果.已创建步骤节点 = 治理结果.已创建步骤节点 || 新建步骤;
                治理结果.已创建结果节点 = 治理结果.已创建结果节点 || 新建结果;
            }

            当前步骤 = 校验宿主子树节点(
                reinterpret_cast<任务节点*>(宿主任务->主信息.当前步骤节点.指针),
                宿主任务);
            当前结果 = 校验宿主子树节点(当前结果, 宿主任务);
            治理结果.当前步骤节点 = 当前步骤;
            治理结果.最新结果节点 = 当前结果;
            治理结果.上下文.当前步骤 = 当前步骤;
            治理结果.上下文.最近结果 = 当前结果;
            治理结果.当前一步结果.当前步骤节点 = 当前步骤;
            治理结果.当前一步结果.最新结果节点 = 当前结果;
            治理结果.已推进任务状态 = true;
            治理结果.已命中最近结果 = 当前结果 != nullptr;
            治理结果.当前功能域 =
                宿主任务->主信息.状态 == 枚举_任务状态::等待中
                ? 枚举_任务管理功能域::等待
                : 枚举_任务管理功能域::筹办;
            治理结果.当前下一步去向 =
                宿主任务->主信息.状态 == 枚举_任务状态::完成
                ? 枚举_任务管理下一步去向::进入收束
                : ((下一本能ID == 6039U || 宿主任务->主信息.等待学习唤醒)
                    ? 枚举_任务管理下一步去向::保持等待
                    : 枚举_任务管理下一步去向::保持运行);
            治理结果.最近总控结果 =
                宿主任务->主信息.状态 == 枚举_任务状态::完成
                ? 枚举_任务管理总控结果::宿主进入收束
                : (治理结果.当前下一步去向 == 枚举_任务管理下一步去向::保持等待
                    ? 枚举_任务管理总控结果::宿主保持等待
                    : 枚举_任务管理总控结果::宿主保持运行);
            治理结果.已上报学习需求 =
                下一本能ID == 6039U
                || 执行结果.方法执行结果.成功码 == 本能方法结果_任务筹办已激活学习任务
                || 执行结果.方法执行结果.成功码 == 本能方法结果_任务执行一步已激活学习任务
                || 执行结果.方法执行结果.成功码 == 本能方法结果_学习任务已建立任务头待重入;
        }
    }

    治理结果.宿主任务新状态 = 宿主任务->主信息.状态;
    任务局部运行态->当前步骤前沿 = reinterpret_cast<std::uintptr_t>(治理结果.当前步骤节点);
    任务局部运行态->最近局部结果 = reinterpret_cast<std::uintptr_t>(治理结果.最新结果节点);
    任务局部运行态->局部运行摘要.clear();
    任务局部运行态->局部完成度 =
        宿主任务->主信息.状态 == 枚举_任务状态::完成 ? 100 :
        (治理结果.已创建步骤节点 || 治理结果.已创建结果节点 ? 60 : 20);

    if (控制阻断执行) {
        任务局部运行态->当前状态 =
            任务控制态->请求收束
            ? 枚举_任务局部运行状态::已收束
            : 枚举_任务局部运行状态::已停止;
        任务局部运行态->当前等待原因 =
            任务控制态->请求收束 ? "收到收束请求" : "收到停止请求";
        任务控制态->队列状态 =
            任务局部运行态->当前状态 == 枚举_任务局部运行状态::已收束
            ? 枚举_任务队列状态::收束中
            : 枚举_任务队列状态::已停止;
    } else if (治理结果.当前下一步去向 == 枚举_任务管理下一步去向::保持等待) {
        任务局部运行态->当前状态 = 枚举_任务局部运行状态::等待条件;
        任务局部运行态->当前等待原因 = "等待学习或外部条件";
        任务控制态->队列状态 = 枚举_任务队列状态::等待;
    } else if (治理结果.当前下一步去向 == 枚举_任务管理下一步去向::进入收束) {
        任务局部运行态->当前状态 = 枚举_任务局部运行状态::已收束;
        任务局部运行态->当前等待原因.clear();
        任务控制态->队列状态 = 枚举_任务队列状态::收束中;
    } else {
        任务局部运行态->当前状态 = 枚举_任务局部运行状态::当前步骤可执行;
        任务局部运行态->当前等待原因.clear();
        任务控制态->队列状态 = 枚举_任务队列状态::可运行;
    }

    if (任务局部运行态->当前状态 == 枚举_任务局部运行状态::等待条件) {
        结果.推进事件列表.push_back(构造推进事件(
            任务根节点.任务根ID,
            枚举_任务推进事件类型::当前步骤阻塞,
            任务局部运行态->当前步骤前沿,
            任务局部运行态->最近局部结果,
            "当前步骤等待",
            任务局部运行态->当前等待原因));
    } else if (任务局部运行态->当前状态 == 枚举_任务局部运行状态::已收束
        || 任务局部运行态->当前状态 == 枚举_任务局部运行状态::已停止) {
        结果.推进事件列表.push_back(构造推进事件(
            任务根节点.任务根ID,
            枚举_任务推进事件类型::最终结果返回,
            任务局部运行态->当前步骤前沿,
            任务局部运行态->最近局部结果,
            "工作线程返回最终结果"));
    } else {
        结果.推进事件列表.push_back(构造推进事件(
            任务根节点.任务根ID,
            枚举_任务推进事件类型::当前步骤可执行,
            任务局部运行态->当前步骤前沿,
            任务局部运行态->最近局部结果,
            "当前步骤已执行并更新前沿"));
    }

    if (治理结果.已上报学习需求) {
        追加派生需求消息(
            枚举_任务管理派生需求类型::缺方法,
            枚举_任务管理阻塞级别::严重,
            true,
            true,
            true,
            false,
            false,
            false,
            true,
            true,
            治理结果.当前一步结果.当前方法节点
                ? 安全方法主键(治理结果.当前一步结果.当前方法节点)
                : std::string{},
            "等待方法学习补齐",
            "当前步骤方法不可直接完成，已转入学习任务");
    }

    if (!控制阻断执行) {
        结果.推进事件列表.push_back(构造推进事件(
            任务根节点.任务根ID,
            枚举_任务推进事件类型::局部结果返回,
            任务局部运行态->当前步骤前沿,
            任务局部运行态->最近局部结果,
            "工作线程返回局部结果"));
    }

    if (!控制阻断执行
        && (治理结果.当前下一步去向 == 枚举_任务管理下一步去向::进入收束
            || 治理结果.最近总控结果 == 枚举_任务管理总控结果::宿主进入收束)) {
        任务局部运行态->当前状态 = 枚举_任务局部运行状态::已收束;
        任务控制态->队列状态 = 枚举_任务队列状态::收束中;
        结果.推进事件列表.push_back(构造推进事件(
            任务根节点.任务根ID,
            枚举_任务推进事件类型::最终结果返回,
            任务局部运行态->当前步骤前沿,
            任务局部运行态->最近局部结果,
            "工作线程返回最终结果"));
    }

    const auto 线程状态消息 = 构造线程状态消息(结果);
    结果.当前消息合同.状态回报.已生成线程状态消息 = true;
    结果.当前消息合同.状态回报.状态消息 = 线程状态消息;
    结构_任务管理上行消息 上行消息{};
    上行消息.类型 = 枚举_任务管理上行消息类型::线程状态消息;
    上行消息.载荷 = 线程状态消息;
    结果.上行消息集.push_back(std::move(上行消息));

    if (治理结果.已推进任务状态 || 治理结果.最新结果节点 || 最近执行结果.has_value()) {
        const auto 结果状态消息 = 构造结果状态消息(结果, 宿主任务, 最近执行结果);
        结构_任务管理上行消息 结果上行消息{};
        结果上行消息.类型 = 枚举_任务管理上行消息类型::结果状态消息;
        结果上行消息.载荷 = 结果状态消息;
        结果.上行消息集.push_back(std::move(结果上行消息));
    }

    结果.当前消息合同.结果上行.推进事件列表 = 结果.推进事件列表;
    结果.当前消息合同.结果上行.上行消息集 = 结果.上行消息集;
    治理结果.当前请求.宿主任务 = 治理结果.当前请求.宿主任务
        ? 治理结果.当前请求.宿主任务
        : 宿主任务;
    治理结果.当前请求.上下文 = 治理结果.上下文;
    治理结果.当前请求.来源最小原语位图 = 治理结果.来源最小原语位图;
    治理结果.当前请求.来源主观察特征 = 治理结果.来源主观察特征;
    治理结果.当前请求.影子验证状态 = 治理结果.当前影子验证状态;
    治理结果.当前请求.允许正式资产提交 = 治理结果.允许正式资产提交;
    治理结果.当前请求.当前治理二次特征证据 = 治理结果.当前治理二次特征证据;
    治理结果.当前请求.当前原语判定汇总 = 治理结果.当前原语判定汇总;
    治理结果.当前请求.当前高阶排序请求 = 治理结果.当前高阶排序请求;
    治理结果.当前请求.当前高阶胜出绑定 = 治理结果.当前高阶胜出绑定;
    治理结果.当前请求.当前控制承接 = 治理结果.当前控制承接;
    (void)任务管理任务模块::形成任务管理单步决策(治理结果, &治理结果.当前单步决策);
    (void)任务管理任务模块::形成任务管理写回结果(治理结果, &治理结果.当前写回结果);
    (void)任务管理任务模块::组装任务管理一步结果(治理结果, &治理结果.当前一步结果);
    结果.已生成一步治理任务包 =
        任务管理任务模块::生成一步治理任务包(治理结果, &结果.一步治理请求包);

    return true;
}

inline bool 确保任务管理工作线程壳已启动() noexcept
{
    return 私有_确保任务管理工作线程壳已启动();
}

inline bool 接收任务信息并启动任务管理任务(
    自我类& 自我对象,
    const 结构_任务信息消息& 消息,
    const std::string& 调用点,
    结构_任务信息承接结果* 输出) noexcept
{
    结构_任务信息承接结果 承接结果{};
    auto* 任务头 = 私有_归一到任务头结点_工作线程(消息.新任务);
    auto* 任务目标 = 消息.任务目标 ? 消息.任务目标 : 私有_任务来源需求_工作线程(任务头);
    auto* 来源步骤 = 消息.来源步骤节点;
    if (!来源步骤) {
        来源步骤 = 私有_任务来源步骤节点_工作线程(任务头);
    }
    const auto 当前时间 = 消息.当前时间 == 0 ? 结构体_时间戳::当前_微秒() : 消息.当前时间;

    if (!任务头 || !任务目标) {
        承接结果.摘要 = "任务信息缺失，任务管理任务未承接";
        if (输出) {
            *输出 = std::move(承接结果);
        }
        return false;
    }

    承接结果.已接收任务信息 = true;

    auto* 世界任务根 = 私有_获取世界任务根_工作线程(自我对象);
    承接结果.已确认根链挂接 = 私有_任务头已直接挂到根链_工作线程(世界任务根, 任务头);

    if (来源步骤 && 来源步骤->主信息.节点种类 == 枚举_任务节点种类::步骤节点) {
        私有_写入任务节点引用_工作线程(任务头->主信息.来源父步骤节点, 来源步骤);
        if (auto* 父任务头 = 私有_归一到任务头结点_工作线程(来源步骤)) {
            私有_登记直属子任务_工作线程(父任务头, 任务头);
        }
        私有_登记步骤前置任务_工作线程(来源步骤, 任务头);
        承接结果.已登记步骤前置任务 = true;
    }

    if (任务管理任务模块::写入上位输入镜像(
            自我对象,
            枚举_任务管理根层重判结果::允许普通推进,
            枚举_任务管理执行前门控结果::允许普通执行,
            任务目标->获取主键(),
            当前时间,
            调用点 + "/写入上位输入镜像")) {
        承接结果.桥接结果.任务管理上位输入已刷新 = true;
    }

    结构_任务管理显式事件控制 显式控制{};
    显式控制.启用 = true;
    显式控制.事件类型 = 枚举_任务管理触发事件类型::普通推进;
    显式控制.触发来源 = 枚举_任务管理触发来源::自我线程控制意图;
    显式控制.来源主观察特征 = 任务目标->获取主键();
    显式控制.事件摘要 = "任务管理任务收到任务信息，按 筹办 -> 执行 推进";
    承接结果.已写入任务管理任务 = 任务管理任务模块::设置治理显式事件控制(显式控制);

    承接结果.任务根节点 = 私有_构造任务根节点_任务信息消息_工作线程(任务头, 任务目标, 当前时间);
    承接结果.最新任务控制态 =
        私有_构造任务控制态_任务信息消息_工作线程(承接结果.任务根节点, 任务头);
    承接结果.最新任务局部运行态 =
        私有_构造任务局部运行态_任务信息消息_工作线程(承接结果.任务根节点, 任务头);
    const auto 控制事件 = 私有_构造控制事件_任务信息消息_工作线程(承接结果.最新任务控制态);

    结构_任务管理请求 提交请求{};
    (void)任务管理任务模块::构造任务管理请求(自我对象, 当前时间, &提交请求);
    提交请求.提交时间 = 当前时间;
    提交请求.宿主任务 = 任务头;
    提交请求.触发事件类型 = 枚举_任务管理触发事件类型::普通推进;
    提交请求.触发来源 = 枚举_任务管理触发来源::自我线程控制意图;
    提交请求.触发事件摘要 = "任务管理任务界面线程收到任务信息";
    提交请求.上下文.当前时间 = 当前时间;
    提交请求.上下文.当前主需求 = 任务目标;
    提交请求.上下文.当前宿主任务 = 任务头;
    提交请求.上下文.当前步骤 = 来源步骤;
    提交请求.上下文.最近功能域 = 枚举_任务管理功能域::筹办;

    承接结果.已启动任务管理工作线程 = 通过工作线程壳推进任务管理工作线程(
        自我对象,
        承接结果.任务根节点,
        &承接结果.最新任务控制态,
        &承接结果.最新任务局部运行态,
        当前时间,
        控制事件,
        枚举_任务管理根层重判结果::允许普通推进,
        枚举_任务管理执行前门控结果::允许普通执行,
        任务目标->获取主键(),
        调用点 + "/启动任务管理任务工作线程",
        &承接结果.桥接结果,
        &提交请求);
    承接结果.提交ID = 提交请求.请求ID;
    承接结果.摘要 =
        承接结果.已启动任务管理工作线程
            ? "任务信息已被任务管理任务承接，并进入筹办/执行"
            : "任务信息已送达任务管理任务，但工作线程尚未承接";

    if (输出) {
        *输出 = std::move(承接结果);
    }
    return 承接结果.已启动任务管理工作线程;
}

inline bool 通过工作线程壳推进任务管理工作线程(
    自我类& 自我对象,
    const 结构_任务根节点& 任务根节点,
    结构_任务控制态* 任务控制态,
    结构_任务局部运行态* 任务局部运行态,
    const 时间戳 now,
    const 结构_任务控制事件& 控制事件,
    const 枚举_任务管理根层重判结果 根层重判结果,
    const 枚举_任务管理执行前门控结果 执行前门控结果,
    const std::string& 上层反馈特征键,
    const std::string& 调用点,
    结构_工作线程桥接结果* 输出,
    const 结构_任务管理请求* 提交请求) noexcept
{
    if (!任务控制态 || !任务局部运行态) {
        return false;
    }
    if (!私有_确保任务管理工作线程壳已启动()) {
        return false;
    }

    auto 请求 = std::make_unique<结构_工作线程壳请求>();
    请求->自我对象 = &自我对象;
    请求->任务根节点 = 任务根节点;
    请求->任务控制态 = *任务控制态;
    请求->任务局部运行态 = *任务局部运行态;
    请求->now = now;
    请求->控制事件 = 控制事件;
    请求->根层重判结果 = 根层重判结果;
    请求->执行前门控结果 = 执行前门控结果;
    请求->上层反馈特征键 = 上层反馈特征键;
    请求->调用点 = 调用点;
    请求->存在正式任务管理请求 = 提交请求 != nullptr;
    if (提交请求) {
        请求->正式任务管理请求 = *提交请求;
    }
    auto 完成结果 = 请求->完成承诺.get_future();

    auto& 壳 = 私有_任务管理工作线程壳();
    {
        std::lock_guard 锁(壳.锁);
        壳.队列.push_back(std::move(请求));
        ++壳.快照.累计收到请求数;
        if (提交请求 && 提交请求->存在控制请求) {
            ++壳.快照.累计收到控制请求数;
        }
        私有_更新工作线程壳快照_已加锁(
            true,
            壳.正在执行,
            任务根节点.任务根ID,
            now,
            提交请求 ? 提交请求->请求ID : 0,
            提交请求 ? 私有_工作线程请求宿主主键(*提交请求) : std::string{});
    }
    壳.条件.notify_one();

    const auto 响应 = 完成结果.get();
    *任务控制态 = 响应.最新任务控制态;
    *任务局部运行态 = 响应.最新任务局部运行态;
    if (输出) {
        *输出 = 响应.桥接结果;
    }
    return 响应.推进成功;
}

inline bool 读取任务管理工作线程快照(结构_工作线程实例快照* 输出) noexcept
{
    if (!输出) {
        return false;
    }
    auto& 壳 = 私有_任务管理工作线程壳();
    std::lock_guard 锁(壳.锁);
    *输出 = 壳.快照;
    输出->已启动 = 壳.已启动;
    输出->正在执行 = 壳.正在执行;
    输出->当前排队数 = static_cast<std::uint64_t>(壳.队列.size());
    return true;
}

inline bool 读取任务管理工作线程界面回报列表(
    std::vector<结构_工作线程界面回报记录>* 输出,
    const std::size_t 最大数量) noexcept
{
    if (!输出) {
        return false;
    }
    输出->clear();
    auto& 壳 = 私有_任务管理工作线程壳();
    std::lock_guard 锁(壳.锁);
    const auto 实际数量 = (std::min)(最大数量, 壳.界面回报列表.size());
    输出->reserve(实际数量);
    for (std::size_t 索引 = 0; 索引 < 实际数量; ++索引) {
        输出->push_back(壳.界面回报列表[索引]);
    }
    return true;
}

inline void 停止任务管理工作线程壳() noexcept
{
    std::thread 待回收线程{};
    auto& 壳 = 私有_任务管理工作线程壳();
    {
        std::lock_guard 锁(壳.锁);
        if (!壳.已启动) {
            return;
        }
        壳.停止请求 = true;
        私有_更新工作线程壳快照_已加锁(
            壳.快照.已收到请求,
            false,
            壳.快照.最近任务根ID,
            壳.快照.最近推进时间);
        待回收线程 = std::move(壳.线程);
        壳.已启动 = false;
    }
    壳.条件.notify_all();
    if (待回收线程.joinable()) {
        待回收线程.join();
    }
}

} // namespace 任务管理工作线程
