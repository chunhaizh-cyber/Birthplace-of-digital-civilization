const 语素入口节点类* 私有_值_执行缺口_当前方法执行失败() noexcept { return 私有_任务语义状态词("执行缺口_当前方法执行失败"); }

bool 私有_写基础节点指针特征(
    基础信息节点类* 宿主,
    const 语素入口节点类* 特征类型,
    const void* 指针,
    时间戳 now) noexcept
{
    return 宿主 && 特征类型 && 指针
        && 世界树.写入特征_指针(宿主, 特征类型, 指针, now);
}

bool 私有_写基础节点I64特征(
    基础信息节点类* 宿主,
    const 语素入口节点类* 特征类型,
    I64 值,
    时间戳 now) noexcept
{
    return 宿主 && 特征类型
        && 世界树.写入特征_I64(宿主, 特征类型, 值, now);
}

bool 私有_读基础节点指针特征(
    const 基础信息节点类* 宿主,
    const 语素入口节点类* 特征类型,
    void*& 输出指针) noexcept
{
    输出指针 = nullptr;
    return 宿主
        && 特征类型
        && 世界树.读取特征_指针(宿主, 特征类型, 输出指针)
        && 输出指针;
}

bool 私有_读基础节点I64特征(
    const 基础信息节点类* 宿主,
    const 语素入口节点类* 特征类型,
    I64& 输出值) noexcept
{
    输出值 = 0;
    return 宿主
        && 特征类型
        && 世界树.读取特征_I64(宿主, 特征类型, 输出值);
}

场景节点类* 私有_读取任务可执行输入参数场景(任务节点* 任务) noexcept
{
    auto* 任务虚拟存在 = 任务
        ? reinterpret_cast<存在节点类*>(任务->主信息.任务虚拟存在.指针)
        : nullptr;
    void* 指针 = nullptr;
    if (私有_读基础节点指针特征(
            reinterpret_cast<基础信息节点类*>(任务虚拟存在),
            私有_特征_可执行输入参数场景(),
            指针)) {
        return reinterpret_cast<场景节点类*>(指针);
    }
    return nullptr;
}

任务模块::筹办::枚举_任务推进状况 私有_从筹办运行回执推导状况(
    枚举_任务状态 建议状态,
    const 语素入口节点类* 筹办缺口) noexcept
{
    using 任务模块::筹办::枚举_任务推进状况;
    if (建议状态 == 枚举_任务状态::完成) {
        return 枚举_任务推进状况::父需求已满足;
    }
    if (建议状态 == 枚举_任务状态::就绪
        || 私有_语素入口相同(筹办缺口, 私有_值_无筹办缺口())) {
        return 枚举_任务推进状况::方法可执行;
    }
    if (私有_语素入口相同(筹办缺口, 私有_值_筹办缺口_任务信息缺失())
        || 私有_语素入口相同(筹办缺口, 私有_值_筹办缺口_需求目标不可解析())) {
        return 枚举_任务推进状况::未定义;
    }
    if (私有_语素入口相同(筹办缺口, 私有_值_筹办缺口_无确定候选方法())) {
        return 枚举_任务推进状况::已建立方法头待重入;
    }
    if (私有_语素入口相同(筹办缺口, 私有_值_筹办缺口_候选方法缺执行入口())) {
        return 枚举_任务推进状况::方法缺可执行入口;
    }
    if (私有_语素入口相同(筹办缺口, 私有_值_筹办缺口_候选方法条件不满足())) {
        return 枚举_任务推进状况::方法缺条件结果对;
    }
    if (私有_语素入口相同(筹办缺口, 私有_值_筹办缺口_参数配对失败())) {
        return 枚举_任务推进状况::参数不可配;
    }
    if (私有_语素入口相同(筹办缺口, 私有_值_筹办缺口_候选方法不可用())) {
        return 枚举_任务推进状况::方法运行账不足;
    }
    return 建议状态 == 枚举_任务状态::等待中
        ? 枚举_任务推进状况::存在活动子需求
        : 枚举_任务推进状况::未定义;
}

任务模块::筹办::结构_任务筹办结果 私有_从任务筹办运行存在构造结果(
    任务节点* 任务,
    存在节点类* 运行存在,
    场景节点类* 输出结果场景) noexcept
{
    任务模块::筹办::结构_任务筹办结果 结果{};
    结果.已执行筹办 = 运行存在 != nullptr;
    结果.结果场景 = 输出结果场景;
    auto* 宿主 = reinterpret_cast<基础信息节点类*>(运行存在);
    结果.方法运行结果 = reinterpret_cast<特征节点类*>(运行存在);
    结果.回执.阶段 = 任务模块::筹办::枚举_任务推进阶段::筹办;
    私有_写入任务节点引用(结果.回执.当前任务, 任务);

    I64 状态值 = 0;
    if (私有_读基础节点I64特征(宿主, 私有_特征_建议任务状态(), 状态值)) {
        结果.回执.建议任务状态 = static_cast<枚举_任务状态>(状态值);
    }
    I64 阶段值 = 0;
    if (私有_读基础节点I64特征(宿主, 私有_特征_建议任务阶段(), 阶段值)) {
        结果.回执.建议任务阶段 = static_cast<枚举_任务阶段>(阶段值);
    }
    I64 达成值 = 0;
    if (私有_读基础节点I64特征(宿主, 私有_特征_目标是否达成(), 达成值)) {
        结果.回执.当前任务目标达成 = 达成值 != 0;
    }

    void* 指针 = nullptr;
    if (私有_读基础节点指针特征(宿主, 私有_特征_目标方法头节点(), 指针)) {
        auto* 当前方法 = reinterpret_cast<方法类::节点类*>(指针);
        私有_写入方法节点引用(结果.回执.当前方法, 当前方法);
        结果.已绑定方法 = 当前方法 != nullptr;
    }
    if (私有_读基础节点指针特征(宿主, 私有_特征_可执行输入参数场景(), 指针)) {
        // 任务筹办只生成“过程回执”；这里把可执行输入场景搬进工作结果，
        // 后续由界面线程调同步回执本能方法写入任务虚拟存在。
        私有_写入场景节点引用(
            结果.回执.可执行输入参数场景,
            reinterpret_cast<场景节点类*>(指针));
    }
    if (私有_读基础节点指针特征(宿主, 私有_特征_方法运行结果(), 指针)) {
        结果.方法运行结果 = reinterpret_cast<特征节点类*>(指针);
    }
    if (私有_读基础节点指针特征(宿主, 私有_特征_输出结果场景(), 指针)) {
        // 任务筹办普通函数只返回运行存在；具体缺口状态场景通过该引用传给工作线程。
        // 这里不把它提交到世界树，只作为派生需求构造的输入事实。
        结果.结果场景 = reinterpret_cast<场景节点类*>(指针);
    }
    if (私有_读基础节点指针特征(宿主, 私有_特征_筹办缺口类型(), 指针)) {
        结果.回执.缺口特征类型 = reinterpret_cast<const 语素入口节点类*>(指针);
    }
    if (私有_读基础节点指针特征(宿主, 私有_特征_派生需求提示(), 指针)) {
        结果.回执.需要自我线程 = true;
        结果.回执.需要创建或复用子需求 = true;
    }
    结果.回执.状况 = 私有_从筹办运行回执推导状况(
        结果.回执.建议任务状态,
        结果.回执.缺口特征类型);
    结果.已建立方法头待重入 =
        结果.回执.状况 == 任务模块::筹办::枚举_任务推进状况::已建立方法头待重入;
    结果.说明 = 运行存在 ? "任务筹办普通函数回执" : "任务筹办普通函数未返回运行存在";
    return 结果;
}

任务模块::筹办::结构_任务推进回执 私有_从任务执行运行存在构造回执(
    任务节点* 任务,
    存在节点类* 运行存在,
    方法类::节点类* 输入当前方法) noexcept
{
    任务模块::筹办::结构_任务推进回执 回执{};
    回执.阶段 = 任务模块::筹办::枚举_任务推进阶段::执行;
    私有_写入任务节点引用(回执.当前任务, 任务);
    auto* 宿主 = reinterpret_cast<基础信息节点类*>(运行存在);

    I64 状态值 = 0;
    if (私有_读基础节点I64特征(宿主, 私有_特征_建议任务状态(), 状态值)) {
        回执.建议任务状态 = static_cast<枚举_任务状态>(状态值);
    }
    I64 阶段值 = 0;
    if (私有_读基础节点I64特征(宿主, 私有_特征_建议任务阶段(), 阶段值)) {
        回执.建议任务阶段 = static_cast<枚举_任务阶段>(阶段值);
    }
    I64 达成值 = 0;
    if (私有_读基础节点I64特征(宿主, 私有_特征_目标是否达成(), 达成值)) {
        回执.当前任务目标达成 = 达成值 != 0;
    }

    void* 指针 = nullptr;
    if (私有_读基础节点指针特征(宿主, 私有_特征_目标方法头节点(), 指针)) {
        私有_写入方法节点引用(回执.当前方法, reinterpret_cast<方法类::节点类*>(指针));
    } else if (输入当前方法) {
        私有_写入方法节点引用(回执.当前方法, 输入当前方法);
    }
    if (私有_读基础节点指针特征(宿主, 私有_特征_执行缺口类型(), 指针)) {
        回执.缺口特征类型 = reinterpret_cast<const 语素入口节点类*>(指针);
    }
    if (私有_读基础节点指针特征(宿主, 私有_特征_派生需求提示(), 指针)) {
        回执.需要自我线程 = true;
        回执.需要创建或复用子需求 = true;
        回执.父任务需要重筹办 = true;
    }

    using 任务模块::筹办::枚举_任务推进状况;
    if (回执.当前任务目标达成 || 回执.建议任务状态 == 枚举_任务状态::完成) {
        回执.状况 = 枚举_任务推进状况::目标结果符合;
    } else if (回执.建议任务状态 == 枚举_任务状态::失败
        || 私有_语素入口相同(回执.缺口特征类型, 私有_值_执行缺口_当前方法执行失败())) {
        回执.状况 = 枚举_任务推进状况::动作执行失败;
    } else if (私有_语素入口相同(回执.缺口特征类型, 私有_值_无执行缺口())) {
        回执.状况 = 枚举_任务推进状况::动作执行成功无可比较结果;
    } else if (私有_语素入口相同(回执.缺口特征类型, 私有_值_执行缺口_需求未满足())) {
        回执.状况 = 枚举_任务推进状况::目标结果不符合;
    } else {
        回执.状况 = 枚举_任务推进状况::动作执行失败;
    }
    return 回执;
}

结构_执行任务结果 私有_从任务执行运行存在构造结果(
    任务节点* 任务,
    存在节点类* 运行存在,
    场景节点类* 输出结果场景,
    场景节点类* 输入条件场景,
    方法类::节点类* 输入当前方法) noexcept
{
    结构_执行任务结果 结果{};
    结果.有效 = 运行存在 != nullptr;
    结果.方法运行结果 = reinterpret_cast<特征节点类*>(运行存在);
    auto& 数据 = 结果.任务执行结果;
    数据.有效 = 运行存在 != nullptr;
    数据.主任务 = 任务;
    数据.当前步骤节点 = 任务;
    数据.条件场景 = 输入条件场景;
    数据.结果场景 = 输出结果场景;
    数据.方法运行结果 = reinterpret_cast<特征节点类*>(运行存在);
    数据.当前方法 = 输入当前方法;
    数据.记账结果 = 本能动作运行成功(运行存在)
        ? 枚举_任务执行记账结果::成功
        : 枚举_任务执行记账结果::失败;
    数据.方法运行说明 = 运行存在 ? "任务执行普通函数回执" : "任务执行普通函数未返回运行存在";

    auto* 宿主 = reinterpret_cast<基础信息节点类*>(运行存在);
    void* 指针 = nullptr;
    if (私有_读基础节点指针特征(宿主, 私有_特征_目标方法头节点(), 指针)) {
        数据.当前方法 = reinterpret_cast<方法类::节点类*>(指针);
    }
    if (私有_读基础节点指针特征(宿主, 私有_特征_输出结果场景(), 指针)) {
        数据.结果场景 = reinterpret_cast<场景节点类*>(指针);
    }
    if (私有_读基础节点指针特征(宿主, 私有_特征_当前方法运行存在(), 指针)) {
        数据.方法运行结果 = reinterpret_cast<特征节点类*>(指针);
    }
    同步执行桥语义槽(结果);
    return 结果;
}

任务模块::筹办::结构_任务推进回执 私有_构造执行推进回执(
    const 任务节点* 任务,
    const 需求节点* 来源需求,
    const 结构_执行任务结果& 执行结果) noexcept;

任务模块::筹办::结构_任务筹办结果 私有_调用任务筹办普通函数(
    自我类& 自我对象,
    任务节点* 任务,
    时间戳 now) noexcept
{
    // 任务筹办是任务管理生命周期普通函数，不进入方法树候选体系，
    // 也不作为本能方法运行；它只产出结构化筹办回执供后续同步/状态提交方法使用。
    项目运行日志("任务管理工作线程/调用任务筹办普通函数 | 任务="
        + 私有_任务主键(任务));
    return 任务模块::筹办::筹办任务(自我对象, 任务, now);
}

结构_执行任务结果 私有_调用任务执行普通函数(
    任务节点* 任务,
    时间戳 now,
    任务模块::筹办::结构_任务推进回执* 输出回执) noexcept
{
    // 任务执行同样是任务管理生命周期普通函数。真正被执行的“当前方法”
    // 仍然必须是方法树中的动作能力；任务执行本身不再伪装成可选本能方法。
    项目运行日志("任务管理工作线程/调用任务执行普通函数 | 任务="
        + 私有_任务主键(任务));
    任务执行桥类 执行桥{};
    执行桥.启动(1);
    auto 结果 = 执行任务(
        执行桥,
        任务,
        now);
    if (输出回执) {
        *输出回执 = 私有_构造执行推进回执(
            任务,
            任务 ? reinterpret_cast<需求节点*>(任务->主信息.对应需求.指针) : nullptr,
            结果);
    }
    return 结果;
}

结构_任务控制态 私有_构造任务控制态(
    const 结构_任务根节点& 根节点,
    const 任务节点* 任务) noexcept
{
    结构_任务控制态 控制态{};
    控制态.任务根ID = 根节点.任务根ID;
    控制态.队列状态 = !任务
        ? 枚举_任务队列状态::等待
        : (任务类::任务状态已终结(任务类::读取任务状态(任务))
            ? 枚举_任务队列状态::已结算
            : 枚举_任务队列状态::可运行);
    控制态.全局优先级 = 任务 ? 任务类::读取任务调度优先级(任务) : 0;
    控制态.绑定工作线程ID = 1;
    return 控制态;
}

结构_任务局部运行态 私有_构造任务局部运行态(
    const 结构_任务根节点& 根节点,
    const 任务节点* 任务) noexcept
{
    结构_任务局部运行态 运行态{};
    运行态.任务根ID = 根节点.任务根ID;
    运行态.当前状态 = !任务
        ? 枚举_任务局部运行状态::等待条件
        : (任务类::任务状态已终结(任务类::读取任务状态(任务))
            ? 枚举_任务局部运行状态::局部完成
            : 枚举_任务局部运行状态::已受理);
    运行态.当前步骤前沿 = reinterpret_cast<std::uintptr_t>(任务);
    运行态.当前等待原因 = 任务 ? std::string{} : std::string("缺少任务节点");
    return 运行态;
}

枚举_任务状态 私有_从执行结果推导界面任务状态(
    const 结构_任务步骤执行结果_最小& 任务数据,
    const 特征节点类* 方法运行结果) noexcept
{
    if (任务结果缺条件_最小_v0(方法运行结果)) {
        return 枚举_任务状态::等待中;
    }
    if (本能动作运行结果值(方法运行结果) == 本能方法结果_任务筹办已建立方法头待重入) {
        return 枚举_任务状态::待重筹办;
    }
    if (本能动作运行成功(方法运行结果)) {
        return 枚举_任务状态::待重筹办;
    }
    return 任务数据.当前方法 ? 枚举_任务状态::待重筹办 : 枚举_任务状态::等待中;
}

std::string 私有_任务推进状况文本(
    const 任务模块::筹办::枚举_任务推进状况 状况)
{
    using 任务模块::筹办::枚举_任务推进状况;
    switch (状况) {
    case 枚举_任务推进状况::父需求已满足:
        return "父需求已满足";
    case 枚举_任务推进状况::存在活动子需求:
        return "存在活动子需求";
    case 枚举_任务推进状况::方法查找未命中:
        return "方法查找未命中";
    case 枚举_任务推进状况::已建立方法头待重入:
        return "已建立方法头待重入";
    case 枚举_任务推进状况::方法缺动作骨架:
        return "方法缺动作骨架";
    case 枚举_任务推进状况::方法缺可执行入口:
        return "方法缺可执行入口";
    case 枚举_任务推进状况::方法缺条件节点:
        return "方法缺条件节点";
    case 枚举_任务推进状况::方法缺结果节点:
        return "方法缺结果节点";
    case 枚举_任务推进状况::方法缺条件结果对:
        return "方法缺条件结果对";
    case 枚举_任务推进状况::参数不可配:
        return "参数不可配";
    case 枚举_任务推进状况::方法运行账不足:
        return "方法运行账不足";
    case 枚举_任务推进状况::方法结果不稳定:
        return "方法结果不稳定";
    case 枚举_任务推进状况::方法可执行:
        return "方法可执行";
    case 枚举_任务推进状况::动作执行失败:
        return "动作执行失败";
    case 枚举_任务推进状况::动作执行成功无可比较结果:
        return "动作执行成功无可比较结果";
    case 枚举_任务推进状况::目标结果符合:
        return "目标结果符合";
    case 枚举_任务推进状况::目标结果不符合:
        return "目标结果不符合";
    case 枚举_任务推进状况::出现需要附带结果:
        return "出现需要附带结果";
    case 枚举_任务推进状况::出现不需要附带结果:
        return "出现不需要附带结果";
    case 枚举_任务推进状况::出现禁止结果:
        return "出现禁止结果";
    default:
        return "未定义";
    }
}

std::string 私有_任务推进阶段文本(
    const 任务模块::筹办::枚举_任务推进阶段 阶段)
{
    switch (阶段) {
    case 任务模块::筹办::枚举_任务推进阶段::筹办:
        return "筹办";
    case 任务模块::筹办::枚举_任务推进阶段::执行:
        return "执行";
    default:
        return "未定义";
    }
}

bool 私有_任务推进回执目标成功(
    const 任务模块::筹办::结构_任务推进回执& 回执) noexcept
{
    return 回执.当前任务目标达成
        || 回执.状况 == 任务模块::筹办::枚举_任务推进状况::目标结果符合
        || 回执.状况 == 任务模块::筹办::枚举_任务推进状况::父需求已满足;
}

bool 私有_任务推进回执目标失败(
    const 任务模块::筹办::结构_任务推进回执& 回执) noexcept
{
    return 回执.状况 == 任务模块::筹办::枚举_任务推进状况::目标结果不符合;
}

枚举_任务状态 私有_从任务推进回执推导界面任务状态(
    const 任务模块::筹办::结构_任务推进回执& 回执,
    const 结构_任务步骤执行结果_最小& 任务数据,
    const 特征节点类* 方法运行结果) noexcept
{
    if (回执.建议任务状态 != 枚举_任务状态::未定义) {
        return 回执.建议任务状态;
    }

    using 任务模块::筹办::枚举_任务推进状况;
    switch (回执.状况) {
    case 枚举_任务推进状况::父需求已满足:
    case 枚举_任务推进状况::目标结果符合:
        return 枚举_任务状态::完成;
    case 枚举_任务推进状况::已建立方法头待重入:
    case 枚举_任务推进状况::动作执行成功无可比较结果:
    case 枚举_任务推进状况::目标结果不符合:
        return 枚举_任务状态::待重筹办;
    case 枚举_任务推进状况::存在活动子需求:
    case 枚举_任务推进状况::方法缺动作骨架:
    case 枚举_任务推进状况::方法缺可执行入口:
    case 枚举_任务推进状况::方法缺条件节点:
    case 枚举_任务推进状况::方法缺结果节点:
    case 枚举_任务推进状况::方法缺条件结果对:
    case 枚举_任务推进状况::参数不可配:
    case 枚举_任务推进状况::方法运行账不足:
    case 枚举_任务推进状况::方法结果不稳定:
        return 枚举_任务状态::等待中;
    case 枚举_任务推进状况::出现禁止结果:
        return 枚举_任务状态::挂起;
    case 枚举_任务推进状况::动作执行失败:
        return 回执.需要创建或复用子需求 ? 枚举_任务状态::等待中 : 枚举_任务状态::失败;
    default:
        return 私有_从执行结果推导界面任务状态(任务数据, 方法运行结果);
    }
}

枚举_任务阶段 私有_从任务推进回执推导任务阶段(
    const 任务模块::筹办::结构_任务推进回执& 回执,
    const 枚举_任务状态 状态) noexcept
{
    if (回执.建议任务阶段 != 枚举_任务阶段::未定义) {
        return 回执.建议任务阶段;
    }

    switch (状态) {
    case 枚举_任务状态::完成:
        return 枚举_任务阶段::已完成;
    case 枚举_任务状态::就绪:
    case 枚举_任务状态::排队中:
    case 枚举_任务状态::执行中:
        return 枚举_任务阶段::执行;
    case 枚举_任务状态::等待中:
    case 枚举_任务状态::挂起:
        return 枚举_任务阶段::阻塞;
    case 枚举_任务状态::待重筹办:
    case 枚举_任务状态::无法执行:
    case 枚举_任务状态::未启动:
    case 枚举_任务状态::筹办中:
        return 枚举_任务阶段::筹办;
    default:
        return 枚举_任务阶段::未定义;
    }
}

void 私有_填充任务层回执到治理结果(
    结构_任务管理结果& 治理结果,
    任务节点* 任务,
    const 任务模块::筹办::结构_任务推进回执& 回执,
    const 枚举_任务状态 任务状态) noexcept
{
    if (!任务) {
        return;
    }
    if (任务状态 == 枚举_任务状态::未定义) {
        return;
    }

    // 工作线程只填写“建议任务状态”和“候选/当前方法”到治理结果。
    // 任务状态、阶段、候选方法集和镜像特征的真实写入由管理界面线程统一提交。
    治理结果.宿主任务旧状态 = 任务类::读取任务状态(任务);
    if (治理结果.宿主任务旧状态 == 枚举_任务状态::未定义) {
        治理结果.宿主任务旧状态 = 枚举_任务状态::执行中;
    }
    治理结果.宿主任务新状态 = 任务状态;
    if (回执.当前方法.指针) {
        治理结果.当前方法 = reinterpret_cast<方法类::节点类*>(回执.当前方法.指针);
    }
    治理结果.已推进任务状态 = true;
}

I64 私有_方法自我能力值(const 方法类::节点类* 方法) noexcept
{
    if (!方法
        || 方法->主信息.首节点信息().动作句柄.类型 != 枚举_动作句柄类型::本能函数ID) {
        return 0;
    }
    const I64 能力值 = 方法->主信息.首节点信息().动作句柄.本能ID;
    return 本能方法类::是有效本能方法能力值(能力值) ? 能力值 : 0;
}

void 私有_同步任务回执方法到任务虚拟存在(
    任务节点* 任务,
    const 任务模块::筹办::结构_任务推进回执& 回执,
    const 时间戳 now) noexcept
{
    (void)任务;
    (void)回执;
    (void)now;
    // 兼容旧调用点的空实现：工作线程不得写任务虚拟存在。
    // 当前方法和候选方法集由管理界面线程读取工作结果后统一提交。
}

枚举_任务管理控制意图值 私有_控制事件映射控制意图(
    const 枚举_任务控制事件类型 事件类型) noexcept
{
    switch (事件类型) {
    case 枚举_任务控制事件类型::启动:
        return 枚举_任务管理控制意图值::请求启动;
    case 枚举_任务控制事件类型::打断:
        return 枚举_任务管理控制意图值::请求打断;
    case 枚举_任务控制事件类型::收束:
        return 枚举_任务管理控制意图值::请求收束;
    case 枚举_任务控制事件类型::停止:
        return 枚举_任务管理控制意图值::请求停止;
    case 枚举_任务控制事件类型::优先级刷新:
        return 枚举_任务管理控制意图值::请求刷新优先级;
    case 枚举_任务控制事件类型::预算刷新:
        return 枚举_任务管理控制意图值::请求刷新预算;
    default:
        return 枚举_任务管理控制意图值::未定义;
    }
}

bool 私有_本轮禁止工作线程执行(
    const 结构_任务控制事件& 控制事件,
    枚举_任务管理根层重判结果 根层重判结果,
    枚举_任务管理执行前门控结果 执行前门控结果) noexcept
{
    return 根层重判结果 == 枚举_任务管理根层重判结果::停止退出边界
        || 执行前门控结果 == 枚举_任务管理执行前门控结果::禁止继续
        || 控制事件.事件类型 == 枚举_任务控制事件类型::停止;
}

结构_执行任务结果 私有_构造未执行任务结果(
    任务节点* 任务,
    const I64 错误码,
    const std::string& 解释) noexcept
{
    结构_执行任务结果 输出{};
    输出.任务执行结果.主任务 = 任务;
    输出.任务执行结果.当前步骤节点 = 任务;
    输出.任务执行结果.记账结果 = 枚举_任务执行记账结果::失败;
    输出.任务执行结果.结果场景 = 任务 ? 任务->主信息.场景.指针 : nullptr;
    输出.任务执行结果.方法运行结果 = 创建本能动作运行结果实例_按码(
        nullptr,
        输出.任务执行结果.结果场景,
        错误码);
    输出.任务执行结果.方法运行说明 = 解释;
    输出.方法运行结果 = 输出.任务执行结果.方法运行结果;
    return 输出;
}

std::string 私有_执行结果等待原因(
    const 结构_任务步骤执行结果_最小& 任务数据,
    const 特征节点类* 方法运行结果)
{
    if (任务结果缺条件_最小_v0(方法运行结果)) {
        return !任务数据.方法运行说明.empty()
            ? 任务数据.方法运行说明
            : std::string("执行发现实际缺失，已上报自我线程生成原子需求");
    }
    return 任务数据.当前方法
        ? std::string("方法执行未完成")
        : std::string("缺少选中自我能力值或可执行方法");
}

bool 私有_回报包含派生需求消息(
    const 任务管理工作线程::结构_工作线程一步响应& 响应) noexcept
{
    return std::any_of(
        响应.一步结果.上行消息集.begin(),
        响应.一步结果.上行消息集.end(),
        [](const auto& 消息) noexcept {
            return 消息.类型 == 枚举_任务管理上行消息类型::派生需求消息;
        });
}

void 私有_填充派生需求父需求字段(
    结构_任务管理派生需求消息& 消息,
    const 任务节点* 任务) noexcept
{
    auto* 父需求 = 任务
        ? reinterpret_cast<需求节点*>(任务->主信息.对应需求.指针)
        : nullptr;
    if (父需求 && 父需求->父 == nullptr) {
        父需求 = nullptr;
    }
    if (!父需求) {
        return;
    }
    消息.父需求指针 = reinterpret_cast<std::uintptr_t>(父需求);
    消息.父需求主键 = 私有_需求主键(父需求);
}

const 语素入口节点类* 私有_执行输出特征_派生需求() noexcept
{
    static const 语素入口节点类* s_词 = 语素集.添加信息入口词("派生需求", 枚举_信息入口类型::特征模板入口);
    return s_词;
}

const 语素入口节点类* 私有_执行输出特征_失败原因() noexcept
{
    static const 语素入口节点类* s_词 = 语素集.添加信息入口词("失败原因", 枚举_信息入口类型::特征模板入口);
    return s_词;
}

const 语素入口节点类* 私有_执行输出特征_派生需求当前状态() noexcept
{
    static const 语素入口节点类* s_词 = 语素集.添加信息入口词("派生需求当前状态", 枚举_信息入口类型::特征模板入口);
    return s_词;
}

const 语素入口节点类* 私有_执行输出特征_派生需求目标状态() noexcept
{
    static const 语素入口节点类* s_词 = 语素集.添加信息入口词("派生需求目标状态", 枚举_信息入口类型::特征模板入口);
    return s_词;
}

bool 私有_语素入口同一_工作线程(const 语素入口节点类* 左, const 语素入口节点类* 右) noexcept
{
    if (!左 || !右) {
        return false;
    }
    if (左 == 右) {
        return true;
    }
    const auto 左键 = 左->获取主键();
    const auto 右键 = 右->获取主键();
    return !左键.empty() && 左键 == 右键;
}

任务模块::筹办::枚举_任务推进状况 私有_从派生需求特征推导推进状况(
    const 语素入口节点类* 派生需求特征) noexcept
{
    using 任务模块::筹办::枚举_任务推进状况;
    if (私有_语素入口同一_工作线程(
            派生需求特征,
            私有_方法动作骨架状态特征类型_执行桥_最小_v0())) {
        return 枚举_任务推进状况::方法缺动作骨架;
    }
    if (私有_语素入口同一_工作线程(
            派生需求特征,
            私有_方法可执行入口数量特征类型_执行桥_最小_v0())) {
        return 枚举_任务推进状况::方法缺可执行入口;
    }
    if (私有_语素入口同一_工作线程(
            派生需求特征,
            私有_方法条件节点数量特征类型_执行桥_最小_v0())) {
        return 枚举_任务推进状况::方法缺条件节点;
    }
    if (私有_语素入口同一_工作线程(
            派生需求特征,
            私有_方法结果节点数量特征类型_执行桥_最小_v0())) {
        return 枚举_任务推进状况::方法缺结果节点;
    }
    if (私有_语素入口同一_工作线程(
            派生需求特征,
            私有_方法条件结果配对状态特征类型_执行桥_最小_v0())) {
        return 枚举_任务推进状况::方法缺条件结果对;
    }
    if (私有_语素入口同一_工作线程(
            派生需求特征,
            私有_参数配对状态特征类型_执行桥_最小_v0())) {
        return 枚举_任务推进状况::参数不可配;
    }
    if (私有_语素入口同一_工作线程(
            派生需求特征,
            私有_方法运行账完整性特征类型_执行桥_最小_v0())) {
        return 枚举_任务推进状况::方法运行账不足;
    }
    if (私有_语素入口同一_工作线程(
            派生需求特征,
            私有_方法稳定状态特征类型_执行桥_最小_v0())) {
        return 枚举_任务推进状况::方法结果不稳定;
    }
    return 枚举_任务推进状况::未定义;
}

const 语素入口节点类* 私有_读取输出语素入口指针(
    const 基础信息节点类* 宿主,
    const 语素入口节点类* 特征类型) noexcept
{
    if (!宿主 || !特征类型) {
        return nullptr;
    }
    void* 指针 = nullptr;
    if (!世界树.读取特征_指针(宿主, 特征类型, 指针) || !指针) {
        return nullptr;
    }
    return reinterpret_cast<const 语素入口节点类*>(指针);
}

状态节点类* 私有_读取输出状态指针(
    const 基础信息节点类* 宿主,
    const 语素入口节点类* 特征类型) noexcept
{
    if (!宿主 || !特征类型) {
        return nullptr;
    }
    void* 指针 = nullptr;
    if (!世界树.读取特征_指针(宿主, 特征类型, 指针) || !指针) {
        return nullptr;
    }
    return reinterpret_cast<状态节点类*>(指针);
}

状态节点类* 私有_读取输出场景内状态指针(
    const 基础信息节点类* 宿主,
    const 语素入口节点类* 特征类型) noexcept
{
    if (!宿主 || !特征类型) {
        return nullptr;
    }
    void* 场景指针 = nullptr;
    if (!世界树.读取特征_指针(宿主, 私有_特征_输出结果场景(), 场景指针) || !场景指针) {
        return nullptr;
    }
    return 私有_读取输出状态指针(
        reinterpret_cast<const 基础信息节点类*>(场景指针),
        特征类型);
}

const 语素入口节点类* 私有_读取执行输出语素入口指针(
    const 结构_执行任务结果& 执行结果,
    const 语素入口节点类* 特征类型,
    const bool 允许结果场景) noexcept
{
    if (!特征类型) {
        return nullptr;
    }
    if (const auto* 运行存在 = reinterpret_cast<const 基础信息节点类*>(
            执行结果.方法运行结果)) {
        if (const auto* 词 = 私有_读取输出语素入口指针(运行存在, 特征类型)) {
            return 词;
        }
    }
    if (允许结果场景) {
        if (const auto* 结果场景 = reinterpret_cast<const 基础信息节点类*>(
                执行结果.任务执行结果.结果场景)) {
            if (const auto* 词 = 私有_读取输出语素入口指针(结果场景, 特征类型)) {
                return 词;
            }
        }
    }
    return nullptr;
}

状态节点类* 私有_读取执行输出状态指针(
    const 结构_执行任务结果& 执行结果,
    const 语素入口节点类* 特征类型) noexcept
{
    if (!特征类型) {
        return nullptr;
    }
    if (const auto* 运行存在 = reinterpret_cast<const 基础信息节点类*>(
            执行结果.方法运行结果)) {
        if (auto* 状态 = 私有_读取输出状态指针(运行存在, 特征类型)) {
            return 状态;
        }
        // 本能方法的运行存在只承载回执；真实可比较结果常写在它引用的输出结果场景中。
        if (auto* 状态 = 私有_读取输出场景内状态指针(运行存在, 特征类型)) {
            return 状态;
        }
    }
    if (const auto* 结果场景 = reinterpret_cast<const 基础信息节点类*>(
            执行结果.任务执行结果.结果场景)) {
        if (auto* 状态 = 私有_读取输出状态指针(结果场景, 特征类型)) {
            return 状态;
        }
        if (auto* 状态 = 私有_读取输出场景内状态指针(结果场景, 特征类型)) {
            return 状态;
        }
    }
    return nullptr;
}

void 私有_记录执行目标状态读取(
    const 任务节点* 任务,
    const 需求节点* 需求,
    const 方法节点* 方法,
    const 结构_执行任务结果& 执行结果,
    const 语素入口节点类* 特征类型,
    const 状态节点类* 目标状态,
    const 状态节点类* 实际状态) noexcept
{
    std::ostringstream 输出;
    输出 << "任务管理工作线程/执行目标状态读取"
        << " | 任务=" << 私有_任务主键(任务)
        << " | 需求=" << 私有_需求主键(需求)
        << " | 方法=" << (方法 ? 方法->获取主键() : std::string{})
        << " | 目标特征=" << (特征类型 ? 特征类型->获取主键() : std::string{})
        << " | 目标状态=" << (目标状态 ? 目标状态->获取主键() : std::string{})
        << " | 实际状态=" << (实际状态 ? 实际状态->获取主键() : std::string{})
        << " | 方法运行存在=" << (执行结果.方法运行结果 ? 执行结果.方法运行结果->获取主键() : std::string{})
        << " | 结果场景=" << (执行结果.任务执行结果.结果场景 ? 执行结果.任务执行结果.结果场景->获取主键() : std::string{})
        << " | 当前方法运行存在=" << (执行结果.任务执行结果.方法运行结果 ? 执行结果.任务执行结果.方法运行结果->获取主键() : std::string{});
    项目运行日志(输出.str());
}

bool 私有_读取状态I64值_工作线程(
    const 状态节点类* 状态,
    I64& 输出值) noexcept
{
    const auto* 主信息 = 状态
        ? dynamic_cast<const 状态节点主信息类*>(状态->主信息)
        : nullptr;
    if (!主信息) {
        return false;
    }
    if (const auto* 值 = std::get_if<I64>(&主信息->状态值)) {
        输出值 = *值;
        return true;
    }
    return false;
}

void 私有_记录执行目标状态比较(
    const 任务节点* 任务,
    const 需求节点* 需求,
    const 方法节点* 方法,
    const 语素入口节点类* 特征类型,
    const 状态节点类* 目标状态,
    const 状态节点类* 实际状态,
    const 结构_特征状态比较结果& 比较,
    三向关系掩码 目标满足关系) noexcept
{
    I64 目标值 = 0;
    I64 实际值 = 0;
    const bool 目标值有效 = 私有_读取状态I64值_工作线程(目标状态, 目标值);
    const bool 实际值有效 = 私有_读取状态I64值_工作线程(实际状态, 实际值);

    // 该日志只记录比较输入和输出，用于定位目标状态、实际状态或满足关系的来源错误。
    std::ostringstream 输出;
    输出 << "任务管理工作线程/执行目标状态比较"
        << " | 任务=" << 私有_任务主键(任务)
        << " | 需求=" << 私有_需求主键(需求)
        << " | 方法=" << (方法 ? 方法->获取主键() : std::string{})
        << " | 目标特征=" << (特征类型 ? 特征类型->获取主键() : std::string{})
        << " | 目标状态=" << (目标状态 ? 目标状态->获取主键() : std::string{})
        << " | 目标值=" << (目标值有效 ? std::to_string(目标值) : std::string{"非I64"})
        << " | 实际状态=" << (实际状态 ? 实际状态->获取主键() : std::string{})
        << " | 实际值=" << (实际值有效 ? std::to_string(实际值) : std::string{"非I64"})
        << " | 可比较=" << (比较.可比较 ? 1 : 0)
        << " | 比较关系=" << static_cast<int>(比较.关系)
        << " | 满足关系=" << static_cast<int>(目标满足关系)
        << " | 差值=" << 比较.差值
        << " | 接受=" << (比较.可比较 && 三向关系被接受(比较.关系, 目标满足关系) ? 1 : 0)
        << " | 说明=" << 比较.说明;
    项目运行日志(输出.str());
}

const 语素入口节点类* 私有_执行输出派生需求词(
    const 结构_执行任务结果& 执行结果) noexcept
{
    // 显式派生目标特征可能由方法域输出场景携带，例如“目标方法.方法状态=可用”。
    // 它不是任务状态回执；因此允许从输出结果场景读取。派生需求提示仍走任务层回执。
    return 私有_读取执行输出语素入口指针(
        执行结果,
        私有_执行输出特征_派生需求(),
        true);
}

const 语素入口节点类* 私有_执行输出失败原因词(
    const 结构_执行任务结果& 执行结果) noexcept
{
    return 私有_读取执行输出语素入口指针(
        执行结果,
        私有_执行输出特征_失败原因(),
        false);
}

bool 私有_执行输出需要派生原子需求(
    const 结构_执行任务结果& 执行结果) noexcept
{
    if (本能动作运行成功(执行结果.方法运行结果)) {
        return false;
    }
    return 私有_执行输出派生需求词(执行结果)
        || 私有_执行输出失败原因词(执行结果);
}

const 语素入口节点类* 私有_状态特征类型(const 状态节点类* 状态) noexcept
{
    const auto* 状态主信息 = 状态
        ? dynamic_cast<const 状态节点主信息类*>(状态->主信息)
        : nullptr;
    const auto* 特征主信息 = 状态主信息 && 状态主信息->状态特征.指针
        ? dynamic_cast<const 特征节点主信息类*>(状态主信息->状态特征.指针->主信息)
        : nullptr;
    return 特征主信息 ? 特征主信息->类型 : nullptr;
}

基础信息节点类* 私有_状态主体节点(const 状态节点类* 状态) noexcept
{
    const auto* 状态主信息 = 状态
        ? dynamic_cast<const 状态节点主信息类*>(状态->主信息)
        : nullptr;
    return 状态主信息 ? 状态主信息->状态主体.指针 : nullptr;
}

const 语素入口节点类* 私有_任务目标特征类型(
    const 任务节点* 任务,
    const 需求节点* 需求) noexcept
{
    if (需求 && 需求->主信息.目标特征类型缓存) {
        return 需求->主信息.目标特征类型缓存;
    }
    if (任务 && 任务->主信息.目标状态.指针) {
        return 私有_状态特征类型(任务->主信息.目标状态.指针);
    }
    if (任务 && 任务->主信息.结果状态信息.指针) {
        return 私有_状态特征类型(任务->主信息.结果状态信息.指针);
    }
    return nullptr;
}

状态节点类* 私有_任务目标状态(
    const 任务节点* 任务,
    const 需求节点* 需求) noexcept
{
    if (需求 && 需求->主信息.需求状态.指针) {
        return 需求->主信息.需求状态.指针;
    }
    return 任务 ? 任务->主信息.目标状态.指针 : nullptr;
}

bool 私有_目标特征是学习承接缺口(
    const 语素入口节点类* 特征类型) noexcept
{
    return 私有_语素入口同一_工作线程(
            特征类型,
            私有_方法状态特征类型_执行桥_最小_v0())
        || 私有_语素入口同一_工作线程(
            特征类型,
            私有_方法稳定状态特征类型_执行桥_最小_v0())
        || 私有_语素入口同一_工作线程(
            特征类型,
            私有_方法运行账完整性特征类型_执行桥_最小_v0())
        || 私有_语素入口同一_工作线程(
            特征类型,
            私有_方法动作骨架状态特征类型_执行桥_最小_v0())
        || 私有_语素入口同一_工作线程(
            特征类型,
            私有_方法动作骨架数量特征类型_执行桥_最小_v0())
        || 私有_语素入口同一_工作线程(
            特征类型,
            私有_方法可执行入口数量特征类型_执行桥_最小_v0())
        || 私有_语素入口同一_工作线程(
            特征类型,
            私有_方法条件节点数量特征类型_执行桥_最小_v0())
        || 私有_语素入口同一_工作线程(
            特征类型,
            私有_方法结果节点数量特征类型_执行桥_最小_v0())
        || 私有_语素入口同一_工作线程(
            特征类型,
            私有_方法条件结果配对状态特征类型_执行桥_最小_v0())
        || 私有_语素入口同一_工作线程(
            特征类型,
            私有_参数配对状态特征类型_执行桥_最小_v0());
}

bool 私有_方法是学习承接本能(
    const 方法节点* 方法) noexcept
{
    if (!方法
        || 方法->主信息.首节点信息().动作句柄.类型 != 枚举_动作句柄类型::本能函数ID) {
        return false;
    }
    switch (static_cast<枚举_本能方法ID>(
        方法->主信息.首节点信息().动作句柄.本能ID)) {
    case 枚举_本能方法ID::自我_尝试学习:
    case 枚举_本能方法ID::自我_定向学习:
    case 枚举_本能方法ID::自我_练习:
    case 枚举_本能方法ID::自我_配对参数:
        return true;
    default:
        return false;
    }
}

void 私有_记录动作成功无可比较目标结果(
    const 任务节点* 任务,
    const 需求节点* 需求,
    const 方法节点* 方法,
    const 语素入口节点类* 特征类型,
    const 状态节点类* 目标状态,
    const char* 原因) noexcept
{
    std::ostringstream 输出;
    输出 << "任务管理工作线程/动作成功无可比较目标结果"
        << " | 原因=" << (原因 ? 原因 : "")
        << " | 任务=" << 私有_任务主键(任务)
        << " | 需求=" << (需求 ? 需求->获取主键() : std::string{})
        << " | 方法=" << (方法 ? 方法->获取主键() : std::string{})
        << " | 目标特征=" << (特征类型 ? 特征类型->获取主键() : std::string{})
        << " | 目标状态=" << (目标状态 ? 目标状态->获取主键() : std::string{})
        << " | 说明=动作成功后缺少可比较实际结果，已记录诊断；该路径不应长期重复重排。";
    项目运行警告日志(输出.str());
}

任务模块::筹办::结构_任务推进回执 私有_构造执行推进回执(
    const 任务节点* 任务,
    const 需求节点* 需求,
    const 结构_执行任务结果& 执行结果) noexcept
{
    任务模块::筹办::结构_任务推进回执 回执{};
    回执.阶段 = 任务模块::筹办::枚举_任务推进阶段::执行;
    私有_写入任务节点引用(回执.当前任务, const_cast<任务节点*>(任务));
    私有_写入需求节点引用(回执.对应需求, const_cast<需求节点*>(需求));
    auto* 回执方法 = 执行结果.任务执行结果.当前方法
        ? reinterpret_cast<方法类::节点类*>(执行结果.任务执行结果.当前方法)
        : (任务
            ? reinterpret_cast<方法类::节点类*>(任务类::读取任务执行方法(const_cast<任务节点*>(任务)))
            : nullptr);
    私有_写入方法节点引用(回执.当前方法, 回执方法);
    回执.目标特征类型 = 私有_任务目标特征类型(任务, 需求);
    回执.目标满足关系 = 需求 && 需求->主信息.满足关系 != 0
        ? 需求->主信息.满足关系
        : 关系_等于;
    回执.治理结果可接受 = true;

    const bool 动作成功 = 本能动作运行成功(执行结果.方法运行结果);
    if (!动作成功) {
        const auto* 派生需求特征 = 私有_执行输出派生需求词(执行结果);
        const auto 派生状况 = 私有_从派生需求特征推导推进状况(派生需求特征);
        if (派生状况 != 任务模块::筹办::枚举_任务推进状况::未定义) {
            回执.状况 = 派生状况;
            回执.缺口特征类型 = 派生需求特征;
            回执.需要自我线程 = true;
            回执.需要创建或复用子需求 = true;
            回执.父任务需要重筹办 = false;
            回执.摘要 = std::string("执行阶段发现缺口：") + 私有_任务推进状况文本(派生状况);
            return 回执;
        }
        回执.状况 = 任务模块::筹办::枚举_任务推进状况::动作执行失败;
        回执.需要自我线程 = 私有_执行输出需要派生原子需求(执行结果);
        回执.需要创建或复用子需求 = 回执.需要自我线程;
        回执.父任务需要重筹办 = false;
        回执.摘要 = "动作执行失败";
        return 回执;
    }

    auto* 目标状态 = 私有_任务目标状态(任务, 需求);
    auto* 实际状态 = 回执.目标特征类型
        ? 私有_读取执行输出状态指针(执行结果, 回执.目标特征类型)
        : nullptr;
    私有_记录执行目标状态读取(
        任务,
        需求,
        回执方法,
        执行结果,
        回执.目标特征类型,
        目标状态,
        实际状态);
    if (实际状态) {
        可解析引用<状态节点类> 实际引用{};
        私有_写入状态节点引用(实际引用, 实际状态);
        回执.实际结果状态集.push_back(实际引用);
    }

    if (!实际状态
        && 目标状态
        && 回执.目标特征类型
        && 私有_方法是学习承接本能(回执方法)
        && 私有_目标特征是学习承接缺口(回执.目标特征类型)) {
        // 学习承接动作成功只说明本能方法产生了运行事实。
        // 目标是否达成必须由显式实际结果状态或需求满足证据支撑，不能用动作成功直接替代。
        回执.状况 = 任务模块::筹办::枚举_任务推进状况::动作执行成功无可比较结果;
        回执.父任务需要重筹办 = true;
        回执.摘要 = "学习承接动作成功但缺少显式目标结果";
        私有_记录动作成功无可比较目标结果(
            任务,
            需求,
            回执方法,
            回执.目标特征类型,
            目标状态,
            "学习承接未产出显式实际结果状态");
        return 回执;
    }

    if (!实际状态 || !目标状态) {
        回执.状况 = 任务模块::筹办::枚举_任务推进状况::动作执行成功无可比较结果;
        回执.父任务需要重筹办 = true;
        回执.摘要 = "动作执行成功但无可比较目标结果";
        私有_记录动作成功无可比较目标结果(
            任务,
            需求,
            回执方法,
            回执.目标特征类型,
            目标状态,
            !实际状态 ? "缺少实际结果状态" : "缺少目标状态");
        return 回执;
    }

    const auto 比较 = 世界树.特征().比较状态(实际状态, 目标状态);
    私有_记录执行目标状态比较(
        任务,
        需求,
        回执方法,
        回执.目标特征类型,
        目标状态,
        实际状态,
        比较,
        回执.目标满足关系);
    if (!比较.可比较) {
        回执.状况 = 任务模块::筹办::枚举_任务推进状况::动作执行成功无可比较结果;
        回执.父任务需要重筹办 = true;
        回执.摘要 = "动作执行成功但目标结果不可比较";
        私有_记录动作成功无可比较目标结果(
            任务,
            需求,
            回执方法,
            回执.目标特征类型,
            目标状态,
            "状态比较器返回不可比较");
        return 回执;
    }

    if (三向关系被接受(比较.关系, 回执.目标满足关系)) {
        回执.状况 = 任务模块::筹办::枚举_任务推进状况::目标结果符合;
        回执.当前任务目标达成 = true;
        回执.需要自我线程 = true;
        回执.摘要 = "目标结果符合";
    } else {
        回执.状况 = 任务模块::筹办::枚举_任务推进状况::目标结果不符合;
        回执.父任务需要重筹办 = true;
        回执.需要自我线程 = true;
        回执.摘要 = "目标结果不符合";
    }
    return 回执;
}

void 私有_补充执行输出派生需求字段(
    结构_任务管理派生需求消息& 消息,
    const 结构_执行任务结果& 执行结果) noexcept
{
    const auto* 派生需求词 = 私有_执行输出派生需求词(执行结果);
    const auto* 失败原因词 = 私有_执行输出失败原因词(执行结果);
    const auto* 需求词 = 派生需求词 ? 派生需求词 : 失败原因词;
    if (!需求词) {
        return;
    }

    消息.需求特征类型指针 = reinterpret_cast<std::uintptr_t>(需求词);
    消息.需求特征类型主键 = 需求词->获取主键();

    if (auto* 当前状态 = 私有_读取执行输出状态指针(
            执行结果,
            私有_执行输出特征_派生需求当前状态())) {
        消息.需求当前状态指针 = reinterpret_cast<std::uintptr_t>(当前状态);
        消息.需求当前状态主键 = 当前状态->获取主键();
    }
    if (auto* 目标状态 = 私有_读取执行输出状态指针(
            执行结果,
            私有_执行输出特征_派生需求目标状态())) {
        消息.需求目标状态指针 = reinterpret_cast<std::uintptr_t>(目标状态);
        消息.需求目标状态主键 = 目标状态->获取主键();
    }

    (void)失败原因词;
}

方法节点* 私有_派生需求来源方法头(
    const 任务节点* 任务,
    const 结构_执行任务结果& 执行结果) noexcept
{
    if (执行结果.任务执行结果.当前方法) {
        return 执行结果.任务执行结果.当前方法;
    }
    if (!任务) {
        return nullptr;
    }
    if (auto* 方法 = 任务类::读取任务执行方法(const_cast<任务节点*>(任务))) {
        return reinterpret_cast<方法节点*>(方法);
    }
    return nullptr;
}

void 私有_提示执行桥派生需求逻辑错误(const std::string& 文本) noexcept
{
    项目运行错误日志(文本);
    项目弹窗错误提示("鱼巢 - 执行桥逻辑错误", 文本);
}

bool 私有_派生需求执行输出完整(
    const 结构_任务管理派生需求消息& 消息) noexcept
{
    return (消息.需求特征类型指针 != 0 || !消息.需求特征类型主键.empty())
        && (消息.需求当前状态指针 != 0 || !消息.需求当前状态主键.empty())
        && (消息.需求目标状态指针 != 0 || !消息.需求目标状态主键.empty());
}

结构_任务管理上行消息 私有_构造执行缺失原子需求消息(
    const 任务节点* 任务,
    const 结构_执行任务结果& 执行结果,
    const 任务模块::筹办::结构_任务推进回执* 回执,
    const 时间戳 now) noexcept
{
    if (回执
        && (回执->状况 == 任务模块::筹办::枚举_任务推进状况::存在活动子需求
            || 回执->状况 == 任务模块::筹办::枚举_任务推进状况::父需求已满足)) {
        // 这两类回执已经表达了父任务的既有治理事实：
        // “存在活动子需求”应等待/复用原子子需求，“父需求已满足”应进入结算，
        // 不能再把未执行运行结果中的失败原因升级成新的派生需求。
        项目运行日志(
            "任务管理工作线程/派生需求构造跳过"
            " | 原因=回执不需要新增子需求"
            " | 任务=" + 私有_任务主键(任务)
            + " | 推进状况=" + 私有_任务推进状况文本(回执->状况));
        return {};
    }
    结构_任务管理派生需求消息 消息{};
    const auto 任务主键 = 私有_任务主键(任务);
    const auto 步骤主键 = 私有_任务主键(执行结果.任务执行结果.当前步骤节点);
    消息.消息头.发出者主键 = "任务管理工作线程";
    消息.消息头.任务主键 = 任务主键;
    消息.消息头.步骤主键 = 步骤主键.empty() ? 任务主键 : 步骤主键;
    消息.消息头.产生时间 = now;
    消息.消息头.执行尝试主键 = 任务主键 + "|执行缺失";
    auto* 来源方法 = 私有_派生需求来源方法头(任务, 执行结果);
    消息.当前方法主键 = 来源方法 ? 来源方法->获取主键() : std::string{};
    消息.派生需求类型 = 枚举_任务管理派生需求类型::执行缺失;
    消息.阻塞级别 = 枚举_任务管理阻塞级别::严重;
    消息.是否阻塞当前步骤 = true;
    消息.是否影响父任务推进 = true;
    消息.是否建议线程重判 = true;
    私有_填充派生需求父需求字段(消息, 任务);
    const auto* 来源方法首节点信息 = 来源方法 ? 来源方法->主信息.取首节点信息() : nullptr;
    if (auto* 方法虚拟存在 = 来源方法首节点信息 ? 来源方法首节点信息->方法虚拟存在.指针 : nullptr) {
        消息.方法虚拟存在指针 = reinterpret_cast<std::uintptr_t>(方法虚拟存在);
        消息.方法虚拟存在主键 = 方法虚拟存在->获取主键();
    }
    if (回执
        && (回执->缺口目标主体.指针 || !回执->缺口目标主体.主键.empty())) {
        消息.需求目标主体指针 =
            reinterpret_cast<std::uintptr_t>(回执->缺口目标主体.指针);
        消息.需求目标主体主键 = 回执->缺口目标主体.主键;
    }
    私有_补充执行输出派生需求字段(消息, 执行结果);
    if (回执
        && 消息.需求特征类型指针 == 0
        && 消息.需求特征类型主键.empty()
        && 回执->缺口特征类型) {
        // 筹办阶段发现的方法缺口可能只存在于任务推进回执中。
        // 此处只补“需求目标特征类型”，当前/目标状态仍必须来自方法输出结果场景。
        消息.需求特征类型指针 =
            reinterpret_cast<std::uintptr_t>(回执->缺口特征类型);
        消息.需求特征类型主键 = 回执->缺口特征类型->获取主键();
    }
    if (消息.需求当前状态指针 == 0 && 消息.需求当前状态主键.empty()) {
        if (auto* 当前状态 = 私有_读取执行输出状态指针(
                执行结果,
                私有_执行输出特征_派生需求当前状态())) {
            消息.需求当前状态指针 = reinterpret_cast<std::uintptr_t>(当前状态);
            消息.需求当前状态主键 = 当前状态->获取主键();
        }
    }
    if (消息.需求目标状态指针 == 0 && 消息.需求目标状态主键.empty()) {
        if (auto* 目标状态 = 私有_读取执行输出状态指针(
                执行结果,
                私有_执行输出特征_派生需求目标状态())) {
            消息.需求目标状态指针 = reinterpret_cast<std::uintptr_t>(目标状态);
            消息.需求目标状态主键 = 目标状态->获取主键();
        }
    }
    if (消息.需求目标主体指针 == 0 && 消息.需求目标主体主键.empty()) {
        auto* 目标状态 = reinterpret_cast<状态节点类*>(消息.需求目标状态指针);
        auto* 当前状态 = reinterpret_cast<状态节点类*>(消息.需求当前状态指针);
        auto* 状态主体 = 私有_状态主体节点(目标状态);
        if (!状态主体) {
            状态主体 = 私有_状态主体节点(当前状态);
        }
        if (状态主体) {
            消息.需求目标主体指针 = reinterpret_cast<std::uintptr_t>(状态主体);
            消息.需求目标主体主键 = 状态主体->获取主键();
        } else if (auto* 方法虚拟存在 = 来源方法首节点信息 ? 来源方法首节点信息->方法虚拟存在.指针 : nullptr) {
            消息.需求目标主体指针 = reinterpret_cast<std::uintptr_t>(方法虚拟存在);
            消息.需求目标主体主键 = 方法虚拟存在->获取主键();
        }
    }
    {
        std::ostringstream 输出;
        输出 << "任务管理工作线程/派生需求构造"
            << " | 任务=" << 任务主键
            << " | 来源方法=" << 消息.当前方法主键
            << " | 方法虚拟存在=" << 消息.方法虚拟存在主键
            << " | 需求特征=" << 消息.需求特征类型主键
            << " | 目标主体=" << 消息.需求目标主体主键
            << " | 当前状态=" << 消息.需求当前状态主键
            << " | 目标状态=" << 消息.需求目标状态主键
            << " | 回执缺口特征=" << (回执 && 回执->缺口特征类型
                ? 回执->缺口特征类型->获取主键()
                : std::string{});
        项目运行日志(输出.str());
    }
    if (!私有_派生需求执行输出完整(消息)) {
        std::ostringstream 输出;
        输出 << "执行桥逻辑错误：执行缺失派生需求缺少执行桥输出的目标状态。"
            << " | 任务=" << 任务主键
            << " | 方法=" << 消息.当前方法主键
            << " | 需求特征=" << 消息.需求特征类型主键
            << " | 当前状态=" << 消息.需求当前状态主键
            << " | 目标状态=" << 消息.需求目标状态主键
            << " | 已拒绝发送派生需求。";
        私有_提示执行桥派生需求逻辑错误(输出.str());
        return {};
    }
    结构_任务管理上行消息 上行{};
    上行.类型 = 枚举_任务管理上行消息类型::派生需求消息;
    上行.载荷 = 消息;
    同步任务管理上行消息语义槽(上行);
    return 上行;
}

结构_任务管理上行消息 私有_构造结果状态上行消息(
    const 任务节点* 任务,
    const 结构_执行任务结果& 执行结果,
    const 任务模块::筹办::结构_任务推进回执& 回执,
    const 时间戳 now) noexcept
{
    结构_任务管理结果状态消息 消息{};
    const auto 任务主键 = 私有_任务主键(任务);
    const auto 步骤主键 = 私有_任务主键(执行结果.任务执行结果.当前步骤节点);
    消息.消息头.发出者主键 = "任务管理工作线程";
    消息.消息头.任务主键 = 任务主键;
    消息.消息头.步骤主键 = 步骤主键.empty() ? 任务主键 : 步骤主键;
    消息.消息头.产生时间 = now;
    消息.消息头.执行尝试主键 = 任务主键 + "|执行任务";
    消息.执行结束时间 = now;
    auto* 当前方法 = 执行结果.任务执行结果.当前方法;
    const auto* 当前方法首节点信息 = 当前方法 ? 当前方法->主信息.取首节点信息() : nullptr;
    if (auto* 方法虚拟存在 = 当前方法首节点信息 ? 当前方法首节点信息->方法虚拟存在.指针 : nullptr) {
        消息.方法虚拟存在指针 = reinterpret_cast<std::uintptr_t>(方法虚拟存在);
        消息.方法虚拟存在主键 = 方法虚拟存在->获取主键();
    }
    const bool 目标成功 = 私有_任务推进回执目标成功(回执);
    const bool 目标失败 = 私有_任务推进回执目标失败(回执)
        || 回执.状况 == 任务模块::筹办::枚举_任务推进状况::动作执行失败;
    const auto 运行码 = 本能动作运行结果值(执行结果.方法运行结果);
    消息.结果状态 = 目标成功
        ? 枚举_任务管理结果状态::成功
        : (目标失败
            ? 枚举_任务管理结果状态::失败
            : 枚举_任务管理结果状态::部分完成);
    消息.完成度 = 目标成功 ? 1.0 : 0.0;
    消息.是否成功 = 目标成功;
    消息.错误码 = 运行码;
    消息.完成时间 = now;
    消息.任务价值反馈.反馈事件主键 =
        任务主键 + "|" + 消息.消息头.步骤主键 + "|" + std::to_string(now) + "|任务价值反馈";
    if (目标成功 && 回执.治理结果可接受) {
        消息.任务价值反馈.安全累计比例_百万分比 = 1'000'000;
        消息.任务价值反馈.服务累计比例_百万分比 = 1'000'000;
    }
    消息.是否仍有未满足项 =
        !目标成功
        || 回执.需要创建或复用子需求
        || 任务结果缺条件_最小_v0(执行结果.方法运行结果);
    消息.未满足项类型文本 =
        消息.是否仍有未满足项
            ? 私有_任务推进状况文本(回执.状况)
            : std::string{};
    消息.是否需要父任务处理 = 回执.父任务需要重筹办;
    消息.是否需要自我线程重判 =
        回执.需要自我线程
        || 目标成功
        || 任务结果缺条件_最小_v0(执行结果.方法运行结果);
    if (消息.是否仍有未满足项) {
        结构_任务管理未满足项 未满足项{};
        未满足项.未满足项类型 = 消息.未满足项类型文本;
        未满足项.作用主体主键 = 任务主键;
        未满足项.是否关键阻塞 = true;
        未满足项.是否建议线程重判 = 消息.是否需要自我线程重判;
        消息.未满足项集.push_back(未满足项);
    }

    结构_任务管理上行消息 上行{};
    上行.类型 = 枚举_任务管理上行消息类型::结果状态消息;
    上行.载荷 = 消息;
    同步任务管理上行消息语义槽(上行);
    return 上行;
}

结构_任务管理上行消息 私有_构造线程状态上行消息(
    const 任务节点* 任务,
    const 结构_执行任务结果& 执行结果,
    const 结构_任务控制事件& 控制事件,
    枚举_任务管理线程运行状态 运行状态,
    枚举_任务管理线程结束状态 结束状态,
    bool 是否结束,
    时间戳 now,
    const std::string& 阶段) noexcept
{
    结构_任务管理线程状态消息 消息{};
    const auto 任务主键 = 私有_任务主键(任务);
    const auto 步骤主键 = 私有_任务主键(执行结果.任务执行结果.当前步骤节点);
    消息.消息头.发出者主键 = "任务管理工作线程";
    消息.消息头.任务主键 = 任务主键;
    消息.消息头.步骤主键 = 步骤主键.empty() ? 任务主键 : 步骤主键;
    消息.消息头.产生时间 = now;
    消息.消息头.执行尝试主键 = 任务主键 + "|线程状态|" + 阶段;
    消息.消息头.幂等键 = 消息.消息头.执行尝试主键;
    消息.当前运行状态 = 运行状态;
    消息.是否执行尝试结束 = 是否结束;
    消息.结束状态 = 结束状态;
    消息.开始时间 = 任务 ? 任务->主信息.启动时间 : 0;
    消息.结束时间 = 是否结束 ? now : 0;

    if (控制事件.事件类型 != 枚举_任务控制事件类型::未定义) {
        消息.是否携带控制请求 = true;
        消息.控制请求主键 = std::to_string(控制事件.任务根ID)
            + "|" + std::to_string(static_cast<int>(控制事件.事件类型));
        消息.当前控制意图 = 私有_控制事件映射控制意图(控制事件.事件类型);
        消息.当前控制响应状态 = 是否结束
            ? 枚举_任务管理控制响应状态::已执行完成
            : 枚举_任务管理控制响应状态::已响应;
        消息.是否控制已执行完成 = 是否结束;
        消息.补充特征集.push_back(结构_任务管理线程补充特征{
            枚举_任务管理线程补充特征类型::当前控制请求主键,
            消息.控制请求主键,
            0,
            false,
            0
        });
        消息.补充特征集.push_back(结构_任务管理线程补充特征{
            枚举_任务管理线程补充特征类型::当前控制意图值,
            {},
            static_cast<I64>(消息.当前控制意图),
            false,
            0
        });
        消息.补充特征集.push_back(结构_任务管理线程补充特征{
            枚举_任务管理线程补充特征类型::当前控制响应状态,
            {},
            static_cast<I64>(消息.当前控制响应状态),
            消息.是否控制已执行完成,
            0
        });
    }

    if (!步骤主键.empty()) {
        消息.补充特征集.push_back(结构_任务管理线程补充特征{
            枚举_任务管理线程补充特征类型::当前步骤主键,
            步骤主键,
            0,
            false,
            reinterpret_cast<std::uintptr_t>(执行结果.任务执行结果.当前步骤节点)
        });
    }
    if (!执行结果.任务执行结果.方法运行说明.empty()) {
        消息.补充特征集.push_back(结构_任务管理线程补充特征{
            枚举_任务管理线程补充特征类型::当前等待原因,
            执行结果.任务执行结果.方法运行说明,
            0,
            false,
            0
        });
    }

    结构_任务管理上行消息 上行{};
    上行.类型 = 枚举_任务管理上行消息类型::线程状态消息;
    上行.载荷 = 消息;
    同步任务管理上行消息语义槽(上行);
    return 上行;
}

任务管理工作线程::结构_工作线程一步响应 私有_工作线程执行当前任务方法(
    自我类& 自我对象,
    const 任务管理线程协议::结构_任务工作包& 工作包,
    const 结构_任务根节点& 任务根节点,
    结构_任务控制态* 任务控制态,
    结构_任务局部运行态* 任务局部运行态,
    时间戳 now,
    const 结构_任务控制事件& 控制事件,
    枚举_任务管理根层重判结果 根层重判结果,
    枚举_任务管理执行前门控结果 执行前门控结果) noexcept
{
    now = 私有_时间(now);
    auto* 任务 = 私有_任务根节点取任务(任务根节点);

    任务管理工作线程::结构_工作线程一步响应 响应{};
    响应.最新任务控制态 = 任务控制态 ? *任务控制态 : 私有_构造任务控制态(任务根节点, 任务);
    响应.最新任务局部运行态 = 任务局部运行态 ? *任务局部运行态 : 私有_构造任务局部运行态(任务根节点, 任务);
    结构_执行任务结果 执行结果{};
    const bool 禁止执行 = 私有_本轮禁止工作线程执行(控制事件, 根层重判结果, 执行前门控结果);
    if (!任务) {
        执行结果 = 私有_构造未执行任务结果(nullptr, -12, "当前任务节点为空");
    } else if (禁止执行) {
        执行结果 = 私有_构造未执行任务结果(任务, -15, "门控禁止本轮执行");
    } else {
        try {
            // 推进模式由管理界面线程决定。工作线程只按授权执行本轮动作，
            // 避免“筹办刚选出方法就同轮执行”的双阶段串账。
            if (工作包.允许筹办) {
            const auto 筹办结果 = 私有_调用任务筹办普通函数(自我对象, 任务, now);
            {
                std::ostringstream 输出;
                auto* 当前方法 = reinterpret_cast<方法类::节点类*>(筹办结果.回执.当前方法.指针);
                输出 << "任务管理工作线程/筹办回执"
                    << " | 任务=" << 私有_任务主键(任务)
                    << " | 状况=" << 私有_任务推进状况文本(筹办结果.回执.状况)
                    << " | 当前方法=" << (当前方法
                        ? 当前方法->获取主键()
                        : std::string("空"))
                    << " | 需要子需求=" << (筹办结果.回执.需要创建或复用子需求 ? 1 : 0)
                    << " | 父任务需重筹办=" << (筹办结果.回执.父任务需要重筹办 ? 1 : 0);
                项目运行日志(输出.str());
            }
            私有_同步任务回执方法到任务虚拟存在(
                任务,
                筹办结果.回执,
                now);
            if (筹办结果.已执行筹办 && !筹办结果.说明.empty()) {
                项目运行日志("任务管理工作线程/普通任务筹办 | " + 筹办结果.说明);
            }
            if (筹办结果.回执.状况 == 任务模块::筹办::枚举_任务推进状况::父需求已满足
                || 筹办结果.回执.状况 == 任务模块::筹办::枚举_任务推进状况::存在活动子需求) {
                const I64 运行码 =
                    筹办结果.回执.状况 == 任务模块::筹办::枚举_任务推进状况::父需求已满足
                        ? 0
                        : -26002;
                执行结果 = 私有_构造未执行任务结果(
                    任务,
                    运行码,
                    筹办结果.说明.empty()
                        ? std::string("任务筹办前置状态已返回")
                        : 筹办结果.说明);
                响应.一步结果.已执行当前步骤方法 = false;
                响应.一步结果.存在当前步骤方法执行数据 = true;
                响应.一步结果.当前步骤方法执行数据 = 执行结果.任务执行结果;
                响应.一步结果.当前步骤方法运行结果 = 执行结果.方法运行结果;
                响应.一步结果.存在任务推进回执 = true;
                响应.一步结果.当前任务推进回执 = 筹办结果.回执;
                响应.推进成功 = true;
                return 响应;
            }
            if (筹办结果.已建立方法头待重入
                || 筹办结果.回执.父任务需要重筹办) {
                执行结果 = 私有_构造未执行任务结果(
                    任务,
                    本能方法结果_任务筹办已建立方法头待重入,
                    筹办结果.说明.empty()
                        ? std::string("任务筹办已建立目标方法头，等待下一轮重筹办")
                        : 筹办结果.说明);
                响应.一步结果.已执行当前步骤方法 = false;
                响应.一步结果.存在当前步骤方法执行数据 = true;
                响应.一步结果.当前步骤方法执行数据 = 执行结果.任务执行结果;
                响应.一步结果.当前步骤方法运行结果 = 执行结果.方法运行结果;
                响应.一步结果.存在任务推进回执 = true;
                响应.一步结果.当前任务推进回执 = 筹办结果.回执;
                响应.推进成功 = true;
                return 响应;
            }
            if (筹办结果.回执.需要创建或复用子需求
                && 筹办结果.方法运行结果) {
                执行结果.有效 = true;
                执行结果.方法运行结果 = 筹办结果.方法运行结果;
                执行结果.任务执行结果.有效 = true;
                执行结果.任务执行结果.主任务 = 任务;
                执行结果.任务执行结果.当前步骤节点 = 任务;
                执行结果.任务执行结果.当前方法 =
                    reinterpret_cast<方法类::节点类*>(筹办结果.回执.当前方法.指针);
                if (!执行结果.任务执行结果.当前方法) {
                    执行结果.任务执行结果.当前方法 =
                        reinterpret_cast<方法类::节点类*>(任务类::读取任务执行方法(任务));
                }
                执行结果.任务执行结果.结果场景 = 筹办结果.结果场景
                    ? 筹办结果.结果场景
                    : (任务 ? 任务->主信息.场景.指针 : nullptr);
                执行结果.任务执行结果.方法运行结果 = 筹办结果.方法运行结果;
                执行结果.任务执行结果.方法运行说明 = 筹办结果.说明;
                执行结果.任务执行结果.记账结果 = 枚举_任务执行记账结果::失败;
                同步执行桥语义槽(执行结果);
                响应.一步结果.已执行当前步骤方法 = false;
                响应.一步结果.存在当前步骤方法执行数据 = true;
                响应.一步结果.当前步骤方法执行数据 = 执行结果.任务执行结果;
                响应.一步结果.当前步骤方法运行结果 = 执行结果.方法运行结果;
                响应.一步结果.存在任务推进回执 = true;
                响应.一步结果.当前任务推进回执 = 筹办结果.回执;
                响应.推进成功 = true;
                return 响应;
            }
            if (!工作包.允许执行方法) {
                执行结果 = 私有_构造未执行任务结果(
                    任务,
                    0,
                    筹办结果.说明.empty()
                        ? std::string("任务筹办已完成，本轮不执行方法")
                        : 筹办结果.说明);
                响应.一步结果.已执行当前步骤方法 = false;
                响应.一步结果.存在当前步骤方法执行数据 = true;
                响应.一步结果.当前步骤方法执行数据 = 执行结果.任务执行结果;
                响应.一步结果.当前步骤方法运行结果 = 执行结果.方法运行结果;
                响应.一步结果.存在任务推进回执 = true;
                响应.一步结果.当前任务推进回执 = 筹办结果.回执;
                响应.推进成功 = true;
                return 响应;
            }
            } else if (!工作包.允许执行方法) {
                执行结果 = 私有_构造未执行任务结果(
                    任务,
                    0,
                    "工作包未授权筹办或执行，本轮仅同步状态");
                响应.一步结果.已执行当前步骤方法 = false;
                响应.一步结果.存在当前步骤方法执行数据 = true;
                响应.一步结果.当前步骤方法执行数据 = 执行结果.任务执行结果;
                响应.一步结果.当前步骤方法运行结果 = 执行结果.方法运行结果;
                响应.推进成功 = true;
                return 响应;
            }
            auto* 当前方法 = reinterpret_cast<方法类::节点类*>(任务类::读取任务执行方法(任务));
            auto* 管理对象任务 = 任务类::读取任务管理对象任务(任务);
            std::ostringstream 输出;
            const I64 选中能力值 = 任务类::读取任务选中自我能力值(任务);
            输出 << "任务管理工作线程/执行任务入口"
                << " | 管理任务=" << 私有_任务主键(任务)
                << " | 管理对象=" << 私有_任务主键(管理对象任务)
                << " | 当前方法=" << (当前方法 ? 当前方法->获取主键() : std::string("空"))
                << " | 当前本能ID=" << (当前方法 ? 当前方法->主信息.首节点信息().动作句柄.本能ID : -1)
                << " | 选中自我能力值=" << 选中能力值
                << " | 管理任务角色=" << static_cast<int>(任务类::读取任务角色(任务))
                << " | 管理对象角色=" << (管理对象任务 ? static_cast<int>(任务类::读取任务角色(管理对象任务)) : -1);
            项目运行日志(输出.str());
            任务模块::筹办::结构_任务推进回执 执行回执{};
            执行结果 = 私有_调用任务执行普通函数(任务, now, &执行回执);
            响应.一步结果.存在任务推进回执 = true;
            响应.一步结果.当前任务推进回执 = 执行回执;
        } catch (...) {
            执行结果.任务执行结果.结果场景 = 任务 ? 任务->主信息.场景.指针 : nullptr;
            执行结果.任务执行结果.方法运行结果 = 创建本能动作运行结果实例_按码(
                nullptr,
                执行结果.任务执行结果.结果场景,
                -9001,
                now);
            执行结果.任务执行结果.方法运行说明 = "执行任务异常";
            执行结果.方法运行结果 = 执行结果.任务执行结果.方法运行结果;
        }
    }

    响应.一步结果.已执行当前步骤方法 = 任务 != nullptr && !禁止执行;
    响应.一步结果.存在当前步骤方法执行数据 = true;
    响应.一步结果.当前步骤方法执行数据 = 执行结果.任务执行结果;
    响应.一步结果.当前步骤方法运行结果 = 执行结果.方法运行结果;
    响应.推进成功 = true;
    return 响应;
}

void 私有_刷新快照_已加锁(
    结构_工作线程壳状态& 状态,
    const 任务管理工作线程::结构_工作线程一步响应& 响应,
    const 任务节点* 任务,
    const 时间戳 now) noexcept
{
    状态.快照.已启动 = 状态.工作线程壳已启动;
    状态.快照.正在执行 = false;
    状态.快照.已收到请求 = true;
    状态.快照.最近任务根ID = 响应.最新任务控制态.任务根ID;
    状态.快照.累计推进次数 += 1;
    状态.快照.最近推进时间 = now;
    状态.快照.最近宿主任务主键 = 私有_任务主键(任务);
    状态.快照.最近步骤主键 = 私有_任务主键(
        响应.一步结果.当前步骤方法执行数据.当前步骤节点);
    if (状态.快照.最近步骤主键.empty()) {
        状态.快照.最近步骤主键 = 状态.快照.最近宿主任务主键;
    }
    状态.快照.最近方法主键 = 响应.一步结果.当前步骤方法执行数据.当前方法
        ? 响应.一步结果.当前步骤方法执行数据.当前方法->获取主键()
        : std::string{};
    状态.快照.最近下一步去向 = 响应.一步结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::进入收束
        ? "进入收束"
        : (响应.一步结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::保持等待
            ? "保持等待"
            : "进入运行");
    状态.快照.最近总控结果 = 响应.一步结果.治理结果.最近总控结果 == 枚举_任务管理总控结果::宿主进入收束
        ? "宿主进入收束"
        : (响应.一步结果.治理结果.最近总控结果 == 枚举_任务管理总控结果::宿主保持等待
            ? "宿主保持等待"
            : "宿主已进入运行");
    状态.快照.最近缺口归类 = 响应.一步结果.治理结果.当前缺口类型 == 枚举_任务管理缺口类型::方法挂点缺失
        ? "方法挂点缺失"
        : (响应.一步结果.治理结果.当前缺口类型 == 枚举_任务管理缺口类型::无缺口
            ? "无缺口"
            : "工作线程按一步结果归类");
    if (响应.一步结果.存在任务推进回执) {
        状态.快照.最近推进阶段 = 私有_任务推进阶段文本(
            响应.一步结果.当前任务推进回执.阶段);
        状态.快照.最近推进状况 = 私有_任务推进状况文本(
            响应.一步结果.当前任务推进回执.状况);
    } else {
        状态.快照.最近推进阶段 = "未定义";
        状态.快照.最近推进状况 = "未定义";
    }
    状态.快照.最近筹办承接 = "工作线程已生成一步结果";
    状态.快照.最近等待原因 = 响应.最新任务局部运行态.当前等待原因;
    状态.快照.最近一次上行消息数 = static_cast<std::uint64_t>(响应.一步结果.上行消息集.size());
    状态.快照.累计发送上行消息数 += 状态.快照.最近一次上行消息数;
}

void 私有_补齐工作线程一步结果(
    任务管理工作线程::结构_工作线程一步响应& 响应,
    任务节点* 任务,
    任务节点* 管理对象任务,
    需求节点* 需求,
    const 结构_任务根节点& 任务根节点,
    const 结构_任务控制事件& 控制事件,
    const 枚举_任务管理根层重判结果 根层重判结果,
    const 枚举_任务管理执行前门控结果 执行前门控结果,
    const 时间戳 now) noexcept
{
    auto& 一步 = 响应.一步结果;
    auto* 管理任务 = 任务;
    auto* 宿主任务 = 管理对象任务 ? 管理对象任务 : 任务;
    auto* 当前步骤节点 =
        一步.当前步骤方法执行数据.当前步骤节点
            ? 一步.当前步骤方法执行数据.当前步骤节点
            : 宿主任务;
    一步.任务管理治理触发 = true;
    一步.任务管理上位输入已刷新 = true;
    一步.治理结果.最近根层重判结果 = 根层重判结果;
    一步.治理结果.最近执行前门控结果 = 执行前门控结果;
    一步.治理结果.当前主需求 = 需求;
    一步.治理结果.当前管理任务 = 管理任务;
    一步.治理结果.当前宿主任务 = 宿主任务;
    一步.治理结果.当前步骤节点 = 当前步骤节点;
    一步.治理结果.已选中宿主任务 = 宿主任务 != nullptr;

    const bool 禁止执行 = 私有_本轮禁止工作线程执行(
        控制事件,
        根层重判结果,
        执行前门控结果);
    if (!任务) {
        响应.最新任务控制态.队列状态 = 枚举_任务队列状态::等待;
        响应.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::等待条件;
        响应.最新任务局部运行态.当前等待原因 = "缺少任务节点";
        一步.治理结果.当前缺口类型 = 枚举_任务管理缺口类型::宿主任务缺失;
        一步.治理结果.当前下一步去向 = 枚举_任务管理下一步去向::保持等待;
        一步.治理结果.最近总控结果 = 枚举_任务管理总控结果::宿主保持等待;
        结构_执行任务结果 空执行结果{};
        空执行结果.任务执行结果 = 一步.当前步骤方法执行数据;
        空执行结果.方法运行结果 = 一步.当前步骤方法运行结果;
        一步.上行消息集.push_back(私有_构造线程状态上行消息(
            nullptr,
            空执行结果,
            控制事件,
            枚举_任务管理线程运行状态::故障,
            枚举_任务管理线程结束状态::故障结束,
            true,
            now,
            "缺少任务"));
        return;
    }

    if (禁止执行) {
        响应.最新任务控制态.队列状态 = 枚举_任务队列状态::已停止;
        响应.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::已停止;
        响应.最新任务局部运行态.当前等待原因 = "根层或门控禁止继续";
        一步.治理结果.宿主任务旧状态 = 任务类::读取任务状态(宿主任务);
        一步.治理结果.宿主任务新状态 = 枚举_任务状态::挂起;
        一步.治理结果.当前缺口类型 =
            根层重判结果 == 枚举_任务管理根层重判结果::停止退出边界
                ? 枚举_任务管理缺口类型::上位停止约束
                : 枚举_任务管理缺口类型::上位等待约束;
        一步.治理结果.当前下一步去向 = 枚举_任务管理下一步去向::保持等待;
        一步.治理结果.最近总控结果 = 枚举_任务管理总控结果::宿主保持等待;
        结构_执行任务结果 禁止执行结果{};
        禁止执行结果.任务执行结果 = 一步.当前步骤方法执行数据;
        禁止执行结果.方法运行结果 = 一步.当前步骤方法运行结果;
        一步.上行消息集.push_back(私有_构造线程状态上行消息(
            宿主任务,
            禁止执行结果,
            控制事件,
            控制事件.事件类型 == 枚举_任务控制事件类型::停止
                ? 枚举_任务管理线程运行状态::已停止
                : 枚举_任务管理线程运行状态::阻塞,
            控制事件.事件类型 == 枚举_任务控制事件类型::停止
                ? 枚举_任务管理线程结束状态::中断结束
                : 枚举_任务管理线程结束状态::未结束,
            控制事件.事件类型 == 枚举_任务控制事件类型::停止,
            now,
            "禁止执行"));
        return;
    }

    结构_执行任务结果 执行结果{};
    执行结果.任务执行结果 = 一步.当前步骤方法执行数据;
    执行结果.方法运行结果 = 一步.当前步骤方法运行结果;
    if (!一步.存在任务推进回执) {
        一步.当前任务推进回执 = 私有_构造执行推进回执(
            宿主任务,
            需求,
            执行结果);
        一步.存在任务推进回执 = true;
    }
    auto& 推进回执 = 一步.当前任务推进回执;
    auto* 上行任务 = 宿主任务;
    const bool 仅任务管理内部换步 = false;
    const bool 回执表示等待既有子需求 =
        推进回执.状况 == 任务模块::筹办::枚举_任务推进状况::存在活动子需求;
    const bool 回执表示父需求已满足 =
        推进回执.状况 == 任务模块::筹办::枚举_任务推进状况::父需求已满足;
    const bool 执行结果缺最小条件 =
        !回执表示等待既有子需求
        && !回执表示父需求已满足
        && 任务结果缺条件_最小_v0(执行结果.方法运行结果);
    const bool 执行输出需要派生需求 =
        !回执表示等待既有子需求
        && !回执表示父需求已满足
        && 私有_执行输出需要派生原子需求(执行结果);
    const bool 存在阻塞性派生需求 = 执行结果缺最小条件 || 执行输出需要派生需求;
    {
        std::ostringstream 输出;
        输出 << "任务管理工作线程/执行输出派生判定"
            << " | 任务=" << (管理任务 ? 管理任务->获取主键() : std::string{})
            << " | 管理对象任务=" << (管理对象任务 ? 管理对象任务->获取主键() : std::string{})
            << " | 上行任务=" << (上行任务 ? 上行任务->获取主键() : std::string{})
            << " | 当前方法=" << (一步.当前步骤方法执行数据.当前方法
                ? 一步.当前步骤方法执行数据.当前方法->获取主键()
                : std::string{})
            << " | 推进状况=" << 私有_任务推进状况文本(推进回执.状况)
            << " | 等待既有子需求=" << (回执表示等待既有子需求 ? 1 : 0)
            << " | 父需求已满足=" << (回执表示父需求已满足 ? 1 : 0)
            << " | 缺最小条件=" << (执行结果缺最小条件 ? 1 : 0)
            << " | 执行输出需要派生需求=" << (执行输出需要派生需求 ? 1 : 0);
        项目运行日志(输出.str());
    }

    auto 推导状态 = 私有_从任务推进回执推导界面任务状态(
        推进回执,
        一步.当前步骤方法执行数据,
        一步.当前步骤方法运行结果);
    if (存在阻塞性派生需求
        && (推导状态 == 枚举_任务状态::完成
            || 推导状态 == 枚举_任务状态::失败)) {
        推导状态 = 枚举_任务状态::等待中;
    }
    私有_填充任务层回执到治理结果(
        一步.治理结果,
        宿主任务,
        推进回执,
        推导状态);
    if (!一步.治理结果.当前方法) {
        一步.治理结果.当前方法 = 一步.当前步骤方法执行数据.当前方法;
    }

    if (推导状态 == 枚举_任务状态::完成) {
        响应.最新任务控制态.队列状态 = 枚举_任务队列状态::已结算;
        响应.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::局部完成;
        响应.最新任务局部运行态.局部完成度 = 10000;
        // 这里表示“存在任务状态推进建议”，真实提交仍由提交类本能方法完成。
        一步.治理结果.已推进任务状态 = true;
        一步.治理结果.当前缺口类型 = 枚举_任务管理缺口类型::无缺口;
        一步.治理结果.当前下一步去向 = 枚举_任务管理下一步去向::进入收束;
        一步.治理结果.最近总控结果 = 枚举_任务管理总控结果::宿主进入收束;
    } else if (推导状态 == 枚举_任务状态::待重筹办
        || 推导状态 == 枚举_任务状态::就绪
        || 推导状态 == 枚举_任务状态::排队中) {
        响应.最新任务控制态.队列状态 = 枚举_任务队列状态::可运行;
        响应.最新任务控制态.已派发 = false;
        响应.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::当前步骤可执行;
        响应.最新任务局部运行态.当前等待原因 = 推进回执.摘要;
        一步.治理结果.当前缺口类型 = 枚举_任务管理缺口类型::无缺口;
        一步.治理结果.当前下一步去向 =
            推导状态 == 枚举_任务状态::待重筹办
                ? 枚举_任务管理下一步去向::回到重筹办
                : 枚举_任务管理下一步去向::进入运行;
        一步.治理结果.最近总控结果 = 枚举_任务管理总控结果::宿主已进入运行;
    } else {
        响应.最新任务控制态.队列状态 = 枚举_任务队列状态::等待;
        响应.最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::等待条件;
        响应.最新任务局部运行态.当前等待原因 = 推进回执.摘要.empty()
            ? 私有_执行结果等待原因(
                一步.当前步骤方法执行数据,
                一步.当前步骤方法运行结果)
            : 推进回执.摘要;
        一步.治理结果.当前缺口类型 =
            执行输出需要派生需求 || 一步.当前步骤方法执行数据.当前方法
                ? 枚举_任务管理缺口类型::任务运行中
                : 枚举_任务管理缺口类型::任务待启动;
        一步.治理结果.当前下一步去向 = 枚举_任务管理下一步去向::保持等待;
        一步.治理结果.最近总控结果 = 枚举_任务管理总控结果::宿主保持等待;
    }

    一步.上行消息集.push_back(私有_构造线程状态上行消息(
        宿主任务,
        执行结果,
        控制事件,
        枚举_任务管理线程运行状态::推进中,
        枚举_任务管理线程结束状态::未结束,
        false,
        now,
        "推进中"));

    bool 实际已上报派生需求 = false;
    auto 尝试上报派生需求 = [&]() noexcept {
        auto 派生需求消息 = 私有_构造执行缺失原子需求消息(
            上行任务,
            执行结果,
            &推进回执,
            now);
        if (派生需求消息.类型 != 枚举_任务管理上行消息类型::未定义) {
            一步.上行消息集.push_back(std::move(派生需求消息));
            实际已上报派生需求 = true;
        }
    };

    if (!仅任务管理内部换步) {
        if (执行结果缺最小条件) {
            尝试上报派生需求();
        }
        if (执行输出需要派生需求
            && !执行结果缺最小条件) {
            尝试上报派生需求();
        }
        auto 上行消息 = 私有_构造结果状态上行消息(上行任务, 执行结果, 推进回执, now);
        一步.上行消息集.push_back(上行消息);
    }
    const auto 最终运行状态 =
        推导状态 == 枚举_任务状态::完成
            ? 枚举_任务管理线程运行状态::已停止
            : (推导状态 == 枚举_任务状态::等待中 || 推导状态 == 枚举_任务状态::挂起
                ? 枚举_任务管理线程运行状态::等待中
                : 枚举_任务管理线程运行状态::推进中);
    const auto 最终结束状态 =
        推导状态 == 枚举_任务状态::完成
            ? 枚举_任务管理线程结束状态::正常结束
            : 枚举_任务管理线程结束状态::未结束;
    一步.上行消息集.push_back(私有_构造线程状态上行消息(
        宿主任务,
        执行结果,
        控制事件,
        最终运行状态,
        最终结束状态,
        推导状态 == 枚举_任务状态::完成,
        now,
        "回报"));
    结构_任务推进事件 推进事件{};
    推进事件.任务根ID = 任务根节点.任务根ID;
    推进事件.事件类型 =
        实际已上报派生需求
            ? 枚举_任务推进事件类型::派生需求上报
            : (推导状态 == 枚举_任务状态::完成
                ? 枚举_任务推进事件类型::最终结果返回
                : 枚举_任务推进事件类型::当前步骤阻塞);
    推进事件.当前步骤指针 = reinterpret_cast<std::uintptr_t>(当前步骤节点);
    推进事件.结果指针 = 0;
    推进事件.等待原因 = 响应.最新任务局部运行态.当前等待原因;
    推进事件.说明 = 推进回执.摘要.empty()
        ? 一步.当前步骤方法执行数据.方法运行说明
        : 推进回执.摘要;
    同步工作线程事件语义槽(推进事件);
    一步.推进事件列表.push_back(推进事件);
}

} // namespace

namespace 任务管理工作线程 {

bool 确保任务管理工作线程壳已启动() noexcept
{
    auto& 状态 = 私有_壳状态();
    std::lock_guard<std::mutex> 锁(状态.锁);
    状态.工作线程壳已启动 = true;
    状态.快照.已启动 = true;
    return true;
}

bool 提交任务工作包(
    自我类& 自我对象,
    const 任务管理线程协议::结构_任务工作包& 工作包,
    任务管理线程协议::结构_任务工作结果* 输出) noexcept
{
    (void)确保任务管理工作线程壳已启动();
    const auto now = 私有_时间(工作包.当前时间);
    任务管理线程协议::结构_任务工作结果 局部结果{};
    auto* 有效输出 = 输出 ? 输出 : &局部结果;
    *有效输出 = {};
    有效输出->请求ID = 工作包.请求ID;
    有效输出->工作包ID = 工作包.工作包ID;
    有效输出->幂等键 = 工作包.幂等键;
    有效输出->任务信息节点 = 工作包.任务信息节点;
    有效输出->任务虚拟存在 = 工作包.任务虚拟存在;
    有效输出->来源需求 = 工作包.来源需求;
    有效输出->最新任务控制态 = 工作包.任务控制态;
    有效输出->最新任务局部运行态 = 工作包.任务局部运行态;

    auto 根节点 = 工作包.任务根节点;
    auto 控制态 = 工作包.任务控制态;
    auto 局部运行态 = 工作包.任务局部运行态;
    auto* 管理任务 = reinterpret_cast<任务节点*>(工作包.任务信息节点);
    if (管理任务 && 根节点.管理对象任务指针 == 0) {
        根节点.管理对象任务指针 = reinterpret_cast<std::uintptr_t>(管理任务);
    }
    {
        auto& 状态 = 私有_壳状态();
        std::lock_guard<std::mutex> 锁(状态.锁);
        状态.快照.已启动 = true;
        状态.快照.正在执行 = true;
        状态.快照.已收到请求 = true;
        状态.快照.最近请求ID = 工作包.请求ID;
        状态.快照.最近工作包ID = 工作包.工作包ID;
        状态.快照.最近任务根ID = 根节点.任务根ID;
        状态.快照.最近开始时间 = now;
        状态.快照.最近推进时间 = now;
        状态.快照.最近宿主任务主键 = 私有_任务主键(管理任务);
        状态.快照.最近任务虚拟存在主键 =
            工作包.任务虚拟存在 ? 工作包.任务虚拟存在->获取主键() : std::string{};
        状态.快照.最近需求主键 =
            工作包.来源需求 ? 工作包.来源需求->获取主键() : std::string{};
        状态.快照.累计收到请求数 += 1;
        状态.快照.累计收到工作包数 += 1;
        if (工作包.控制事件.事件类型 != 枚举_任务控制事件类型::未定义) {
            状态.快照.累计收到控制请求数 += 1;
        }
    }

    const auto 写失败结果 = [&](I64 错误码, const std::string& 说明) noexcept {
        有效输出->已处理 = true;
        有效输出->推进成功 = false;
        有效输出->任务失败 = true;
        有效输出->错误码 = 错误码;
        有效输出->错误说明 = 说明;
        有效输出->等待原因 = 说明;
        有效输出->摘要 = 说明;
        有效输出->最新任务控制态 = 控制态;
        有效输出->最新任务控制态.队列状态 = 枚举_任务队列状态::等待;
        有效输出->最新任务局部运行态 = 局部运行态;
        有效输出->最新任务局部运行态.当前状态 = 枚举_任务局部运行状态::等待条件;
        有效输出->最新任务局部运行态.当前等待原因 = 说明;
        结构_任务推进事件 事件{};
        事件.任务根ID = 根节点.任务根ID;
        事件.事件类型 = 枚举_任务推进事件类型::异常上报;
        事件.当前步骤指针 = reinterpret_cast<std::uintptr_t>(管理任务);
        事件.等待原因 = 说明;
        事件.说明 = 说明;
        同步工作线程事件语义槽(事件);
        有效输出->推进事件列表.push_back(事件);
        auto& 状态 = 私有_壳状态();
        std::lock_guard<std::mutex> 锁(状态.锁);
        状态.快照.正在执行 = false;
        状态.快照.故障 = true;
        状态.快照.累计处理工作包数 += 1;
        状态.快照.累计失败数 += 1;
        状态.快照.最近结束时间 = now;
        状态.快照.最近错误说明 = 说明;
        状态.快照.最近等待原因 = 说明;
    };

    if (!管理任务) {
        写失败结果(-1001, "缺少任务信息节点");
        return false;
    }
    if (!工作包.任务虚拟存在) {
        写失败结果(-1002, "缺少任务虚拟存在，界面线程未完成绑定");
        return false;
    }
    if (根节点.任务根ID == 0) {
        写失败结果(-1003, "缺少任务根ID");
        return false;
    }
    if (工作包.执行前门控结果 == 枚举_任务管理执行前门控结果::未定义) {
        写失败结果(-1004, "缺少执行前门控结果");
        return false;
    }
    if (!任务类::任务允许派发(管理任务)) {
        写失败结果(-1005, "任务信息节点当前不可派发");
        return false;
    }
    if (!工作包.允许筹办 && !工作包.允许执行方法) {
        using enum 任务管理线程协议::枚举_任务推进模式;
        if (工作包.推进模式 == 只创建
            || 工作包.推进模式 == 只同步回执
            || 工作包.推进模式 == 只状态推进) {
            有效输出->已处理 = true;
            有效输出->推进成功 = true;
            有效输出->任务完成 = false;
            有效输出->任务失败 = false;
            有效输出->需要等待 = false;
            有效输出->最新任务控制态 = 控制态;
            有效输出->最新任务局部运行态 = 局部运行态;
            有效输出->摘要 = "工作包仅承接任务域请求，本轮不调用筹办或执行";
            return true;
        }
        写失败结果(-1006, "工作包未授权筹办或方法执行");
        有效输出->任务失败 = false;
        有效输出->需要等待 = true;
        return false;
    }

    auto 响应 = 私有_工作线程执行当前任务方法(
        自我对象,
        工作包,
        根节点,
        &控制态,
        &局部运行态,
        now,
        工作包.控制事件,
        工作包.根层重判结果,
        工作包.执行前门控结果);
    私有_补齐工作线程一步结果(
        响应,
        管理任务,
        私有_任务根节点取管理对象任务(根节点),
        reinterpret_cast<需求节点*>(工作包.来源需求),
        根节点,
        工作包.控制事件,
        工作包.根层重判结果,
        工作包.执行前门控结果,
        now);

    有效输出->已处理 = true;
    有效输出->推进成功 = 响应.推进成功;
    有效输出->被门控阻断 = 私有_本轮禁止工作线程执行(
        工作包.控制事件,
        工作包.根层重判结果,
        工作包.执行前门控结果);
    有效输出->已执行筹办 = 响应.一步结果.存在任务推进回执;
    有效输出->已执行方法 = 响应.一步结果.已执行当前步骤方法;
    有效输出->任务完成 =
        响应.一步结果.治理结果.宿主任务新状态 == 枚举_任务状态::完成;
    有效输出->任务失败 =
        响应.一步结果.治理结果.宿主任务新状态 == 枚举_任务状态::失败
        || 响应.一步结果.治理结果.宿主任务新状态 == 枚举_任务状态::无法执行;
    有效输出->需要等待 =
        响应.一步结果.治理结果.宿主任务新状态 == 枚举_任务状态::等待中
        || 响应.一步结果.治理结果.宿主任务新状态 == 枚举_任务状态::挂起;
    有效输出->产生派生需求 = 私有_回报包含派生需求消息(响应);
    有效输出->建议进入收束 =
        响应.一步结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::进入收束;
    有效输出->建议界面线程下一轮 =
        响应.一步结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::进入运行
        || 响应.一步结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::保持运行
        || 响应.一步结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::回到重筹办
        || 响应.一步结果.治理结果.当前下一步去向 == 枚举_任务管理下一步去向::绑定方法;
    有效输出->建议自我线程重判 = 有效输出->产生派生需求 || 有效输出->任务完成;
    有效输出->最新任务控制态 = 响应.最新任务控制态;
    有效输出->最新任务局部运行态 = 响应.最新任务局部运行态;
    有效输出->治理结果 = 响应.一步结果.治理结果;
    有效输出->存在任务推进回执 = 响应.一步结果.存在任务推进回执;
    有效输出->任务推进回执 = 响应.一步结果.当前任务推进回执;
    有效输出->存在方法执行数据 = 响应.一步结果.存在当前步骤方法执行数据;
    有效输出->方法执行数据 = 响应.一步结果.当前步骤方法执行数据;
    有效输出->方法运行结果 = 响应.一步结果.当前步骤方法运行结果;
    有效输出->推进事件列表 = std::move(响应.一步结果.推进事件列表);
    有效输出->上行消息集 = std::move(响应.一步结果.上行消息集);
    有效输出->下一步去向 = 响应.一步结果.治理结果.当前下一步去向;
    有效输出->最近总控结果 = 响应.一步结果.治理结果.最近总控结果;
    有效输出->任务管理上位输入已刷新 = 响应.一步结果.任务管理上位输入已刷新;
    有效输出->任务管理治理触发 = 响应.一步结果.任务管理治理触发;
    有效输出->等待原因 = 响应.最新任务局部运行态.当前等待原因;
    有效输出->摘要 = 有效输出->等待原因.empty()
        ? std::string("任务工作包已处理一轮")
        : 有效输出->等待原因;
    有效输出->错误码 = 本能动作运行结果值(有效输出->方法运行结果);

    {
        auto& 状态 = 私有_壳状态();
        std::lock_guard<std::mutex> 锁(状态.锁);
        状态.快照.正在执行 = false;
        状态.快照.累计处理工作包数 += 1;
        状态.快照.累计推进次数 += 1;
        if (有效输出->推进成功) {
            状态.快照.累计成功推进数 += 1;
        } else {
            状态.快照.累计失败数 += 1;
        }
        if (有效输出->产生派生需求) {
            状态.快照.累计派生需求数 += 1;
        }
        状态.快照.最近结束时间 = now;
        私有_刷新快照_已加锁(状态, 响应, 管理任务, now);
    }
    return 有效输出->推进成功;
}

bool 读取任务管理工作线程快照(结构_工作线程实例快照* 输出) noexcept
{
    if (!输出) {
        return false;
    }
    auto& 状态 = 私有_壳状态();
    std::lock_guard<std::mutex> 锁(状态.锁);
    *输出 = 状态.快照;
    return true;
}

bool 计算任务管理界面优先级结果(
    const 自我类& 自我对象,
    结构_界面优先级结果* 输出) noexcept
{
    if (!输出) {
        return false;
    }
    auto* 任务 = 自我对象.获取当前主任务();

    *输出 = {};
    输出->当前最高优先级任务 = 任务;
    if (!任务) {
        return false;
    }
    const auto 调度优先级 = 任务类::读取任务调度优先级(任务);
    输出->调度优先级 = 调度优先级 != 0
        ? 调度优先级
        : (任务类::读取任务基准优先级(任务) + 任务类::读取任务局部优先级偏移(任务));
    输出->是否可执行 =
        !任务类::任务状态已终结(任务类::读取任务状态(任务));

    if (auto* 需求 = reinterpret_cast<需求节点*>(任务->主信息.对应需求.指针)) {
        输出->是否安全方向任务 = 需求->主信息.安全权重 >= 需求->主信息.服务权重;
        输出->是否服务方向任务 = 需求->主信息.服务权重 > 需求->主信息.安全权重;
    }
    return true;
}

void 停止任务管理工作线程壳() noexcept
{
    auto& 状态 = 私有_壳状态();
    std::lock_guard<std::mutex> 锁(状态.锁);
    状态.工作线程壳已启动 = false;
    状态.快照.已启动 = false;
    状态.快照.正在执行 = false;
}

} // namespace 任务管理工作线程
