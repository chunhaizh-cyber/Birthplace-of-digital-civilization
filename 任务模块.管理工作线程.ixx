namespace {

using 任务节点 = 任务类::节点类;
using 需求节点 = 需求类::节点类;
using 方法节点 = 方法类::节点类;

struct 结构_工作线程壳状态 {
    std::mutex 锁{};
    任务管理工作线程::结构_工作线程实例快照 快照{};
    std::deque<任务管理工作线程::结构_工作线程界面回报记录> 界面回报列表{};
    std::deque<结构_任务管理上行消息> 上行消息直达队列{};
    std::deque<结构_任务根节点> 负载等待任务队列{};
    std::uint64_t 下一个请求ID = 1;
    bool 界面线程壳已启动 = false;
    bool 工作线程壳已启动 = false;
    bool 正在恢复负载等待任务 = false;
};

enum class 枚举_界面线程工作调度动作 : std::uint8_t {
    挂起等待 = 0,
    开启下一轮 = 1,
    结束调度 = 2,
};

struct 结构_界面线程工作调度决策 {
    枚举_界面线程工作调度动作 动作 = 枚举_界面线程工作调度动作::挂起等待;
    std::string 原因{};
};

结构_工作线程壳状态& 私有_壳状态() noexcept
{
    static 结构_工作线程壳状态 状态{};
    return 状态;
}

时间戳 私有_时间(时间戳 now) noexcept
{
    return now != 0 ? now : 结构体_时间戳::当前_微秒();
}

std::string 私有_任务主键(const 任务节点* 节点) noexcept
{
    return 节点 ? 节点->获取主键() : std::string{};
}

std::string 私有_需求主键(const 需求节点* 节点) noexcept
{
    return 节点 ? 节点->获取主键() : std::string{};
}

constexpr std::size_t 私有_工作线程并发限额() noexcept
{
    return 1;
}

void 私有_刷新负载等待排队数_已加锁(结构_工作线程壳状态& 状态) noexcept
{
    状态.快照.当前排队数 = static_cast<std::uint64_t>(状态.负载等待任务队列.size());
}

任务节点* 私有_按主键解析任务节点(const std::string& 主键) noexcept
{
    if (主键.empty()) {
        return nullptr;
    }
    return reinterpret_cast<任务节点*>(世界树.基础信息().查找主键(主键));
}

任务节点* 私有_解析任务引用(const 可解析引用<任务节点类>& 引用) noexcept
{
    if (引用.指针) {
        return reinterpret_cast<任务节点*>(引用.指针);
    }
    return 私有_按主键解析任务节点(引用.主键);
}

const 任务节点* 私有_归一到任务头结点(const 任务节点* 节点) noexcept
{
    auto* 当前 = 节点;
    while (当前) {
        if (当前->主信息.节点种类 == 枚举_任务节点种类::头结点) {
            return 当前;
        }
        当前 = static_cast<const 任务节点*>(当前->父);
    }
    return nullptr;
}

任务节点* 私有_查找最新步骤节点(任务节点* 任务头) noexcept
{
    if (!任务头) {
        return nullptr;
    }
    任务头 = const_cast<任务节点*>(私有_归一到任务头结点(任务头));
    if (!任务头) {
        return nullptr;
    }

    std::vector<任务节点*> 待查{ 任务头 };
    任务节点* 最新步骤 = nullptr;
    时间戳 最新时间 = 0;
    while (!待查.empty()) {
        auto* 当前 = 待查.back();
        待查.pop_back();
        if (!当前) {
            continue;
        }
        if (当前 != 任务头 && 当前->主信息.节点种类 == 枚举_任务节点种类::步骤节点) {
            const auto 当前时间 = 当前->主信息.完成时间 != 0
                ? 当前->主信息.完成时间
                : (当前->主信息.启动时间 != 0 ? 当前->主信息.启动时间 : 当前->主信息.创建时间);
            if (!最新步骤 || 当前时间 >= 最新时间) {
                最新步骤 = 当前;
                最新时间 = 当前时间;
            }
        }
        if (!当前->子) {
            continue;
        }
        auto* 首子 = static_cast<任务节点*>(当前->子);
        auto* 子 = 首子;
        do {
            if (子) {
                待查.push_back(子);
            }
            子 = 子 ? static_cast<任务节点*>(子->下) : nullptr;
        } while (子 && 子 != 首子);
    }
    return 最新步骤;
}

任务节点* 私有_任务根节点取任务(const 结构_任务根节点& 根节点) noexcept
{
    if (根节点.世界任务根指针 != 0) {
        return reinterpret_cast<任务节点*>(根节点.世界任务根指针);
    }
    if (根节点.父任务指针 != 0) {
        return reinterpret_cast<任务节点*>(根节点.父任务指针);
    }
    return nullptr;
}

任务节点* 私有_任务根节点取管理对象任务(const 结构_任务根节点& 根节点) noexcept
{
    return 根节点.管理对象任务指针 != 0
        ? reinterpret_cast<任务节点*>(根节点.管理对象任务指针)
        : nullptr;
}

需求节点* 私有_任务根节点取需求(const 结构_任务根节点& 根节点) noexcept
{
    return 根节点.来源需求指针 != 0
        ? reinterpret_cast<需求节点*>(根节点.来源需求指针)
        : nullptr;
}

bool 私有_任务已在需求列表(const 需求节点* 需求, const 任务节点* 任务) noexcept
{
    if (!需求 || !任务) {
        return false;
    }
    const auto 主键 = 私有_任务主键(任务);
    for (const auto& 项 : 需求->主信息.任务列表) {
        if (项.指针 == reinterpret_cast<const 任务节点类*>(任务)
            || (!主键.empty() && 项.主键 == 主键)) {
            return true;
        }
    }
    return false;
}

void 私有_绑定任务需求关系(任务节点* 任务, 需求节点* 需求) noexcept
{
    if (!任务 || !需求) {
        return;
    }

    任务->主信息.对应需求.指针 = reinterpret_cast<需求节点类*>(需求);
    任务->主信息.对应需求.主键 = 私有_需求主键(需求);
    任务->主信息.目标状态.指针 = 需求->主信息.需求状态.指针;
    任务->主信息.目标状态.主键 = 需求->主信息.需求状态.主键;
    const auto 基准优先级 = 需求->主信息.安全权重 + 需求->主信息.服务权重;
    const auto 局部优先级偏移 = 任务类::读取任务局部优先级偏移(任务);
    (void)任务类::写入任务基准优先级(任务, 基准优先级);
    (void)任务类::写入任务调度优先级(任务, 基准优先级 + 局部优先级偏移);

    任务类::确保任务初始状态(任务);
    if (任务类::读取任务当前阶段(任务) == 枚举_任务阶段::未定义) {
        (void)任务类::写入任务当前阶段(任务, 枚举_任务阶段::筹办);
    }
    if (任务类::读取任务角色(任务) == 枚举_任务角色::未定义) {
        (void)任务类::写入任务角色(
            任务,
            需求->子节点数量 > 0
            ? 枚举_任务角色::需求管理任务
            : 枚举_任务角色::需求执行任务);
    }
    if (!私有_任务已在需求列表(需求, 任务)) {
        可解析引用<任务节点类> 引用{};
        引用.指针 = reinterpret_cast<任务节点类*>(任务);
        引用.主键 = 私有_任务主键(任务);
        需求->主信息.任务列表.push_back(引用);
    }
    if (!需求->主信息.对应任务.有效()) {
        需求->主信息.对应任务.指针 = reinterpret_cast<任务节点类*>(任务);
        需求->主信息.对应任务.主键 = 私有_任务主键(任务);
    }
    (void)任务类::同步任务运行镜像特征(任务);
}

任务节点* 私有_从需求任务列表取任务(const 需求节点* 需求) noexcept
{
    if (!需求) {
        return nullptr;
    }
    if (auto* 任务 = reinterpret_cast<任务节点*>(需求->主信息.对应任务.指针)) {
        return 任务;
    }
    for (const auto& 引用 : 需求->主信息.任务列表) {
        if (auto* 任务 = reinterpret_cast<任务节点*>(引用.指针)) {
            return 任务;
        }
    }
    return nullptr;
}

任务节点* 私有_消息取任务(const 任务管理工作线程::结构_任务信息消息& 消息) noexcept
{
    if (消息.新任务) {
        return 消息.新任务;
    }
    return 私有_从需求任务列表取任务(消息.任务目标);
}

