namespace {

using 任务节点 = 任务类::节点类;
using 需求节点 = 需求类::节点类;
using 方法节点 = 方法类::节点类;

struct 结构_工作线程壳状态 {
    std::mutex 锁{};
    任务管理工作线程::结构_工作线程实例快照 快照{};
    bool 工作线程壳已启动 = false;
};

结构_工作线程壳状态& 私有_壳状态() noexcept
{
    static 结构_工作线程壳状态 状态{};
    return 状态;
}

时间戳 私有_时间(时间戳 now) noexcept
{
    return now != 0 ? now : 结构体_时间戳::当前_微秒();
}

std::string 私有_任务主键(const 任务节点* 节点) noexcept
{
    return 节点 ? 节点->获取主键() : std::string{};
}

std::string 私有_需求主键(const 需求节点* 节点) noexcept
{
    return 节点 ? 节点->获取主键() : std::string{};
}

任务节点* 私有_任务根节点取任务(const 结构_任务根节点& 根节点) noexcept
{
    if (根节点.世界任务根指针 != 0) {
        return reinterpret_cast<任务节点*>(根节点.世界任务根指针);
    }
    if (根节点.父任务指针 != 0) {
        return reinterpret_cast<任务节点*>(根节点.父任务指针);
    }
    return nullptr;
}

任务节点* 私有_任务根节点取管理对象任务(const 结构_任务根节点& 根节点) noexcept
{
    return 根节点.管理对象任务指针 != 0
        ? reinterpret_cast<任务节点*>(根节点.管理对象任务指针)
        : nullptr;
}

void 私有_写入任务节点引用(
    可解析引用<任务节点类>& 输出,
    任务节点* 节点) noexcept
{
    输出.指针 = reinterpret_cast<任务节点类*>(节点);
    输出.主键 = 节点 ? 节点->获取主键() : std::string{};
}

void 私有_写入需求节点引用(
    可解析引用<需求节点类>& 输出,
    需求节点* 节点) noexcept
{
    输出.指针 = reinterpret_cast<需求节点类*>(节点);
    输出.主键 = 节点 ? 节点->获取主键() : std::string{};
}

void 私有_写入方法节点引用(
    可解析引用<方法节点类>& 输出,
    方法类::节点类* 节点) noexcept
{
    输出.指针 = reinterpret_cast<方法节点类*>(节点);
    输出.主键 = 节点 ? 节点->获取主键() : std::string{};
}

void 私有_写入场景节点引用(
    可解析引用<场景节点类>& 输出,
    场景节点类* 节点) noexcept
{
    输出.指针 = 节点;
    输出.主键 = 节点 ? 节点->获取主键() : std::string{};
}

void 私有_写入状态节点引用(
    可解析引用<状态节点类>& 输出,
    状态节点类* 节点) noexcept
{
    输出.指针 = 节点;
    输出.主键 = 节点 ? 节点->获取主键() : std::string{};
}

bool 私有_语素入口相同(const 语素入口节点类* 左, const 语素入口节点类* 右) noexcept
{
    if (左 == 右) return true;
    if (!左 || !右) return false;
    return 左->获取主键() == 右->获取主键();
}

const 语素入口节点类* 私有_任务语义特征词(const char* 名称) noexcept
{
    return 名称 ? 语素集.添加信息入口词(名称, 枚举_信息入口类型::特征模板入口) : nullptr;
}

const 语素入口节点类* 私有_任务语义状态词(const char* 名称) noexcept
{
    return 名称 ? 语素集.添加信息入口词(名称, 枚举_信息入口类型::状态模板入口) : nullptr;
}

