module;

#include <condition_variable>
#include <deque>
#include <future>
#include <memory>
#include <mutex>
#include <string>
#include <thread>
#include <utility>
#include <vector>

export module 任务模块.管理工作线程;

import 自我模块;
import 任务模块.实体;
import 任务模块.工作线程协议;
import 任务管理任务模块;
import 任务模块.最小回写器;
import 任务模块.运行包;

export namespace 任务管理工作线程 {

struct 结构_工作线程桥接结果 {
    结构_线程消息处理合同 当前消息合同{};
    结构_任务控制事件 已消费控制事件{};
    bool 已消费控制请求 = false;
    结构_任务管理控制请求 已消费控制请求对象{};
    结构_任务管理控制承接记录 当前控制承接{};
    std::vector<结构_任务推进事件> 推进事件列表{};
    std::vector<结构_任务管理上行消息> 上行消息集{};
    bool 任务管理上位输入已刷新 = false;
    枚举_任务管理根层重判结果 根层重判结果 = 枚举_任务管理根层重判结果::未定义;
    枚举_任务管理执行前门控结果 执行前门控结果 = 枚举_任务管理执行前门控结果::未定义;
    std::string 上层反馈摘要{};
    bool 任务管理治理触发 = false;
    bool 已生成一步治理任务包 = false;
    bool 已生成回流结算包 = false;
    bool 已写入动态节点 = false;
    bool 已写入因果候选 = false;
    bool 已构建学习调度快照 = false;
    bool 已选中学习任务 = false;
    bool 已执行学习任务 = false;
    std::uint64_t 当前学习账本ID = 0;
    std::string 学习调度摘要{};
    std::string 学习执行摘要{};
    std::string 学习反馈摘要{};
    结构_任务管理结果 治理结果{};
    任务运行包::结构_一步治理任务包 一步治理请求包{};
    任务最小回写器::结构_最小回写结果 最小回写结果{};
};

struct 结构_工作线程推进响应 {
    bool 推进成功 = false;
    结构_任务控制态 最新任务控制态{};
    结构_任务局部运行态 最新任务局部运行态{};
    结构_工作线程桥接结果 桥接结果{};
    std::string 摘要{};
};

struct 结构_工作线程实例快照 {
    bool 已启动 = false;
    bool 正在执行 = false;
    bool 已收到请求 = false;
    std::uint64_t 最近任务根ID = 0;
    std::uint64_t 累计推进次数 = 0;
    std::uint64_t 累计收到请求数 = 0;
    std::uint64_t 累计收到控制请求数 = 0;
    std::uint64_t 累计发送上行消息数 = 0;
    std::uint64_t 最近一次上行消息数 = 0;
    std::uint64_t 累计学习执行次数 = 0;
    std::uint64_t 当前排队数 = 0;
    时间戳 最近推进时间 = 0;
    std::string 最近摘要{};
    std::string 最近学习摘要{};
};

bool 确保任务管理工作线程壳已启动() noexcept;

bool 通过工作线程壳推进任务管理工作线程(
    自我类& 自我对象,
    const 结构_任务根节点& 任务根节点,
    结构_任务控制态* 任务控制态,
    结构_任务局部运行态* 任务局部运行态,
    时间戳 now,
    const 结构_任务控制事件& 控制事件,
    枚举_任务管理根层重判结果 根层重判结果,
    枚举_任务管理执行前门控结果 执行前门控结果,
    const std::string& 上层反馈摘要,
    const std::string& 调用点 = "任务管理工作线程::通过工作线程壳推进任务管理工作线程",
    结构_工作线程桥接结果* 输出 = nullptr) noexcept;

bool 读取任务管理工作线程快照(结构_工作线程实例快照* 输出) noexcept;

void 停止任务管理工作线程壳() noexcept;

bool 推进任务管理工作线程(
    自我类& 自我对象,
    const 结构_任务根节点& 任务根节点,
    结构_任务控制态* 任务控制态,
    结构_任务局部运行态* 任务局部运行态,
    时间戳 now,
    const 结构_任务控制事件& 控制事件,
    枚举_任务管理根层重判结果 根层重判结果,
    枚举_任务管理执行前门控结果 执行前门控结果,
    const std::string& 上层反馈摘要,
    const std::string& 调用点 = "任务管理工作线程::推进任务管理工作线程",
    结构_工作线程桥接结果* 输出 = nullptr) noexcept;

} // namespace 任务管理工作线程

namespace {

struct 结构_工作线程壳请求 {
    自我类* 自我对象 = nullptr;
    结构_任务根节点 任务根节点{};
    结构_任务控制态 任务控制态{};
    结构_任务局部运行态 任务局部运行态{};
    时间戳 now = 0;
    结构_任务控制事件 控制事件{};
    枚举_任务管理根层重判结果 根层重判结果 = 枚举_任务管理根层重判结果::未定义;
    枚举_任务管理执行前门控结果 执行前门控结果 = 枚举_任务管理执行前门控结果::未定义;
    std::string 上层反馈摘要{};
    std::string 调用点{};
    std::promise<任务管理工作线程::结构_工作线程推进响应> 完成承诺{};
};

struct 结构_工作线程壳状态 {
    std::mutex 锁{};
    std::condition_variable 条件{};
    bool 已启动 = false;
    bool 停止请求 = false;
    bool 正在执行 = false;
    std::deque<std::unique_ptr<结构_工作线程壳请求>> 队列{};
    std::thread 线程{};
    任务管理工作线程::结构_工作线程实例快照 快照{};
};

inline 结构_工作线程壳状态& 私有_任务管理工作线程壳() noexcept
{
    static 结构_工作线程壳状态 壳{};
    return 壳;
}

inline void 私有_更新工作线程壳快照_已加锁(
    const bool 已收到请求,
    const bool 正在执行,
    const std::uint64_t 最近任务根ID,
    const 时间戳 最近推进时间,
    const std::string& 最近摘要)
{
    auto& 壳 = 私有_任务管理工作线程壳();
    auto& 快照 = 壳.快照;
    快照.已启动 = 壳.已启动;
    快照.正在执行 = 正在执行;
    快照.已收到请求 = 已收到请求;
    快照.最近任务根ID = 最近任务根ID;
    快照.最近推进时间 = 最近推进时间;
    快照.最近摘要 = 最近摘要;
    快照.当前排队数 = static_cast<std::uint64_t>(壳.队列.size());
}

inline void 私有_任务管理工作线程壳线程主体() noexcept
{
    auto& 壳 = 私有_任务管理工作线程壳();
    for (;;) {
        std::unique_ptr<结构_工作线程壳请求> 当前请求{};
        {
            std::unique_lock 锁(壳.锁);
            壳.条件.wait(
                锁,
                [&壳] { return 壳.停止请求 || !壳.队列.empty(); });
            if (壳.停止请求 && 壳.队列.empty()) {
                壳.正在执行 = false;
                私有_更新工作线程壳快照_已加锁(
                    false,
                    false,
                    壳.快照.最近任务根ID,
                    壳.快照.最近推进时间,
                    "任务管理工作线程壳已停止");
                return;
            }

            当前请求 = std::move(壳.队列.front());
            壳.队列.pop_front();
            壳.正在执行 = true;
            私有_更新工作线程壳快照_已加锁(
                true,
                true,
                当前请求 ? 当前请求->任务根节点.任务根ID : 0,
                当前请求 ? 当前请求->now : 0,
                "任务管理工作线程壳正在推进任务");
        }

        任务管理工作线程::结构_工作线程推进响应 响应{};
        if (当前请求 && 当前请求->自我对象) {
            响应.最新任务控制态 = 当前请求->任务控制态;
            响应.最新任务局部运行态 = 当前请求->任务局部运行态;
            响应.推进成功 = 任务管理工作线程::推进任务管理工作线程(
                *当前请求->自我对象,
                当前请求->任务根节点,
                &响应.最新任务控制态,
                &响应.最新任务局部运行态,
                当前请求->now,
                当前请求->控制事件,
                当前请求->根层重判结果,
                当前请求->执行前门控结果,
                当前请求->上层反馈摘要,
                当前请求->调用点,
                &响应.桥接结果);
            响应.摘要.clear();
        } else {
            响应.摘要.clear();
        }

        {
            std::lock_guard 锁(壳.锁);
            壳.正在执行 = false;
            ++壳.快照.累计推进次数;
            壳.快照.最近一次上行消息数 =
                static_cast<std::uint64_t>(响应.桥接结果.上行消息集.size());
            壳.快照.累计发送上行消息数 += 壳.快照.最近一次上行消息数;
            if (响应.桥接结果.已执行学习任务) {
                ++壳.快照.累计学习执行次数;
            }
            壳.快照.最近学习摘要.clear();
            if (响应.桥接结果.已消费控制请求) {
                ++壳.快照.累计收到控制请求数;
            }
            私有_更新工作线程壳快照_已加锁(
                true,
                false,
                当前请求 ? 当前请求->任务根节点.任务根ID : 0,
                当前请求 ? 当前请求->now : 0,
                响应.摘要);
        }

        if (当前请求) {
            当前请求->完成承诺.set_value(std::move(响应));
        }
    }
}

inline bool 私有_确保任务管理工作线程壳已启动() noexcept
{
    auto& 壳 = 私有_任务管理工作线程壳();
    std::lock_guard 锁(壳.锁);
    if (壳.已启动) {
        return true;
    }

    try {
        壳.停止请求 = false;
        壳.正在执行 = false;
        壳.线程 = std::thread(私有_任务管理工作线程壳线程主体);
        壳.已启动 = true;
        私有_更新工作线程壳快照_已加锁(
            false,
            false,
            0,
            0,
            "任务管理工作线程壳已启动");
        return true;
    } catch (...) {
        壳.已启动 = false;
        私有_更新工作线程壳快照_已加锁(
            false,
            false,
            0,
            0,
            "任务管理工作线程壳启动失败");
        return false;
    }
}

} // namespace

namespace 任务管理工作线程 {

inline bool 推进任务管理工作线程(
    自我类& 自我对象,
    const 结构_任务根节点& 任务根节点,
    结构_任务控制态* 任务控制态,
    结构_任务局部运行态* 任务局部运行态,
    时间戳 now,
    const 结构_任务控制事件& 控制事件,
    const 枚举_任务管理根层重判结果 根层重判结果,
    const 枚举_任务管理执行前门控结果 执行前门控结果,
    const std::string& 上层反馈摘要,
    const std::string& 调用点,
    结构_工作线程桥接结果* 输出) noexcept
{
    if (!输出 || !任务控制态 || !任务局部运行态) {
        return false;
    }

    const auto 安全任务主键 = [](auto* 节点) -> std::string {
        return 节点 ? 节点->获取主键() : std::string{};
    };
    const auto 构造推进事件 = [](
        const std::uint64_t 任务根ID,
        const 枚举_任务推进事件类型 类型,
        const std::uintptr_t 当前步骤指针,
        const std::uintptr_t 结果指针,
        const std::string& 摘要,
        const std::string& 等待原因 = std::string{},
        const std::string& 派生需求摘要 = std::string{}) {
            结构_任务推进事件 事件{};
            事件.任务根ID = 任务根ID;
            事件.事件类型 = 类型;
            事件.当前步骤指针 = 当前步骤指针;
            事件.结果指针 = 结果指针;
            事件.等待原因 = 等待原因;
            (void)摘要;
            (void)派生需求摘要;
            事件.派生需求摘要.clear();
            事件.摘要.clear();
            return 事件;
        };
    const auto 映射线程运行状态 = [](
        const 结构_任务控制态& 控制态,
        const 结构_任务局部运行态& 局部运行态) noexcept {
            if (控制态.请求停止 || 局部运行态.当前状态 == 枚举_任务局部运行状态::已停止) {
                return 枚举_任务管理线程运行状态::已停止;
            }
            if (局部运行态.当前状态 == 枚举_任务局部运行状态::已收束) {
                return 枚举_任务管理线程运行状态::收束中;
            }
            if (局部运行态.当前状态 == 枚举_任务局部运行状态::局部失败
                || 局部运行态.当前状态 == 枚举_任务局部运行状态::已中断) {
                return 枚举_任务管理线程运行状态::故障;
            }
            if (局部运行态.当前状态 == 枚举_任务局部运行状态::等待条件
                || 局部运行态.当前状态 == 枚举_任务局部运行状态::等待前序步骤
                || 局部运行态.当前状态 == 枚举_任务局部运行状态::等待子结果) {
                return 枚举_任务管理线程运行状态::等待中;
            }
            if (局部运行态.当前状态 == 枚举_任务局部运行状态::当前步骤可执行
                || 局部运行态.当前状态 == 枚举_任务局部运行状态::已受理
                || 局部运行态.当前状态 == 枚举_任务局部运行状态::展开步骤中) {
                return 枚举_任务管理线程运行状态::推进中;
            }
            return 枚举_任务管理线程运行状态::已启动;
        };
    const auto 追加线程补充特征 = [](
        std::vector<结构_任务管理线程补充特征>& 补充特征集,
        const 枚举_任务管理线程补充特征类型 特征类型,
        const std::string& 文本值,
        const I64 数值,
        const bool 布尔值) {
            结构_任务管理线程补充特征 特征{};
            特征.特征类型 = 特征类型;
            特征.文本值 = 文本值;
            特征.数值 = 数值;
            特征.布尔值 = 布尔值;
            补充特征集.push_back(std::move(特征));
        };
    const auto 控制意图需要阻断执行 = [](
        const 枚举_任务管理控制意图值 控制意图) noexcept {
            switch (控制意图) {
            case 枚举_任务管理控制意图值::请求暂停:
            case 枚举_任务管理控制意图值::请求打断:
            case 枚举_任务管理控制意图值::请求收束:
            case 枚举_任务管理控制意图值::请求停止:
            case 枚举_任务管理控制意图值::请求恢复重建:
                return true;
            default:
                return false;
            }
        };
    const auto 构造线程状态消息 = [&](
        const 结构_工作线程桥接结果& 桥接结果) {
            结构_任务管理线程状态消息 消息{};
            消息.消息头.发出者主键 = std::to_string(任务根节点.任务根ID);
            消息.消息头.任务管理任务主键 = 安全任务主键(桥接结果.治理结果.上下文.当前管理任务);
            消息.消息头.任务主键 = 安全任务主键(桥接结果.治理结果.上下文.当前宿主任务);
            消息.消息头.父任务主键 = 安全任务主键(桥接结果.治理结果.上下文.当前管理任务);
            消息.消息头.步骤主键 = 安全任务主键(桥接结果.治理结果.当前步骤节点);
            消息.消息头.产生时间 = now;
            消息.消息头.执行尝试号 = 任务根节点.任务根ID;
            if (桥接结果.已生成一步治理任务包) {
                消息.消息头.执行尝试主键 = std::to_string(桥接结果.一步治理请求包.包头.包主键);
                消息.消息头.路径签名 = 桥接结果.一步治理请求包.包头.追踪签名;
            } else {
                消息.消息头.执行尝试主键 = std::to_string(任务根节点.任务根ID) + "|control";
                消息.消息头.路径签名 = 任务根节点.任务根ID;
            }
            消息.消息头.幂等键 = 消息.消息头.执行尝试主键 + "|" + std::to_string(now);
            消息.消息头.影子验证状态 = 桥接结果.治理结果.当前影子验证状态;
            消息.消息头.允许正式资产提交 = 桥接结果.治理结果.允许正式资产提交;
            消息.当前运行状态 = 映射线程运行状态(*任务控制态, *任务局部运行态);
            消息.开始时间 = now;
            消息.结束时间 = 0;
            消息.是否执行尝试结束 =
                任务控制态->请求停止
                || 任务局部运行态->当前状态 == 枚举_任务局部运行状态::已收束
                || 任务局部运行态->当前状态 == 枚举_任务局部运行状态::已停止;
            消息.结束状态 =
                任务控制态->请求停止
                ? 枚举_任务管理线程结束状态::中断结束
                : (任务局部运行态->当前状态 == 枚举_任务局部运行状态::已收束
                    ? 枚举_任务管理线程结束状态::收束结束
                    : 枚举_任务管理线程结束状态::未结束);

            if (桥接结果.已消费控制请求) {
                消息.是否携带控制请求 = true;
                消息.消息头.回复目标消息主键 = 桥接结果.已消费控制请求对象.回复目标消息主键;
                消息.控制请求主键 = 桥接结果.已消费控制请求对象.请求主键;
                消息.当前控制意图 = 桥接结果.已消费控制请求对象.控制意图值;
                消息.当前控制响应状态 = 桥接结果.当前控制承接.当前响应状态;
                消息.是否控制已执行完成 = 桥接结果.当前控制承接.是否已执行完成;
                消息.控制拒绝原因 = 桥接结果.当前控制承接.拒绝原因;
                追加线程补充特征(
                    消息.补充特征集,
                    枚举_任务管理线程补充特征类型::当前控制请求主键,
                    消息.控制请求主键,
                    0,
                    false);
                追加线程补充特征(
                    消息.补充特征集,
                    枚举_任务管理线程补充特征类型::当前控制意图值,
                    任务管理控制意图值文本(消息.当前控制意图),
                    static_cast<I64>(消息.当前控制意图),
                    false);
                追加线程补充特征(
                    消息.补充特征集,
                    枚举_任务管理线程补充特征类型::当前控制响应状态,
                    任务管理控制响应状态文本(消息.当前控制响应状态),
                    static_cast<I64>(消息.当前控制响应状态),
                    false);
                追加线程补充特征(
                    消息.补充特征集,
                    枚举_任务管理线程补充特征类型::是否已响应控制意图,
                    std::string{},
                    0,
                    桥接结果.当前控制承接.是否已响应);
                if (!消息.控制拒绝原因.empty()) {
                    追加线程补充特征(
                        消息.补充特征集,
                        枚举_任务管理线程补充特征类型::控制拒绝原因,
                        消息.控制拒绝原因,
                        0,
                        false);
                }
            }

            追加线程补充特征(
                消息.补充特征集,
                枚举_任务管理线程补充特征类型::当前步骤前沿,
                std::to_string(任务局部运行态->当前步骤前沿),
                static_cast<I64>(任务局部运行态->当前步骤前沿),
                false);
            追加线程补充特征(
                消息.补充特征集,
                枚举_任务管理线程补充特征类型::当前等待原因,
                任务局部运行态->当前等待原因,
                0,
                false);
            追加线程补充特征(
                消息.补充特征集,
                枚举_任务管理线程补充特征类型::是否可继续推进,
                std::string{},
                0,
                消息.当前运行状态 != 枚举_任务管理线程运行状态::等待中
                    && 消息.当前运行状态 != 枚举_任务管理线程运行状态::阻塞
                    && 消息.当前运行状态 != 枚举_任务管理线程运行状态::已停止);
            return 消息;
        };
    const auto 应用控制请求 = [&](const 结构_任务管理控制请求& 请求, bool* 输出阻断执行) {
        结构_任务管理控制响应摘要 响应{};
        响应.请求主键 = 请求.请求主键;
        响应.控制意图值 = 请求.控制意图值;
        响应.是否已下发 = true;
        响应.最近回报时间 = now;

        bool 阻断执行 = false;
        if (输出阻断执行) {
            *输出阻断执行 = false;
        }

        if (!请求.目标线程主键.empty()
            && 请求.目标线程主键 != std::to_string(任务根节点.任务根ID)) {
            响应.响应状态 = 枚举_任务管理控制响应状态::已拒绝;
            响应.拒绝原因 = "目标线程与当前任务根不匹配";
            任务控制态->是否已响应控制意图 = true;
            任务控制态->控制请求待确认 = false;
            return 响应;
        }
        if (请求.控制意图值 == 枚举_任务管理控制意图值::未定义) {
            响应.响应状态 = 枚举_任务管理控制响应状态::已拒绝;
            响应.拒绝原因 = "控制意图未定义";
            任务控制态->是否已响应控制意图 = true;
            任务控制态->控制请求待确认 = false;
            return 响应;
        }

        任务控制态->当前控制请求主键 = 请求.请求主键;
        任务控制态->当前控制意图摘要.clear();
        任务控制态->控制请求待确认 = 请求.是否需要确认;
        任务控制态->是否已响应控制意图 = true;
        阻断执行 = 控制意图需要阻断执行(请求.控制意图值);

        switch (请求.控制意图值) {
        case 枚举_任务管理控制意图值::请求启动:
        case 枚举_任务管理控制意图值::请求继续:
            任务控制态->请求停止 = false;
            任务控制态->请求收束 = false;
            任务控制态->队列状态 = 枚举_任务队列状态::可运行;
            if (任务局部运行态->当前状态 == 枚举_任务局部运行状态::等待条件
                || 任务局部运行态->当前状态 == 枚举_任务局部运行状态::已中断
                || 任务局部运行态->当前状态 == 枚举_任务局部运行状态::未定义) {
                任务局部运行态->当前状态 = 枚举_任务局部运行状态::已受理;
            }
            任务局部运行态->当前等待原因.clear();
            break;
        case 枚举_任务管理控制意图值::请求暂停:
            任务控制态->队列状态 = 枚举_任务队列状态::等待;
            任务局部运行态->当前状态 = 枚举_任务局部运行状态::等待条件;
            任务局部运行态->当前等待原因 = "控制请求暂停";
            break;
        case 枚举_任务管理控制意图值::请求打断:
            任务控制态->队列状态 = 枚举_任务队列状态::等待;
            任务局部运行态->当前状态 = 枚举_任务局部运行状态::已中断;
            任务局部运行态->当前等待原因 = "控制请求打断";
            任务局部运行态->局部错误摘要 = "控制请求打断";
            break;
        case 枚举_任务管理控制意图值::请求收束:
            任务控制态->请求收束 = true;
            任务控制态->队列状态 = 枚举_任务队列状态::收束中;
            任务局部运行态->当前状态 = 枚举_任务局部运行状态::已收束;
            任务局部运行态->当前等待原因 = "控制请求收束";
            break;
        case 枚举_任务管理控制意图值::请求停止:
            任务控制态->请求停止 = true;
            任务控制态->队列状态 = 枚举_任务队列状态::已停止;
            任务局部运行态->当前状态 = 枚举_任务局部运行状态::已停止;
            任务局部运行态->当前等待原因 = "控制请求停止";
            break;
        case 枚举_任务管理控制意图值::请求恢复重建:
            任务控制态->队列状态 = 枚举_任务队列状态::等待;
            任务局部运行态->当前状态 = 枚举_任务局部运行状态::等待条件;
            任务局部运行态->当前等待原因 = "控制请求恢复重建";
            break;
        case 枚举_任务管理控制意图值::请求刷新预算:
            if (请求.请求预算 > 0) {
                任务控制态->时间预算_ms = 请求.请求预算;
            }
            阻断执行 = false;
            break;
        case 枚举_任务管理控制意图值::请求刷新优先级:
            if (请求.请求优先级 != 0) {
                任务控制态->全局优先级 = 请求.请求优先级;
            }
            阻断执行 = false;
            break;
        case 枚举_任务管理控制意图值::未定义:
        default:
            响应.响应状态 = 枚举_任务管理控制响应状态::已拒绝;
            响应.拒绝原因 = "不支持的控制意图";
            任务控制态->控制请求待确认 = false;
            return 响应;
        }

        任务控制态->控制请求待确认 = false;
        响应.响应状态 = 枚举_任务管理控制响应状态::已执行完成;
        响应.是否已响应 = true;
        响应.是否已执行完成 = true;
        if (输出阻断执行) {
            *输出阻断执行 = 阻断执行;
        }
        return 响应;
    };

    auto& 结果 = *输出;
    结果 = {};
    结果.当前消息合同.消息输入.控制事件 = 控制事件;
    结果.当前消息合同.消息输入.当前时间 = now;
    结果.当前消息合同.消息输入.调用点 = 调用点;
    结果.已消费控制事件 = 控制事件;
    结果.根层重判结果 = 根层重判结果;
    结果.执行前门控结果 = 执行前门控结果;
    结果.上层反馈摘要.clear();

    任务控制态->任务根ID = 任务根节点.任务根ID;
    任务局部运行态->任务根ID = 任务根节点.任务根ID;
    任务控制态->已派发 = true;
    任务控制态->绑定工作线程ID = 任务根节点.任务根ID;
    任务控制态->控制摘要.clear();
    任务控制态->队列状态 = 枚举_任务队列状态::已派发;
    任务局部运行态->当前状态 = 枚举_任务局部运行状态::已受理;

    const auto 上位输入调用点 = 调用点 + "/上位输入";
    结果.任务管理上位输入已刷新 = 任务管理任务模块::写入上位输入镜像(
        自我对象,
        根层重判结果,
        执行前门控结果,
        std::string{},
        now,
        上位输入调用点);

    const auto 任务管理调用点 = 调用点 + "/任务管理";
    结果.任务管理治理触发 = 任务管理任务模块::执行一步治理(
        自我对象,
        now,
        任务管理调用点,
        &结果.治理结果);

    if (!结果.任务管理治理触发) {
        任务局部运行态->当前状态 = 枚举_任务局部运行状态::等待条件;
        任务局部运行态->当前等待原因 = "任务管理未触发治理";
        任务控制态->队列状态 = 枚举_任务队列状态::等待;
        结果.推进事件列表.push_back(构造推进事件(
            任务根节点.任务根ID,
            枚举_任务推进事件类型::当前步骤阻塞,
            0,
            0,
            "工作线程未推进治理",
            任务局部运行态->当前等待原因));
        return true;
    }

    auto& 治理结果 = 结果.治理结果;
    任务局部运行态->当前步骤前沿 = reinterpret_cast<std::uintptr_t>(治理结果.当前步骤节点);
    任务局部运行态->最近局部结果 = reinterpret_cast<std::uintptr_t>(治理结果.最新结果节点);
    任务局部运行态->局部运行摘要.clear();
    任务局部运行态->局部完成度 =
        治理结果.已推进任务状态 ? 100 : (治理结果.已创建步骤节点 || 治理结果.已创建结果节点 ? 60 : 20);

    bool 控制阻断执行 = false;
    if (治理结果.当前请求.存在控制请求) {
        结果.已消费控制请求 = true;
        结果.已消费控制请求对象 = 治理结果.当前请求.当前控制请求;
        结果.当前消息合同.消息输入.存在控制请求 = true;
        结果.当前消息合同.消息输入.控制请求 = 结果.已消费控制请求对象;
        结果.当前控制承接 = 治理结果.当前请求.当前控制承接;
        结果.当前控制承接.是否已下发 = true;
        const auto 控制响应 = 应用控制请求(结果.已消费控制请求对象, &控制阻断执行);
        结果.当前控制承接.控制请求主键 = 控制响应.请求主键;
        结果.当前控制承接.当前控制意图 = 控制响应.控制意图值;
        结果.当前控制承接.当前响应状态 = 控制响应.响应状态;
        结果.当前控制承接.是否已下发 = 控制响应.是否已下发;
        结果.当前控制承接.是否已响应 = 控制响应.是否已响应;
        结果.当前控制承接.是否已执行完成 = 控制响应.是否已执行完成;
        结果.当前控制承接.是否超时 = 控制响应.是否超时;
        结果.当前控制承接.最近回报时间 = 控制响应.最近回报时间;
        结果.当前控制承接.拒绝原因 = 控制响应.拒绝原因;
        结果.当前控制承接.摘要.clear();
        结果.当前消息合同.控制消费.已消费控制请求 = true;
        结果.当前消息合同.控制消费.已消费控制请求对象 = 结果.已消费控制请求对象;
        结果.当前消息合同.控制消费.控制响应 = 控制响应;
        结果.当前消息合同.控制消费.控制阻断执行 = 控制阻断执行;
        (void)任务管理任务模块::写入治理控制响应(控制响应);
        (void)任务管理任务模块::读取最近治理控制承接记录(&结果.当前控制承接);
    }

    if (控制阻断执行) {
        if (任务控制态->请求停止 || 任务局部运行态->当前状态 == 枚举_任务局部运行状态::已停止) {
            结果.推进事件列表.push_back(构造推进事件(
                任务根节点.任务根ID,
                枚举_任务推进事件类型::最终结果返回,
                任务局部运行态->当前步骤前沿,
                任务局部运行态->最近局部结果,
                "工作线程响应停止控制请求"));
        } else if (任务控制态->请求收束 || 任务局部运行态->当前状态 == 枚举_任务局部运行状态::已收束) {
            结果.推进事件列表.push_back(构造推进事件(
                任务根节点.任务根ID,
                枚举_任务推进事件类型::最终结果返回,
                任务局部运行态->当前步骤前沿,
                任务局部运行态->最近局部结果,
                "工作线程响应收束控制请求"));
        } else {
            结果.推进事件列表.push_back(构造推进事件(
                任务根节点.任务根ID,
                枚举_任务推进事件类型::当前步骤阻塞,
                任务局部运行态->当前步骤前沿,
                任务局部运行态->最近局部结果,
                "工作线程响应控制请求并转入等待/中断",
                任务局部运行态->当前等待原因));
        }
    } else if (治理结果.当前下一步去向 == 枚举_任务管理下一步去向::保持等待) {
        任务局部运行态->当前状态 = 枚举_任务局部运行状态::等待条件;
        任务局部运行态->当前等待原因 = "等待条件";
        任务控制态->队列状态 = 枚举_任务队列状态::等待;
        结果.推进事件列表.push_back(构造推进事件(
            任务根节点.任务根ID,
            枚举_任务推进事件类型::当前步骤阻塞,
            任务局部运行态->当前步骤前沿,
            任务局部运行态->最近局部结果,
            "当前步骤阻塞",
            任务局部运行态->当前等待原因));
    } else {
        任务局部运行态->当前状态 = 枚举_任务局部运行状态::当前步骤可执行;
        任务控制态->队列状态 = 枚举_任务队列状态::可运行;
        结果.推进事件列表.push_back(构造推进事件(
            任务根节点.任务根ID,
            枚举_任务推进事件类型::当前步骤可执行,
            任务局部运行态->当前步骤前沿,
            任务局部运行态->最近局部结果,
            "当前步骤可执行"));
    }

    if (!控制阻断执行) {
        结果.已生成一步治理任务包 = 任务管理任务模块::生成一步治理任务包(
            治理结果,
            &结果.一步治理请求包);

        const auto* 任务包指针 =
            结果.已生成一步治理任务包
            ? &结果.一步治理请求包
            : nullptr;
        结果.已生成回流结算包 = 任务最小回写器::执行最小回流结算与回写(
            自我对象,
            now,
            任务包指针,
            治理结果,
            &结果.最小回写结果);
        结果.已写入动态节点 = 结果.最小回写结果.已写入动态;
        结果.已写入因果候选 = 结果.最小回写结果.已写入因果候选;
        if (结果.已消费控制请求
            && 结果.当前控制承接.当前响应状态 == 枚举_任务管理控制响应状态::已执行完成
            && 结果.已生成一步治理任务包) {
            结果.当前控制承接.对应执行尝试主键 =
                std::to_string(结果.一步治理请求包.包头.包主键);
        }
    }

    if (!控制阻断执行) {
        结果.已构建学习调度快照 = true;
        结构_任务管理学习推进结果 学习推进结果{};
        if (任务管理任务模块::执行一步学习推进(
            自我对象,
            now,
            调用点 + "/学习执行",
            &学习推进结果)) {
            结果.已构建学习调度快照 = 学习推进结果.已构建学习调度快照;
            结果.已选中学习任务 = 学习推进结果.已选中学习任务;
            结果.已执行学习任务 = 学习推进结果.已执行学习任务;
            结果.当前学习账本ID = 学习推进结果.当前学习账本ID;
            结果.学习调度摘要.clear();
            结果.学习执行摘要.clear();
            结果.学习反馈摘要.clear();
        }
    }

    if (治理结果.已创建业务子任务 || 治理结果.已创建补条件子任务 || 治理结果.已创建学习子任务) {
        const auto 派生摘要 = std::string{};
        任务局部运行态->派生需求缓存.push_back(派生摘要);
        结果.推进事件列表.push_back(构造推进事件(
            任务根节点.任务根ID,
            枚举_任务推进事件类型::派生需求上报,
            任务局部运行态->当前步骤前沿,
            任务局部运行态->最近局部结果,
            "工作线程上报派生需求",
            {},
            派生摘要));
    }

    if (!控制阻断执行) {
        结果.推进事件列表.push_back(构造推进事件(
            任务根节点.任务根ID,
            枚举_任务推进事件类型::局部结果返回,
            任务局部运行态->当前步骤前沿,
            任务局部运行态->最近局部结果,
            "工作线程返回局部结果"));
    }

    if (!控制阻断执行
        && (治理结果.当前下一步去向 == 枚举_任务管理下一步去向::进入收束
            || 治理结果.最近总控结果 == 枚举_任务管理总控结果::宿主进入收束)) {
        任务局部运行态->当前状态 = 枚举_任务局部运行状态::已收束;
        任务控制态->队列状态 = 枚举_任务队列状态::收束中;
        结果.推进事件列表.push_back(构造推进事件(
            任务根节点.任务根ID,
            枚举_任务推进事件类型::最终结果返回,
            任务局部运行态->当前步骤前沿,
            任务局部运行态->最近局部结果,
            "工作线程返回最终结果"));
    }

    if (结果.已消费控制请求) {
        const auto 线程状态消息 = 构造线程状态消息(结果);
        结果.当前消息合同.状态回报.已生成线程状态消息 = true;
        结果.当前消息合同.状态回报.状态消息 = 线程状态消息;
        结构_任务管理上行消息 上行消息{};
        上行消息.类型 = 枚举_任务管理上行消息类型::线程状态消息;
        上行消息.载荷 = 线程状态消息;
        结果.上行消息集.push_back(std::move(上行消息));
    }

    结果.当前消息合同.结果上行.推进事件列表 = 结果.推进事件列表;
    结果.当前消息合同.结果上行.上行消息集 = 结果.上行消息集;

    return true;
}

inline bool 确保任务管理工作线程壳已启动() noexcept
{
    return 私有_确保任务管理工作线程壳已启动();
}

inline bool 通过工作线程壳推进任务管理工作线程(
    自我类& 自我对象,
    const 结构_任务根节点& 任务根节点,
    结构_任务控制态* 任务控制态,
    结构_任务局部运行态* 任务局部运行态,
    const 时间戳 now,
    const 结构_任务控制事件& 控制事件,
    const 枚举_任务管理根层重判结果 根层重判结果,
    const 枚举_任务管理执行前门控结果 执行前门控结果,
    const std::string& 上层反馈摘要,
    const std::string& 调用点,
    结构_工作线程桥接结果* 输出) noexcept
{
    if (!任务控制态 || !任务局部运行态) {
        return false;
    }
    if (!私有_确保任务管理工作线程壳已启动()) {
        return false;
    }

    auto 请求 = std::make_unique<结构_工作线程壳请求>();
    请求->自我对象 = &自我对象;
    请求->任务根节点 = 任务根节点;
    请求->任务控制态 = *任务控制态;
    请求->任务局部运行态 = *任务局部运行态;
    请求->now = now;
    请求->控制事件 = 控制事件;
    请求->根层重判结果 = 根层重判结果;
    请求->执行前门控结果 = 执行前门控结果;
    请求->上层反馈摘要.clear();
    请求->调用点 = 调用点;
    auto 完成结果 = 请求->完成承诺.get_future();

    auto& 壳 = 私有_任务管理工作线程壳();
    {
        std::lock_guard 锁(壳.锁);
        壳.队列.push_back(std::move(请求));
        ++壳.快照.累计收到请求数;
        私有_更新工作线程壳快照_已加锁(
            true,
            壳.正在执行,
            任务根节点.任务根ID,
            now,
            "任务管理工作线程壳已收到推进请求");
    }
    壳.条件.notify_one();

    const auto 响应 = 完成结果.get();
    *任务控制态 = 响应.最新任务控制态;
    *任务局部运行态 = 响应.最新任务局部运行态;
    if (输出) {
        *输出 = 响应.桥接结果;
    }
    return 响应.推进成功;
}

inline bool 读取任务管理工作线程快照(结构_工作线程实例快照* 输出) noexcept
{
    if (!输出) {
        return false;
    }
    auto& 壳 = 私有_任务管理工作线程壳();
    std::lock_guard 锁(壳.锁);
    *输出 = 壳.快照;
    输出->已启动 = 壳.已启动;
    输出->正在执行 = 壳.正在执行;
    输出->当前排队数 = static_cast<std::uint64_t>(壳.队列.size());
    return true;
}

inline void 停止任务管理工作线程壳() noexcept
{
    std::thread 待回收线程{};
    auto& 壳 = 私有_任务管理工作线程壳();
    {
        std::lock_guard 锁(壳.锁);
        if (!壳.已启动) {
            return;
        }
        壳.停止请求 = true;
        私有_更新工作线程壳快照_已加锁(
            壳.快照.已收到请求,
            false,
            壳.快照.最近任务根ID,
            壳.快照.最近推进时间,
            "任务管理工作线程壳收到停止请求");
        待回收线程 = std::move(壳.线程);
        壳.已启动 = false;
    }
    壳.条件.notify_all();
    if (待回收线程.joinable()) {
        待回收线程.join();
    }
}

} // namespace 任务管理工作线程
