module;

#include <string>

#include "基础数据类型.h"

export module 自我_固定机制模块;

import 自我模块;

namespace 自我_固定机制模块_detail {
    inline void 追加摘要(std::string& 摘要, const std::string& 片段)
    {
        if (片段.empty()) {
            return;
        }
        if (!摘要.empty()) {
            摘要 += " | ";
        }
        摘要 += 片段;
    }
}

export {

struct 结构_固定机制执行结果_最小_v0 {
    bool 服务归零待机保护已执行 = false;
    bool 服务值定时衰减已执行 = false;
    bool 服务衰减步长已重算 = false;
    bool 安全增加步长已重算 = false;
    bool 安全减少步长已重算 = false;
    bool 安全低位回升已执行 = false;
    bool 安全高位回落已执行 = false;
    bool 风险安全回归已执行 = false;
    I64 执行命中数 = 0;
    std::string 摘要{};
};

inline bool 应用服务归零待机保护_最小_v0(
    自我类& 自我对象,
    时间戳 now = 0,
    const std::string& 调用点 = "应用服务归零待机保护_最小_v0") noexcept
{
    if (now == 0) {
        now = 结构体_时间戳::当前_微秒();
    }
    return 自我对象.应用服务归零待机保护(now);
}

inline bool 应用定时衰减服务值_最小_v0(
    自我类& 自我对象,
    I64 delta = 0,
    时间戳 now = 0,
    const std::string& 调用点 = "应用定时衰减服务值_最小_v0") noexcept
{
    if (now == 0) {
        now = 结构体_时间戳::当前_微秒();
    }
    return 自我对象.应用定时衰减服务值(delta, now);
}

inline bool 应用按双值重算服务衰减步长_最小_v0(
    自我类& 自我对象,
    时间戳 now = 0,
    const std::string& 调用点 = "应用按双值重算服务衰减步长_最小_v0") noexcept
{
    if (now == 0) {
        now = 结构体_时间戳::当前_微秒();
    }
    return 自我对象.应用按双值重算服务衰减步长(now);
}

inline bool 应用按服务值重算安全增加步长_最小_v0(
    自我类& 自我对象,
    时间戳 now = 0,
    const std::string& 调用点 = "应用按服务值重算安全增加步长_最小_v0") noexcept
{
    if (now == 0) {
        now = 结构体_时间戳::当前_微秒();
    }
    return 自我对象.应用按服务值重算安全增加步长(now);
}

inline bool 应用按服务值重算安全减少步长_最小_v0(
    自我类& 自我对象,
    时间戳 now = 0,
    const std::string& 调用点 = "应用按服务值重算安全减少步长_最小_v0") noexcept
{
    if (now == 0) {
        now = 结构体_时间戳::当前_微秒();
    }
    return 自我对象.应用按服务值重算安全减少步长(now);
}

inline bool 应用安全低位回升_最小_v0(
    自我类& 自我对象,
    I64 delta = 0,
    时间戳 now = 0,
    const std::string& 调用点 = "应用安全低位回升_最小_v0") noexcept
{
    if (now == 0) {
        now = 结构体_时间戳::当前_微秒();
    }
    return 自我对象.应用安全低位回升(delta, now);
}

inline bool 应用安全高位回落_最小_v0(
    自我类& 自我对象,
    I64 delta = 0,
    时间戳 now = 0,
    const std::string& 调用点 = "应用安全高位回落_最小_v0") noexcept
{
    if (now == 0) {
        now = 结构体_时间戳::当前_微秒();
    }
    return 自我对象.应用安全高位回落(delta, now);
}

inline bool 应用风险安全回归_最小_v0(
    自我类& 自我对象,
    I64 delta = 1,
    时间戳 now = 0,
    const std::string& 调用点 = "应用风险安全回归_最小_v0") noexcept
{
    if (now == 0) {
        now = 结构体_时间戳::当前_微秒();
    }
    return 自我对象.应用风险安全回归(delta, now);
}

inline 结构_固定机制执行结果_最小_v0 执行固定机制一步_最小_v0(
    自我类& 自我对象,
    I64 服务衰减delta = 0,
    I64 安全低位回升delta = 0,
    I64 安全高位回落delta = 0,
    I64 风险安全回归delta = 1,
    时间戳 now = 0,
    const std::string& 调用点 = "执行固定机制一步_最小_v0") noexcept
{
    if (now == 0) {
        now = 结构体_时间戳::当前_微秒();
    }

    结构_固定机制执行结果_最小_v0 输出{};
    输出.服务归零待机保护已执行 = 应用服务归零待机保护_最小_v0(
        自我对象);
    输出.服务值定时衰减已执行 = 应用定时衰减服务值_最小_v0(
        自我对象, 服务衰减delta);
    输出.服务衰减步长已重算 = 应用按双值重算服务衰减步长_最小_v0(
        自我对象);
    输出.安全增加步长已重算 = 应用按服务值重算安全增加步长_最小_v0(
        自我对象);
    输出.安全减少步长已重算 = 应用按服务值重算安全减少步长_最小_v0(
        自我对象);
    输出.安全低位回升已执行 = 应用安全低位回升_最小_v0(
        自我对象);
    输出.安全高位回落已执行 = 应用安全高位回落_最小_v0(
        自我对象);
    输出.风险安全回归已执行 = 应用风险安全回归_最小_v0(
        自我对象, 风险安全回归delta);

    输出.执行命中数 += 输出.服务归零待机保护已执行 ? 1 : 0;
    输出.执行命中数 += 输出.服务值定时衰减已执行 ? 1 : 0;
    输出.执行命中数 += 输出.服务衰减步长已重算 ? 1 : 0;
    输出.执行命中数 += 输出.安全增加步长已重算 ? 1 : 0;
    输出.执行命中数 += 输出.安全减少步长已重算 ? 1 : 0;
    输出.执行命中数 += 输出.安全低位回升已执行 ? 1 : 0;
    输出.执行命中数 += 输出.安全高位回落已执行 ? 1 : 0;
    输出.执行命中数 += 输出.风险安全回归已执行 ? 1 : 0;

    using namespace 自我_固定机制模块_detail;
    if (输出.服务归零待机保护已执行) 追加摘要(输出.摘要, "服务归零待机保护");
    if (输出.服务值定时衰减已执行) 追加摘要(输出.摘要, "服务值定时衰减");
    if (输出.服务衰减步长已重算) 追加摘要(输出.摘要, "服务衰减步长重算");
    if (输出.安全增加步长已重算) 追加摘要(输出.摘要, "安全增加步长重算");
    if (输出.安全减少步长已重算) 追加摘要(输出.摘要, "安全减少步长重算");
    if (输出.安全低位回升已执行) 追加摘要(输出.摘要, "安全低位回升");
    if (输出.安全高位回落已执行) 追加摘要(输出.摘要, "安全高位回落");
    if (输出.风险安全回归已执行) 追加摘要(输出.摘要, "风险安全回归");
    if (输出.摘要.empty()) {
        输出.摘要 = "本轮固定机制无命中";
    }
    return 输出;
}

} // export
