module;

#include <cstdint>
#include <functional>
#include <optional>
#include <sstream>
#include <string>
#include <unordered_set>
#include <variant>
#include <vector>

#include "基础数据类型.h"
#include "需求类.h"

export module 自我线程模块.消息协议;

import 任务管理任务模块;
import 任务模块.工作线程协议;

export namespace 自我线程消息协议 {

enum class 枚举_消息来源链 : std::uint8_t {
    未定义 = 0,
    线程直达消息 = 1,
    任务管理工作线程回流消息 = 2,
};

enum class 枚举_消息处理类型 : std::uint8_t {
    未定义 = 0,
    控制域事实消息 = 1,
    业务域事实消息 = 2,
    延迟事实消息 = 3,
    工作线程状态消息 = 4,
    任务推进关键事件消息 = 5,
    派生需求上报消息 = 6,
    结果与关键中间状态回流消息 = 7,
};

enum class 枚举_存在类型 : std::uint16_t {
    未定义 = 0,
    自我 = 1,
    自我线程 = 2,
    任务 = 3,
    任务控制态 = 4,
    任务管理任务 = 5,
    任务管理工作线程 = 6,
    方法 = 7,
    场景 = 8,
    资源 = 9,
    外部对象 = 10,
    外部系统 = 11,
    环境监测器 = 12,
    派生需求 = 13,
    线程池 = 14,
};

enum class 枚举_动作类型 : std::uint16_t {
    未定义 = 0,
    下发控制意图 = 1,
    上报事实 = 2,
    到期生效 = 3,
    状态回报 = 4,
    推进事件上报 = 5,
    派生需求上报 = 6,
    结果回流 = 7,
    关键中间状态回流 = 8,
    路由回父任务 = 9,
};

enum class 枚举_特征类型 : std::uint16_t {
    未定义 = 0,
    控制意图 = 1,
    实际运行状态 = 2,
    运行状态 = 实际运行状态,
    生命周期状态 = 3,
    运行模式 = 4,
    当前预算 = 5,
    优先级策略 = 6,
    资源可用性 = 7,
    风险等级 = 8,
    条件满足状态 = 9,
    当前等待原因 = 10,
    当前步骤前沿 = 11,
    局部运行状态 = 12,
    结果状态 = 13,
    局部完成度 = 14,
    父任务语义影响 = 15,
    健康状态 = 16,
    生效时点 = 17,
    是否允许继续派发 = 18,
};

enum class 枚举_治理消息优先级 : std::uint8_t {
    未定义 = 0,
    低 = 1,
    中 = 2,
    高 = 3,
    很高 = 4,
    紧急 = 5,
};

enum class 枚举_结果状态 : std::uint8_t {
    未定义 = 0,
    成功 = 1,
    失败 = 2,
    中断 = 3,
    收束 = 4,
    异常 = 5,
    待重试 = 6,
};

enum class 枚举_执行尝试汇总状态 : std::uint8_t {
    未定义 = 0,
    执行中 = 1,
    已结束待结果 = 2,
    已收结果待确认 = 3,
    已验证成功 = 4,
    已验证失败 = 5,
    已争议 = 6,
    已过期 = 7,
};

enum class 枚举_执行尝试验证状态 : std::uint8_t {
    未定义 = 0,
    待确认 = 1,
    已验证成功 = 2,
    已验证失败 = 3,
    已争议 = 4,
    已过期 = 5,
};

enum class 枚举_执行尝试对账结论 : std::uint8_t {
    未定义 = 0,
    对账通过 = 1,
    缺结果 = 2,
    缺结束消息 = 3,
    重复 = 4,
    冲突 = 5,
    超时 = 6,
    时序异常 = 7,
    串单 = 8,
};

struct 结构_治理消息头 {
    std::uint64_t 消息主键 = 0;
    枚举_消息来源链 来源链 = 枚举_消息来源链::未定义;
    枚举_消息处理类型 处理类型 = 枚举_消息处理类型::未定义;
    枚举_治理消息优先级 优先级 = 枚举_治理消息优先级::未定义;
    std::uint64_t 发出者主键 = 0;
    std::uint64_t 动作主体主键 = 0;
    std::uint64_t 作用对象主键 = 0;
    std::uint64_t 来源线程主键 = 0;
    std::uint64_t 来源任务主键 = 0;
    std::uint64_t 目标任务主键 = 0;
    std::uint64_t 父任务主键 = 0;
    std::uint64_t 关联场景主键 = 0;
    时间戳 产生时间 = 0;
    std::uint64_t 路径签名 = 0;
    bool 来源成功 = false;
    I64 错误码 = 0;
    I64 置信度 = 0;
    bool 可抢占 = false;
    bool 仅局部有效 = false;
};

struct 结构_特征变化项 {
    枚举_存在类型 变化主体类型 = 枚举_存在类型::未定义;
    std::uint64_t 变化主体主键 = 0;
    枚举_特征类型 特征类型 = 枚举_特征类型::未定义;
    std::uint64_t 特征主键 = 0;
    特征值 变化前值{};
    特征值 变化后值{};
    bool 已确认生效 = false;
    bool 是否关键中间状态 = false;
    bool 已恢复 = false;
    std::string 变化原因键{};
};

struct 结构_关键中间状态变化项 {
    std::uint64_t 动作主体主键 = 0;
    std::string 动作语义键{};
    std::uint64_t 变化主体主键 = 0;
    std::uint64_t 特征主键 = 0;
    特征值 变化前值{};
    特征值 变化后值{};
    时间戳 发生时间 = 0;
    bool 已确认生效 = false;
    bool 已恢复 = false;
};

struct 结构_结果回流提示段 {
    bool 可能存在反向推进 = false;
    bool 可能形成阻塞 = false;
    bool 可能影响父任务 = false;
    bool 可能形成否定项候选 = false;
};

struct 结构_任务结果回流消息 {
    std::uint64_t 任务主键 = 0;
    std::uint64_t 父任务主键 = 0;
    枚举_结果状态 最终结果状态 = 枚举_结果状态::未定义;
    特征值 最终结果值{};
    std::vector<结构_关键中间状态变化项> 关键中间变化集{};
    结构_结果回流提示段 提示段{};
};

struct 结构_执行尝试标识 {
    std::string 执行尝试主键{};
    std::string 任务管理任务主键{};
    std::string 任务主键{};
    std::string 父任务主键{};
    std::string 步骤主键{};
    std::uint64_t 路径签名 = 0;
    std::uint64_t 执行尝试号 = 0;
    std::string 幂等键{};
};

struct 结构_执行尝试对账结果 {
    结构_执行尝试标识 标识{};
    枚举_执行尝试对账结论 结论 = 枚举_执行尝试对账结论::未定义;
    bool 是否同一次执行尝试 = false;
    bool 是否完整 = false;
    bool 是否一致 = false;
    bool 是否进入待确认池 = false;
    std::string 说明{};
};

struct 结构_执行尝试汇总 {
    结构_执行尝试标识 标识{};

    bool 已收到线程状态 = false;
    bool 已收到结果消息 = false;
    bool 已收到确认消息 = false;

    枚举_任务管理线程运行状态 当前线程运行状态 = 枚举_任务管理线程运行状态::未定义;
    枚举_任务管理线程结束状态 线程结束状态 = 枚举_任务管理线程结束状态::未定义;
    枚举_任务管理结果状态 结果状态 = 枚举_任务管理结果状态::未定义;
    枚举_执行尝试验证状态 验证状态 = 枚举_执行尝试验证状态::未定义;
    枚举_执行尝试汇总状态 汇总状态 = 枚举_执行尝试汇总状态::未定义;

    时间戳 开始时间 = 0;
    时间戳 结束时间 = 0;
    时间戳 最近结果时间 = 0;
    时间戳 最近归并时间 = 0;

    std::size_t 线程状态消息累计数 = 0;
    std::size_t 结果消息累计数 = 0;
    std::size_t 重复消息累计数 = 0;

    std::string 最近线程状态消息幂等键{};
    std::string 最近结果消息幂等键{};
    std::string 最近对账说明{};
    std::string 最近结果摘要{};

    std::vector<结构_任务管理状态变化项> 服务对象状态变化集{};
    std::vector<结构_任务管理关键中间状态变化项> 关键中间状态变化集{};

    std::optional<结构_任务管理线程状态消息> 最近线程状态消息{};
    std::optional<结构_任务管理结果状态消息> 最近结果消息{};
};

struct 结构_线程状态变化消息段 {
    时间戳 发生时间 = 0;
    枚举_存在类型 决策者类型 = 枚举_存在类型::未定义;
    std::uint64_t 决策者主键 = 0;
    std::string 决策者标签{};
    std::string 触发动作{};
    std::string 原因键{};
    std::string 原因摘要{};
    std::uint64_t 线程存在主键 = 0;
    std::string 线程标签{};
    枚举_存在类型 线程存在类型 = 枚举_存在类型::未定义;
    std::string 线程种类{};
    枚举_存在类型 直属拥有者类型 = 枚举_存在类型::未定义;
    std::uint64_t 直属拥有者主键 = 0;
    枚举_特征类型 状态特征类型 = 枚举_特征类型::生命周期状态;
    I64 旧状态 = 0;
    I64 新状态 = 0;
    bool 是否故障触发 = false;
    bool 是否stop链触发 = false;
    std::uint64_t 关联任务主键 = 0;
    std::uint64_t 关联线程主键 = 0;
};

struct 结构_存在动作语义 {
    枚举_存在类型 发出者类型 = 枚举_存在类型::未定义;
    std::uint64_t 发出者主键 = 0;
    枚举_存在类型 动作主体类型 = 枚举_存在类型::未定义;
    std::uint64_t 动作主体主键 = 0;
    枚举_动作类型 动作类型 = 枚举_动作类型::未定义;
    std::string 动作语义键{};
    枚举_存在类型 作用对象类型 = 枚举_存在类型::未定义;
    std::uint64_t 作用对象主键 = 0;
    枚举_存在类型 记录者类型 = 枚举_存在类型::未定义;
    std::uint64_t 记录者主键 = 0;
    std::string 事实摘要{};
    std::string 因果摘要{};
};

struct 结构_治理消息来源诊断 {
    std::uint64_t 来源最小原语位图 = 0;
    std::string 来源主观察特征{};
    std::string 影子验证状态{};
    bool 允许正式资产提交 = false;
};

struct 结构_治理消息附加载荷 {
    std::optional<结构_治理恢复快照> 恢复快照{};
    std::optional<结构_需求树更新指令> 需求树更新{};
    std::optional<结构_线程状态变化消息段> 线程状态变化{};
    std::optional<结构_任务管理线程状态消息> 任务管理线程状态{};
    std::optional<结构_任务管理派生需求消息> 任务管理派生需求{};
    std::optional<结构_任务管理结果状态消息> 任务管理结果状态{};
    std::optional<结构_执行尝试汇总> 执行尝试汇总{};
    std::optional<结构_执行尝试对账结果> 执行对账结果{};
};

struct 结构_治理消息轨迹 {
    std::uint32_t 重放代数 = 0;
    std::uint32_t 消费次数 = 0;
    std::string 最后消费结果{};
};

struct 结构_治理消息 {
    结构_治理消息头 头{};
    结构_存在动作语义 语义{};
    结构_治理消息来源诊断 来源{};
    结构_治理消息附加载荷 附加载荷{};
    结构_治理消息轨迹 轨迹{};
    std::vector<结构_特征变化项> 变化项集{};
    std::string 载荷键{};
    std::string 摘要{};
};

inline const char* 默认动作语义键(const 枚举_消息处理类型 处理类型) noexcept
{
    switch (处理类型) {
    case 枚举_消息处理类型::控制域事实消息: return "控制域事实变化";
    case 枚举_消息处理类型::业务域事实消息: return "业务域事实变化";
    case 枚举_消息处理类型::延迟事实消息: return "延迟事实生效";
    case 枚举_消息处理类型::工作线程状态消息: return "线程状态变化上报";
    case 枚举_消息处理类型::任务推进关键事件消息: return "任务推进关键事件上报";
    case 枚举_消息处理类型::派生需求上报消息: return "派生需求上报";
    case 枚举_消息处理类型::结果与关键中间状态回流消息: return "结果与关键中间状态回流";
    case 枚举_消息处理类型::未定义:
    default:
        return "未定义动作";
    }
}

inline 枚举_治理消息优先级 默认消息优先级(const 枚举_消息处理类型 处理类型) noexcept
{
    switch (处理类型) {
    case 枚举_消息处理类型::控制域事实消息:
        return 枚举_治理消息优先级::很高;
    case 枚举_消息处理类型::业务域事实消息:
    case 枚举_消息处理类型::延迟事实消息:
    case 枚举_消息处理类型::工作线程状态消息:
    case 枚举_消息处理类型::结果与关键中间状态回流消息:
        return 枚举_治理消息优先级::高;
    case 枚举_消息处理类型::任务推进关键事件消息:
    case 枚举_消息处理类型::派生需求上报消息:
        return 枚举_治理消息优先级::中;
    case 枚举_消息处理类型::未定义:
    default:
        return 枚举_治理消息优先级::低;
    }
}

inline bool 默认可抢占(const 枚举_消息处理类型 处理类型) noexcept
{
    return 处理类型 == 枚举_消息处理类型::控制域事实消息;
}

inline bool 默认仅局部有效(const 枚举_消息处理类型) noexcept
{
    return false;
}

inline 枚举_动作类型 从处理类型映射动作类型(const 枚举_消息处理类型 处理类型) noexcept
{
    switch (处理类型) {
    case 枚举_消息处理类型::控制域事实消息:
        return 枚举_动作类型::下发控制意图;
    case 枚举_消息处理类型::业务域事实消息:
        return 枚举_动作类型::上报事实;
    case 枚举_消息处理类型::延迟事实消息:
        return 枚举_动作类型::到期生效;
    case 枚举_消息处理类型::工作线程状态消息:
        return 枚举_动作类型::状态回报;
    case 枚举_消息处理类型::任务推进关键事件消息:
        return 枚举_动作类型::推进事件上报;
    case 枚举_消息处理类型::派生需求上报消息:
        return 枚举_动作类型::派生需求上报;
    case 枚举_消息处理类型::结果与关键中间状态回流消息:
        return 枚举_动作类型::结果回流;
    case 枚举_消息处理类型::未定义:
    default:
        return 枚举_动作类型::未定义;
    }
}

inline 结构_特征变化项 构造特征变化项(
    const 枚举_存在类型 变化主体类型,
    const std::uint64_t 变化主体主键,
    const 枚举_特征类型 特征类型,
    const std::uint64_t 特征主键,
    const 特征值& 变化后值,
    const bool 已确认生效 = false,
    const bool 是否关键中间状态 = false,
    const bool 已恢复 = false,
    const std::string& 变化原因键 = {}) noexcept
{
    结构_特征变化项 变化{};
    变化.变化主体类型 = 变化主体类型;
    变化.变化主体主键 = 变化主体主键;
    变化.特征类型 = 特征类型;
    变化.特征主键 = 特征主键;
    变化.变化后值 = 变化后值;
    变化.已确认生效 = 已确认生效;
    变化.是否关键中间状态 = 是否关键中间状态;
    变化.已恢复 = 已恢复;
    变化.变化原因键 = 变化原因键;
    return 变化;
}

inline 结构_特征变化项 构造特征变化项_含前后值(
    const 枚举_存在类型 变化主体类型,
    const std::uint64_t 变化主体主键,
    const 枚举_特征类型 特征类型,
    const std::uint64_t 特征主键,
    const 特征值& 变化前值,
    const 特征值& 变化后值,
    const bool 已确认生效 = false,
    const bool 是否关键中间状态 = false,
    const bool 已恢复 = false,
    const std::string& 变化原因键 = {}) noexcept
{
    auto 变化 = 构造特征变化项(
        变化主体类型,
        变化主体主键,
        特征类型,
        特征主键,
        变化后值,
        已确认生效,
        是否关键中间状态,
        已恢复,
        变化原因键);
    变化.变化前值 = 变化前值;
    return 变化;
}

inline const char* 线程状态特征文本(const 枚举_特征类型 特征类型) noexcept
{
    switch (特征类型) {
    case 枚举_特征类型::控制意图: return "控制意图";
    case 枚举_特征类型::实际运行状态: return "实际运行状态";
    case 枚举_特征类型::生命周期状态: return "生命周期状态";
    default: return "未定义状态特征";
    }
}

inline bool 是否线程状态型特征(const 枚举_特征类型 特征类型) noexcept
{
    return 特征类型 == 枚举_特征类型::控制意图
        || 特征类型 == 枚举_特征类型::实际运行状态
        || 特征类型 == 枚举_特征类型::生命周期状态;
}

inline bool 是否线程状态变化处理类型(const 枚举_消息处理类型 处理类型) noexcept
{
    return 处理类型 == 枚举_消息处理类型::工作线程状态消息;
}

inline std::string 生成线程状态变化摘要(const 结构_线程状态变化消息段& 消息段)
{
    std::ostringstream 输出;
    输出 << "线程状态变化";
    if (!消息段.线程标签.empty()) {
        输出 << "[" << 消息段.线程标签 << "]";
    } else {
        输出 << "[#" << 消息段.线程存在主键 << "]";
    }
    输出 << " | 特征=" << 线程状态特征文本(消息段.状态特征类型)
        << " | " << 消息段.旧状态 << "->" << 消息段.新状态;
    if (!消息段.决策者标签.empty()) {
        输出 << " | 决策者=" << 消息段.决策者标签;
    } else if (消息段.决策者主键 != 0) {
        输出 << " | 决策者=#" << 消息段.决策者主键;
    }
    if (!消息段.原因摘要.empty()) {
        输出 << " | 原因=" << 消息段.原因摘要;
    }
    return 输出.str();
}

inline 结构_治理消息 构造治理消息(
    const 枚举_消息处理类型 处理类型,
    const 枚举_消息来源链 来源链 = 枚举_消息来源链::线程直达消息,
    const 时间戳 产生时间 = 0) noexcept
{
    结构_治理消息 消息{};
    消息.头.来源链 = 来源链;
    消息.头.处理类型 = 处理类型;
    消息.头.优先级 = 默认消息优先级(处理类型);
    消息.头.产生时间 = 产生时间;
    消息.头.可抢占 = 默认可抢占(处理类型);
    消息.头.仅局部有效 = 默认仅局部有效(处理类型);
    消息.头.来源成功 = true;
    消息.语义.动作类型 = 从处理类型映射动作类型(处理类型);
    消息.语义.动作语义键 = 默认动作语义键(处理类型);
    return 消息;
}

inline bool 是否存在线程状态变化消息段(const 结构_治理消息& 消息) noexcept
{
    return 消息.附加载荷.线程状态变化.has_value();
}

inline const 结构_线程状态变化消息段* 获取线程状态变化消息段(
    const 结构_治理消息& 消息) noexcept
{
    if (!消息.附加载荷.线程状态变化.has_value()) {
        return nullptr;
    }
    return &(*消息.附加载荷.线程状态变化);
}

inline bool 是否线程状态变化治理消息(const 结构_治理消息& 消息) noexcept
{
    return 是否线程状态变化处理类型(消息.头.处理类型)
        || 是否存在线程状态变化消息段(消息);
}

inline 结构_治理消息 从线程状态变化构造治理消息(
    const 结构_线程状态变化消息段& 消息段,
    const 枚举_消息来源链 来源链 = 枚举_消息来源链::线程直达消息,
    const 枚举_消息处理类型 处理类型 = 枚举_消息处理类型::工作线程状态消息) noexcept
{
    auto 消息 = 构造治理消息(处理类型, 来源链, 消息段.发生时间);
    消息.头.发出者主键 = 消息段.决策者主键;
    消息.头.动作主体主键 = 消息段.线程存在主键;
    消息.头.作用对象主键 = 消息段.线程存在主键;
    消息.头.来源线程主键 =
        消息段.关联线程主键 != 0
        ? 消息段.关联线程主键
        : 消息段.线程存在主键;
    消息.头.来源任务主键 = 消息段.关联任务主键;
    消息.头.目标任务主键 = 消息段.关联任务主键;
    消息.头.父任务主键 = 消息段.关联任务主键;
    消息.头.来源成功 = !消息段.是否故障触发;
    消息.语义.发出者类型 = 消息段.决策者类型;
    消息.语义.发出者主键 = 消息段.决策者主键;
    消息.语义.动作主体类型 = 消息段.线程存在类型;
    消息.语义.动作主体主键 = 消息段.线程存在主键;
    消息.语义.动作类型 = 从处理类型映射动作类型(处理类型);
    消息.语义.动作语义键 =
        消息段.触发动作.empty()
        ? "线程状态变更"
        : 消息段.触发动作;
    消息.语义.作用对象类型 = 消息段.线程存在类型;
    消息.语义.作用对象主键 = 消息段.线程存在主键;
    消息.语义.记录者类型 = 枚举_存在类型::自我线程;
    消息.语义.事实摘要 = 消息段.原因摘要;
    消息.语义.因果摘要 = 消息段.原因键;
    消息.附加载荷.线程状态变化 = 消息段;
    if (是否线程状态型特征(消息段.状态特征类型)) {
        消息.变化项集.push_back(构造特征变化项_含前后值(
            消息段.线程存在类型,
            消息段.线程存在主键,
            消息段.状态特征类型,
            0,
            特征值{ 消息段.旧状态 },
            特征值{ 消息段.新状态 },
            true,
            false,
            false,
            消息段.原因键));
    }
    消息.摘要 = 生成线程状态变化摘要(消息段);
    return 消息;
}

inline bool 是否存在已确认变化项(const 结构_治理消息& 消息) noexcept
{
    for (const auto& 变化项 : 消息.变化项集) {
        if (变化项.已确认生效) {
            return true;
        }
    }
    return false;
}

inline bool 是否存在关键中间状态变化项(const 结构_治理消息& 消息) noexcept
{
    for (const auto& 变化项 : 消息.变化项集) {
        if (变化项.是否关键中间状态) {
            return true;
        }
    }
    return false;
}

inline const char* 执行尝试汇总状态文本(const 枚举_执行尝试汇总状态 状态) noexcept
{
    switch (状态) {
    case 枚举_执行尝试汇总状态::执行中: return "执行中";
    case 枚举_执行尝试汇总状态::已结束待结果: return "已结束待结果";
    case 枚举_执行尝试汇总状态::已收结果待确认: return "已收结果待确认";
    case 枚举_执行尝试汇总状态::已验证成功: return "已验证成功";
    case 枚举_执行尝试汇总状态::已验证失败: return "已验证失败";
    case 枚举_执行尝试汇总状态::已争议: return "已争议";
    case 枚举_执行尝试汇总状态::已过期: return "已过期";
    case 枚举_执行尝试汇总状态::未定义:
    default:
        return "未定义";
    }
}

inline const char* 执行尝试验证状态文本(const 枚举_执行尝试验证状态 状态) noexcept
{
    switch (状态) {
    case 枚举_执行尝试验证状态::待确认: return "待确认";
    case 枚举_执行尝试验证状态::已验证成功: return "已验证成功";
    case 枚举_执行尝试验证状态::已验证失败: return "已验证失败";
    case 枚举_执行尝试验证状态::已争议: return "已争议";
    case 枚举_执行尝试验证状态::已过期: return "已过期";
    case 枚举_执行尝试验证状态::未定义:
    default:
        return "未定义";
    }
}

inline const char* 执行尝试对账结论文本(const 枚举_执行尝试对账结论 结论) noexcept
{
    switch (结论) {
    case 枚举_执行尝试对账结论::对账通过: return "对账通过";
    case 枚举_执行尝试对账结论::缺结果: return "缺结果";
    case 枚举_执行尝试对账结论::缺结束消息: return "缺结束消息";
    case 枚举_执行尝试对账结论::重复: return "重复";
    case 枚举_执行尝试对账结论::冲突: return "冲突";
    case 枚举_执行尝试对账结论::超时: return "超时";
    case 枚举_执行尝试对账结论::时序异常: return "时序异常";
    case 枚举_执行尝试对账结论::串单: return "串单";
    case 枚举_执行尝试对账结论::未定义:
    default:
        return "未定义";
    }
}

inline std::uint64_t 安全解析或散列任务管理主键(const std::string& 文本) noexcept
{
    if (文本.empty()) {
        return 0;
    }

    try {
        return static_cast<std::uint64_t>(std::stoull(文本));
    }
    catch (...) {
        return static_cast<std::uint64_t>(std::hash<std::string>{}(文本));
    }
}

inline 枚举_结果状态 映射任务管理结果状态(const 枚举_任务管理结果状态 状态) noexcept
{
    switch (状态) {
    case 枚举_任务管理结果状态::成功: return 枚举_结果状态::成功;
    case 枚举_任务管理结果状态::失败: return 枚举_结果状态::失败;
    case 枚举_任务管理结果状态::中断: return 枚举_结果状态::中断;
    case 枚举_任务管理结果状态::收束完成: return 枚举_结果状态::收束;
    case 枚举_任务管理结果状态::异常结束: return 枚举_结果状态::异常;
    case 枚举_任务管理结果状态::部分完成: return 枚举_结果状态::待重试;
    case 枚举_任务管理结果状态::未定义:
    default:
        return 枚举_结果状态::未定义;
    }
}

inline 枚举_存在类型 推断任务管理动作主体类型(
    const std::string& 类型摘要) noexcept
{
    if (类型摘要.find("方法") != std::string::npos) {
        return 枚举_存在类型::方法;
    }
    if (类型摘要.find("资源") != std::string::npos) {
        return 枚举_存在类型::资源;
    }
    if (类型摘要.find("场景") != std::string::npos) {
        return 枚举_存在类型::场景;
    }
    if (类型摘要.find("任务管理") != std::string::npos) {
        return 枚举_存在类型::任务管理任务;
    }
    if (类型摘要.find("任务") != std::string::npos) {
        return 枚举_存在类型::任务;
    }
    if (类型摘要.find("系统") != std::string::npos) {
        return 枚举_存在类型::外部系统;
    }
    if (类型摘要.find("派生需求") != std::string::npos) {
        return 枚举_存在类型::派生需求;
    }
    return 枚举_存在类型::外部对象;
}

inline 结构_执行尝试标识 从任务管理消息头提取执行尝试标识(const 结构_任务管理消息头& 消息头) noexcept
{
    结构_执行尝试标识 标识{};
    标识.执行尝试主键 = 构造任务管理执行尝试键(消息头);
    标识.任务管理任务主键 = 消息头.任务管理任务主键;
    标识.任务主键 = 消息头.任务主键;
    标识.父任务主键 = 消息头.父任务主键;
    标识.步骤主键 = 消息头.步骤主键;
    标识.路径签名 = 消息头.路径签名;
    标识.执行尝试号 = 消息头.执行尝试号;
    标识.幂等键 = 消息头.幂等键;
    return 标识;
}

inline 结构_执行尝试标识 从任务管理线程状态消息提取执行尝试标识(
    const 结构_任务管理线程状态消息& 消息) noexcept
{
    return 从任务管理消息头提取执行尝试标识(消息.消息头);
}

inline 结构_执行尝试标识 从任务管理结果状态消息提取执行尝试标识(
    const 结构_任务管理结果状态消息& 消息) noexcept
{
    return 从任务管理消息头提取执行尝试标识(消息.消息头);
}

inline bool 执行尝试键字段可对齐(
    const std::string& 左,
    const std::string& 右) noexcept
{
    return 左.empty() || 右.empty() || 左 == 右;
}

inline bool 执行尝试键字段可对齐(
    const std::uint64_t 左,
    const std::uint64_t 右) noexcept
{
    return 左 == 0 || 右 == 0 || 左 == 右;
}

inline bool 是否同一次执行尝试(
    const 结构_执行尝试标识& 左,
    const 结构_执行尝试标识& 右) noexcept
{
    return 执行尝试键字段可对齐(左.执行尝试主键, 右.执行尝试主键)
        && 执行尝试键字段可对齐(左.任务管理任务主键, 右.任务管理任务主键)
        && 执行尝试键字段可对齐(左.任务主键, 右.任务主键)
        && 执行尝试键字段可对齐(左.父任务主键, 右.父任务主键)
        && 执行尝试键字段可对齐(左.步骤主键, 右.步骤主键)
        && 执行尝试键字段可对齐(左.路径签名, 右.路径签名)
        && 执行尝试键字段可对齐(左.执行尝试号, 右.执行尝试号);
}

inline bool 线程状态与结果状态一致(
    const 结构_任务管理线程状态消息& 线程消息,
    const 结构_任务管理结果状态消息& 结果消息) noexcept
{
    const auto 结束状态 = 线程消息.结束状态;
    const auto 结果状态 = 结果消息.结果状态;

    switch (结束状态) {
    case 枚举_任务管理线程结束状态::正常结束:
        return 结果状态 != 枚举_任务管理结果状态::中断
            && 结果状态 != 枚举_任务管理结果状态::异常结束;
    case 枚举_任务管理线程结束状态::收束结束:
        return 结果状态 == 枚举_任务管理结果状态::收束完成
            || 结果状态 == 枚举_任务管理结果状态::部分完成
            || 结果状态 == 枚举_任务管理结果状态::失败;
    case 枚举_任务管理线程结束状态::中断结束:
        return 结果状态 == 枚举_任务管理结果状态::中断
            || 结果状态 == 枚举_任务管理结果状态::部分完成;
    case 枚举_任务管理线程结束状态::故障结束:
        return 结果状态 == 枚举_任务管理结果状态::失败
            || 结果状态 == 枚举_任务管理结果状态::异常结束;
    case 枚举_任务管理线程结束状态::超时结束:
        return 结果状态 == 枚举_任务管理结果状态::失败
            || 结果状态 == 枚举_任务管理结果状态::中断
            || 结果状态 == 枚举_任务管理结果状态::异常结束;
    case 枚举_任务管理线程结束状态::未结束:
    case 枚举_任务管理线程结束状态::未定义:
    default:
        return true;
    }
}

inline 结构_执行尝试对账结果 对账线程状态消息与结果消息(
    const 结构_任务管理线程状态消息& 线程消息,
    const 结构_任务管理结果状态消息& 结果消息) noexcept
{
    结构_执行尝试对账结果 结果{};
    结果.标识 = 从任务管理线程状态消息提取执行尝试标识(线程消息);
    const auto 结果标识 = 从任务管理结果状态消息提取执行尝试标识(结果消息);
    结果.是否同一次执行尝试 = 是否同一次执行尝试(结果.标识, 结果标识);
    if (!结果.是否同一次执行尝试) {
        结果.结论 = 枚举_执行尝试对账结论::串单;
        结果.说明 = "线程状态消息与结果消息的任务/步骤/路径签名或尝试号无法对齐";
        return 结果;
    }

    if (!是否线程状态消息表示执行结束(线程消息)) {
        结果.结论 = 枚举_执行尝试对账结论::缺结束消息;
        结果.说明 = "线程状态消息尚未声明本次执行尝试结束";
        return 结果;
    }

    if (结果消息.消息头.产生时间 != 0
        && 线程消息.结束时间 != 0
        && 结果消息.消息头.产生时间 < 线程消息.结束时间) {
        结果.结论 = 枚举_执行尝试对账结论::时序异常;
        结果.说明 = "结果消息产生时间早于线程结束时间";
        return 结果;
    }

    结果.是否一致 = 线程状态与结果状态一致(线程消息, 结果消息);
    if (!结果.是否一致) {
        结果.结论 = 枚举_执行尝试对账结论::冲突;
        结果.说明 = "线程结束状态与结果状态存在语义冲突";
        return 结果;
    }

    结果.结论 = 枚举_执行尝试对账结论::对账通过;
    结果.是否完整 = true;
    结果.是否进入待确认池 = true;
    结果.说明 = "线程状态消息与结果消息已完成完整性、一致性和时序校验";
    return 结果;
}

inline void 追加任务管理特征值归并摘要(std::ostringstream* 输出, const 特征值& 值)
{
    if (!输出) {
        return;
    }

    if (std::holds_alternative<std::monostate>(值)) {
        *输出 << "null";
        return;
    }
    if (const auto* 数值 = std::get_if<I64>(&值)) {
        *输出 << "i:" << *数值;
        return;
    }
    if (const auto* 向量句柄 = std::get_if<VecU句柄>(&值)) {
        *输出 << "v:" << 向量句柄->主信息指针;
        return;
    }
    if (const auto* 指针 = std::get_if<指针句柄>(&值)) {
        *输出 << "p:" << 指针->指针;
        return;
    }

    *输出 << "unknown";
}

inline std::string 构造任务管理状态变化项归并键(
    const 结构_任务管理状态变化项& 变化项)
{
    std::ostringstream 输出;
    输出 << 变化项.变化主体主键
        << "|" << 变化项.变化主体类型摘要
        << "|" << 变化项.特征类型摘要
        << "|" << 变化项.特征标签
        << "|前=";
    追加任务管理特征值归并摘要(&输出, 变化项.变化前值);
    输出 << "|后=";
    追加任务管理特征值归并摘要(&输出, 变化项.变化后值);
    输出 << "|" << (变化项.已确认生效 ? 1 : 0)
        << "|" << (变化项.是否关键中间状态 ? 1 : 0)
        << "|" << (变化项.已恢复 ? 1 : 0)
        << "|" << 变化项.变化原因键;
    return 输出.str();
}

inline std::string 构造任务管理关键中间状态变化项归并键(
    const 结构_任务管理关键中间状态变化项& 变化项)
{
    std::ostringstream 输出;
    输出 << 变化项.动作主体主键
        << "|" << 变化项.动作主体类型摘要
        << "|" << 变化项.动作语义键
        << "|" << 变化项.输入场景主键
        << "|" << 变化项.输出场景主键
        << "|" << 变化项.变化主体主键
        << "|" << 变化项.变化主体类型摘要
        << "|" << 变化项.特征类型摘要
        << "|前=";
    追加任务管理特征值归并摘要(&输出, 变化项.变化前值);
    输出 << "|后=";
    追加任务管理特征值归并摘要(&输出, 变化项.变化后值);
    输出 << "|" << 变化项.发生时间
        << "|" << (变化项.执行成功 ? 1 : 0)
        << "|" << 变化项.错误码
        << "|" << 变化项.路径签名
        << "|" << (变化项.已确认生效 ? 1 : 0)
        << "|" << (变化项.已恢复 ? 1 : 0);
    return 输出.str();
}

inline void 归并任务管理状态变化集(
    std::vector<结构_任务管理状态变化项>* 目标,
    const std::vector<结构_任务管理状态变化项>& 来源,
    std::vector<结构_任务管理状态变化项>* 新增项 = nullptr)
{
    if (!目标 || 来源.empty()) {
        return;
    }

    std::unordered_set<std::string> 已有键{};
    已有键.reserve(目标->size() + 来源.size());
    for (const auto& 变化项 : *目标) {
        已有键.insert(构造任务管理状态变化项归并键(变化项));
    }

    for (const auto& 变化项 : 来源) {
        const auto 归并键 = 构造任务管理状态变化项归并键(变化项);
        if (!已有键.insert(归并键).second) {
            continue;
        }
        目标->push_back(变化项);
        if (新增项) {
            新增项->push_back(变化项);
        }
    }
}

inline void 归并任务管理关键中间状态变化集(
    std::vector<结构_任务管理关键中间状态变化项>* 目标,
    const std::vector<结构_任务管理关键中间状态变化项>& 来源,
    std::vector<结构_任务管理关键中间状态变化项>* 新增项 = nullptr)
{
    if (!目标 || 来源.empty()) {
        return;
    }

    std::unordered_set<std::string> 已有键{};
    已有键.reserve(目标->size() + 来源.size());
    for (const auto& 变化项 : *目标) {
        已有键.insert(构造任务管理关键中间状态变化项归并键(变化项));
    }

    for (const auto& 变化项 : 来源) {
        const auto 归并键 = 构造任务管理关键中间状态变化项归并键(变化项);
        if (!已有键.insert(归并键).second) {
            continue;
        }
        目标->push_back(变化项);
        if (新增项) {
            新增项->push_back(变化项);
        }
    }
}

inline 结构_执行尝试对账结果 刷新执行尝试汇总状态(
    结构_执行尝试汇总* 汇总) noexcept
{
    结构_执行尝试对账结果 对账结果{};
    if (!汇总) {
        return 对账结果;
    }

    对账结果.标识 = 汇总->标识;

    if (汇总->最近线程状态消息.has_value() && 汇总->最近结果消息.has_value()) {
        对账结果 = 对账线程状态消息与结果消息(
            *汇总->最近线程状态消息,
            *汇总->最近结果消息);
        汇总->最近对账说明 = 对账结果.说明;
        switch (对账结果.结论) {
        case 枚举_执行尝试对账结论::对账通过:
            汇总->汇总状态 = 枚举_执行尝试汇总状态::已收结果待确认;
            汇总->验证状态 = 枚举_执行尝试验证状态::待确认;
            break;
        case 枚举_执行尝试对账结论::时序异常:
        case 枚举_执行尝试对账结论::冲突:
        case 枚举_执行尝试对账结论::串单:
            汇总->汇总状态 = 枚举_执行尝试汇总状态::已争议;
            汇总->验证状态 = 枚举_执行尝试验证状态::已争议;
            break;
        case 枚举_执行尝试对账结论::缺结束消息:
            汇总->汇总状态 = 枚举_执行尝试汇总状态::执行中;
            break;
        case 枚举_执行尝试对账结论::缺结果:
            汇总->汇总状态 = 枚举_执行尝试汇总状态::已结束待结果;
            break;
        case 枚举_执行尝试对账结论::重复:
        case 枚举_执行尝试对账结论::超时:
        case 枚举_执行尝试对账结论::未定义:
        default:
            break;
        }
        return 对账结果;
    }

    if (汇总->最近线程状态消息.has_value()) {
        if (是否线程状态消息表示执行结束(*汇总->最近线程状态消息)) {
            汇总->汇总状态 = 枚举_执行尝试汇总状态::已结束待结果;
            对账结果.结论 = 枚举_执行尝试对账结论::缺结果;
            对账结果.说明 = "已收到线程结束消息，等待结果消息";
        } else {
            汇总->汇总状态 = 枚举_执行尝试汇总状态::执行中;
            对账结果.结论 = 枚举_执行尝试对账结论::缺结果;
            对账结果.说明 = "执行尝试仍在运行，尚未形成最终结果";
        }
        汇总->最近对账说明 = 对账结果.说明;
        return 对账结果;
    }

    if (汇总->最近结果消息.has_value()) {
        汇总->汇总状态 = 枚举_执行尝试汇总状态::执行中;
        对账结果.结论 = 枚举_执行尝试对账结论::缺结束消息;
        对账结果.说明 = "已收到结果消息，但缺少线程结束消息";
        汇总->最近对账说明 = 对账结果.说明;
        return 对账结果;
    }

    汇总->汇总状态 = 枚举_执行尝试汇总状态::未定义;
    汇总->验证状态 = 枚举_执行尝试验证状态::未定义;
    return 对账结果;
}

inline 结构_执行尝试对账结果 合并线程状态消息到执行尝试汇总(
    结构_执行尝试汇总* 汇总,
    const 结构_任务管理线程状态消息& 消息) noexcept
{
    结构_执行尝试对账结果 对账结果{};
    if (!汇总) {
        return 对账结果;
    }

    const auto 标识 = 从任务管理线程状态消息提取执行尝试标识(消息);
    if (汇总->标识.执行尝试主键.empty()) {
        汇总->标识 = 标识;
    } else if (!是否同一次执行尝试(汇总->标识, 标识)) {
        对账结果.标识 = 标识;
        对账结果.结论 = 枚举_执行尝试对账结论::串单;
        对账结果.说明 = "线程状态消息无法并入现有执行尝试汇总";
        汇总->汇总状态 = 枚举_执行尝试汇总状态::已争议;
        汇总->验证状态 = 枚举_执行尝试验证状态::已争议;
        汇总->最近对账说明 = 对账结果.说明;
        return 对账结果;
    }

    if (!消息.消息头.幂等键.empty()
        && 消息.消息头.幂等键 == 汇总->最近线程状态消息幂等键) {
        ++汇总->重复消息累计数;
        对账结果.标识 = 汇总->标识;
        对账结果.结论 = 枚举_执行尝试对账结论::重复;
        对账结果.说明 = "线程状态消息幂等键重复";
        汇总->最近对账说明 = 对账结果.说明;
        return 对账结果;
    }

    汇总->已收到线程状态 = true;
    ++汇总->线程状态消息累计数;
    汇总->当前线程运行状态 = 消息.当前运行状态;
    汇总->线程结束状态 = 消息.结束状态;
    汇总->开始时间 = 消息.开始时间 != 0 ? 消息.开始时间 : 汇总->开始时间;
    汇总->结束时间 = 消息.结束时间 != 0 ? 消息.结束时间 : 汇总->结束时间;
    汇总->最近归并时间 = 消息.消息头.产生时间;
    汇总->最近线程状态消息幂等键 = 消息.消息头.幂等键;
    汇总->最近线程状态消息 = 消息;
    return 刷新执行尝试汇总状态(汇总);
}

inline 结构_执行尝试对账结果 合并结果消息到执行尝试汇总(
    结构_执行尝试汇总* 汇总,
    const 结构_任务管理结果状态消息& 消息,
    std::vector<结构_任务管理状态变化项>* 新增服务对象状态变化集 = nullptr,
    std::vector<结构_任务管理关键中间状态变化项>* 新增关键中间状态变化集 = nullptr) noexcept
{
    结构_执行尝试对账结果 对账结果{};
    if (!汇总) {
        return 对账结果;
    }

    const auto 标识 = 从任务管理结果状态消息提取执行尝试标识(消息);
    if (汇总->标识.执行尝试主键.empty()) {
        汇总->标识 = 标识;
    } else if (!是否同一次执行尝试(汇总->标识, 标识)) {
        对账结果.标识 = 标识;
        对账结果.结论 = 枚举_执行尝试对账结论::串单;
        对账结果.说明 = "结果消息无法并入现有执行尝试汇总";
        汇总->汇总状态 = 枚举_执行尝试汇总状态::已争议;
        汇总->验证状态 = 枚举_执行尝试验证状态::已争议;
        汇总->最近对账说明 = 对账结果.说明;
        return 对账结果;
    }

    if (!消息.消息头.幂等键.empty()
        && 消息.消息头.幂等键 == 汇总->最近结果消息幂等键) {
        ++汇总->重复消息累计数;
        对账结果.标识 = 汇总->标识;
        对账结果.结论 = 枚举_执行尝试对账结论::重复;
        对账结果.说明 = "结果消息幂等键重复";
        汇总->最近对账说明 = 对账结果.说明;
        return 对账结果;
    }

    汇总->已收到结果消息 = true;
    ++汇总->结果消息累计数;
    汇总->结果状态 = 消息.结果状态;
    汇总->最近结果时间 =
        消息.完成时间 != 0
        ? 消息.完成时间
        : (消息.执行结束时间 != 0 ? 消息.执行结束时间 : 消息.消息头.产生时间);
    汇总->最近归并时间 = 消息.消息头.产生时间;
    汇总->最近结果消息幂等键 = 消息.消息头.幂等键;
    汇总->最近结果摘要 =
        !消息.摘要.empty()
        ? 消息.摘要
        : 构造任务管理结果状态消息摘要(消息);
    归并任务管理状态变化集(
        &汇总->服务对象状态变化集,
        消息.服务对象状态变化集,
        新增服务对象状态变化集);
    归并任务管理关键中间状态变化集(
        &汇总->关键中间状态变化集,
        消息.关键中间状态变化集,
        新增关键中间状态变化集);
    if (汇总->开始时间 == 0) {
        汇总->开始时间 = 消息.执行开始时间;
    }
    if (汇总->结束时间 == 0) {
        汇总->结束时间 =
            消息.执行结束时间 != 0
            ? 消息.执行结束时间
            : 消息.完成时间;
    }
    汇总->最近结果消息 = 消息;
    return 刷新执行尝试汇总状态(汇总);
}

inline 结构_执行尝试汇总 从线程状态消息构造执行尝试汇总(
    const 结构_任务管理线程状态消息& 消息) noexcept
{
    结构_执行尝试汇总 汇总{};
    (void)合并线程状态消息到执行尝试汇总(&汇总, 消息);
    return 汇总;
}

inline 结构_执行尝试汇总 从结果消息构造执行尝试汇总(
    const 结构_任务管理结果状态消息& 消息) noexcept
{
    结构_执行尝试汇总 汇总{};
    (void)合并结果消息到执行尝试汇总(&汇总, 消息);
    return 汇总;
}

inline 枚举_任务管理触发事件类型 映射到任务管理触发事件类型(
    const 结构_治理消息& 消息) noexcept
{
    if (消息.附加载荷.恢复快照.has_value()) {
        return 枚举_任务管理触发事件类型::恢复重建;
    }

    switch (消息.头.来源链) {
    case 枚举_消息来源链::线程直达消息:
        return 枚举_任务管理触发事件类型::外部反馈;
    case 枚举_消息来源链::任务管理工作线程回流消息:
        return 枚举_任务管理触发事件类型::执行回流;
    case 枚举_消息来源链::未定义:
    default:
        return 枚举_任务管理触发事件类型::未定义;
    }
}

inline 枚举_任务管理触发来源 映射到任务管理触发来源(
    const 结构_治理消息& 消息) noexcept
{
    if (消息.头.来源链 == 枚举_消息来源链::未定义) {
        return 枚举_任务管理触发来源::未定义;
    }
    return 枚举_任务管理触发来源::自然运行态;
}

inline 枚举_治理恢复事件处理方式 计算恢复事件处理方式(
    const 结构_治理消息& 消息) noexcept
{
    if (消息.附加载荷.恢复快照.has_value()) {
        return 枚举_治理恢复事件处理方式::由恢复重建承接;
    }

    switch (消息.头.处理类型) {
    case 枚举_消息处理类型::控制域事实消息:
        return 枚举_治理恢复事件处理方式::仅内存态;
    case 枚举_消息处理类型::业务域事实消息:
    case 枚举_消息处理类型::延迟事实消息:
    case 枚举_消息处理类型::工作线程状态消息:
    case 枚举_消息处理类型::任务推进关键事件消息:
    case 枚举_消息处理类型::派生需求上报消息:
    case 枚举_消息处理类型::结果与关键中间状态回流消息:
        return 枚举_治理恢复事件处理方式::待回判事实;
    case 枚举_消息处理类型::未定义:
    default:
        return 枚举_治理恢复事件处理方式::未定义;
    }
}

inline 结构_治理消息 从任务推进事件构造治理消息(const 结构_任务推进事件& 事件) noexcept
{
    结构_治理消息 消息{};
    switch (事件.事件类型) {
    case 枚举_任务推进事件类型::当前步骤可执行:
        消息 = 构造治理消息(
            枚举_消息处理类型::任务推进关键事件消息,
            枚举_消息来源链::任务管理工作线程回流消息);
        消息.变化项集.push_back(构造特征变化项(
            枚举_存在类型::任务管理任务,
            事件.任务根ID,
            枚举_特征类型::局部运行状态,
            0,
            特征值{ static_cast<I64>(枚举_任务推进事件类型::当前步骤可执行) },
            true,
            false,
            false,
            "当前步骤可执行"));
        break;
    case 枚举_任务推进事件类型::当前步骤阻塞:
        消息 = 构造治理消息(
            枚举_消息处理类型::任务推进关键事件消息,
            枚举_消息来源链::任务管理工作线程回流消息);
        消息.变化项集.push_back(构造特征变化项(
            枚举_存在类型::任务管理任务,
            事件.任务根ID,
            枚举_特征类型::当前等待原因,
            0,
            特征值{ static_cast<I64>(枚举_任务推进事件类型::当前步骤阻塞) },
            true,
            true,
            false,
            事件.等待原因.empty() ? "当前步骤阻塞" : 事件.等待原因));
        break;
    case 枚举_任务推进事件类型::派生需求上报:
        消息 = 构造治理消息(
            枚举_消息处理类型::派生需求上报消息,
            枚举_消息来源链::任务管理工作线程回流消息);
        消息.变化项集.push_back(构造特征变化项(
            枚举_存在类型::任务管理任务,
            事件.任务根ID,
            枚举_特征类型::当前等待原因,
            0,
            特征值{ static_cast<I64>(枚举_任务推进事件类型::派生需求上报) },
            true,
            true,
            false,
            事件.派生需求摘要.empty() ? "派生需求上报" : 事件.派生需求摘要));
        break;
    case 枚举_任务推进事件类型::局部结果返回:
    case 枚举_任务推进事件类型::最终结果返回:
    case 枚举_任务推进事件类型::异常上报:
        消息 = 构造治理消息(
            枚举_消息处理类型::结果与关键中间状态回流消息,
            枚举_消息来源链::任务管理工作线程回流消息);
        消息.变化项集.push_back(构造特征变化项(
            枚举_存在类型::任务,
            事件.任务根ID,
            枚举_特征类型::结果状态,
            0,
            特征值{ static_cast<I64>(事件.事件类型) },
            true,
            事件.事件类型 == 枚举_任务推进事件类型::异常上报,
            false,
            事件.摘要));
        break;
    case 枚举_任务推进事件类型::未定义:
    default:
        消息 = 构造治理消息(
            枚举_消息处理类型::未定义,
            枚举_消息来源链::任务管理工作线程回流消息);
        break;
    }

    消息.头.来源任务主键 = 事件.任务根ID;
    消息.头.目标任务主键 = 事件.任务根ID;
    消息.头.作用对象主键 = 事件.任务根ID;
    消息.语义.动作主体类型 = 枚举_存在类型::任务管理任务;
    消息.语义.动作主体主键 = 事件.任务根ID;
    消息.语义.作用对象类型 = 枚举_存在类型::任务;
    消息.语义.作用对象主键 = 事件.任务根ID;
    消息.语义.事实摘要 = 事件.摘要;
    消息.摘要 = 事件.摘要;
    return 消息;
}

inline 结构_治理消息 从任务管理线程状态消息构造治理消息(
    const 结构_任务管理线程状态消息& 任务管理消息) noexcept
{
    结构_线程状态变化消息段 线程状态变化{};
    线程状态变化.发生时间 =
        任务管理消息.结束时间 != 0
        ? 任务管理消息.结束时间
        : 任务管理消息.消息头.产生时间;
    线程状态变化.决策者类型 = 枚举_存在类型::任务管理工作线程;
    线程状态变化.决策者主键 = 安全解析或散列任务管理主键(任务管理消息.消息头.发出者主键);
    线程状态变化.决策者标签 = "任务管理工作线程";
    线程状态变化.触发动作 = "任务管理执行状态上报";
    线程状态变化.原因键 = 任务管理线程结束状态文本(任务管理消息.结束状态);
    线程状态变化.原因摘要 = 构造任务管理线程状态消息摘要(任务管理消息);
    线程状态变化.线程存在主键 = 安全解析或散列任务管理主键(任务管理消息.消息头.发出者主键);
    线程状态变化.线程标签 = "任务管理工作线程";
    线程状态变化.线程存在类型 = 枚举_存在类型::任务管理工作线程;
    线程状态变化.线程种类 = "任务管理工作线程";
    线程状态变化.直属拥有者类型 = 枚举_存在类型::线程池;
    线程状态变化.状态特征类型 = 枚举_特征类型::实际运行状态;
    线程状态变化.旧状态 = 0;
    线程状态变化.新状态 = static_cast<I64>(任务管理消息.当前运行状态);
    线程状态变化.是否故障触发 =
        任务管理消息.结束状态 == 枚举_任务管理线程结束状态::故障结束
        || 任务管理消息.当前运行状态 == 枚举_任务管理线程运行状态::故障;
    线程状态变化.是否stop链触发 =
        任务管理消息.结束状态 == 枚举_任务管理线程结束状态::中断结束;
    线程状态变化.关联任务主键 = 安全解析或散列任务管理主键(任务管理消息.消息头.任务主键);
    线程状态变化.关联线程主键 = 线程状态变化.线程存在主键;

    auto 治理消息 = 从线程状态变化构造治理消息(
        线程状态变化,
        枚举_消息来源链::任务管理工作线程回流消息,
        枚举_消息处理类型::工作线程状态消息);
    治理消息.头.发出者主键 = 线程状态变化.决策者主键;
    治理消息.头.动作主体主键 = 安全解析或散列任务管理主键(任务管理消息.消息头.任务管理任务主键);
    治理消息.头.作用对象主键 = 安全解析或散列任务管理主键(任务管理消息.消息头.任务主键);
    治理消息.头.来源线程主键 = 线程状态变化.线程存在主键;
    治理消息.头.来源任务主键 = 安全解析或散列任务管理主键(任务管理消息.消息头.任务主键);
    治理消息.头.目标任务主键 = 治理消息.头.来源任务主键;
    治理消息.头.父任务主键 = 安全解析或散列任务管理主键(任务管理消息.消息头.父任务主键);
    治理消息.头.关联场景主键 = 安全解析或散列任务管理主键(任务管理消息.消息头.关联场景主键);
    治理消息.头.路径签名 = 任务管理消息.消息头.路径签名;
    治理消息.语义.发出者类型 = 枚举_存在类型::任务管理工作线程;
    治理消息.语义.动作主体类型 = 枚举_存在类型::任务管理任务;
    治理消息.语义.动作主体主键 = 治理消息.头.动作主体主键;
    治理消息.语义.作用对象类型 = 枚举_存在类型::任务;
    治理消息.语义.作用对象主键 = 治理消息.头.作用对象主键;
    治理消息.来源.影子验证状态 = 任务管理消息.消息头.影子验证状态;
    治理消息.来源.允许正式资产提交 = 任务管理消息.消息头.允许正式资产提交;
    治理消息.附加载荷.任务管理线程状态 = 任务管理消息;

    auto 汇总 = 从线程状态消息构造执行尝试汇总(任务管理消息);
    auto 对账结果 = 刷新执行尝试汇总状态(&汇总);
    治理消息.附加载荷.执行尝试汇总 = 汇总;
    治理消息.附加载荷.执行对账结果 = 对账结果;
    治理消息.摘要 = 构造任务管理线程状态消息摘要(任务管理消息);
    if (!任务管理消息.消息头.幂等键.empty()) {
        治理消息.载荷键 = "任务管理线程状态|" + 任务管理消息.消息头.幂等键;
    }
    return 治理消息;
}

inline 结构_治理消息 从任务管理派生需求消息构造治理消息(
    const 结构_任务管理派生需求消息& 任务管理消息) noexcept
{
    auto 治理消息 = 构造治理消息(
        枚举_消息处理类型::派生需求上报消息,
        枚举_消息来源链::任务管理工作线程回流消息,
        任务管理消息.消息头.产生时间);
    治理消息.头.发出者主键 = 安全解析或散列任务管理主键(任务管理消息.消息头.发出者主键);
    治理消息.头.动作主体主键 = 安全解析或散列任务管理主键(任务管理消息.消息头.任务管理任务主键);
    治理消息.头.作用对象主键 = 安全解析或散列任务管理主键(任务管理消息.消息头.任务主键);
    治理消息.头.来源线程主键 = 治理消息.头.发出者主键;
    治理消息.头.来源任务主键 = 治理消息.头.作用对象主键;
    治理消息.头.目标任务主键 = 治理消息.头.作用对象主键;
    治理消息.头.父任务主键 = 安全解析或散列任务管理主键(任务管理消息.消息头.父任务主键);
    治理消息.头.关联场景主键 = 安全解析或散列任务管理主键(任务管理消息.消息头.关联场景主键);
    治理消息.头.路径签名 = 任务管理消息.消息头.路径签名;
    治理消息.头.来源成功 = true;
    治理消息.语义.发出者类型 = 枚举_存在类型::任务管理工作线程;
    治理消息.语义.发出者主键 = 治理消息.头.发出者主键;
    治理消息.语义.动作主体类型 = 枚举_存在类型::任务管理任务;
    治理消息.语义.动作主体主键 = 治理消息.头.动作主体主键;
    治理消息.语义.动作类型 = 枚举_动作类型::派生需求上报;
    治理消息.语义.动作语义键 =
        !任务管理消息.触发动作语义键.empty()
        ? 任务管理消息.触发动作语义键
        : "任务管理派生需求上报";
    治理消息.语义.作用对象类型 = 枚举_存在类型::任务;
    治理消息.语义.作用对象主键 = 治理消息.头.作用对象主键;
    治理消息.语义.事实摘要 = 构造任务管理派生需求消息摘要(任务管理消息);
    治理消息.语义.因果摘要 = 任务管理派生需求类型文本(任务管理消息.派生需求类型);
    治理消息.来源.影子验证状态 = 任务管理消息.消息头.影子验证状态;
    治理消息.来源.允许正式资产提交 = 任务管理消息.消息头.允许正式资产提交;
    治理消息.附加载荷.任务管理派生需求 = 任务管理消息;

    if (任务管理消息.是否阻塞当前步骤 || !任务管理消息.当前等待原因.empty()) {
        治理消息.变化项集.push_back(构造特征变化项(
            枚举_存在类型::任务管理任务,
            治理消息.头.动作主体主键,
            枚举_特征类型::当前等待原因,
            0,
            特征值{ static_cast<I64>(任务管理消息.派生需求类型) },
            true,
            任务管理消息.是否阻塞当前步骤,
            false,
            任务管理消息.当前等待原因.empty()
            ? 任务管理派生需求类型文本(任务管理消息.派生需求类型)
            : 任务管理消息.当前等待原因));
    }
    if (任务管理消息.是否本地不可消化 || 任务管理消息.是否阻塞当前步骤) {
        治理消息.变化项集.push_back(构造特征变化项(
            枚举_存在类型::任务,
            治理消息.头.作用对象主键,
            枚举_特征类型::条件满足状态,
            0,
            特征值{ static_cast<I64>(0) },
            true,
            任务管理消息.是否阻塞当前步骤,
            false,
            !任务管理消息.条件特征类型摘要.empty()
            ? 任务管理消息.条件特征类型摘要
            : "本地不可消化缺口"));
    }
    if (任务管理消息.是否阻塞当前步骤 || 任务管理消息.是否影响父任务推进) {
        治理消息.变化项集.push_back(构造特征变化项(
            枚举_存在类型::任务,
            治理消息.头.作用对象主键,
            枚举_特征类型::是否允许继续派发,
            0,
            特征值{ static_cast<I64>(0) },
            true,
            false,
            false,
            "派生需求阻塞推进"));
    }
    if (任务管理消息.是否可能影响安全) {
        治理消息.变化项集.push_back(构造特征变化项(
            枚举_存在类型::任务管理任务,
            治理消息.头.动作主体主键,
            枚举_特征类型::风险等级,
            0,
            特征值{ static_cast<I64>(任务管理消息.阻塞级别) },
            true,
            false,
            false,
            "派生需求风险提示"));
    }

    治理消息.摘要 = 构造任务管理派生需求消息摘要(任务管理消息);
    if (!任务管理消息.消息头.幂等键.empty()) {
        治理消息.载荷键 = "任务管理派生需求|" + 任务管理消息.消息头.幂等键;
    }
    return 治理消息;
}

inline 结构_治理消息 从任务管理结果状态消息构造治理消息(
    const 结构_任务管理结果状态消息& 任务管理消息) noexcept
{
    auto 治理消息 = 构造治理消息(
        枚举_消息处理类型::结果与关键中间状态回流消息,
        枚举_消息来源链::任务管理工作线程回流消息,
        任务管理消息.消息头.产生时间);
    治理消息.头.发出者主键 = 安全解析或散列任务管理主键(任务管理消息.消息头.发出者主键);
    治理消息.头.动作主体主键 = 安全解析或散列任务管理主键(任务管理消息.消息头.任务管理任务主键);
    治理消息.头.作用对象主键 = 安全解析或散列任务管理主键(任务管理消息.消息头.任务主键);
    治理消息.头.来源线程主键 = 治理消息.头.发出者主键;
    治理消息.头.来源任务主键 = 治理消息.头.作用对象主键;
    治理消息.头.目标任务主键 = 治理消息.头.作用对象主键;
    治理消息.头.父任务主键 = 安全解析或散列任务管理主键(任务管理消息.消息头.父任务主键);
    治理消息.头.关联场景主键 = 安全解析或散列任务管理主键(任务管理消息.消息头.关联场景主键);
    治理消息.头.路径签名 = 任务管理消息.消息头.路径签名;
    治理消息.头.来源成功 = 任务管理消息.是否成功;
    治理消息.头.错误码 = 任务管理消息.错误码;
    治理消息.语义.发出者类型 = 枚举_存在类型::任务管理工作线程;
    治理消息.语义.发出者主键 = 治理消息.头.发出者主键;
    治理消息.语义.动作主体类型 = 枚举_存在类型::任务管理任务;
    治理消息.语义.动作主体主键 = 治理消息.头.动作主体主键;
    治理消息.语义.动作类型 = 枚举_动作类型::结果回流;
    治理消息.语义.动作语义键 = "任务管理结果上报";
    治理消息.语义.作用对象类型 = 枚举_存在类型::任务;
    治理消息.语义.作用对象主键 = 治理消息.头.作用对象主键;
    治理消息.语义.事实摘要 = 构造任务管理结果状态消息摘要(任务管理消息);
    治理消息.语义.因果摘要 = 任务管理结果状态文本(任务管理消息.结果状态);
    治理消息.来源.影子验证状态 = 任务管理消息.消息头.影子验证状态;
    治理消息.来源.允许正式资产提交 = 任务管理消息.消息头.允许正式资产提交;
    治理消息.变化项集.push_back(构造特征变化项(
        枚举_存在类型::任务,
        治理消息.头.作用对象主键,
        枚举_特征类型::结果状态,
        0,
        特征值{ static_cast<I64>(映射任务管理结果状态(任务管理消息.结果状态)) },
        true,
        false,
        false,
        任务管理结果状态文本(任务管理消息.结果状态)));
    治理消息.变化项集.push_back(构造特征变化项(
        枚举_存在类型::任务,
        治理消息.头.作用对象主键,
        枚举_特征类型::局部完成度,
        0,
        特征值{ static_cast<I64>(任务管理消息.完成度 * 10000.0) },
        true,
        false,
        false,
        "结果完成度"));
    治理消息.附加载荷.任务管理结果状态 = 任务管理消息;

    auto 汇总 = 从结果消息构造执行尝试汇总(任务管理消息);
    auto 对账结果 = 刷新执行尝试汇总状态(&汇总);
    治理消息.附加载荷.执行尝试汇总 = 汇总;
    治理消息.附加载荷.执行对账结果 = 对账结果;
    治理消息.摘要 = 构造任务管理结果状态消息摘要(任务管理消息);
    if (!任务管理消息.消息头.幂等键.empty()) {
        治理消息.载荷键 = "任务管理结果状态|" + 任务管理消息.消息头.幂等键;
    }
    return 治理消息;
}

inline 结构_治理消息 从任务管理上行消息构造治理消息(
    const 结构_任务管理上行消息& 上行消息) noexcept
{
    switch (上行消息.类型) {
    case 枚举_任务管理上行消息类型::线程状态消息:
        if (const auto* 消息 = std::get_if<结构_任务管理线程状态消息>(&上行消息.载荷)) {
            return 从任务管理线程状态消息构造治理消息(*消息);
        }
        break;
    case 枚举_任务管理上行消息类型::派生需求消息:
        if (const auto* 消息 = std::get_if<结构_任务管理派生需求消息>(&上行消息.载荷)) {
            return 从任务管理派生需求消息构造治理消息(*消息);
        }
        break;
    case 枚举_任务管理上行消息类型::结果状态消息:
        if (const auto* 消息 = std::get_if<结构_任务管理结果状态消息>(&上行消息.载荷)) {
            return 从任务管理结果状态消息构造治理消息(*消息);
        }
        break;
    case 枚举_任务管理上行消息类型::未定义:
    default:
        break;
    }

    return 构造治理消息(
        枚举_消息处理类型::未定义,
        枚举_消息来源链::任务管理工作线程回流消息);
}

} // namespace 自我线程消息协议

export using 自我线程消息协议::枚举_消息来源链;
export using 自我线程消息协议::枚举_消息处理类型;
export using 自我线程消息协议::枚举_存在类型;
export using 自我线程消息协议::枚举_动作类型;
export using 自我线程消息协议::枚举_特征类型;
export using 自我线程消息协议::枚举_治理消息优先级;
export using 自我线程消息协议::枚举_结果状态;
export using 自我线程消息协议::枚举_执行尝试汇总状态;
export using 自我线程消息协议::枚举_执行尝试验证状态;
export using 自我线程消息协议::枚举_执行尝试对账结论;
export using 自我线程消息协议::结构_治理消息头;
export using 自我线程消息协议::结构_特征变化项;
export using 自我线程消息协议::结构_关键中间状态变化项;
export using 自我线程消息协议::结构_结果回流提示段;
export using 自我线程消息协议::结构_任务结果回流消息;
export using 自我线程消息协议::结构_执行尝试标识;
export using 自我线程消息协议::结构_执行尝试对账结果;
export using 自我线程消息协议::结构_执行尝试汇总;
export using 自我线程消息协议::结构_线程状态变化消息段;
export using 自我线程消息协议::结构_存在动作语义;
