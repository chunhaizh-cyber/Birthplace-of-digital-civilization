module;

#include <cstdint>
#include <optional>
#include <sstream>
#include <string>
#include <vector>

#include "基础数据类型.h"
#include "需求类.h"

export module 自我线程模块.消息协议;

import 任务管理任务模块;
import 任务模块.工作线程协议;

export namespace 自我线程消息协议 {

enum class 枚举_消息来源链 : std::uint8_t {
    未定义 = 0,
    线程直达消息 = 1,
    任务管理工作线程回流消息 = 2,
};

enum class 枚举_消息处理类型 : std::uint8_t {
    未定义 = 0,
    控制域事实消息 = 1,
    业务域事实消息 = 2,
    延迟事实消息 = 3,
    工作线程状态消息 = 4,
    任务推进关键事件消息 = 5,
    派生需求上报消息 = 6,
    结果与关键中间状态回流消息 = 7,
};

enum class 枚举_存在类型 : std::uint16_t {
    未定义 = 0,
    自我 = 1,
    自我线程 = 2,
    任务 = 3,
    任务控制态 = 4,
    任务管理任务 = 5,
    任务管理工作线程 = 6,
    方法 = 7,
    场景 = 8,
    资源 = 9,
    外部对象 = 10,
    外部系统 = 11,
    环境监测器 = 12,
    派生需求 = 13,
    线程池 = 14,
};

enum class 枚举_动作类型 : std::uint16_t {
    未定义 = 0,
    下发控制意图 = 1,
    上报事实 = 2,
    到期生效 = 3,
    状态回报 = 4,
    推进事件上报 = 5,
    派生需求上报 = 6,
    结果回流 = 7,
    关键中间状态回流 = 8,
    路由回父任务 = 9,
};

enum class 枚举_特征类型 : std::uint16_t {
    未定义 = 0,
    控制意图 = 1,
    实际运行状态 = 2,
    运行状态 = 实际运行状态,
    生命周期状态 = 3,
    运行模式 = 4,
    当前预算 = 5,
    优先级策略 = 6,
    资源可用性 = 7,
    风险等级 = 8,
    条件满足状态 = 9,
    当前等待原因 = 10,
    当前步骤前沿 = 11,
    局部运行状态 = 12,
    结果状态 = 13,
    局部完成度 = 14,
    父任务语义影响 = 15,
    健康状态 = 16,
    生效时点 = 17,
    是否允许继续派发 = 18,
};

enum class 枚举_治理消息优先级 : std::uint8_t {
    未定义 = 0,
    低 = 1,
    中 = 2,
    高 = 3,
    很高 = 4,
    紧急 = 5,
};

enum class 枚举_结果状态 : std::uint8_t {
    未定义 = 0,
    成功 = 1,
    失败 = 2,
    中断 = 3,
    收束 = 4,
    异常 = 5,
    待重试 = 6,
};

struct 结构_治理消息头 {
    std::uint64_t 消息主键 = 0;
    枚举_消息来源链 来源链 = 枚举_消息来源链::未定义;
    枚举_消息处理类型 处理类型 = 枚举_消息处理类型::未定义;
    枚举_治理消息优先级 优先级 = 枚举_治理消息优先级::未定义;
    std::uint64_t 发出者主键 = 0;
    std::uint64_t 动作主体主键 = 0;
    std::uint64_t 作用对象主键 = 0;
    std::uint64_t 来源线程主键 = 0;
    std::uint64_t 来源任务主键 = 0;
    std::uint64_t 目标任务主键 = 0;
    std::uint64_t 父任务主键 = 0;
    std::uint64_t 关联场景主键 = 0;
    时间戳 产生时间 = 0;
    std::uint64_t 路径签名 = 0;
    bool 来源成功 = false;
    I64 错误码 = 0;
    I64 置信度 = 0;
    bool 可抢占 = false;
    bool 仅局部有效 = false;
};

struct 结构_特征变化项 {
    枚举_存在类型 变化主体类型 = 枚举_存在类型::未定义;
    std::uint64_t 变化主体主键 = 0;
    枚举_特征类型 特征类型 = 枚举_特征类型::未定义;
    std::uint64_t 特征主键 = 0;
    特征值 变化前值{};
    特征值 变化后值{};
    bool 已确认生效 = false;
    bool 是否关键中间状态 = false;
    bool 已恢复 = false;
    std::string 变化原因键{};
};

struct 结构_关键中间状态变化项 {
    std::uint64_t 动作主体主键 = 0;
    std::string 动作语义键{};
    std::uint64_t 变化主体主键 = 0;
    std::uint64_t 特征主键 = 0;
    特征值 变化前值{};
    特征值 变化后值{};
    时间戳 发生时间 = 0;
    bool 已确认生效 = false;
    bool 已恢复 = false;
};

struct 结构_结果回流提示段 {
    bool 可能存在反向推进 = false;
    bool 可能形成阻塞 = false;
    bool 可能影响父任务 = false;
    bool 可能形成否定项候选 = false;
};

struct 结构_任务结果回流消息 {
    std::uint64_t 任务主键 = 0;
    std::uint64_t 父任务主键 = 0;
    枚举_结果状态 最终结果状态 = 枚举_结果状态::未定义;
    特征值 最终结果值{};
    std::vector<结构_关键中间状态变化项> 关键中间变化集{};
    结构_结果回流提示段 提示段{};
};

struct 结构_线程状态变化消息段 {
    时间戳 发生时间 = 0;
    枚举_存在类型 决策者类型 = 枚举_存在类型::未定义;
    std::uint64_t 决策者主键 = 0;
    std::string 决策者标签{};
    std::string 触发动作{};
    std::string 原因键{};
    std::string 原因摘要{};
    std::uint64_t 线程存在主键 = 0;
    std::string 线程标签{};
    枚举_存在类型 线程存在类型 = 枚举_存在类型::未定义;
    std::string 线程种类{};
    枚举_存在类型 直属拥有者类型 = 枚举_存在类型::未定义;
    std::uint64_t 直属拥有者主键 = 0;
    枚举_特征类型 状态特征类型 = 枚举_特征类型::生命周期状态;
    I64 旧状态 = 0;
    I64 新状态 = 0;
    bool 是否故障触发 = false;
    bool 是否stop链触发 = false;
    std::uint64_t 关联任务主键 = 0;
    std::uint64_t 关联线程主键 = 0;
};

struct 结构_存在动作语义 {
    枚举_存在类型 发出者类型 = 枚举_存在类型::未定义;
    std::uint64_t 发出者主键 = 0;
    枚举_存在类型 动作主体类型 = 枚举_存在类型::未定义;
    std::uint64_t 动作主体主键 = 0;
    枚举_动作类型 动作类型 = 枚举_动作类型::未定义;
    std::string 动作语义键{};
    枚举_存在类型 作用对象类型 = 枚举_存在类型::未定义;
    std::uint64_t 作用对象主键 = 0;
    枚举_存在类型 记录者类型 = 枚举_存在类型::未定义;
    std::uint64_t 记录者主键 = 0;
    std::string 事实摘要{};
    std::string 因果摘要{};
};

struct 结构_治理消息来源诊断 {
    std::uint64_t 来源最小原语位图 = 0;
    std::string 来源主观察特征{};
    std::string 影子验证状态{};
    bool 允许正式资产提交 = false;
};

struct 结构_治理消息附加载荷 {
    std::optional<结构_治理恢复快照> 恢复快照{};
    std::optional<结构_需求树更新指令> 需求树更新{};
    std::optional<结构_线程状态变化消息段> 线程状态变化{};
};

struct 结构_治理消息轨迹 {
    std::uint32_t 重放代数 = 0;
    std::uint32_t 消费次数 = 0;
    std::string 最后消费结果{};
};

struct 结构_治理消息 {
    结构_治理消息头 头{};
    结构_存在动作语义 语义{};
    结构_治理消息来源诊断 来源{};
    结构_治理消息附加载荷 附加载荷{};
    结构_治理消息轨迹 轨迹{};
    std::vector<结构_特征变化项> 变化项集{};
    std::string 载荷键{};
    std::string 摘要{};
};

inline const char* 默认动作语义键(const 枚举_消息处理类型 处理类型) noexcept
{
    switch (处理类型) {
    case 枚举_消息处理类型::控制域事实消息: return "控制域事实变化";
    case 枚举_消息处理类型::业务域事实消息: return "业务域事实变化";
    case 枚举_消息处理类型::延迟事实消息: return "延迟事实生效";
    case 枚举_消息处理类型::工作线程状态消息: return "线程状态变化上报";
    case 枚举_消息处理类型::任务推进关键事件消息: return "任务推进关键事件上报";
    case 枚举_消息处理类型::派生需求上报消息: return "派生需求上报";
    case 枚举_消息处理类型::结果与关键中间状态回流消息: return "结果与关键中间状态回流";
    case 枚举_消息处理类型::未定义:
    default:
        return "未定义动作";
    }
}

inline 枚举_治理消息优先级 默认消息优先级(const 枚举_消息处理类型 处理类型) noexcept
{
    switch (处理类型) {
    case 枚举_消息处理类型::控制域事实消息:
        return 枚举_治理消息优先级::很高;
    case 枚举_消息处理类型::业务域事实消息:
    case 枚举_消息处理类型::延迟事实消息:
    case 枚举_消息处理类型::工作线程状态消息:
    case 枚举_消息处理类型::结果与关键中间状态回流消息:
        return 枚举_治理消息优先级::高;
    case 枚举_消息处理类型::任务推进关键事件消息:
    case 枚举_消息处理类型::派生需求上报消息:
        return 枚举_治理消息优先级::中;
    case 枚举_消息处理类型::未定义:
    default:
        return 枚举_治理消息优先级::低;
    }
}

inline bool 默认可抢占(const 枚举_消息处理类型 处理类型) noexcept
{
    return 处理类型 == 枚举_消息处理类型::控制域事实消息;
}

inline bool 默认仅局部有效(const 枚举_消息处理类型) noexcept
{
    return false;
}

inline 枚举_动作类型 从处理类型映射动作类型(const 枚举_消息处理类型 处理类型) noexcept
{
    switch (处理类型) {
    case 枚举_消息处理类型::控制域事实消息:
        return 枚举_动作类型::下发控制意图;
    case 枚举_消息处理类型::业务域事实消息:
        return 枚举_动作类型::上报事实;
    case 枚举_消息处理类型::延迟事实消息:
        return 枚举_动作类型::到期生效;
    case 枚举_消息处理类型::工作线程状态消息:
        return 枚举_动作类型::状态回报;
    case 枚举_消息处理类型::任务推进关键事件消息:
        return 枚举_动作类型::推进事件上报;
    case 枚举_消息处理类型::派生需求上报消息:
        return 枚举_动作类型::派生需求上报;
    case 枚举_消息处理类型::结果与关键中间状态回流消息:
        return 枚举_动作类型::结果回流;
    case 枚举_消息处理类型::未定义:
    default:
        return 枚举_动作类型::未定义;
    }
}

inline 结构_特征变化项 构造特征变化项(
    const 枚举_存在类型 变化主体类型,
    const std::uint64_t 变化主体主键,
    const 枚举_特征类型 特征类型,
    const std::uint64_t 特征主键,
    const 特征值& 变化后值,
    const bool 已确认生效 = false,
    const bool 是否关键中间状态 = false,
    const bool 已恢复 = false,
    const std::string& 变化原因键 = {}) noexcept
{
    结构_特征变化项 变化{};
    变化.变化主体类型 = 变化主体类型;
    变化.变化主体主键 = 变化主体主键;
    变化.特征类型 = 特征类型;
    变化.特征主键 = 特征主键;
    变化.变化后值 = 变化后值;
    变化.已确认生效 = 已确认生效;
    变化.是否关键中间状态 = 是否关键中间状态;
    变化.已恢复 = 已恢复;
    变化.变化原因键 = 变化原因键;
    return 变化;
}

inline 结构_特征变化项 构造特征变化项_含前后值(
    const 枚举_存在类型 变化主体类型,
    const std::uint64_t 变化主体主键,
    const 枚举_特征类型 特征类型,
    const std::uint64_t 特征主键,
    const 特征值& 变化前值,
    const 特征值& 变化后值,
    const bool 已确认生效 = false,
    const bool 是否关键中间状态 = false,
    const bool 已恢复 = false,
    const std::string& 变化原因键 = {}) noexcept
{
    auto 变化 = 构造特征变化项(
        变化主体类型,
        变化主体主键,
        特征类型,
        特征主键,
        变化后值,
        已确认生效,
        是否关键中间状态,
        已恢复,
        变化原因键);
    变化.变化前值 = 变化前值;
    return 变化;
}

inline const char* 线程状态特征文本(const 枚举_特征类型 特征类型) noexcept
{
    switch (特征类型) {
    case 枚举_特征类型::控制意图: return "控制意图";
    case 枚举_特征类型::实际运行状态: return "实际运行状态";
    case 枚举_特征类型::生命周期状态: return "生命周期状态";
    default: return "未定义状态特征";
    }
}

inline bool 是否线程状态型特征(const 枚举_特征类型 特征类型) noexcept
{
    return 特征类型 == 枚举_特征类型::控制意图
        || 特征类型 == 枚举_特征类型::实际运行状态
        || 特征类型 == 枚举_特征类型::生命周期状态;
}

inline bool 是否线程状态变化处理类型(const 枚举_消息处理类型 处理类型) noexcept
{
    return 处理类型 == 枚举_消息处理类型::工作线程状态消息;
}

inline std::string 生成线程状态变化摘要(const 结构_线程状态变化消息段& 消息段)
{
    std::ostringstream 输出;
    输出 << "线程状态变化";
    if (!消息段.线程标签.empty()) {
        输出 << "[" << 消息段.线程标签 << "]";
    } else {
        输出 << "[#" << 消息段.线程存在主键 << "]";
    }
    输出 << " | 特征=" << 线程状态特征文本(消息段.状态特征类型)
        << " | " << 消息段.旧状态 << "->" << 消息段.新状态;
    if (!消息段.决策者标签.empty()) {
        输出 << " | 决策者=" << 消息段.决策者标签;
    } else if (消息段.决策者主键 != 0) {
        输出 << " | 决策者=#" << 消息段.决策者主键;
    }
    if (!消息段.原因摘要.empty()) {
        输出 << " | 原因=" << 消息段.原因摘要;
    }
    return 输出.str();
}

inline 结构_治理消息 构造治理消息(
    const 枚举_消息处理类型 处理类型,
    const 枚举_消息来源链 来源链 = 枚举_消息来源链::线程直达消息,
    const 时间戳 产生时间 = 0) noexcept
{
    结构_治理消息 消息{};
    消息.头.来源链 = 来源链;
    消息.头.处理类型 = 处理类型;
    消息.头.优先级 = 默认消息优先级(处理类型);
    消息.头.产生时间 = 产生时间;
    消息.头.可抢占 = 默认可抢占(处理类型);
    消息.头.仅局部有效 = 默认仅局部有效(处理类型);
    消息.头.来源成功 = true;
    消息.语义.动作类型 = 从处理类型映射动作类型(处理类型);
    消息.语义.动作语义键 = 默认动作语义键(处理类型);
    return 消息;
}

inline bool 是否存在线程状态变化消息段(const 结构_治理消息& 消息) noexcept
{
    return 消息.附加载荷.线程状态变化.has_value();
}

inline const 结构_线程状态变化消息段* 获取线程状态变化消息段(
    const 结构_治理消息& 消息) noexcept
{
    if (!消息.附加载荷.线程状态变化.has_value()) {
        return nullptr;
    }
    return &(*消息.附加载荷.线程状态变化);
}

inline bool 是否线程状态变化治理消息(const 结构_治理消息& 消息) noexcept
{
    return 是否线程状态变化处理类型(消息.头.处理类型)
        || 是否存在线程状态变化消息段(消息);
}

inline 结构_治理消息 从线程状态变化构造治理消息(
    const 结构_线程状态变化消息段& 消息段,
    const 枚举_消息来源链 来源链 = 枚举_消息来源链::线程直达消息,
    const 枚举_消息处理类型 处理类型 = 枚举_消息处理类型::工作线程状态消息) noexcept
{
    auto 消息 = 构造治理消息(处理类型, 来源链, 消息段.发生时间);
    消息.头.发出者主键 = 消息段.决策者主键;
    消息.头.动作主体主键 = 消息段.线程存在主键;
    消息.头.作用对象主键 = 消息段.线程存在主键;
    消息.头.来源线程主键 =
        消息段.关联线程主键 != 0
        ? 消息段.关联线程主键
        : 消息段.线程存在主键;
    消息.头.来源任务主键 = 消息段.关联任务主键;
    消息.头.目标任务主键 = 消息段.关联任务主键;
    消息.头.父任务主键 = 消息段.关联任务主键;
    消息.头.来源成功 = !消息段.是否故障触发;
    消息.语义.发出者类型 = 消息段.决策者类型;
    消息.语义.发出者主键 = 消息段.决策者主键;
    消息.语义.动作主体类型 = 消息段.线程存在类型;
    消息.语义.动作主体主键 = 消息段.线程存在主键;
    消息.语义.动作类型 = 从处理类型映射动作类型(处理类型);
    消息.语义.动作语义键 =
        消息段.触发动作.empty()
        ? "线程状态变更"
        : 消息段.触发动作;
    消息.语义.作用对象类型 = 消息段.线程存在类型;
    消息.语义.作用对象主键 = 消息段.线程存在主键;
    消息.语义.记录者类型 = 枚举_存在类型::自我线程;
    消息.语义.事实摘要 = 消息段.原因摘要;
    消息.语义.因果摘要 = 消息段.原因键;
    消息.附加载荷.线程状态变化 = 消息段;
    if (是否线程状态型特征(消息段.状态特征类型)) {
        消息.变化项集.push_back(构造特征变化项_含前后值(
            消息段.线程存在类型,
            消息段.线程存在主键,
            消息段.状态特征类型,
            0,
            特征值{ 消息段.旧状态 },
            特征值{ 消息段.新状态 },
            true,
            false,
            false,
            消息段.原因键));
    }
    消息.摘要 = 生成线程状态变化摘要(消息段);
    return 消息;
}

inline bool 是否存在已确认变化项(const 结构_治理消息& 消息) noexcept
{
    for (const auto& 变化项 : 消息.变化项集) {
        if (变化项.已确认生效) {
            return true;
        }
    }
    return false;
}

inline bool 是否存在关键中间状态变化项(const 结构_治理消息& 消息) noexcept
{
    for (const auto& 变化项 : 消息.变化项集) {
        if (变化项.是否关键中间状态) {
            return true;
        }
    }
    return false;
}

inline 枚举_任务管理触发事件类型 映射到任务管理触发事件类型(
    const 结构_治理消息& 消息) noexcept
{
    if (消息.附加载荷.恢复快照.has_value()) {
        return 枚举_任务管理触发事件类型::恢复重建;
    }

    switch (消息.头.来源链) {
    case 枚举_消息来源链::线程直达消息:
        return 枚举_任务管理触发事件类型::外部反馈;
    case 枚举_消息来源链::任务管理工作线程回流消息:
        return 枚举_任务管理触发事件类型::执行回流;
    case 枚举_消息来源链::未定义:
    default:
        return 枚举_任务管理触发事件类型::未定义;
    }
}

inline 枚举_任务管理触发来源 映射到任务管理触发来源(
    const 结构_治理消息& 消息) noexcept
{
    if (消息.头.来源链 == 枚举_消息来源链::未定义) {
        return 枚举_任务管理触发来源::未定义;
    }
    return 枚举_任务管理触发来源::自然运行态;
}

inline 枚举_治理恢复事件处理方式 计算恢复事件处理方式(
    const 结构_治理消息& 消息) noexcept
{
    if (消息.附加载荷.恢复快照.has_value()) {
        return 枚举_治理恢复事件处理方式::由恢复重建承接;
    }

    switch (消息.头.处理类型) {
    case 枚举_消息处理类型::控制域事实消息:
        return 枚举_治理恢复事件处理方式::仅内存态;
    case 枚举_消息处理类型::业务域事实消息:
    case 枚举_消息处理类型::延迟事实消息:
    case 枚举_消息处理类型::工作线程状态消息:
    case 枚举_消息处理类型::任务推进关键事件消息:
    case 枚举_消息处理类型::派生需求上报消息:
    case 枚举_消息处理类型::结果与关键中间状态回流消息:
        return 枚举_治理恢复事件处理方式::待回判事实;
    case 枚举_消息处理类型::未定义:
    default:
        return 枚举_治理恢复事件处理方式::未定义;
    }
}

inline 结构_治理消息 从任务推进事件构造治理消息(const 结构_任务推进事件& 事件) noexcept
{
    结构_治理消息 消息{};
    switch (事件.事件类型) {
    case 枚举_任务推进事件类型::当前步骤可执行:
        消息 = 构造治理消息(
            枚举_消息处理类型::任务推进关键事件消息,
            枚举_消息来源链::任务管理工作线程回流消息);
        消息.变化项集.push_back(构造特征变化项(
            枚举_存在类型::任务管理任务,
            事件.任务根ID,
            枚举_特征类型::局部运行状态,
            0,
            特征值{ static_cast<I64>(枚举_任务推进事件类型::当前步骤可执行) },
            true,
            false,
            false,
            "当前步骤可执行"));
        break;
    case 枚举_任务推进事件类型::当前步骤阻塞:
        消息 = 构造治理消息(
            枚举_消息处理类型::任务推进关键事件消息,
            枚举_消息来源链::任务管理工作线程回流消息);
        消息.变化项集.push_back(构造特征变化项(
            枚举_存在类型::任务管理任务,
            事件.任务根ID,
            枚举_特征类型::当前等待原因,
            0,
            特征值{ static_cast<I64>(枚举_任务推进事件类型::当前步骤阻塞) },
            true,
            true,
            false,
            事件.等待原因.empty() ? "当前步骤阻塞" : 事件.等待原因));
        break;
    case 枚举_任务推进事件类型::派生需求上报:
        消息 = 构造治理消息(
            枚举_消息处理类型::派生需求上报消息,
            枚举_消息来源链::任务管理工作线程回流消息);
        消息.变化项集.push_back(构造特征变化项(
            枚举_存在类型::任务管理任务,
            事件.任务根ID,
            枚举_特征类型::当前等待原因,
            0,
            特征值{ static_cast<I64>(枚举_任务推进事件类型::派生需求上报) },
            true,
            true,
            false,
            事件.派生需求摘要.empty() ? "派生需求上报" : 事件.派生需求摘要));
        break;
    case 枚举_任务推进事件类型::局部结果返回:
    case 枚举_任务推进事件类型::最终结果返回:
    case 枚举_任务推进事件类型::异常上报:
        消息 = 构造治理消息(
            枚举_消息处理类型::结果与关键中间状态回流消息,
            枚举_消息来源链::任务管理工作线程回流消息);
        消息.变化项集.push_back(构造特征变化项(
            枚举_存在类型::任务,
            事件.任务根ID,
            枚举_特征类型::结果状态,
            0,
            特征值{ static_cast<I64>(事件.事件类型) },
            true,
            事件.事件类型 == 枚举_任务推进事件类型::异常上报,
            false,
            事件.摘要));
        break;
    case 枚举_任务推进事件类型::未定义:
    default:
        消息 = 构造治理消息(
            枚举_消息处理类型::未定义,
            枚举_消息来源链::任务管理工作线程回流消息);
        break;
    }

    消息.头.来源任务主键 = 事件.任务根ID;
    消息.头.目标任务主键 = 事件.任务根ID;
    消息.头.作用对象主键 = 事件.任务根ID;
    消息.语义.动作主体类型 = 枚举_存在类型::任务管理任务;
    消息.语义.动作主体主键 = 事件.任务根ID;
    消息.语义.作用对象类型 = 枚举_存在类型::任务;
    消息.语义.作用对象主键 = 事件.任务根ID;
    消息.语义.事实摘要 = 事件.摘要;
    消息.摘要 = 事件.摘要;
    return 消息;
}

} // namespace 自我线程消息协议

