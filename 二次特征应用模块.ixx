module;

#include <algorithm>
#include <cmath>
#include <cstdint>
#include <functional>
#include <optional>
#include <string>
#include <utility>
#include <vector>

#include "基础信息主信息类.h"
#include "基础信息类.h"
#include "特征类.h"
#include "世界树类.h"
#include "语素类.h"

export module 二次特征应用模块;

namespace 二次特征匹配模块_detail {
    template<class T节点>
    std::string 引用键(const 可解析引用<T节点>& 引用)
    {
        if (!引用.主键.empty()) return 引用.主键;
        return 引用.指针 ? 引用.指针->获取主键() : std::string{};
    }

    inline bool 区间有效(const std::optional<I64区间>& 区间值) noexcept
    {
        return 区间值.has_value() && 区间值->有效();
    }

    inline bool 词性主键相等(const 词性节点类* 左, const 词性节点类* 右) noexcept
    {
        if (左 == 右) return true;
        if (!左 || !右) return false;
        const auto 左主键 = 左->获取主键();
        const auto 右主键 = 右->获取主键();
        return !左主键.empty() && 左主键 == 右主键;
    }

    inline const 二次特征主信息类* 主信息(const 二次特征节点类* 节点) noexcept
    {
        return 节点 ? dynamic_cast<const 二次特征主信息类*>(节点->主信息) : nullptr;
    }

    inline I64 点值(const 二次特征主信息类& 主信息) noexcept
    {
        switch (主信息.值形态) {
        case 枚举_二次特征值形态::布尔:
            return 主信息.是否满足 ? 1 : 0;
        case 枚举_二次特征值形态::枚举:
        case 枚举_二次特征值形态::签名:
            return static_cast<I64>(主信息.离散编码);
        default:
            return 主信息.标量值;
        }
    }

    inline bool 对象约束匹配(
        const 基础信息节点类* 条件侧,
        const 基础信息节点类* 状态侧,
        bool 条件空视为通配) noexcept
    {
        if (!条件侧) return 条件空视为通配;
        return 条件侧 == 状态侧;
    }

    inline bool 概念模板_弱相等(
        const 可解析引用<二次特征节点类>& 左,
        const 可解析引用<二次特征节点类>& 右) noexcept
    {
        if (引用键(左).empty() || 引用键(右).empty()) return false;
        if (引用键(左) == 引用键(右)) return true;

        const auto* 左主信息 = 主信息(左.指针);
        const auto* 右主信息 = 主信息(右.指针);
        if (!左主信息 || !右主信息) return false;

        if (左主信息->概念名称 && 右主信息->概念名称
            && 词性主键相等(左主信息->概念名称, 右主信息->概念名称)) {
            return true;
        }

        return 左主信息->度量签名_链键 == 右主信息->度量签名_链键
            && 左主信息->区间层级 == 右主信息->区间层级
            && 左主信息->标量区间.has_value() == 右主信息->标量区间.has_value()
            && (!左主信息->标量区间.has_value()
                || (左主信息->标量区间->低值 == 右主信息->标量区间->低值
                    && 左主信息->标量区间->高值 == 右主信息->标量区间->高值));
    }
}

export namespace 二次特征匹配模块 {

struct 结构_匹配配置 {
    bool 使用对象绑定 = true;
    bool 条件空指针视为通配 = true;
    bool 允许用概念名称弱匹配 = true;
};

struct 结构_匹配结果 {
    I64 命中数 = 0;
    I64 摘要数 = 0;
    I64 目标数 = 0;
    I64 精确率_Q10000 = 0;
    I64 召回率_Q10000 = 0;
    I64 得分_Q10000 = 0;
};

export inline bool 二次特征_满足(
    const 二次特征主信息类* 条件,
    const 二次特征主信息类* 状态,
    const 结构_匹配配置& 配置 = {}) noexcept
{
    using namespace 二次特征匹配模块_detail;

    if (!条件 || !状态) return false;
    if (条件->度量签名_链键.empty() || 状态->度量签名_链键.empty()) return false;
    if (条件->度量签名_链键 != 状态->度量签名_链键) return false;

    if (配置.使用对象绑定) {
        if (!对象约束匹配(条件->主体.指针, 状态->主体.指针, 配置.条件空指针视为通配)) return false;
        if (!对象约束匹配(条件->客体.指针, 状态->客体.指针, 配置.条件空指针视为通配)) return false;
        if (!对象约束匹配(条件->左对象.指针, 状态->左对象.指针, 配置.条件空指针视为通配)) return false;
        if (!对象约束匹配(条件->右对象.指针, 状态->右对象.指针, 配置.条件空指针视为通配)) return false;
    }

    if (条件->概念模板.有效()) {
        if (引用键(条件->概念模板) == 引用键(状态->概念模板)) {
            return true;
        }
        if (配置.允许用概念名称弱匹配
            && 概念模板_弱相等(条件->概念模板, 状态->概念模板)) {
            return true;
        }
        return false;
    }

    if (条件->概念名称) {
        if (状态->概念名称 && 词性主键相等(条件->概念名称, 状态->概念名称)) {
            return true;
        }
        if (状态->概念模板.指针) {
            const auto* 概念主信息 = 主信息(状态->概念模板.指针);
            if (概念主信息 && 概念主信息->概念名称
                && 词性主键相等(条件->概念名称, 概念主信息->概念名称)) {
                return true;
            }
        }
        return false;
    }

    if (区间有效(条件->标量区间)) {
        if (区间有效(状态->标量区间)) {
            const I64 低值 = std::max<I64>(条件->标量区间->低值, 状态->标量区间->低值);
            const I64 高值 = std::min<I64>(条件->标量区间->高值, 状态->标量区间->高值);
            return 高值 >= 低值;
        }
        const auto 当前点值 = 点值(*状态);
        return 当前点值 >= 条件->标量区间->低值 && 当前点值 <= 条件->标量区间->高值;
    }

    if (!条件->离散语义键.empty() && 状态->离散语义键 != 条件->离散语义键) return false;
    if (条件->离散编码 != 0 && 状态->离散编码 != 条件->离散编码) return false;

    if (条件->值形态 == 枚举_二次特征值形态::布尔) {
        return 状态->是否满足 == 条件->是否满足;
    }

    return true;
}

export inline bool 条件索引_满足(
    const std::vector<const 二次特征节点类*>& 条件索引,
    const std::vector<const 二次特征节点类*>& 当前判定集,
    I64* 输出满足数 = nullptr,
    const 结构_匹配配置& 配置 = {}) noexcept
{
    using namespace 二次特征匹配模块_detail;

    if (输出满足数) *输出满足数 = 0;
    if (条件索引.empty()) return true;
    if (当前判定集.empty()) return false;

    I64 命中 = 0;
    for (const auto* 条件节点 : 条件索引) {
        const auto* 条件主信息 = 主信息(条件节点);
        if (!条件主信息) continue;

        bool 当前命中 = false;
        for (const auto* 状态节点 : 当前判定集) {
            const auto* 状态主信息 = 主信息(状态节点);
            if (!状态主信息) continue;
            if (二次特征_满足(条件主信息, 状态主信息, 配置)) {
                当前命中 = true;
                break;
            }
        }
        if (当前命中) ++命中;
    }

    if (输出满足数) *输出满足数 = 命中;
    return 命中 >= static_cast<I64>(条件索引.size());
}

export inline 结构_匹配结果 结果摘要_匹配目标(
    const std::vector<const 二次特征节点类*>& 摘要索引,
    const std::vector<const 二次特征节点类*>& 目标判定集,
    const 结构_匹配配置& 配置 = {}) noexcept
{
    using namespace 二次特征匹配模块_detail;

    结构_匹配结果 输出{};
    输出.摘要数 = static_cast<I64>(摘要索引.size());
    输出.目标数 = static_cast<I64>(目标判定集.size());
    if (摘要索引.empty() || 目标判定集.empty()) {
        return 输出;
    }

    std::vector<bool> 已用(目标判定集.size(), false);
    for (const auto* 摘要节点 : 摘要索引) {
        const auto* 摘要主信息 = 主信息(摘要节点);
        if (!摘要主信息) continue;

        for (std::size_t i = 0; i < 目标判定集.size(); ++i) {
            if (已用[i]) continue;
            const auto* 目标主信息 = 主信息(目标判定集[i]);
            if (!目标主信息) continue;
            if (二次特征_满足(摘要主信息, 目标主信息, 配置)) {
                已用[i] = true;
                ++输出.命中数;
                break;
            }
        }
    }

    const auto 计算比率Q10000 = [](I64 分子, I64 分母) noexcept -> I64 {
        if (分母 <= 0 || 分子 <= 0) return 0;
        const auto 值 = static_cast<I64>((static_cast<long long>(分子) * 10000LL) / static_cast<long long>(分母));
        return std::clamp<I64>(值, 0, 10000);
    };

    输出.精确率_Q10000 = 计算比率Q10000(输出.命中数, 输出.摘要数);
    输出.召回率_Q10000 = 计算比率Q10000(输出.命中数, 输出.目标数);
    输出.得分_Q10000 = 计算比率Q10000(2 * 输出.命中数, 输出.摘要数 + 输出.目标数);
    return 输出;
}

} // namespace 二次特征匹配模块

export {

struct 二次特征匹配配置_桥接 {
    bool 使用对象绑定 = true;
    bool 条件空指针视为通配 = true;
    bool 允许用概念名称弱匹配 = true;
};

struct 二次特征匹配结果_桥接 {
    std::int64_t 命中数 = 0;
    std::int64_t 摘要数 = 0;
    std::int64_t 目标数 = 0;
    std::int64_t 精确率_Q10000 = 0;
    std::int64_t 召回率_Q10000 = 0;
    std::int64_t 得分_Q10000 = 0;
};

inline const 二次特征主信息类* 二次特征主信息_桥接(
    const 基础信息节点类* 节点) noexcept
{
    return 节点 ? dynamic_cast<const 二次特征主信息类*>(节点->主信息) : nullptr;
}

inline bool 二次特征满足_桥接(
    const 二次特征主信息类* 条件,
    const 二次特征主信息类* 状态,
    const 二次特征匹配配置_桥接& 配置 = {}) noexcept
{
    二次特征匹配模块::结构_匹配配置 模块配置{};
    模块配置.使用对象绑定 = 配置.使用对象绑定;
    模块配置.条件空指针视为通配 = 配置.条件空指针视为通配;
    模块配置.允许用概念名称弱匹配 = 配置.允许用概念名称弱匹配;
    return 二次特征匹配模块::二次特征_满足(条件, 状态, 模块配置);
}

inline bool 二次特征满足_桥接(
    const 二次特征节点类* 条件,
    const 二次特征节点类* 状态,
    const 二次特征匹配配置_桥接& 配置 = {}) noexcept
{
    return 二次特征满足_桥接(
        二次特征主信息_桥接(条件),
        二次特征主信息_桥接(状态),
        配置);
}

namespace 二次特征本能判断模块 {
inline bool 判断二次特征方向(
    const 二次特征主信息类* 输入,
    std::int32_t& 输出方向) noexcept
{
    using namespace 二次特征匹配模块_detail;

    if (!输入) {
        return false;
    }

    if (输入->方向区间 != 二次特征主信息类::枚举_方向区间::未定义) {
        const auto 编码 = 二次特征主信息类::方向区间编码(输入->方向区间);
        if (编码 < -1 || 编码 > 1) {
            return false;
        }
        输出方向 = 编码;
        return true;
    }

    if (输入->差值.has_value()) {
        const auto 编码 = 二次特征主信息类::方向区间编码(
            二次特征主信息类::由差值判断方向区间(*输入->差值));
        if (编码 < -1 || 编码 > 1) {
            return false;
        }
        输出方向 = 编码;
        return true;
    }

    if (区间有效(输入->标量区间)) {
        if (输入->标量区间->低值 > 0) {
            输出方向 = 1;
            return true;
        }
        if (输入->标量区间->高值 < 0) {
            输出方向 = -1;
            return true;
        }
        if (输入->标量区间->低值 == 0 && 输入->标量区间->高值 == 0) {
            输出方向 = 0;
            return true;
        }
        return false;
    }

    switch (输入->值形态) {
    case 枚举_二次特征值形态::标量:
        if (输入->标量值 > 0) {
            输出方向 = 1;
            return true;
        }
        if (输入->标量值 < 0) {
            输出方向 = -1;
            return true;
        }
        输出方向 = 0;
        return true;
    case 枚举_二次特征值形态::枚举:
    case 枚举_二次特征值形态::签名:
        if (输入->离散编码 < -1 || 输入->离散编码 > 1) {
            return false;
        }
        输出方向 = 输入->离散编码;
        return true;
    default:
        return false;
    }
}

inline bool 判断二次特征方向(
    const 二次特征节点类* 输入,
    std::int32_t& 输出方向) noexcept
{
    return 判断二次特征方向(二次特征主信息_桥接(输入), 输出方向);
}

inline bool 判断方向是否一致(
    const 二次特征主信息类* 左,
    const 二次特征主信息类* 右,
    std::int32_t& 输出结果) noexcept
{
    std::int32_t 左方向 = 0;
    std::int32_t 右方向 = 0;
    if (!判断二次特征方向(左, 左方向) || !判断二次特征方向(右, 右方向)) {
        return false;
    }

    if (左方向 == 0 || 右方向 == 0) {
        输出结果 = 0;
        return true;
    }

    输出结果 = 左方向 == 右方向 ? 1 : -1;
    return true;
}

inline bool 判断方向是否一致(
    const 二次特征节点类* 左,
    const 二次特征节点类* 右,
    std::int32_t& 输出结果) noexcept
{
    return 判断方向是否一致(
        二次特征主信息_桥接(左),
        二次特征主信息_桥接(右),
        输出结果);
}

inline bool 判断状态结果方向(
    世界树类* 世界树,
    const 状态节点类* 当前状态,
    const 状态节点类* 结果状态,
    std::int32_t& 输出方向) noexcept
{
    if (!世界树 || !当前状态 || !结果状态) {
        return false;
    }
    if (当前状态 == 结果状态) {
        输出方向 = 0;
        return true;
    }

    const auto* 当前主信息 = 世界树->状态().取状态主信息(当前状态);
    const auto* 结果主信息 = 世界树->状态().取状态主信息(结果状态);
    if (!当前主信息 || !结果主信息) {
        return false;
    }

    const auto* 当前特征主信息 = 当前主信息->状态特征.指针
        ? dynamic_cast<const 特征节点主信息类*>(当前主信息->状态特征.指针->主信息)
        : nullptr;
    const auto* 结果特征主信息 = 结果主信息->状态特征.指针
        ? dynamic_cast<const 特征节点主信息类*>(结果主信息->状态特征.指针->主信息)
        : nullptr;
    const auto* 当前特征类型 = 当前特征主信息 ? 当前特征主信息->类型 : nullptr;
    const auto* 结果特征类型 = 结果特征主信息 ? 结果特征主信息->类型 : nullptr;
    const bool 特征类型一致 =
        当前特征类型 && 结果特征类型
        && (当前特征类型 == 结果特征类型
            || (!当前特征类型->获取主键().empty()
                && 当前特征类型->获取主键() == 结果特征类型->获取主键()));
    if (特征类型一致) {
        const auto 比较方法结果 = 世界树->特征().获取比较方法结果(
            当前特征类型,
            当前主信息->状态值,
            结果主信息->状态值,
            当前特征主信息,
            结果特征主信息);
        if (比较方法结果.可比较) {
            const auto 编码 = 二次特征主信息类::方向区间编码(
                二次特征主信息类::由差值判断方向区间(比较方法结果.差值));
            if (编码 < -1 || 编码 > 1) {
                return false;
            }
            输出方向 = 编码;
            return true;
        }
    }

    const auto* 当前值 = std::get_if<I64>(&当前主信息->状态值);
    const auto* 结果值 = std::get_if<I64>(&结果主信息->状态值);
    if (!当前值 || !结果值) {
        return false;
    }
    if (*结果值 > *当前值) {
        输出方向 = 1;
        return true;
    }
    if (*结果值 < *当前值) {
        输出方向 = -1;
        return true;
    }
    输出方向 = 0;
    return true;
}

inline bool 判断状态是否对齐(
    世界树类* 世界树,
    const 状态节点类* 目标状态,
    const 状态节点类* 结果状态,
    std::int32_t& 输出结果) noexcept
{
    if (!世界树 || !目标状态 || !结果状态) {
        return false;
    }
    if (目标状态 == 结果状态) {
        输出结果 = 1;
        return true;
    }

    const auto* 目标主信息 = 世界树->状态().取状态主信息(目标状态);
    const auto* 结果主信息 = 世界树->状态().取状态主信息(结果状态);
    if (!目标主信息 || !结果主信息) {
        return false;
    }

    const auto* 目标特征主信息 = 目标主信息->状态特征.指针
        ? dynamic_cast<const 特征节点主信息类*>(目标主信息->状态特征.指针->主信息)
        : nullptr;
    const auto* 结果特征主信息 = 结果主信息->状态特征.指针
        ? dynamic_cast<const 特征节点主信息类*>(结果主信息->状态特征.指针->主信息)
        : nullptr;
    const auto* 目标特征类型 = 目标特征主信息 ? 目标特征主信息->类型 : nullptr;
    const auto* 结果特征类型 = 结果特征主信息 ? 结果特征主信息->类型 : nullptr;
    const bool 特征类型一致 =
        目标特征类型 && 结果特征类型
        && (目标特征类型 == 结果特征类型
            || (!目标特征类型->获取主键().empty()
                && 目标特征类型->获取主键() == 结果特征类型->获取主键()));
    if (特征类型一致) {
        const auto 比较方法结果 = 世界树->特征().获取比较方法结果(
            目标特征类型,
            目标主信息->状态值,
            结果主信息->状态值,
            目标特征主信息,
            结果特征主信息);
        if (比较方法结果.可比较) {
            输出结果 = 比较方法结果.差值 == 0 ? 1 : -1;
            return true;
        }
    }

    if (!特征值有效(目标主信息->状态值) || !特征值有效(结果主信息->状态值)) {
        return false;
    }
    输出结果 = 目标主信息->状态值 == 结果主信息->状态值 ? 1 : -1;
    return true;
}

inline bool 判断状态是否命中候选集(
    世界树类* 世界树,
    const 状态节点类* 目标状态,
    const 状态节点类* const* 候选开始,
    const 状态节点类* const* 候选结束,
    std::int32_t& 输出结果) noexcept
{
    if (!世界树 || !目标状态 || !候选开始 || !候选结束 || 候选开始 >= 候选结束) {
        return false;
    }

    bool 有可比较候选 = false;
    for (auto 当前 = 候选开始; 当前 != 候选结束; ++当前) {
        const auto* 候选状态 = *当前;
        if (!候选状态) {
            continue;
        }
        if (候选状态 == 目标状态) {
            输出结果 = 1;
            return true;
        }

        std::int32_t 对齐结果 = 0;
        if (判断状态是否对齐(世界树, 目标状态, 候选状态, 对齐结果)) {
            有可比较候选 = true;
            if (对齐结果 > 0) {
                输出结果 = 1;
                return true;
            }
        }
    }

    if (!有可比较候选) {
        return false;
    }

    输出结果 = -1;
    return true;
}
} // namespace 二次特征本能判断模块

inline bool 条件索引满足_桥接(
    const std::vector<const 二次特征节点类*>& 条件索引,
    const std::vector<const 二次特征节点类*>& 当前判定集,
    std::int64_t* 输出满足数 = nullptr,
    const 二次特征匹配配置_桥接& 配置 = {}) noexcept
{
    二次特征匹配模块::结构_匹配配置 模块配置{};
    模块配置.使用对象绑定 = 配置.使用对象绑定;
    模块配置.条件空指针视为通配 = 配置.条件空指针视为通配;
    模块配置.允许用概念名称弱匹配 = 配置.允许用概念名称弱匹配;
    return 二次特征匹配模块::条件索引_满足(条件索引, 当前判定集, 输出满足数, 模块配置);
}

inline 二次特征匹配结果_桥接 结果摘要匹配目标_桥接(
    const std::vector<const 二次特征节点类*>& 摘要索引,
    const std::vector<const 二次特征节点类*>& 目标判定集,
    const 二次特征匹配配置_桥接& 配置 = {}) noexcept
{
    二次特征匹配模块::结构_匹配配置 模块配置{};
    模块配置.使用对象绑定 = 配置.使用对象绑定;
    模块配置.条件空指针视为通配 = 配置.条件空指针视为通配;
    模块配置.允许用概念名称弱匹配 = 配置.允许用概念名称弱匹配;

    const auto 模块结果 = 二次特征匹配模块::结果摘要_匹配目标(摘要索引, 目标判定集, 模块配置);
    return {
        模块结果.命中数,
        模块结果.摘要数,
        模块结果.目标数,
        模块结果.精确率_Q10000,
        模块结果.召回率_Q10000,
        模块结果.得分_Q10000,
    };
}

struct 二次特征生成配置 {
    bool 生成变化量 = true;
    bool 生成变化方向 = true;
    bool 生成持续时间 = true;
    bool 尝试因果模板匹配 = true;
    bool 匹配命中回写因果实例 = true;
    std::uint32_t 生成版本 = 1;
};

struct 结构_场景二次特征写入请求 {
    std::string 度量签名_链键{};
    std::string 概念名称{};
    std::string 概念词性 = "名词";
    std::string 离散语义键{};
    二次特征主信息类::枚举_形态 形态 = 二次特征主信息类::枚举_形态::未定义;
    枚举_二次特征种类 种类 = 枚举_二次特征种类::未定义;
    枚举_二次特征域 域 = 枚举_二次特征域::未定义;
    枚举_二次特征粒度 粒度 = 枚举_二次特征粒度::未定义;
    枚举_二次特征基准类型 基准类型 = 枚举_二次特征基准类型::未定义;
    枚举_时间归一方式 时间归一方式 = 枚举_时间归一方式::未定义;
    枚举_二次特征值形态 值形态 = 枚举_二次特征值形态::未定义;
    基础信息节点类* 主体 = nullptr;
    基础信息节点类* 客体 = nullptr;
    基础信息节点类* 左对象 = nullptr;
    基础信息节点类* 右对象 = nullptr;
    状态节点类* 来源起始状态 = nullptr;
    状态节点类* 来源结果状态 = nullptr;
    动态节点类* 来源动态 = nullptr;
    枚举_二次特征来源类型 来源类型 = 枚举_二次特征来源类型::未定义;
    结构_时间段 来源时间段{};
    时间戳 分步时长 = 0;
    时间戳 总时长 = 0;
    时间戳 窗口时长 = 0;
    std::uint32_t 来源动态层级 = 0;
    std::uint64_t 来源动态路径签名 = 0;
    std::int32_t 离散编码 = 0;
    I64 标量值 = 0;
    bool 是否满足 = false;
    I64 置信度 = 0;
    std::uint32_t 规则版本 = 1;
    bool 同步名称和类型 = false;
};

class 二次特征生成模块 {
public:
    explicit 二次特征生成模块(世界树类* 世界树 = nullptr) noexcept;

    void 绑定世界树(世界树类* 世界树) noexcept;

    二次特征节点类* 创建任务结果方向二次特征(
        场景节点类* 场景,
        状态节点类* 当前状态,
        状态节点类* 结果状态,
        基础信息节点类* 任务主体 = nullptr);
    bool 写入场景二次特征(
        场景节点类* 场景,
        const 结构_场景二次特征写入请求& 请求,
        二次特征节点类** 输出节点 = nullptr);
    bool 确保二次特征具备默认值(
        二次特征节点类* 条件特征,
        const char* 默认离散语义键 = "待填充") noexcept;
    void 确保二次特征列表具备默认值(
        const std::vector<可解析引用<二次特征节点类>>& 条件索引,
        const char* 默认离散语义键 = "待填充") noexcept;
    二次特征节点类* 查找场景二次特征_按签名(
        场景节点类* 场景,
        const std::string& 度量签名_链键) const noexcept;
    const 二次特征主信息类* 查找场景二次特征主信息(
        场景节点类* 场景,
        const std::string& 概念名称,
        const 基础信息节点类* 主体 = nullptr,
        const std::optional<枚举_二次特征域>& 域 = std::nullopt,
        bool 取最近观测 = false) const noexcept;
    std::optional<bool> 读取场景二次特征布尔(
        场景节点类* 场景,
        const std::string& 概念名称,
        const 基础信息节点类* 主体 = nullptr,
        const std::optional<枚举_二次特征域>& 域 = std::nullopt) const noexcept;
    std::optional<I64> 读取场景二次特征标量(
        场景节点类* 场景,
        const std::string& 概念名称,
        const 基础信息节点类* 主体 = nullptr,
        const std::optional<枚举_二次特征域>& 域 = std::nullopt) const noexcept;
    二次特征节点类* 取或创建场景条件二次特征_布尔(
        场景节点类* 条件场景,
        const std::string& 度量签名_链键,
        const char* 概念文本);
    二次特征节点类* 取或创建场景条件二次特征_枚举(
        场景节点类* 条件场景,
        const std::string& 度量签名_链键,
        std::int32_t 离散编码,
        const char* 离散语义键,
        const char* 概念文本 = nullptr);

    二次特征节点类* 由状态比较生成二次特征(
        状态节点类* 左状态,
        状态节点类* 右状态);
    std::vector<二次特征节点类*> 获取动态二次特征(
        const 动态节点类& 动态,
        const 二次特征生成配置& 配置 = {});
    二次特征节点类* 生成相邻动态协同二次特征(
        场景节点类* 场景,
        动态节点类* 动态,
        时间戳 时间窗口 = 1000000);
    动态节点类* 尝试生成连续同向聚合动态(场景节点类* 场景, 动态节点类* 动态);
    动态节点类* 尝试生成同类事件段聚合动态(场景节点类* 场景, 动态节点类* 动态);
    std::vector<二次特征节点类*> 由存在比较结果生成二次特征(
        场景节点类* 场景,
        存在节点类* 左存在,
        存在节点类* 右存在,
        const 存在比较结果& 比较结果);

    std::vector<二次特征节点类*> 刷新场景存在型基础二次特征(
        场景节点类* 场景,
        std::int64_t 接近阈值_mm = 1000,
        std::int64_t 冲突阈值_mm = 200
    );

private:
    世界树类* 世界树_ = nullptr;
};

} // export

namespace {
    template<class T节点>
    可解析引用<T节点> 私有_生成引用(T节点* 节点)
    {
        可解析引用<T节点> out{};
        out.指针 = 节点;
        if (节点) out.主键 = 节点->获取主键();
        return out;
    }

    std::string 私有_取节点键(const 基础信息节点类* 节点)
    {
        return 节点 ? 节点->获取主键() : std::string{};
    }

    template<class T节点>
    std::string 私有_取引用主键(const 可解析引用<T节点>& 引用) noexcept
    {
        return !引用.主键.empty() ? 引用.主键 : std::string{};
    }

    bool 私有_词性主键相等(const 词性节点类* 左, const 词性节点类* 右) noexcept
    {
        if (左 == 右) return true;
        if (!左 || !右) return false;
        const auto 左主键 = 左->获取主键();
        const auto 右主键 = 右->获取主键();
        return !左主键.empty() && 左主键 == 右主键;
    }

    const 词性节点类* 私有_取概念名称词(const char* 文本)
    {
        return 文本 ? 语素集.添加词性词(文本, "名词") : nullptr;
    }

    std::string 私有_安全词(const 词性节点类* 词) noexcept
    {
        if (!词) {
            return {};
        }

        try {
            return 语素集.获取词(词);
        }
        catch (...) {
            return {};
        }
    }

    bool 私有_二次特征主体匹配(
        const 二次特征主信息类* 主信息,
        const 基础信息节点类* 主体) noexcept
    {
        if (!主信息) {
            return false;
        }
        if (!主体) {
            return true;
        }
        return 主信息->主体.指针 == 主体
            || (!主信息->主体.主键.empty() && 主信息->主体.主键 == 主体->获取主键());
    }

    const char* 私有_任务结果方向语义键(std::int32_t 编码) noexcept
    {
        switch (编码) {
        case 1: return "上升";
        case -1: return "下降";
        case 0: return "持平";
        default: return "未知";
        }
    }

    std::int32_t 私有_推导任务结果方向编码(
        世界树类* 世界树,
        const 状态节点类* 当前状态,
        const 状态节点类* 结果状态) noexcept
    {
        std::int32_t 输出方向 = 0;
        return 二次特征本能判断模块::判断状态结果方向(
            世界树,
            当前状态,
            结果状态,
            输出方向)
            ? 输出方向
            : 2;
    }

    枚举_二次特征粒度 私有_推断动态粒度(const 动态节点主信息类& 主信息) noexcept
    {
        switch (主信息.聚合方式) {
        case 枚举_动态聚合方式::原子相邻:
            return 枚举_二次特征粒度::相邻分步;
        case 枚举_动态聚合方式::路径压缩:
            return 枚举_二次特征粒度::完整路径;
        case 枚举_动态聚合方式::窗口聚合:
        case 枚举_动态聚合方式::同类事件段:
        case 枚举_动态聚合方式::连续同向段:
            return 枚举_二次特征粒度::聚合段;
        default:
            return 主信息.动态层级 == 0
                ? 枚举_二次特征粒度::首尾整体
                : 枚举_二次特征粒度::聚合段;
        }
    }

    bool 私有_读取状态I64(const 状态节点主信息类* 主信息, I64& 输出值) noexcept
    {
        if (!主信息) return false;
        if (const auto* 标量 = std::get_if<I64>(&主信息->状态值)) {
            输出值 = *标量;
            return true;
        }
        return false;
    }

    时间戳 私有_读取状态时间(const 状态节点主信息类* 主信息) noexcept
    {
        if (!主信息) return 0;
        return 主信息->发生时间 != 0 ? 主信息->发生时间 : 主信息->收到时间;
    }

    场景节点类* 私有_取所属场景(const 基础信息类* 基础信息, const 基础信息节点类* 节点) noexcept
    {
        if (!基础信息 || !节点 || !节点->父) return nullptr;
        auto* 父节点 = static_cast<基础信息节点类*>(节点->父);
        return 基础信息->取主信息<场景节点主信息类>(父节点)
            ? static_cast<场景节点类*>(父节点)
            : nullptr;
    }

    const 词性节点类* 私有_取状态特征类型(
        const 基础信息类* 基础信息,
        const 状态节点主信息类* 状态主信息) noexcept
    {
        if (!基础信息 || !状态主信息 || !状态主信息->状态特征.指针) return nullptr;
        const auto* 特征主信息 = 基础信息->取主信息<特征节点主信息类>(状态主信息->状态特征.指针);
        return 特征主信息 ? 特征主信息->类型 : nullptr;
    }

    enum class 枚举_状态二次特征类型 : std::uint8_t {
        未定义 = 0,
        差值型 = 1,
        判等型 = 2,
        差异度型 = 3,
    };

    枚举_状态二次特征类型 私有_推断状态二次特征类型(
        const 枚举_特征值比较模式 比较方式) noexcept
    {
        switch (比较方式) {
        case 枚举_特征值比较模式::有序标量:
            return 枚举_状态二次特征类型::差值型;
        case 枚举_特征值比较模式::相等:
            return 枚举_状态二次特征类型::判等型;
        case 枚举_特征值比较模式::相等或相似度:
            return 枚举_状态二次特征类型::差异度型;
        default:
            return 枚举_状态二次特征类型::未定义;
        }
    }

    const char* 私有_状态二次特征类型文本(const 枚举_状态二次特征类型 类型) noexcept
    {
        switch (类型) {
        case 枚举_状态二次特征类型::差值型: return "差值型";
        case 枚举_状态二次特征类型::判等型: return "判等型";
        case 枚举_状态二次特征类型::差异度型: return "差异度型";
        default: return "未定义";
        }
    }

    enum class 枚举_动态二次特征类型 : std::uint8_t {
        未定义 = 0,
        差值型 = 1,
        判等型 = 2,
        差异度型 = 3,
    };

    枚举_动态二次特征类型 私有_推断动态二次特征类型(
        const 枚举_特征值比较模式 比较方式) noexcept
    {
        switch (比较方式) {
        case 枚举_特征值比较模式::有序标量:
            return 枚举_动态二次特征类型::差值型;
        case 枚举_特征值比较模式::相等:
            return 枚举_动态二次特征类型::判等型;
        case 枚举_特征值比较模式::相等或相似度:
            return 枚举_动态二次特征类型::差异度型;
        default:
            return 枚举_动态二次特征类型::未定义;
        }
    }

    const char* 私有_动态二次特征类型文本(const 枚举_动态二次特征类型 类型) noexcept
    {
        switch (类型) {
        case 枚举_动态二次特征类型::差值型: return "差值型";
        case 枚举_动态二次特征类型::判等型: return "判等型";
        case 枚举_动态二次特征类型::差异度型: return "差异度型";
        default: return "未定义";
        }
    }

    const char* 私有_动态标量概念名称(const 枚举_动态二次特征类型 类型) noexcept
    {
        return 类型 == 枚举_动态二次特征类型::差值型 ? "变化量" : "差异度";
    }

    bool 私有_动态支持方向(const 枚举_动态二次特征类型 类型) noexcept
    {
        return 类型 == 枚举_动态二次特征类型::差值型;
    }

    struct 结构_动态视图片段 {
        动态节点类* 动态 = nullptr;
        const 动态节点主信息类* 动态主信息 = nullptr;
        状态节点类* 起始状态 = nullptr;
        状态节点类* 结果状态 = nullptr;
        const 状态节点主信息类* 起始状态主信息 = nullptr;
        const 状态节点主信息类* 结果状态主信息 = nullptr;
        基础信息节点类* 主体 = nullptr;
        特征节点类* 特征 = nullptr;
        const 词性节点类* 特征类型 = nullptr;
        特征值 起始状态值{};
        特征值 结果状态值{};
        bool 有原始I64值 = false;
        I64 原始起始值 = 0;
        I64 原始结果值 = 0;
        I64 起始值 = 0;
        I64 结果值 = 0;
        I64 差值 = 0;
        std::int32_t 方向 = 0;
        枚举_特征值比较模式 比较方式 = 枚举_特征值比较模式::相等;
        时间戳 起时间 = 0;
        时间戳 止时间 = 0;
    };

    bool 私有_解析动态视图片段(
        世界树类* 世界树,
        动态节点类* 动态,
        结构_动态视图片段& 输出,
        bool 仅接受原子相邻 = false,
        bool 要求有序标量 = false,
        bool 要求非零方向 = false) noexcept
    {
        if (!世界树 || !动态) return false;
        const auto* 动态主信息 = 世界树->动态().取动态主信息(动态);
        if (!动态主信息 || !动态主信息->初始状态.指针 || !动态主信息->结果状态.指针) {
            return false;
        }
        if (仅接受原子相邻
            && (动态主信息->动态层级 != 0 || 动态主信息->聚合方式 != 枚举_动态聚合方式::原子相邻)) {
            return false;
        }

        auto* 起始状态 = 动态主信息->初始状态.指针;
        auto* 结果状态 = 动态主信息->结果状态.指针;
        const auto* 起始状态主信息 = 世界树->状态().取状态主信息(起始状态);
        const auto* 结果状态主信息 = 世界树->状态().取状态主信息(结果状态);
        if (!起始状态主信息 || !结果状态主信息) {
            return false;
        }

        const auto* 动态特征主信息 = 动态主信息->动态特征.指针
            ? 世界树->特征().取特征主信息(动态主信息->动态特征.指针)
            : nullptr;
        const auto* 起始特征主信息 = 起始状态主信息->状态特征.指针
            ? 世界树->特征().取特征主信息(起始状态主信息->状态特征.指针)
            : 动态特征主信息;
        const auto* 结果特征主信息 = 结果状态主信息->状态特征.指针
            ? 世界树->特征().取特征主信息(结果状态主信息->状态特征.指针)
            : 动态特征主信息;
        const auto* 起始特征类型 = 起始特征主信息 ? 起始特征主信息->类型 : nullptr;
        const auto* 结果特征类型 = 结果特征主信息 ? 结果特征主信息->类型 : nullptr;
        if (!起始特征类型 || !结果特征类型 || !私有_词性主键相等(起始特征类型, 结果特征类型)) {
            return false;
        }

        const auto 比较方法结果 = 世界树->特征().获取比较方法结果(
            起始特征类型,
            起始状态主信息->状态值,
            结果状态主信息->状态值,
            起始特征主信息,
            结果特征主信息);
        if (!比较方法结果.可比较) {
            return false;
        }
        if (要求有序标量 && 比较方法结果.比较方式 != 枚举_特征值比较模式::有序标量) {
            return false;
        }

        auto* 主体 = 动态主信息->动态主体.指针
            ? 动态主信息->动态主体.指针
            : 起始状态主信息->状态主体.指针;
        auto* 特征 = 动态主信息->动态特征.指针
            ? 动态主信息->动态特征.指针
            : 起始状态主信息->状态特征.指针;
        if (!主体 || !特征) {
            return false;
        }

        时间戳 起时间 = 动态主信息->时间.起 != 0 ? 动态主信息->时间.起 : 私有_读取状态时间(起始状态主信息);
        时间戳 止时间 = 动态主信息->时间.止 != 0 ? 动态主信息->时间.止 : 私有_读取状态时间(结果状态主信息);
        if (起时间 != 0 && 止时间 != 0 && 止时间 < 起时间) {
            std::swap(起时间, 止时间);
        }

        输出.动态 = 动态;
        输出.动态主信息 = 动态主信息;
        输出.起始状态 = 起始状态;
        输出.结果状态 = 结果状态;
        输出.起始状态主信息 = 起始状态主信息;
        输出.结果状态主信息 = 结果状态主信息;
        输出.主体 = 主体;
        输出.特征 = 特征;
        输出.特征类型 = 起始特征类型;
        输出.起始状态值 = 起始状态主信息->状态值;
        输出.结果状态值 = 结果状态主信息->状态值;
        输出.比较方式 = 比较方法结果.比较方式;
        输出.起始值 = 比较方法结果.左比较值;
        输出.结果值 = 比较方法结果.右比较值;
        输出.差值 = 比较方法结果.差值;
        输出.方向 = 二次特征主信息类::方向区间编码(
            二次特征主信息类::由差值判断方向区间(输出.差值));
        输出.有原始I64值 =
            私有_读取状态I64(起始状态主信息, 输出.原始起始值)
            && 私有_读取状态I64(结果状态主信息, 输出.原始结果值);
        输出.起时间 = 起时间;
        输出.止时间 = 止时间;
        if (要求非零方向 && 输出.方向 == 0) {
            return false;
        }
        return 特征值有效(输出.起始状态值) && 特征值有效(输出.结果状态值);
    }

    动态节点类* 私有_解析动态引用(世界树类* 世界树, const 可解析引用<动态节点类>& 引用)
    {
        if (!世界树) return nullptr;
        if (!引用.主键.empty()) {
            auto* 基础节点 = 世界树->基础信息().查找主键(引用.主键);
            if (基础节点) return static_cast<动态节点类*>(基础节点);
        }
        return 引用.指针;
    }

    std::vector<结构_动态视图片段> 私有_标准化动态单元列表(
        世界树类* 世界树,
        动态节点类* 动态,
        结构_动态视图片段& 整体片段)
    {
        std::vector<结构_动态视图片段> 结果{};
        if (!私有_解析动态视图片段(世界树, 动态, 整体片段, false, false, false)) {
            return 结果;
        }

        const auto* 动态主信息 = 整体片段.动态主信息;
        if (!动态主信息) return 结果;

        const bool 需要来源链 =
            动态主信息->动态层级 > 0
            || 动态主信息->聚合方式 != 枚举_动态聚合方式::原子相邻;

        if (动态主信息->来源低层动态.empty()) {
            if (需要来源链) {
                return {};
            }
            结果.push_back(整体片段);
            return 结果;
        }

        for (const auto& 来源引用 : 动态主信息->来源低层动态) {
            auto* 来源动态 = 私有_解析动态引用(世界树, 来源引用);
            if (!来源动态) return {};

            结构_动态视图片段 标准片段{};
            if (!私有_解析动态视图片段(世界树, 来源动态, 标准片段, false, false, false)) {
                return {};
            }
            结果.push_back(标准片段);
        }

        return 结果;
    }

    void 私有_追加去重二次特征(std::vector<二次特征节点类*>& 列表, 二次特征节点类* 节点)
    {
        if (!节点) return;
        for (auto* 现有节点 : 列表) {
            if (现有节点 == 节点) return;
            if (现有节点 && 现有节点->获取主键() == 节点->获取主键()) return;
        }
        列表.push_back(节点);
    }

    枚举_时间归一方式 私有_推断时长语义(const 动态节点主信息类& 主信息) noexcept
    {
        return 私有_推断动态粒度(主信息) == 枚举_二次特征粒度::相邻分步
            ? 枚举_时间归一方式::分步时长
            : 枚举_时间归一方式::总时长;
    }

    void 私有_收集条件候选(
        世界树类* 世界树,
        场景节点类* 场景,
        const std::vector<二次特征节点类*>& 结果候选,
        std::vector<二次特征节点类*>& 条件候选)
    {
        if (!世界树 || !场景) return;

        auto 全部候选 = 世界树->二次特征().获取子二次特征(场景);
        for (auto* 候选节点 : 全部候选) {
            bool 是结果节点 = false;
            for (auto* 结果节点 : 结果候选) {
                if (结果节点 == 候选节点
                    || (结果节点 && 候选节点 && 结果节点->获取主键() == 候选节点->获取主键())) {
                    是结果节点 = true;
                    break;
                }
            }
            if (!是结果节点) {
                条件候选.push_back(候选节点);
            }
        }
    }

    void 私有_回写因果模板命中(
        世界树类* 世界树,
        场景节点类* 场景,
        动态节点类* 动态,
        const 结构_动态视图片段& 整体片段,
        const std::vector<因果模板节点类*>& 命中模板)
    {
        if (!世界树 || !场景 || !动态 || 命中模板.empty()) return;

        const auto* 动态主信息 = 整体片段.动态主信息;
        if (!动态主信息) return;

        auto* 因果节点 = 世界树->按动态创建因果信息(
            场景,
            动态,
            动态主信息->来源动作.指针
                ? 枚举_因果来源类型::执行生成
                : 枚举_因果来源类型::观察生成,
            动态主信息->动态主体.指针,
            动态主信息->动态特征.指针,
            {},
            true);
        if (!因果节点) return;

        for (auto* 模板节点 : 命中模板) {
            (void)世界树->因果().追加证据动态样本(模板节点, 动态);
        }
    }

    std::vector<二次特征节点类*> 私有_获取动态二次特征(
        世界树类* 世界树,
        场景节点类* 场景,
        动态节点类* 动态,
        const 二次特征生成配置& 配置)
    {
        std::vector<二次特征节点类*> 结果{};
        if (!世界树 || !场景 || !动态) return 结果;

        结构_动态视图片段 整体片段{};
        auto 标准动态单元 = 私有_标准化动态单元列表(世界树, 动态, 整体片段);
        if (标准动态单元.empty()) {
            return 结果;
        }

        const auto 创建或更新标量结果 = [&](const 结构_动态视图片段& 片段,
                                      const char* 概念名称,
                                      枚举_二次特征基准类型 基准类型,
                                      枚举_时间归一方式 时间归一方式,
                                      I64 标量值,
                                      bool 是否满足) -> 二次特征节点类* {
            二次特征主信息类 模板{};
            模板.种类 = 枚举_二次特征种类::动态比较;
            模板.域 = 枚举_二次特征域::动态;
            模板.粒度 = 私有_推断动态粒度(*片段.动态主信息);
            模板.基准类型 = 基准类型;
            模板.时间归一方式 = 时间归一方式;
            模板.值形态 = 枚举_二次特征值形态::标量;
            模板.规则版本 = 配置.生成版本;
            模板.主体 = 私有_生成引用(片段.主体);
            模板.来源起始状态 = 私有_生成引用(片段.起始状态);
            模板.来源结果状态 = 私有_生成引用(片段.结果状态);
            模板.来源动态 = 私有_生成引用(片段.动态);
            模板.来源场景 = 私有_生成引用(场景);
            模板.来源类型 = 枚举_二次特征来源类型::动态;
            模板.来源时间段 = 结构_时间段{ 片段.起时间, 片段.止时间 };
            模板.来源动态层级 = 片段.动态主信息->动态层级;
            模板.来源动态路径签名 = 片段.动态主信息->动态路径签名;
            模板.刷新度量签名_链键();

            auto* 节点 = 世界树->二次特征().获取或创建子二次特征_按签名(
                static_cast<基础信息节点类*>(场景),
                模板);
            if (!节点) return nullptr;

            auto* 主信息 = 世界树->二次特征().取二次特征主信息(节点);
            if (!主信息) return nullptr;

            主信息->种类 = 枚举_二次特征种类::动态比较;
            主信息->概念名称 = 私有_取概念名称词(概念名称);
            主信息->规则版本 = 配置.生成版本;
            (void)世界树->二次特征().绑定场景(节点, 场景);
            (void)世界树->二次特征().设置生成语义(
                节点,
                枚举_二次特征域::动态,
                私有_推断动态粒度(*片段.动态主信息),
                基准类型,
                时间归一方式,
                枚举_二次特征值形态::标量);
            const auto 时长 = (片段.起时间 != 0 && 片段.止时间 >= 片段.起时间)
                ? (片段.止时间 - 片段.起时间)
                : 0;
            const auto 粒度 = 私有_推断动态粒度(*片段.动态主信息);
            const auto 分步时长 = 粒度 == 枚举_二次特征粒度::相邻分步 ? 时长 : 0;
            const auto 总时长 = 粒度 == 枚举_二次特征粒度::相邻分步 ? 0 : 时长;
            (void)世界树->二次特征().绑定来源(
                节点,
                片段.起始状态,
                片段.结果状态,
                片段.动态,
                场景,
                片段.动态主信息->动态层级,
                片段.动态主信息->动态路径签名,
                枚举_二次特征来源类型::动态,
                结构_时间段{ 片段.起时间, 片段.止时间 },
                分步时长,
                总时长,
                0);
            (void)世界树->二次特征().设置主体客体(节点, 片段.主体, nullptr);
            (void)世界树->二次特征().写入标量值(节点, 标量值, 是否满足, 10000);
            私有_追加去重二次特征(结果, 节点);
            return 节点;
        };

        const auto 创建或更新离散结果 = [&](const 结构_动态视图片段& 片段,
                                      const char* 概念名称,
                                      枚举_二次特征基准类型 基准类型,
                                      std::int32_t 离散编码,
                                      const std::string& 离散语义) -> 二次特征节点类* {
            二次特征主信息类 模板{};
            模板.种类 = 枚举_二次特征种类::动态比较;
            模板.域 = 枚举_二次特征域::动态;
            模板.粒度 = 私有_推断动态粒度(*片段.动态主信息);
            模板.基准类型 = 基准类型;
            模板.值形态 = 枚举_二次特征值形态::枚举;
            模板.规则版本 = 配置.生成版本;
            模板.主体 = 私有_生成引用(片段.主体);
            模板.来源起始状态 = 私有_生成引用(片段.起始状态);
            模板.来源结果状态 = 私有_生成引用(片段.结果状态);
            模板.来源动态 = 私有_生成引用(片段.动态);
            模板.来源场景 = 私有_生成引用(场景);
            模板.来源类型 = 枚举_二次特征来源类型::动态;
            模板.来源时间段 = 结构_时间段{ 片段.起时间, 片段.止时间 };
            模板.来源动态层级 = 片段.动态主信息->动态层级;
            模板.来源动态路径签名 = 片段.动态主信息->动态路径签名;
            模板.刷新度量签名_链键();

            auto* 节点 = 世界树->二次特征().获取或创建子二次特征_按签名(
                static_cast<基础信息节点类*>(场景),
                模板);
            if (!节点) return nullptr;

            auto* 主信息 = 世界树->二次特征().取二次特征主信息(节点);
            if (!主信息) return nullptr;

            主信息->种类 = 枚举_二次特征种类::动态比较;
            主信息->概念名称 = 私有_取概念名称词(概念名称);
            主信息->规则版本 = 配置.生成版本;
            (void)世界树->二次特征().绑定场景(节点, 场景);
            (void)世界树->二次特征().设置生成语义(
                节点,
                枚举_二次特征域::动态,
                私有_推断动态粒度(*片段.动态主信息),
                基准类型,
                枚举_时间归一方式::无,
                枚举_二次特征值形态::枚举);
            const auto 时长 = (片段.起时间 != 0 && 片段.止时间 >= 片段.起时间)
                ? (片段.止时间 - 片段.起时间)
                : 0;
            const auto 粒度 = 私有_推断动态粒度(*片段.动态主信息);
            const auto 分步时长 = 粒度 == 枚举_二次特征粒度::相邻分步 ? 时长 : 0;
            const auto 总时长 = 粒度 == 枚举_二次特征粒度::相邻分步 ? 0 : 时长;
            (void)世界树->二次特征().绑定来源(
                节点,
                片段.起始状态,
                片段.结果状态,
                片段.动态,
                场景,
                片段.动态主信息->动态层级,
                片段.动态主信息->动态路径签名,
                枚举_二次特征来源类型::动态,
                结构_时间段{ 片段.起时间, 片段.止时间 },
                分步时长,
                总时长,
                0);
            (void)世界树->二次特征().设置主体客体(节点, 片段.主体, nullptr);
            (void)世界树->二次特征().写入离散值(
                节点,
                离散编码,
                离散语义,
                枚举_二次特征值形态::枚举,
                10000);
            私有_追加去重二次特征(结果, 节点);
            return 节点;
        };

        for (const auto& 标准片段 : 标准动态单元) {
            const auto 持续时长_us = (标准片段.起时间 != 0 && 标准片段.止时间 >= 标准片段.起时间)
                ? (标准片段.止时间 - 标准片段.起时间)
                : 0;
            const auto 时间语义 = 私有_推断时长语义(*标准片段.动态主信息);
            const auto 方向区间 = 二次特征主信息类::由差值判断方向区间(标准片段.差值);
            const auto 二次特征类型 = 私有_推断动态二次特征类型(标准片段.比较方式);

            if (配置.生成变化量) {
                if (auto* 节点 = 创建或更新标量结果(
                    标准片段,
                    私有_动态标量概念名称(二次特征类型),
                    枚举_二次特征基准类型::起始态,
                    枚举_时间归一方式::无,
                    标准片段.差值,
                    标准片段.差值 != 0)) {
                    if (auto* 主信息 = 世界树->二次特征().取二次特征主信息(节点)) {
                        主信息->离散编码 = static_cast<std::int32_t>(二次特征类型);
                        主信息->离散语义键 = 私有_动态二次特征类型文本(二次特征类型);
                    }
                    (void)世界树->二次特征().写入差值结果(
                        节点,
                        标准片段.起始值,
                        标准片段.结果值);
                }
            }
            if (配置.生成变化方向 && 私有_动态支持方向(二次特征类型)) {
                if (auto* 节点 = 创建或更新离散结果(
                    标准片段,
                    "变化方向",
                    枚举_二次特征基准类型::起始态,
                    二次特征主信息类::方向区间编码(方向区间),
                    二次特征主信息类::方向区间文本(方向区间))) {
                    (void)世界树->二次特征().写入差值结果(
                        节点,
                        标准片段.起始值,
                        标准片段.结果值);
                }
            }
            if (配置.生成持续时间 && 持续时长_us > 0) {
                创建或更新标量结果(
                    标准片段,
                    "持续时间",
                    枚举_二次特征基准类型::起始态,
                    时间语义,
                    static_cast<I64>(持续时长_us),
                    true);
            }
        }

        const bool 需要整体结果 =
            标准动态单元.size() > 1
            || 标准动态单元.front().动态 != 整体片段.动态;
        if (需要整体结果) {
            const auto 整体时长_us = (整体片段.起时间 != 0 && 整体片段.止时间 >= 整体片段.起时间)
                ? (整体片段.止时间 - 整体片段.起时间)
                : 0;
            const auto 时间语义 = 私有_推断时长语义(*整体片段.动态主信息);
            const auto 方向区间 = 二次特征主信息类::由差值判断方向区间(整体片段.差值);
            const auto 二次特征类型 = 私有_推断动态二次特征类型(整体片段.比较方式);

            if (配置.生成变化量) {
                if (auto* 节点 = 创建或更新标量结果(
                    整体片段,
                    私有_动态标量概念名称(二次特征类型),
                    枚举_二次特征基准类型::起始态,
                    枚举_时间归一方式::无,
                    整体片段.差值,
                    整体片段.差值 != 0)) {
                    if (auto* 主信息 = 世界树->二次特征().取二次特征主信息(节点)) {
                        主信息->离散编码 = static_cast<std::int32_t>(二次特征类型);
                        主信息->离散语义键 = 私有_动态二次特征类型文本(二次特征类型);
                    }
                    (void)世界树->二次特征().写入差值结果(
                        节点,
                        整体片段.起始值,
                        整体片段.结果值);
                }
            }
            if (配置.生成变化方向 && 私有_动态支持方向(二次特征类型)) {
                if (auto* 节点 = 创建或更新离散结果(
                    整体片段,
                    "变化方向",
                    枚举_二次特征基准类型::起始态,
                    二次特征主信息类::方向区间编码(方向区间),
                    二次特征主信息类::方向区间文本(方向区间))) {
                    (void)世界树->二次特征().写入差值结果(
                        节点,
                        整体片段.起始值,
                        整体片段.结果值);
                }
            }
            if (配置.生成持续时间 && 整体时长_us > 0) {
                创建或更新标量结果(
                    整体片段,
                    "持续时间",
                    枚举_二次特征基准类型::起始态,
                    时间语义,
                    static_cast<I64>(整体时长_us),
                    true);
            }
        }

        if (配置.尝试因果模板匹配 && !结果.empty()) {
            std::vector<二次特征节点类*> 条件候选{};
            私有_收集条件候选(世界树, 场景, 结果, 条件候选);

            const auto* 动态主信息 = 整体片段.动态主信息;
            const auto 命中模板 = 世界树->因果().查找匹配因果模板(
                枚举_因果锚点类型::场景,
                动态主信息 ? 动态主信息->动态层级 : 0,
                条件候选,
                结果);

            if (配置.匹配命中回写因果实例) {
                私有_回写因果模板命中(世界树, 场景, 动态, 整体片段, 命中模板);
            }
        }

        return 结果;
    }

    bool 私有_同一主体特征流(const 结构_动态视图片段& 左, const 结构_动态视图片段& 右) noexcept
    {
        return 私有_取节点键(左.主体) == 私有_取节点键(右.主体)
            && 私有_取节点键(左.特征) == 私有_取节点键(右.特征);
    }

    std::string 私有_取词键(const 词性节点类* 词)
    {
        return 词 ? 词->获取主键() : std::string{};
    }

    bool 私有_同类事件来源流(const 结构_动态视图片段& 左, const 结构_动态视图片段& 右) noexcept
    {
        const auto* 左主信息 = 左.动态主信息;
        const auto* 右主信息 = 右.动态主信息;
        if (!左主信息 || !右主信息) return false;

        const auto 左来源动作键 = 私有_取引用主键(左主信息->来源动作);
        const auto 右来源动作键 = 私有_取引用主键(右主信息->来源动作);

        return 左主信息->来源类型 == 右主信息->来源类型
            && 左主信息->业务语义类型 == 右主信息->业务语义类型
            && 左主信息->来源动作相位 == 右主信息->来源动作相位
            && 左来源动作键 == 右来源动作键
            && 私有_取词键(左主信息->来源动作名) == 私有_取词键(右主信息->来源动作名)
            && 私有_取引用主键(左主信息->来源输入场景) == 私有_取引用主键(右主信息->来源输入场景)
            && 私有_取引用主键(左主信息->来源输出场景) == 私有_取引用主键(右主信息->来源输出场景);
    }

    bool 私有_值形态不适合同类事件段聚合(const 特征值& 值) noexcept
    {
        return std::holds_alternative<VecU句柄>(值)
            || std::holds_alternative<指针句柄>(值);
    }

    std::uint64_t 私有_计算聚合路径签名(const std::vector<结构_动态视图片段>& 片段列表)
    {
        std::string 材料{};
        材料.reserve(片段列表.size() * 48);
        for (const auto& 片段 : 片段列表) {
            if (!材料.empty()) 材料.push_back('|');
            材料 += 私有_取节点键(片段.动态);
        }
        return static_cast<std::uint64_t>(std::hash<std::string>{}(材料));
    }

    bool 私有_聚合来源链相同(
        世界树类* 世界树,
        const 动态节点主信息类* 主信息,
        const std::vector<结构_动态视图片段>& 片段列表)
    {
        if (!世界树 || !主信息) return false;
        if (主信息->来源低层动态.size() != 片段列表.size()) return false;

        for (std::size_t i = 0; i < 片段列表.size(); ++i) {
            const auto& 引用 = 主信息->来源低层动态[i];
            const auto* 节点 = 引用.指针;
            const auto 当前键 = !引用.主键.empty() ? 引用.主键 : 私有_取节点键(节点);
            if (当前键 != 私有_取节点键(片段列表[i].动态)) {
                return false;
            }
        }
        return true;
    }

    std::int64_t 私有_计算距离_mm(const Vector3D& 左位置, const Vector3D& 右位置) noexcept
    {
        const long double dx = static_cast<long double>(左位置.x) - static_cast<long double>(右位置.x);
        const long double dy = static_cast<long double>(左位置.y) - static_cast<long double>(右位置.y);
        const long double dz = static_cast<long double>(左位置.z) - static_cast<long double>(右位置.z);
        return static_cast<std::int64_t>(std::llround(std::sqrt(dx * dx + dy * dy + dz * dz)));
    }

    void 私有_规范化左右对象(基础信息节点类*& 左对象, 基础信息节点类*& 右对象)
    {
        if (!左对象 || !右对象) return;
        if (私有_取节点键(左对象) > 私有_取节点键(右对象)) {
            std::swap(左对象, 右对象);
        }
    }

}

二次特征生成模块::二次特征生成模块(世界树类* 世界树) noexcept
    : 世界树_(世界树)
{
}

void 二次特征生成模块::绑定世界树(世界树类* 世界树) noexcept
{
    世界树_ = 世界树;
}

二次特征节点类* 二次特征生成模块::创建任务结果方向二次特征(
    场景节点类* 场景,
    状态节点类* 当前状态,
    状态节点类* 结果状态,
    基础信息节点类* 任务主体)
{
    if (!世界树_ || !场景) {
        return nullptr;
    }

    const auto 编码 = 私有_推导任务结果方向编码(世界树_, 当前状态, 结果状态);
    const auto* 语义键 = 私有_任务结果方向语义键(编码);

    结构_场景二次特征写入请求 请求{};
    请求.度量签名_链键 = "任务结果方向";
    请求.概念名称 = 语义键;
    请求.概念词性 = "状态词";
    请求.同步名称和类型 = true;
    请求.种类 = 枚举_二次特征种类::状态比较;
    请求.域 = 枚举_二次特征域::存在;
    请求.粒度 = 枚举_二次特征粒度::当前场景;
    请求.基准类型 = 枚举_二次特征基准类型::起始态;
    请求.时间归一方式 = 枚举_时间归一方式::无;
    请求.值形态 = 枚举_二次特征值形态::枚举;
    请求.主体 = 任务主体;
    请求.左对象 = reinterpret_cast<基础信息节点类*>(当前状态);
    请求.右对象 = reinterpret_cast<基础信息节点类*>(结果状态);
    请求.来源起始状态 = 当前状态;
    请求.来源结果状态 = 结果状态;
    请求.来源类型 = 枚举_二次特征来源类型::状态;
    请求.离散编码 = 编码;
    请求.离散语义键 = 语义键;
    请求.是否满足 = (编码 != 2);
    请求.置信度 = (编码 == 2 ? 0 : 10000);

    二次特征节点类* 节点 = nullptr;
    return 写入场景二次特征(场景, 请求, &节点) ? 节点 : nullptr;
}

bool 二次特征生成模块::写入场景二次特征(
    场景节点类* 场景,
    const 结构_场景二次特征写入请求& 请求,
    二次特征节点类** 输出节点)
{
    if (!世界树_ || !场景) {
        return false;
    }

    auto& 二次特征服务 = 世界树_->二次特征();
    二次特征节点类* 节点 = nullptr;
    if (!请求.度量签名_链键.empty()) {
        节点 = 查找场景二次特征_按签名(场景, 请求.度量签名_链键);
        if (!节点) {
            节点 = 二次特征服务.创建二次特征_按度量(
                reinterpret_cast<基础信息节点类*>(场景),
                请求.种类,
                请求.度量签名_链键);
        }
    } else {
        二次特征主信息类 模板{};
        模板.形态 = 请求.形态;
        模板.种类 = 请求.种类;
        模板.域 = 请求.域;
        模板.粒度 = 请求.粒度;
        模板.基准类型 = 请求.基准类型;
        模板.时间归一方式 = 请求.时间归一方式;
        模板.值形态 = 请求.值形态;
        模板.规则版本 = 请求.规则版本;
        模板.主体 = 私有_生成引用(请求.主体);
        模板.客体 = 私有_生成引用(请求.客体);
        模板.左对象 = 私有_生成引用(请求.左对象);
        模板.右对象 = 私有_生成引用(请求.右对象);
        模板.来源起始状态 = 私有_生成引用(请求.来源起始状态);
        模板.来源结果状态 = 私有_生成引用(请求.来源结果状态);
        模板.来源动态 = 私有_生成引用(请求.来源动态);
        模板.来源场景 = 私有_生成引用(场景);
        模板.来源类型 = 请求.来源类型;
        模板.来源时间段 = 请求.来源时间段;
        模板.分步时长 = 请求.分步时长;
        模板.总时长 = 请求.总时长;
        模板.窗口时长 = 请求.窗口时长;
        模板.来源动态层级 = 请求.来源动态层级;
        模板.来源动态路径签名 = 请求.来源动态路径签名;
        模板.刷新度量签名_链键();
        节点 = 二次特征服务.获取或创建子二次特征_按签名(
            reinterpret_cast<基础信息节点类*>(场景),
            模板);
    }
    if (!节点) {
        return false;
    }

    auto* 主信息 = 二次特征服务.取二次特征主信息(节点);
    if (!主信息) {
        return false;
    }

    if (请求.形态 != 二次特征主信息类::枚举_形态::未定义) {
        主信息->形态 = 请求.形态;
    }
    主信息->种类 = 请求.种类;
    主信息->规则版本 = 请求.规则版本;
    if (!请求.概念名称.empty()) {
        const auto* 概念词 = 语素集.添加词性词(
            请求.概念名称,
            请求.概念词性.empty() ? "名词" : 请求.概念词性);
        主信息->概念名称 = 概念词;
        if (请求.同步名称和类型) {
            主信息->名称 = 概念词;
            主信息->类型 = 概念词;
        }
    }

    (void)二次特征服务.绑定场景(节点, 场景);
    (void)二次特征服务.设置生成语义(
        节点,
        请求.域,
        请求.粒度,
        请求.基准类型,
        请求.时间归一方式,
        请求.值形态);
    if (请求.来源起始状态 || 请求.来源结果状态 || 请求.来源动态
        || 请求.来源类型 != 枚举_二次特征来源类型::未定义
        || 请求.来源时间段.起 != 0 || 请求.来源时间段.止 != 0) {
        (void)二次特征服务.绑定来源(
            节点,
            请求.来源起始状态,
            请求.来源结果状态,
            请求.来源动态,
            场景,
            请求.来源动态层级,
            请求.来源动态路径签名,
            请求.来源类型,
            请求.来源时间段,
            请求.分步时长,
            请求.总时长,
            请求.窗口时长);
    }
    (void)二次特征服务.设置主体客体(节点, 请求.主体, 请求.客体);
    (void)二次特征服务.设置左右对象(节点, 请求.左对象, 请求.右对象);

    switch (请求.值形态) {
    case 枚举_二次特征值形态::枚举:
    case 枚举_二次特征值形态::签名:
        (void)二次特征服务.写入离散值(
            节点,
            请求.离散编码,
            请求.离散语义键,
            请求.值形态,
            请求.置信度);
        主信息->是否满足 = 请求.是否满足;
        break;
    case 枚举_二次特征值形态::布尔:
        主信息->值形态 = 枚举_二次特征值形态::布尔;
        主信息->标量值 = 请求.标量值;
        主信息->是否满足 = 请求.是否满足;
        主信息->置信度 = 请求.置信度;
        主信息->离散编码 = 请求.离散编码;
        主信息->离散语义键 = 请求.离散语义键;
        主信息->统计.记录观测(结构体_时间戳::当前_微秒());
        (void)二次特征服务.刷新概念模板(节点);
        break;
    default:
        (void)二次特征服务.写入标量值(
            节点,
            请求.标量值,
            请求.是否满足,
            请求.置信度);
        if (请求.离散编码 != 0 || !请求.离散语义键.empty()) {
            主信息->离散编码 = 请求.离散编码;
            主信息->离散语义键 = 请求.离散语义键;
        }
        break;
    }

    if (!请求.度量签名_链键.empty()) {
        主信息->度量签名_链键 = 请求.度量签名_链键;
    }
    if (输出节点) {
        *输出节点 = 节点;
    }
    return true;
}

bool 二次特征生成模块::确保二次特征具备默认值(
    二次特征节点类* 条件特征,
    const char* 默认离散语义键) noexcept
{
    if (!世界树_ || !条件特征) {
        return false;
    }

    auto& 二次特征服务 = 世界树_->二次特征();
    auto* 主信息 = 二次特征服务.取二次特征主信息(条件特征);
    if (!主信息) {
        return false;
    }

    const std::string 语义键 = (默认离散语义键 && *默认离散语义键)
        ? 默认离散语义键
        : "待填充";
    if (主信息->值形态 == 枚举_二次特征值形态::未定义) {
        return 二次特征服务.写入离散值(
            条件特征,
            0,
            语义键,
            枚举_二次特征值形态::枚举,
            0);
    }

    if ((主信息->值形态 == 枚举_二次特征值形态::枚举
            || 主信息->值形态 == 枚举_二次特征值形态::签名)
        && 主信息->离散编码 == 0
        && 主信息->离散语义键.empty()) {
        return 二次特征服务.写入离散值(
            条件特征,
            0,
            语义键,
            主信息->值形态,
            主信息->置信度);
    }
    return true;
}

void 二次特征生成模块::确保二次特征列表具备默认值(
    const std::vector<可解析引用<二次特征节点类>>& 条件索引,
    const char* 默认离散语义键) noexcept
{
    for (const auto& 条件引用 : 条件索引) {
        (void)确保二次特征具备默认值(条件引用.指针, 默认离散语义键);
    }
}

二次特征节点类* 二次特征生成模块::查找场景二次特征_按签名(
    场景节点类* 场景,
    const std::string& 度量签名_链键) const noexcept
{
    if (!世界树_ || !场景 || 度量签名_链键.empty()) {
        return nullptr;
    }

    for (auto* 节点 : 世界树_->二次特征().获取子二次特征(
             reinterpret_cast<基础信息节点类*>(场景))) {
        const auto* 主信息 = 世界树_->二次特征().取二次特征主信息(节点);
        if (主信息 && 主信息->度量签名_链键 == 度量签名_链键) {
            return 节点;
        }
    }
    return nullptr;
}

const 二次特征主信息类* 二次特征生成模块::查找场景二次特征主信息(
    场景节点类* 场景,
    const std::string& 概念名称,
    const 基础信息节点类* 主体,
    const std::optional<枚举_二次特征域>& 域,
    bool 取最近观测) const noexcept
{
    if (!世界树_ || !场景 || 概念名称.empty()) {
        return nullptr;
    }

    const 二次特征主信息类* 命中主信息 = nullptr;
    时间戳 命中时间 = 0;
    for (auto* 节点 : 世界树_->二次特征().获取子二次特征(场景)) {
        const auto* 主信息 = 世界树_->二次特征().取二次特征主信息(节点);
        if (!主信息) {
            continue;
        }
        if (域.has_value() && 主信息->域 != *域) {
            continue;
        }
        if (!私有_二次特征主体匹配(主信息, 主体)) {
            continue;
        }
        if (私有_安全词(主信息->概念名称) != 概念名称) {
            continue;
        }

        if (!取最近观测) {
            return 主信息;
        }
        if (!命中主信息 || 主信息->统计.最后观测时间 >= 命中时间) {
            命中主信息 = 主信息;
            命中时间 = 主信息->统计.最后观测时间;
        }
    }
    return 命中主信息;
}

std::optional<bool> 二次特征生成模块::读取场景二次特征布尔(
    场景节点类* 场景,
    const std::string& 概念名称,
    const 基础信息节点类* 主体,
    const std::optional<枚举_二次特征域>& 域) const noexcept
{
    const auto* 主信息 = 查找场景二次特征主信息(场景, 概念名称, 主体, 域);
    if (!主信息) {
        return std::nullopt;
    }
    return 主信息->是否满足;
}

std::optional<I64> 二次特征生成模块::读取场景二次特征标量(
    场景节点类* 场景,
    const std::string& 概念名称,
    const 基础信息节点类* 主体,
    const std::optional<枚举_二次特征域>& 域) const noexcept
{
    const auto* 主信息 = 查找场景二次特征主信息(场景, 概念名称, 主体, 域);
    if (!主信息) {
        return std::nullopt;
    }
    return 主信息->标量值;
}

二次特征节点类* 二次特征生成模块::取或创建场景条件二次特征_布尔(
    场景节点类* 条件场景,
    const std::string& 度量签名_链键,
    const char* 概念文本)
{
    if (!世界树_ || !条件场景 || 度量签名_链键.empty() || !概念文本 || !*概念文本) {
        return nullptr;
    }

    结构_场景二次特征写入请求 请求{};
    请求.度量签名_链键 = 度量签名_链键;
    请求.概念名称 = 概念文本;
    请求.概念词性 = "状态词";
    请求.形态 = 二次特征主信息类::枚举_形态::条件;
    请求.种类 = 枚举_二次特征种类::观察关系;
    请求.域 = 枚举_二次特征域::未定义;
    请求.粒度 = 枚举_二次特征粒度::未定义;
    请求.基准类型 = 枚举_二次特征基准类型::未定义;
    请求.时间归一方式 = 枚举_时间归一方式::未定义;
    请求.值形态 = 枚举_二次特征值形态::布尔;
    请求.标量值 = 1;
    请求.是否满足 = true;

    二次特征节点类* 节点 = nullptr;
    return 写入场景二次特征(条件场景, 请求, &节点) ? 节点 : nullptr;
}

二次特征节点类* 二次特征生成模块::取或创建场景条件二次特征_枚举(
    场景节点类* 条件场景,
    const std::string& 度量签名_链键,
    std::int32_t 离散编码,
    const char* 离散语义键,
    const char* 概念文本)
{
    if (!世界树_ || !条件场景 || 度量签名_链键.empty() || !离散语义键 || !*离散语义键) {
        return nullptr;
    }

    结构_场景二次特征写入请求 请求{};
    请求.度量签名_链键 = 度量签名_链键;
    请求.概念名称 = (概念文本 && *概念文本) ? 概念文本 : 离散语义键;
    请求.概念词性 = "状态词";
    请求.形态 = 二次特征主信息类::枚举_形态::条件;
    请求.种类 = 枚举_二次特征种类::观察关系;
    请求.域 = 枚举_二次特征域::未定义;
    请求.粒度 = 枚举_二次特征粒度::未定义;
    请求.基准类型 = 枚举_二次特征基准类型::未定义;
    请求.时间归一方式 = 枚举_时间归一方式::未定义;
    请求.值形态 = 枚举_二次特征值形态::枚举;
    请求.离散编码 = 离散编码;
    请求.离散语义键 = 离散语义键;
    请求.是否满足 = true;

    二次特征节点类* 节点 = nullptr;
    return 写入场景二次特征(条件场景, 请求, &节点) ? 节点 : nullptr;
}

二次特征节点类* 二次特征生成模块::由状态比较生成二次特征(
    状态节点类* 左状态,
    状态节点类* 右状态)
{
    if (!世界树_ || !左状态 || !右状态) return nullptr;

    auto& 基础信息 = 世界树_->基础信息();
    const auto* 左状态主信息 = 世界树_->状态().取状态主信息(左状态);
    const auto* 右状态主信息 = 世界树_->状态().取状态主信息(右状态);
    if (!左状态主信息 || !右状态主信息) return nullptr;

    const auto* 左特征类型 = 私有_取状态特征类型(&基础信息, 左状态主信息);
    const auto* 右特征类型 = 私有_取状态特征类型(&基础信息, 右状态主信息);
    if (!左特征类型 || !右特征类型 || !私有_词性主键相等(左特征类型, 右特征类型)) return nullptr;

    const auto* 左特征主信息 = 世界树_->特征().取特征主信息(左状态主信息->状态特征.指针);
    const auto* 右特征主信息 = 世界树_->特征().取特征主信息(右状态主信息->状态特征.指针);
    const auto 比较方法结果 = 世界树_->特征().获取比较方法结果(
        左特征类型,
        左状态主信息->状态值,
        右状态主信息->状态值,
        左特征主信息,
        右特征主信息);
    if (!比较方法结果.可比较) return nullptr;

    const auto 二次特征类型 = 私有_推断状态二次特征类型(比较方法结果.比较方式);
    if (二次特征类型 == 枚举_状态二次特征类型::未定义) return nullptr;

    auto* 左主体 = 左状态主信息->状态主体.指针;
    auto* 右主体 = 右状态主信息->状态主体.指针;
    auto* 左场景 = 私有_取所属场景(&基础信息, 左状态);
    auto* 右场景 = 私有_取所属场景(&基础信息, 右状态);
    auto* 所属场景 = 左场景 ? 左场景 : 右场景;
    if (左场景 && 右场景 && 私有_取节点键(左场景) == 私有_取节点键(右场景)) {
        所属场景 = 左场景;
    }
    if (!所属场景) return nullptr;

    结构_时间段 来源时间段{ 私有_读取状态时间(左状态主信息), 私有_读取状态时间(右状态主信息) };
    if (来源时间段.起 != 0 && 来源时间段.止 != 0 && 来源时间段.止 < 来源时间段.起) {
        std::swap(来源时间段.起, 来源时间段.止);
    }

    二次特征主信息类 模板{};
    模板.种类 = 枚举_二次特征种类::状态比较;
    模板.域 = 枚举_二次特征域::存在;
    模板.粒度 = 枚举_二次特征粒度::当前场景;
    模板.基准类型 = 枚举_二次特征基准类型::无;
    模板.时间归一方式 = 枚举_时间归一方式::无;
    模板.值形态 = 枚举_二次特征值形态::标量;
    模板.主体 = 私有_生成引用(左主体);
    if (左主体 && 右主体 && 私有_取节点键(左主体) != 私有_取节点键(右主体)) {
        模板.客体 = 私有_生成引用(右主体);
    }
    模板.左对象 = 私有_生成引用(左状态);
    模板.右对象 = 私有_生成引用(右状态);
    模板.来源起始状态 = 私有_生成引用(左状态);
    模板.来源结果状态 = 私有_生成引用(右状态);
    模板.来源场景 = 私有_生成引用(所属场景);
    模板.来源类型 = 枚举_二次特征来源类型::状态;
    模板.来源时间段 = 来源时间段;
    模板.刷新度量签名_链键();

    auto* 节点 = 世界树_->二次特征().获取或创建子二次特征_按签名(
        static_cast<基础信息节点类*>(所属场景),
        模板);
    if (!节点) return nullptr;

    auto* 主信息 = 世界树_->二次特征().取二次特征主信息(节点);
    if (!主信息) return nullptr;

    主信息->种类 = 枚举_二次特征种类::状态比较;
    主信息->概念名称 = 左特征类型;
    if (左特征类型) {
        主信息->名称 = 左特征类型;
        主信息->类型 = 左特征类型;
    }
    主信息->离散编码 = static_cast<std::int32_t>(二次特征类型);
    主信息->离散语义键 = 私有_状态二次特征类型文本(二次特征类型);

    (void)世界树_->二次特征().绑定场景(节点, 所属场景);
    (void)世界树_->二次特征().设置生成语义(
        节点,
        枚举_二次特征域::存在,
        枚举_二次特征粒度::当前场景,
        枚举_二次特征基准类型::无,
        枚举_时间归一方式::无,
        枚举_二次特征值形态::标量);
    (void)世界树_->二次特征().绑定来源(
        节点,
        左状态,
        右状态,
        nullptr,
        所属场景,
        0,
        0,
        枚举_二次特征来源类型::状态,
        来源时间段,
        0,
        0,
        0);
    (void)世界树_->二次特征().设置主体客体(
        节点,
        左主体,
        (左主体 && 右主体 && 私有_取节点键(左主体) != 私有_取节点键(右主体)) ? 右主体 : nullptr);
    (void)世界树_->二次特征().设置左右对象(节点, 左状态, 右状态);
    (void)世界树_->二次特征().写入差值结果(
        节点,
        比较方法结果.左比较值,
        比较方法结果.右比较值);
    const auto 差值 = 主信息->差值.value_or(0);
    (void)世界树_->二次特征().写入标量值(节点, 差值, 差值 != 0, 10000);
    return 节点;
}

std::vector<二次特征节点类*> 二次特征生成模块::获取动态二次特征(
    const 动态节点类& 动态,
    const 二次特征生成配置& 配置)
{
    if (!世界树_) return {};

    auto* 动态节点 = const_cast<动态节点类*>(&动态);
    auto* 父节点 = 动态节点 ? static_cast<基础信息节点类*>(动态节点->父) : nullptr;
    auto* 场景 = 父节点 && 世界树_->基础信息().取主信息<场景节点主信息类>(父节点)
        ? static_cast<场景节点类*>(父节点)
        : nullptr;
    return 私有_获取动态二次特征(世界树_, 场景, 动态节点, 配置);
}

二次特征节点类* 二次特征生成模块::生成相邻动态协同二次特征(
    场景节点类* 场景,
    动态节点类* 动态,
    时间戳 时间窗口)
{
    if (!世界树_ || !场景 || !动态) return nullptr;

    结构_动态视图片段 当前片段{};
    if (!私有_解析动态视图片段(世界树_, 动态, 当前片段, true, false, false)) {
        return nullptr;
    }

    const auto 绝对值饱和 = [](I64 值) noexcept -> I64 {
        if (值 == I64_MIN) return I64_MAX;
        return 值 < 0 ? -值 : 值;
    };
    const auto 饱和加 = [](I64 左, I64 右) noexcept -> I64 {
        if (右 > 0 && 左 > I64_MAX - 右) return I64_MAX;
        if (右 < 0 && 左 < I64_MIN - 右) return I64_MIN;
        return 左 + 右;
    };

    const auto 场景动态 = 世界树_->动态().获取场景动态(场景);
    bool 已遇到当前 = false;
    for (auto it = 场景动态.rbegin(); it != 场景动态.rend(); ++it) {
        auto* 候选动态 = *it;
        if (!候选动态) continue;
        if (候选动态 == 动态 || 候选动态->获取主键() == 动态->获取主键()) {
            已遇到当前 = true;
            continue;
        }
        if (!已遇到当前) continue;

        结构_动态视图片段 候选片段{};
        if (!私有_解析动态视图片段(世界树_, 候选动态, 候选片段, true, false, false)) {
            continue;
        }
        if (候选片段.主体 != 当前片段.主体) {
            continue;
        }
        if (候选片段.特征类型 && 当前片段.特征类型
            && 私有_词性主键相等(候选片段.特征类型, 当前片段.特征类型)) {
            continue;
        }

        const bool 时间重叠 =
            候选片段.起时间 <= 当前片段.止时间
            && 当前片段.起时间 <= 候选片段.止时间;
        const auto 间隔 =
            候选片段.止时间 <= 当前片段.起时间
            ? 当前片段.起时间 - 候选片段.止时间
            : (当前片段.止时间 <= 候选片段.起时间 ? 候选片段.起时间 - 当前片段.止时间 : 0);
        if (!时间重叠 && 时间窗口 != 0 && 间隔 > 时间窗口) {
            continue;
        }

        std::int32_t 关系编码 = 0;
        const char* 关系语义 = "无关系";
        if (时间重叠) {
            关系编码 = 1;
            关系语义 = "同步";
        }
        else if (候选片段.止时间 <= 当前片段.起时间) {
            关系编码 = 2;
            关系语义 = "前置";
        }
        else {
            关系编码 = 3;
            关系语义 = "滞后";
        }

        结构_场景二次特征写入请求 请求{};
        请求.概念名称 = "多特征协同关系";
        请求.概念词性 = "状态词";
        请求.同步名称和类型 = true;
        请求.种类 = 枚举_二次特征种类::动态比较;
        请求.域 = 枚举_二次特征域::动态;
        请求.粒度 = 枚举_二次特征粒度::相邻分步;
        请求.基准类型 = 枚举_二次特征基准类型::相邻前态;
        请求.时间归一方式 = 枚举_时间归一方式::无;
        请求.值形态 = 枚举_二次特征值形态::枚举;
        请求.主体 = 当前片段.主体;
        请求.左对象 = reinterpret_cast<基础信息节点类*>(候选动态);
        请求.右对象 = reinterpret_cast<基础信息节点类*>(动态);
        请求.来源动态 = 动态;
        请求.来源类型 = 枚举_二次特征来源类型::动态;
        请求.来源时间段 = 结构_时间段{
            std::min(候选片段.起时间, 当前片段.起时间),
            std::max(候选片段.止时间, 当前片段.止时间)
        };
        请求.分步时长 = 间隔;
        请求.窗口时长 = 时间窗口;
        请求.来源动态层级 = 当前片段.动态主信息->动态层级;
        请求.来源动态路径签名 = 当前片段.动态主信息->动态路径签名;
        请求.离散编码 = 关系编码;
        请求.离散语义键 = 关系语义;
        请求.是否满足 = 关系编码 != 0;
        请求.置信度 = 关系编码 != 0
            ? 饱和加(绝对值饱和(当前片段.差值), 绝对值饱和(候选片段.差值))
            : 0;

        二次特征节点类* 节点 = nullptr;
        if (写入场景二次特征(场景, 请求, &节点)) {
            return 节点;
        }
    }
    return nullptr;
}

std::vector<二次特征节点类*> 二次特征生成模块::由存在比较结果生成二次特征(
    场景节点类* 场景,
    存在节点类* 左存在,
    存在节点类* 右存在,
    const 存在比较结果& 比较结果)
{
    std::vector<二次特征节点类*> 结果{};
    if (!世界树_ || !场景 || !左存在 || !右存在) return 结果;

    auto* 左对象 = static_cast<基础信息节点类*>(左存在);
    auto* 右对象 = static_cast<基础信息节点类*>(右存在);
    私有_规范化左右对象(左对象, 右对象);

    const auto 创建或更新标量结果 =
        [&](const 词性节点类* 概念名称,
            枚举_二次特征种类 种类,
            I64 标量值,
            const std::string& 度量后缀) {
            二次特征主信息类 模板{};
            模板.种类 = 种类;
            模板.域 = 枚举_二次特征域::存在;
            模板.粒度 = 枚举_二次特征粒度::当前场景;
            模板.时间归一方式 = 枚举_时间归一方式::无;
            模板.值形态 = 枚举_二次特征值形态::标量;
            模板.主体 = 私有_生成引用(左对象);
            模板.客体 = 私有_生成引用(右对象);
            模板.左对象 = 私有_生成引用(左对象);
            模板.右对象 = 私有_生成引用(右对象);
            模板.来源场景 = 私有_生成引用(场景);
            模板.来源类型 = 枚举_二次特征来源类型::状态;
            模板.刷新度量签名_链键();
            模板.度量签名_链键 += "|存在比较|" + 度量后缀;

            if (auto* 节点 = 世界树_->二次特征().获取或创建子二次特征_按签名(
                static_cast<基础信息节点类*>(场景),
                模板)) {
                auto* 主信息 = 世界树_->二次特征().取二次特征主信息(节点);
                if (主信息) {
                    主信息->种类 = 种类;
                    主信息->概念名称 = 概念名称;
                    世界树_->二次特征().绑定场景(节点, 场景);
                    世界树_->二次特征().设置生成语义(
                        节点,
                        枚举_二次特征域::存在,
                        枚举_二次特征粒度::当前场景,
                        枚举_二次特征基准类型::未定义,
                        枚举_时间归一方式::无,
                        枚举_二次特征值形态::标量);
                    世界树_->二次特征().绑定来源(
                        节点,
                        nullptr,
                        nullptr,
                        nullptr,
                        场景,
                        0,
                        0,
                        枚举_二次特征来源类型::状态);
                    世界树_->二次特征().设置主体客体(节点, 左对象, 右对象);
                    世界树_->二次特征().设置左右对象(节点, 左对象, 右对象);
                    世界树_->二次特征().写入标量值(节点, 标量值, false, 10000);
                    私有_追加去重二次特征(结果, 节点);
                }
            }
        };

    const auto 创建或更新缺失结果 =
        [&](const 词性节点类* 概念名称,
            std::int32_t 缺失码,
            const std::string& 语义键,
            const std::string& 度量后缀) {
            二次特征主信息类 模板{};
            模板.种类 = 枚举_二次特征种类::特征比较;
            模板.域 = 枚举_二次特征域::存在;
            模板.粒度 = 枚举_二次特征粒度::当前场景;
            模板.时间归一方式 = 枚举_时间归一方式::无;
            模板.值形态 = 枚举_二次特征值形态::枚举;
            模板.主体 = 私有_生成引用(左对象);
            模板.客体 = 私有_生成引用(右对象);
            模板.左对象 = 私有_生成引用(左对象);
            模板.右对象 = 私有_生成引用(右对象);
            模板.来源场景 = 私有_生成引用(场景);
            模板.来源类型 = 枚举_二次特征来源类型::状态;
            模板.刷新度量签名_链键();
            模板.度量签名_链键 += "|存在比较|" + 度量后缀;

            if (auto* 节点 = 世界树_->二次特征().获取或创建子二次特征_按签名(
                static_cast<基础信息节点类*>(场景),
                模板)) {
                auto* 主信息 = 世界树_->二次特征().取二次特征主信息(节点);
                if (主信息) {
                    主信息->种类 = 枚举_二次特征种类::特征比较;
                    主信息->概念名称 = 概念名称;
                    世界树_->二次特征().绑定场景(节点, 场景);
                    世界树_->二次特征().设置生成语义(
                        节点,
                        枚举_二次特征域::存在,
                        枚举_二次特征粒度::当前场景,
                        枚举_二次特征基准类型::未定义,
                        枚举_时间归一方式::无,
                        枚举_二次特征值形态::枚举);
                    世界树_->二次特征().绑定来源(
                        节点,
                        nullptr,
                        nullptr,
                        nullptr,
                        场景,
                        0,
                        0,
                        枚举_二次特征来源类型::状态);
                    世界树_->二次特征().设置主体客体(节点, 左对象, 右对象);
                    世界树_->二次特征().设置左右对象(节点, 左对象, 右对象);
                    世界树_->二次特征().写入离散值(
                        节点,
                        缺失码,
                        语义键,
                        枚举_二次特征值形态::枚举,
                        10000);
                    私有_追加去重二次特征(结果, 节点);
                }
            }
        };

    创建或更新标量结果(
        私有_取概念名称词("总差异度"),
        枚举_二次特征种类::存在比较,
        比较结果.总差异度,
        "summary:total_diff");
    创建或更新标量结果(
        私有_取概念名称词("命中特征数"),
        枚举_二次特征种类::存在比较,
        static_cast<I64>(比较结果.命中特征数),
        "summary:matched_feature_count");
    创建或更新标量结果(
        私有_取概念名称词("比较特征数"),
        枚举_二次特征种类::存在比较,
        static_cast<I64>(比较结果.明细.size()),
        "summary:compared_feature_count");

    for (const auto& 明细 : 比较结果.明细) {
        if (!明细.类型) continue;

        const auto 特征键 = 明细.类型->获取主键();
        创建或更新标量结果(
            明细.类型,
            枚举_二次特征种类::特征比较,
            明细.差异度,
            "detail:diff_q:" + 特征键);

        const auto 缺失码 =
            static_cast<std::int32_t>((明细.缺失A ? 1 : 0) | (明细.缺失B ? 2 : 0));
        std::string 缺失语义键 = "完整";
        if (缺失码 == 1) 缺失语义键 = "A缺失";
        else if (缺失码 == 2) 缺失语义键 = "B缺失";
        else if (缺失码 == 3) 缺失语义键 = "双缺失";

        创建或更新缺失结果(
            明细.类型,
            缺失码,
            缺失语义键,
            "detail:missing_code:" + 特征键);
    }

    return 结果;
}

动态节点类* 二次特征生成模块::尝试生成连续同向聚合动态(
    场景节点类* 场景,
    动态节点类* 动态)
{
    if (!世界树_ || !场景 || !动态) return nullptr;

    结构_动态视图片段 当前片段{};
    if (!私有_解析动态视图片段(世界树_, 动态, 当前片段, true, true, true)) {
        return nullptr;
    }
    if (!当前片段.有原始I64值) {
        return nullptr;
    }

    auto 场景动态 = 世界树_->动态().获取场景动态(场景);
    if (场景动态.size() < 2) {
        return nullptr;
    }

    std::vector<结构_动态视图片段> 逆序片段{};
    逆序片段.push_back(当前片段);
    I64 当前链起始值 = 当前片段.原始起始值;
    时间戳 当前链起始时间 = 当前片段.起时间;

    bool 已遇到当前 = false;
    for (auto it = 场景动态.rbegin(); it != 场景动态.rend(); ++it) {
        auto* 候选动态 = *it;
        if (候选动态 == 动态) {
            已遇到当前 = true;
            continue;
        }
        if (!已遇到当前) continue;

        结构_动态视图片段 候选片段{};
        if (!私有_解析动态视图片段(世界树_, 候选动态, 候选片段, true, true, true)) {
            continue;
        }
        if (!候选片段.有原始I64值) {
            continue;
        }
        if (!私有_同一主体特征流(当前片段, 候选片段)) {
            continue;
        }
        if (候选片段.方向 != 当前片段.方向) {
            break;
        }
        if (候选片段.原始结果值 != 当前链起始值) {
            break;
        }
        if (候选片段.止时间 != 0 && 当前链起始时间 != 0 && 候选片段.止时间 > 当前链起始时间) {
            break;
        }

        逆序片段.push_back(候选片段);
        当前链起始值 = 候选片段.原始起始值;
        当前链起始时间 = 候选片段.起时间;
    }

    if (逆序片段.size() < 2) {
        return nullptr;
    }

    std::vector<结构_动态视图片段> 片段列表(逆序片段.rbegin(), 逆序片段.rend());

    for (auto* 现有动态 : 场景动态) {
        const auto* 现有主信息 = 世界树_->动态().取动态主信息(现有动态);
        if (!现有主信息) continue;
        if (现有主信息->聚合方式 != 枚举_动态聚合方式::连续同向段
            || 现有主信息->动态层级 != 当前片段.动态主信息->动态层级 + 1) {
            continue;
        }
        if (私有_聚合来源链相同(世界树_, 现有主信息, 片段列表)) {
            return 现有动态;
        }
    }

    auto* 聚合主信息 = new 动态节点主信息类{};
    聚合主信息->初始状态 = 私有_生成引用(片段列表.front().起始状态);
    聚合主信息->结果状态 = 私有_生成引用(片段列表.back().结果状态);
    聚合主信息->动态主体 = 私有_生成引用(当前片段.主体);
    聚合主信息->动态特征 = 私有_生成引用(当前片段.特征);
    聚合主信息->时间 = 结构_时间段{ 片段列表.front().起时间, 片段列表.back().止时间 };
    聚合主信息->名称 = 当前片段.动态主信息->名称;
    聚合主信息->类型 = 当前片段.动态主信息->类型;
    聚合主信息->来源类型 = 当前片段.动态主信息->来源类型;
    聚合主信息->来源动作 = 当前片段.动态主信息->来源动作;
    聚合主信息->来源动作名 = 当前片段.动态主信息->来源动作名;
    聚合主信息->来源动作相位 = 当前片段.动态主信息->来源动作相位;
    聚合主信息->来源输入场景 = 当前片段.动态主信息->来源输入场景;
    聚合主信息->来源输出场景 = 当前片段.动态主信息->来源输出场景;
    聚合主信息->来源执行成功 = 当前片段.动态主信息->来源执行成功;
    聚合主信息->来源错误码 = 当前片段.动态主信息->来源错误码;
    聚合主信息->动态层级 = 当前片段.动态主信息->动态层级 + 1;
    聚合主信息->聚合方式 = 枚举_动态聚合方式::连续同向段;
    聚合主信息->动态路径签名 = 私有_计算聚合路径签名(片段列表);
    for (const auto& 片段 : 片段列表) {
        聚合主信息->来源低层动态.push_back(私有_生成引用(片段.动态));
    }

    return 世界树_->动态().创建动态(场景, 聚合主信息);
}

动态节点类* 二次特征生成模块::尝试生成同类事件段聚合动态(
    场景节点类* 场景,
    动态节点类* 动态)
{
    if (!世界树_ || !场景 || !动态) return nullptr;

    结构_动态视图片段 当前片段{};
    if (!私有_解析动态视图片段(世界树_, 动态, 当前片段, true, false, false)) {
        return nullptr;
    }
    if (私有_值形态不适合同类事件段聚合(当前片段.起始状态值)
        || 私有_值形态不适合同类事件段聚合(当前片段.结果状态值)) {
        return nullptr;
    }

    auto 场景动态 = 世界树_->动态().获取场景动态(场景);
    if (场景动态.size() < 2) {
        return nullptr;
    }

    std::vector<结构_动态视图片段> 逆序片段{};
    逆序片段.push_back(当前片段);
    auto 当前链起始状态值 = 当前片段.起始状态值;
    时间戳 当前链起始时间 = 当前片段.起时间;

    bool 已遇到当前 = false;
    for (auto it = 场景动态.rbegin(); it != 场景动态.rend(); ++it) {
        auto* 候选动态 = *it;
        if (候选动态 == 动态) {
            已遇到当前 = true;
            continue;
        }
        if (!已遇到当前) continue;

        结构_动态视图片段 候选片段{};
        if (!私有_解析动态视图片段(世界树_, 候选动态, 候选片段, true, false, false)) {
            continue;
        }
        if (私有_值形态不适合同类事件段聚合(候选片段.起始状态值)
            || 私有_值形态不适合同类事件段聚合(候选片段.结果状态值)) {
            continue;
        }
        if (!私有_同一主体特征流(当前片段, 候选片段)) {
            continue;
        }
        if (!私有_同类事件来源流(当前片段, 候选片段)) {
            break;
        }
        if (!(候选片段.结果状态值 == 当前链起始状态值)) {
            break;
        }
        if (候选片段.止时间 != 0 && 当前链起始时间 != 0 && 候选片段.止时间 > 当前链起始时间) {
            break;
        }

        逆序片段.push_back(候选片段);
        当前链起始状态值 = 候选片段.起始状态值;
        当前链起始时间 = 候选片段.起时间;
    }

    if (逆序片段.size() < 2) {
        return nullptr;
    }

    std::vector<结构_动态视图片段> 片段列表(逆序片段.rbegin(), 逆序片段.rend());

    for (auto* 现有动态 : 场景动态) {
        const auto* 现有主信息 = 世界树_->动态().取动态主信息(现有动态);
        if (!现有主信息) continue;
        if (现有主信息->聚合方式 != 枚举_动态聚合方式::同类事件段
            || 现有主信息->动态层级 != 当前片段.动态主信息->动态层级 + 1) {
            continue;
        }
        if (私有_聚合来源链相同(世界树_, 现有主信息, 片段列表)) {
            return 现有动态;
        }
    }

    auto* 聚合主信息 = new 动态节点主信息类{};
    聚合主信息->初始状态 = 私有_生成引用(片段列表.front().起始状态);
    聚合主信息->结果状态 = 私有_生成引用(片段列表.back().结果状态);
    聚合主信息->动态主体 = 私有_生成引用(当前片段.主体);
    聚合主信息->动态特征 = 私有_生成引用(当前片段.特征);
    聚合主信息->时间 = 结构_时间段{ 片段列表.front().起时间, 片段列表.back().止时间 };
    聚合主信息->名称 = 当前片段.动态主信息->名称;
    聚合主信息->类型 = 当前片段.动态主信息->类型;
    聚合主信息->来源类型 = 当前片段.动态主信息->来源类型;
    聚合主信息->业务语义类型 = 当前片段.动态主信息->业务语义类型;
    聚合主信息->来源动作 = 当前片段.动态主信息->来源动作;
    聚合主信息->来源动作名 = 当前片段.动态主信息->来源动作名;
    聚合主信息->来源动作相位 = 当前片段.动态主信息->来源动作相位;
    聚合主信息->来源输入场景 = 当前片段.动态主信息->来源输入场景;
    聚合主信息->来源输出场景 = 当前片段.动态主信息->来源输出场景;
    聚合主信息->来源执行成功 = 当前片段.动态主信息->来源执行成功;
    聚合主信息->来源错误码 = 当前片段.动态主信息->来源错误码;
    聚合主信息->动态层级 = 当前片段.动态主信息->动态层级 + 1;
    聚合主信息->聚合方式 = 枚举_动态聚合方式::同类事件段;
    聚合主信息->动态路径签名 = 私有_计算聚合路径签名(片段列表);
    for (const auto& 片段 : 片段列表) {
        聚合主信息->来源低层动态.push_back(私有_生成引用(片段.动态));
    }

    return 世界树_->动态().创建动态(场景, 聚合主信息);
}

std::vector<二次特征节点类*> 二次特征生成模块::刷新场景存在型基础二次特征(
    场景节点类* 场景,
    std::int64_t 接近阈值_mm,
    std::int64_t 冲突阈值_mm)
{
    std::vector<二次特征节点类*> 结果{};
    if (!世界树_ || !场景) return 结果;

    auto 存在列表 = 世界树_->存在().获取子存在(场景);
    if (存在列表.size() < 2) return 结果;

    if (接近阈值_mm < 0) 接近阈值_mm = 0;
    if (冲突阈值_mm < 0) 冲突阈值_mm = 0;

    for (std::size_t i = 0; i < 存在列表.size(); ++i) {
        auto* 左存在 = 存在列表[i];
        const auto* 左主信息 = 世界树_->存在().取存在主信息(左存在);
        if (!左主信息 || !左主信息->有位置历史) continue;

        for (std::size_t j = i + 1; j < 存在列表.size(); ++j) {
            auto* 右存在 = 存在列表[j];
            const auto* 右主信息 = 世界树_->存在().取存在主信息(右存在);
            if (!右主信息 || !右主信息->有位置历史) continue;

            auto* 左对象 = static_cast<基础信息节点类*>(左存在);
            auto* 右对象 = static_cast<基础信息节点类*>(右存在);
            私有_规范化左右对象(左对象, 右对象);

            const auto 距离_mm = 私有_计算距离_mm(左主信息->最近观测位置_mm, 右主信息->最近观测位置_mm);
            const auto 接近余量 = 接近阈值_mm - 距离_mm;
            const auto 冲突余量 = 冲突阈值_mm - 距离_mm;

            {
                二次特征主信息类 模板{};
                模板.种类 = 枚举_二次特征种类::存在比较;
                模板.域 = 枚举_二次特征域::存在;
                模板.粒度 = 枚举_二次特征粒度::当前场景;
                模板.时间归一方式 = 枚举_时间归一方式::无;
                模板.值形态 = 枚举_二次特征值形态::标量;
                模板.左对象 = 私有_生成引用(左对象);
                模板.右对象 = 私有_生成引用(右对象);
                模板.来源场景 = 私有_生成引用(场景);
                模板.来源类型 = 枚举_二次特征来源类型::状态;
                模板.刷新度量签名_链键();

                if (auto* 节点 = 世界树_->二次特征().获取或创建子二次特征_按签名(
                    static_cast<基础信息节点类*>(场景),
                    模板)) {
                    auto* 主信息 = 世界树_->二次特征().取二次特征主信息(节点);
                    if (主信息) {
                        主信息->种类 = 枚举_二次特征种类::存在比较;
                        主信息->概念名称 = 私有_取概念名称词("接近程度");
                        世界树_->二次特征().绑定场景(节点, 场景);
                        世界树_->二次特征().设置生成语义(
                            节点,
                            枚举_二次特征域::存在,
                            枚举_二次特征粒度::当前场景,
                            枚举_二次特征基准类型::未定义,
                            枚举_时间归一方式::无,
                            枚举_二次特征值形态::标量);
                        世界树_->二次特征().绑定来源(
                            节点,
                            nullptr,
                            nullptr,
                            nullptr,
                            场景,
                            0,
                            0,
                            枚举_二次特征来源类型::状态);
                        世界树_->二次特征().设置左右对象(节点, 左对象, 右对象);
                        世界树_->二次特征().写入标量值(节点, 接近余量, 接近余量 >= 0, 10000);
                        结果.push_back(节点);
                    }
                }
            }

            {
                二次特征主信息类 模板{};
                模板.种类 = 枚举_二次特征种类::存在比较;
                模板.域 = 枚举_二次特征域::存在;
                模板.粒度 = 枚举_二次特征粒度::当前场景;
                模板.时间归一方式 = 枚举_时间归一方式::无;
                模板.值形态 = 枚举_二次特征值形态::布尔;
                模板.左对象 = 私有_生成引用(左对象);
                模板.右对象 = 私有_生成引用(右对象);
                模板.来源场景 = 私有_生成引用(场景);
                模板.来源类型 = 枚举_二次特征来源类型::状态;
                模板.刷新度量签名_链键();

                if (auto* 节点 = 世界树_->二次特征().获取或创建子二次特征_按签名(
                    static_cast<基础信息节点类*>(场景),
                    模板)) {
                    auto* 主信息 = 世界树_->二次特征().取二次特征主信息(节点);
                    if (主信息) {
                        主信息->种类 = 枚举_二次特征种类::存在比较;
                        主信息->概念名称 = 私有_取概念名称词("冲突");
                        世界树_->二次特征().绑定场景(节点, 场景);
                        世界树_->二次特征().设置生成语义(
                            节点,
                            枚举_二次特征域::存在,
                            枚举_二次特征粒度::当前场景,
                            枚举_二次特征基准类型::未定义,
                            枚举_时间归一方式::无,
                            枚举_二次特征值形态::布尔);
                        世界树_->二次特征().绑定来源(
                            节点,
                            nullptr,
                            nullptr,
                            nullptr,
                            场景,
                            0,
                            0,
                            枚举_二次特征来源类型::状态);
                        世界树_->二次特征().设置左右对象(节点, 左对象, 右对象);
                        世界树_->二次特征().写入标量值(节点, 冲突余量, 冲突余量 >= 0, 10000);
                        结果.push_back(节点);
                    }
                }
            }
        }
    }

    return 结果;
}
