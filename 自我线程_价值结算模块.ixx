module;

#include <algorithm>
#include <limits>
#include <mutex>
#include <sstream>
#include <string>
#include <unordered_map>
#include <unordered_set>
#include <utility>

#include "基础数据类型.h"
#include "需求类.h"
#include "任务类.h"
#include "日志接入.h"

export module 自我线程_价值结算模块;

import 自我模块;

namespace 自我线程_价值结算模块 {

export struct 结构_任务价值反馈段 {
    std::string 反馈事件主键{};
    I64 本次安全满足量 = 0;
    I64 本次服务满足量 = 0;
    I64 安全累计比例_百万分比 = -1;
    I64 服务累计比例_百万分比 = -1;
};

export struct 结构_价值结算结果 {
    bool 成功 = false;
    bool 已处理 = false;
    bool 已去重 = false;
    I64 实际安全增量 = 0;
    I64 实际服务增量 = 0;
    std::string 摘要{};
};

namespace {

std::mutex g_反馈事件锁;
std::unordered_map<std::string, std::unordered_set<std::string>> g_任务已处理反馈事件;

I64 私有_夹紧非负上限(I64 值, I64 上限) noexcept
{
    if (值 <= 0 || 上限 <= 0) {
        return 0;
    }
    return (std::min<I64>)(值, 上限);
}

I64 私有_安全乘除(I64 左, I64 右, I64 分母) noexcept
{
    if (左 <= 0 || 右 <= 0 || 分母 <= 0) {
        return 0;
    }
    const long double 结果 =
        static_cast<long double>(左) * static_cast<long double>(右) / static_cast<long double>(分母);
    if (结果 <= 0.0L) {
        return 0;
    }
    if (结果 >= static_cast<long double>(std::numeric_limits<I64>::max())) {
        return std::numeric_limits<I64>::max();
    }
    return static_cast<I64>(结果);
}

I64 私有_按百万分比计算目标值(I64 权重上限, I64 比例_百万分比) noexcept
{
    const I64 比例 = std::clamp<I64>(比例_百万分比, 0, 1'000'000);
    return (std::min<I64>)((std::max<I64>)(0, 权重上限), 私有_安全乘除(权重上限, 比例, 1'000'000));
}

I64 私有_计算反馈增量(
    I64 权重上限,
    I64 已折算值,
    I64 本次满足量,
    I64 累计比例_百万分比) noexcept
{
    const I64 剩余额度 = (std::max<I64>)(0, 权重上限 - (std::max<I64>)(0, 已折算值));
    if (剩余额度 <= 0) {
        return 0;
    }
    if (累计比例_百万分比 >= 0) {
        const I64 目标值 = 私有_按百万分比计算目标值(权重上限, 累计比例_百万分比);
        return (std::min<I64>)(剩余额度, (std::max<I64>)(0, 目标值 - 已折算值));
    }
    return 私有_夹紧非负上限(本次满足量, 剩余额度);
}

bool 私有_是增量反馈(const 结构_任务价值反馈段& 反馈) noexcept
{
    return (反馈.本次安全满足量 > 0 && 反馈.安全累计比例_百万分比 < 0)
        || (反馈.本次服务满足量 > 0 && 反馈.服务累计比例_百万分比 < 0);
}

bool 私有_登记增量反馈事件(
    const std::string& 任务主键,
    const std::string& 反馈事件主键,
    结构_价值结算结果& 结果) noexcept
{
    if (反馈事件主键.empty()) {
        结果.摘要 = "任务价值反馈结算失败 | 原因=增量反馈缺少反馈事件主键";
        return false;
    }
    std::scoped_lock 锁(g_反馈事件锁);
    auto& 已处理集 = g_任务已处理反馈事件[任务主键];
    if (已处理集.contains(反馈事件主键)) {
        结果.成功 = true;
        结果.已处理 = true;
        结果.已去重 = true;
        结果.摘要 = "任务价值反馈结算 | 增量反馈事件已处理，跳过去重";
        return false;
    }
    已处理集.insert(反馈事件主键);
    return true;
}

} // namespace

export I64 安全乘除_I64(I64 左, I64 右, I64 分母) noexcept
{
    return 私有_安全乘除(左, 右, 分母);
}

export 结构_价值结算结果 应用自我价值增量(
    自我类& 自我对象,
    I64 安全增量,
    I64 服务增量,
    时间戳 now) noexcept
{
    结构_价值结算结果 结果{};
    const I64 计划安全增量 = (std::max<I64>)(0, 安全增量);
    const I64 计划服务增量 = (std::max<I64>)(0, 服务增量);
    if (计划安全增量 <= 0 && 计划服务增量 <= 0) {
        结果.成功 = true;
        结果.已处理 = true;
        结果.摘要 = "自我价值结算 | 无新增价值";
        return 结果;
    }

    if (计划安全增量 > 0) {
        const I64 旧安全值 = 自我对象.获取安全值();
        (void)自我对象.应用自我需求安全值增加(
            计划安全增量,
            now);
        结果.实际安全增量 = (std::max<I64>)(0, 自我对象.获取安全值() - 旧安全值);
    }
    if (计划服务增量 > 0) {
        const I64 旧服务值 = 自我对象.获取服务值();
        (void)自我对象.应用自我需求服务值增加(
            计划服务增量,
            now);
        结果.实际服务增量 = (std::max<I64>)(0, 自我对象.获取服务值() - 旧服务值);
    }
    结果.成功 = true;
    结果.已处理 = true;
    std::ostringstream 摘要;
    摘要 << "自我价值结算"
        << " | 安全+=" << 结果.实际安全增量
        << " | 服务+=" << 结果.实际服务增量;
    结果.摘要 = 摘要.str();
    return 结果;
}

export 结构_价值结算结果 处理任务价值反馈(
    自我类& 自我对象,
    任务类::节点类* 任务头,
    需求类::节点类* 来源需求,
    const 结构_任务价值反馈段& 反馈,
    时间戳 now) noexcept
{
    结构_价值结算结果 结果{};
    if (!任务头) {
        结果.摘要 = "任务价值反馈结算失败 | 原因=任务为空";
        return 结果;
    }
    if (!来源需求) {
        结果.摘要 = "任务价值反馈结算失败 | 原因=来源需求为空";
        return 结果;
    }

    const auto 任务主键 = 任务头->获取主键();
    if (私有_是增量反馈(反馈)
        && !私有_登记增量反馈事件(任务主键, 反馈.反馈事件主键, 结果)) {
        return 结果;
    }

    const I64 任务安全权重上限 =
        (std::max<I64>)(0, 任务类::读取任务承接安全权重上限(任务头));
    const I64 任务服务权重上限 =
        (std::max<I64>)(0, 任务类::读取任务承接服务权重上限(任务头));
    const I64 已折算安全值 =
        (std::max<I64>)(0, 任务类::读取任务已折算安全值(任务头));
    const I64 已折算服务值 =
        (std::max<I64>)(0, 任务类::读取任务已折算服务值(任务头));

    const I64 计划安全增量 = 私有_计算反馈增量(
        任务安全权重上限,
        已折算安全值,
        反馈.本次安全满足量,
        反馈.安全累计比例_百万分比);
    const I64 计划服务增量 = 私有_计算反馈增量(
        任务服务权重上限,
        已折算服务值,
        反馈.本次服务满足量,
        反馈.服务累计比例_百万分比);

    if (计划安全增量 <= 0 && 计划服务增量 <= 0) {
        结果.成功 = true;
        结果.已处理 = true;
        结果.摘要 = "任务价值反馈结算 | 无新增可兑换额度";
        return 结果;
    }

    // 任务只报告满足量；自我线程价值结算模块统一结账，避免任务执行路径直接改总值。
    auto 应用结果 = 应用自我价值增量(
        自我对象,
        计划安全增量,
        计划服务增量,
        now);
    if (!应用结果.成功) {
        return 应用结果;
    }

    const I64 实际安全增量 = 应用结果.实际安全增量;
    const I64 实际服务增量 = 应用结果.实际服务增量;
    if (实际安全增量 > 0) {
        (void)任务类::写入任务已折算安全值(
            任务头,
            (std::min<I64>)(任务安全权重上限, 已折算安全值 + 实际安全增量),
            任务头->主信息.场景.指针,
            now);
        来源需求->主信息.累计安全结算 += 实际安全增量;
    }
    if (实际服务增量 > 0) {
        (void)任务类::写入任务已折算服务值(
            任务头,
            (std::min<I64>)(任务服务权重上限, 已折算服务值 + 实际服务增量),
            任务头->主信息.场景.指针,
            now);
        来源需求->主信息.累计服务结算 += 实际服务增量;
    }

    // 已折算值是幂等账本锚点：重复累计比例或重复增量事件都不能再次兑换。
    来源需求->主信息.累计安全结算 =
        (std::min<I64>)((std::max<I64>)(0, 来源需求->主信息.安全权重), 来源需求->主信息.累计安全结算);
    来源需求->主信息.累计服务结算 =
        (std::min<I64>)((std::max<I64>)(0, 来源需求->主信息.服务权重), 来源需求->主信息.累计服务结算);
    来源需求->主信息.最近结算任务主键 = 任务主键;
    来源需求->主信息.最近结算时间 = now;

    结果.成功 = true;
    结果.已处理 = true;
    结果.实际安全增量 = 实际安全增量;
    结果.实际服务增量 = 实际服务增量;
    std::ostringstream 摘要;
    摘要 << "任务价值反馈结算"
        << " | 任务=" << 任务主键
        << " | 需求=" << 来源需求->获取主键()
        << " | 安全+=" << 实际安全增量
        << " | 服务+=" << 实际服务增量
        << " | 安全账本="
        << (std::min<I64>)(任务安全权重上限, 已折算安全值 + 实际安全增量)
        << "/" << 任务安全权重上限
        << " | 服务账本="
        << (std::min<I64>)(任务服务权重上限, 已折算服务值 + 实际服务增量)
        << "/" << 任务服务权重上限;
    结果.摘要 = 摘要.str();
    项目运行日志(结果.摘要);
    return 结果;
}

} // namespace 自我线程_价值结算模块
