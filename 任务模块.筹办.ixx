        static const 语素入口节点类* s_词 = 语素集.添加信息入口词("允许默认执行", 枚举_信息入口类型::特征模板入口);
        return s_词;
    }

    void 写入方法补齐任务输入目标方法(
        任务节点* 任务头,
        方法节点* 被补方法,
        时间戳 now) noexcept
    {
        if (!任务头 || !被补方法 || !任务头->主信息.场景.指针) {
            return;
        }
        auto* 输入包 = 世界树.确保特征(
            任务头->主信息.场景.指针,
            特征_输入条件包());
        if (!输入包) {
            return;
        }
        (void)世界树.写入特征_指针(
            输入包,
            特征_目标方法头节点(),
            被补方法,
            now);
    }

    基础信息节点类* 任务参数缺口目标主体(
        任务节点* 任务头,
        方法节点* 目标方法,
        时间戳 now) noexcept
    {
        if (!任务头 || !任务头->主信息.场景.指针) {
            return nullptr;
        }
        auto* 输入包 = 世界树.确保特征(
            任务头->主信息.场景.指针,
            特征_输入条件包());
        if (!输入包) {
            return reinterpret_cast<基础信息节点类*>(任务头->主信息.场景.指针);
        }
        if (目标方法) {
            (void)世界树.写入特征_指针(
                输入包,
                特征_目标方法头节点(),
                目标方法,
                now);
        }
        return reinterpret_cast<基础信息节点类*>(输入包);
    }

    方法节点* 任务已绑定非治理方法(
        自我类* 自我对象,
        任务节点* 任务头,
        时间戳 now) noexcept
    {
        if (!任务头) {
            return nullptr;
        }
        auto* 方法 = reinterpret_cast<方法节点*>(任务类::读取任务执行方法(任务头));
        if (!方法) {
            return nullptr;
        }
        if (自我对象
            && 任务目标是方法结构补齐需求(任务头)
            && !方法是学习补齐本能方法(方法)) {
            auto* 被补方法 = 任务方法结构补齐目标方法(*自我对象, 任务头, now);
            if (被补方法 == 方法) {
                写入方法补齐任务输入目标方法(任务头, 被补方法, now);
                return nullptr;
            }
        }
        return 方法;
    }

    方法节点* 解析或创建任务目标方法(
        自我类& 自我对象,
        任务节点* 任务头,
        时间戳 now,
        bool* 输出已新建占位方法) noexcept
    {
        if (输出已新建占位方法) {
            *输出已新建占位方法 = false;
        }
        if (!任务头) {
            return nullptr;
        }
        if (auto* 已绑定方法 = 任务已绑定非治理方法(&自我对象, 任务头, now)) {
            追加任务方法候选(任务头, 已绑定方法, now);
            return 已绑定方法;
        }

        auto* 自我存在 = 自我对象.确保自我存在();
        auto* 方法根节点 = 自我存在 ? 世界树.存在().获取方法根节点(自我存在) : nullptr;
        if (!方法根节点) {
            return nullptr;
        }

        if (任务目标是方法结构补齐需求(任务头)) {
            (void)本能方法类::查找或创建本能方法首节点(
                自我存在,
                枚举_本能方法ID::自我_尝试学习,
                now);
            (void)本能方法类::查找或创建本能方法首节点(
                自我存在,
                枚举_本能方法ID::自我_定向学习,
                now);
            (void)本能方法类::查找或创建本能方法首节点(
                自我存在,
                枚举_本能方法ID::自我_练习,
                now);
        }

        const auto* 目标特征类型 = 任务对应需求目标特征类型(任务头);
        if (!目标特征类型) {
            return nullptr;
        }

        auto* 需求方向 = 任务需求方向(任务头);
        const auto 原方法根子节点数 = 方法根节点->子节点数量;
        auto* 目标方法 = 方法类::注册需求方向方法首节点(
            方法根节点,
            目标特征类型,
            需求方向,
            枚举_方法来源::运行时方法沉淀,
            now);
        if (目标方法 && 输出已新建占位方法) {
            *输出已新建占位方法 = 方法根节点->子节点数量 > 原方法根子节点数;
        }
        if (!目标方法) {
            return nullptr;
        }

        写入任务节点引用(目标方法->主信息.首节点信息().来源任务, 任务头);
        if (auto* 被补方法 = 任务方法结构补齐目标方法(自我对象, 任务头, now)) {
            写入方法补齐任务输入目标方法(任务头, 被补方法, now);
        }
        追加任务方法候选(任务头, 目标方法, now);
        return 目标方法;
    }

    const 语素入口节点类* 筹办缺口特征类型(
        任务模块::筹办::枚举_任务推进状况 状况) noexcept
    {
        using 任务模块::筹办::枚举_任务推进状况;
        switch (状况) {
        case 枚举_任务推进状况::方法缺动作骨架:
            return 私有_方法动作骨架状态特征类型_执行桥_最小_v0();
        case 枚举_任务推进状况::方法缺可执行入口:
            return 私有_方法可执行入口数量特征类型_执行桥_最小_v0();
        case 枚举_任务推进状况::方法缺条件节点:
            return 私有_方法条件节点数量特征类型_执行桥_最小_v0();
        case 枚举_任务推进状况::方法缺结果节点:
            return 私有_方法结果节点数量特征类型_执行桥_最小_v0();
        case 枚举_任务推进状况::方法缺条件结果对:
            return 私有_方法条件结果配对状态特征类型_执行桥_最小_v0();
        case 枚举_任务推进状况::参数不可配:
            return 特征_参数配对状态();
        case 枚举_任务推进状况::方法运行账不足:
            return 私有_方法运行账完整性特征类型_执行桥_最小_v0();
        case 枚举_任务推进状况::方法结果不稳定:
            return 私有_方法稳定状态特征类型_执行桥_最小_v0();
        default:
            return nullptr;
        }
    }

    bool 返回方法结构缺口(
        任务模块::筹办::结构_任务筹办结果& 结果,
        任务节点* 任务头,
        方法节点* 目标方法,
        任务模块::筹办::枚举_任务推进状况 状况,
        时间戳 now) noexcept
    {
        if (!任务头 || !目标方法) {
            return false;
        }

        using 任务模块::筹办::枚举_任务推进状况;

        场景节点类* 结果场景 = 任务头->主信息.场景.指针;
        特征节点类* 运行结果 = nullptr;
        基础信息节点类* 缺口目标主体 = nullptr;
        switch (状况) {
        case 枚举_任务推进状况::方法缺动作骨架:
            运行结果 = 私有_填充方法缺动作骨架执行结果_执行桥_最小_v0(目标方法, 结果场景, now);
            break;
        case 枚举_任务推进状况::方法缺可执行入口:
            运行结果 = 私有_填充方法缺可执行入口执行结果_执行桥_最小_v0(目标方法, 结果场景, now);
            break;
        case 枚举_任务推进状况::方法缺条件节点:
            运行结果 = 私有_填充方法缺条件节点执行结果_执行桥_最小_v0(目标方法, 结果场景, now);
            break;
        case 枚举_任务推进状况::方法缺结果节点:
            运行结果 = 私有_填充方法缺结果节点执行结果_执行桥_最小_v0(目标方法, 结果场景, now);
            break;
        case 枚举_任务推进状况::方法缺条件结果对:
            运行结果 = 私有_填充方法缺条件结果对执行结果_执行桥_最小_v0(目标方法, 结果场景, now);
            break;
        case 枚举_任务推进状况::参数不可配:
            缺口目标主体 = 任务参数缺口目标主体(任务头, 目标方法, now);
            运行结果 = 私有_填充参数配对缺口执行结果_执行桥_最小_v0(
                目标方法,
                缺口目标主体,
                结果场景,
                now);
            break;
        case 枚举_任务推进状况::方法运行账不足:
            运行结果 = 私有_填充方法运行账不足执行结果_执行桥_最小_v0(目标方法, 结果场景, now);
            break;
        case 枚举_任务推进状况::方法结果不稳定:
            运行结果 = 私有_填充方法结果不稳定执行结果_执行桥_最小_v0(目标方法, 结果场景, now);
            break;
        default:
            return false;
        }
        if (!运行结果) {
            return false;
        }

        任务类::写入任务状态(任务头, 枚举_任务状态::等待中, 任务头->主信息.场景.指针, now);
        (void)任务类::写入任务当前阶段(
            任务头,
            枚举_任务阶段::筹办,
            任务头->主信息.场景.指针,
            now);
        结果.方法运行结果 = 运行结果;
        结果.结果场景 = 结果场景;
        结果.回执.状况 = 状况;
        结果.回执.缺口特征类型 = 筹办缺口特征类型(状况);
        if (缺口目标主体) {
            写入基础节点引用(
                结果.回执.缺口目标主体,
                缺口目标主体);
        } else if (auto* 方法虚拟存在 = 目标方法->主信息.首节点信息().方法虚拟存在.指针
                ? 目标方法->主信息.首节点信息().方法虚拟存在.指针
                : 方法虚拟存在服务类::取或创建方法虚拟存在(目标方法, nullptr, now)) {
            // 方法类缺口归入方法虚拟存在的“方法状态”集合特征；
            // 学习需求以该集合特征为目标主体，再围绕具体缺口特征展开。
            auto* 方法状态 = 世界树.确保特征(
                reinterpret_cast<基础信息节点类*>(方法虚拟存在),
                私有_方法状态特征类型_执行桥_最小_v0());
            写入基础节点引用(
                结果.回执.缺口目标主体,
                方法状态
                    ? reinterpret_cast<基础信息节点类*>(方法状态)
                    : reinterpret_cast<基础信息节点类*>(方法虚拟存在));
        }
        结果.回执.需要自我线程 = true;
        结果.回执.需要创建或复用子需求 = true;
        结果.回执.父任务需要重筹办 = false;
        return true;
    }

    bool 返回方法状态可用性缺口(
        任务模块::筹办::结构_任务筹办结果& 结果,
        任务节点* 任务头,
        方法节点* 目标方法,
        时间戳 now) noexcept
    {
        if (!任务头 || !目标方法) {
            return false;
        }

        auto* 结果场景 = 任务头->主信息.场景.指针;
        auto* 运行结果 = 私有_填充方法不可用执行结果_执行桥_最小_v0(
            目标方法,
            结果场景,
            now);
        if (!运行结果) {
            return false;
        }

        auto* 方法虚拟存在 = 目标方法->主信息.首节点信息().方法虚拟存在.指针
            ? 目标方法->主信息.首节点信息().方法虚拟存在.指针
            : 方法虚拟存在服务类::取或创建方法虚拟存在(目标方法, nullptr, now);

        任务类::写入任务状态(任务头, 枚举_任务状态::等待中, 任务头->主信息.场景.指针, now);
        (void)任务类::写入任务当前阶段(
            任务头,
            枚举_任务阶段::筹办,
            任务头->主信息.场景.指针,
            now);
        结果.方法运行结果 = 运行结果;
        结果.结果场景 = 结果场景;
        结果.回执.状况 = 任务模块::筹办::枚举_任务推进状况::未定义;
        结果.回执.缺口特征类型 = 私有_方法状态特征类型_执行桥_最小_v0();
        if (方法虚拟存在) {
            写入基础节点引用(
                结果.回执.缺口目标主体,
                reinterpret_cast<基础信息节点类*>(方法虚拟存在));
        }
        结果.回执.需要自我线程 = true;
        结果.回执.需要创建或复用子需求 = true;
        结果.回执.父任务需要重筹办 = false;
        结果.回执.治理结果可接受 = false;
        return true;
    }
}

export namespace 任务模块::筹办 {

结构_任务筹办结果 筹办任务(
    ::自我类& 自我对象,
    任务类::节点类* 输入任务,
    时间戳 now) noexcept
{
    using enum 枚举_任务推进状况;

    结构_任务筹办结果 结果{};
    结果.已执行筹办 = true;
    if (now == 0) {
        now = 结构体_时间戳::当前_微秒();
    }

    auto* 任务头 = 归一到任务头结点(输入任务);
    结果.回执.阶段 = 枚举_任务推进阶段::筹办;
    写入任务节点引用(结果.回执.当前任务, 任务头);
    if (!任务头) {
        结果.缺少任务 = true;
        结果.回执.状况 = 未定义;
        return 结果;
    }

    auto* 来源需求 = 任务来源需求(任务头);
    const auto* 目标特征类型 = 需求目标特征类型(来源需求);
    结果.回执.目标特征类型 = 目标特征类型;
    if (来源需求) {
        写入需求节点引用(结果.回执.对应需求, 来源需求);
        结果.回执.目标满足关系 = 来源需求->主信息.满足关系;
    }

    if (来源需求 && 需求已满足(来源需求)) {
        结果.回执.状况 = 父需求已满足;
        结果.回执.当前任务目标达成 = true;
        结果.回执.需要自我线程 = true;
        (void)任务类::应用任务状态(任务头, 枚举_任务状态::完成, now);
        (void)任务类::写入任务当前阶段(
            任务头,
            枚举_任务阶段::已完成,
            任务头->主信息.场景.指针,
            now);
        return 结果;
    }

    if (来源需求 && 存在活动直接子需求(来源需求)) {
        结果.回执.状况 = 存在活动子需求;
        任务类::标记任务等待(任务头, now);
        (void)任务类::写入任务当前阶段(
            任务头,
            枚举_任务阶段::阻塞,
            任务头->主信息.场景.指针,
            now);
        return 结果;
    }

    if (!目标特征类型) {
        结果.缺少需求目标 = true;
        结果.回执.状况 = 未定义;
        (void)任务类::写入任务当前阶段(
            任务头,
            枚举_任务阶段::筹办,
            任务头->主信息.场景.指针,
            now);
        return 结果;
    }

    bool 已新建目标方法头 = false;
    auto* 目标方法 = 任务已绑定非治理方法(&自我对象, 任务头, now);
    if (!目标方法) {
        目标方法 = 解析或创建任务目标方法(
            自我对象,
            任务头,
            now,
            &已新建目标方法头);
    }
    if (!目标方法) {
        结果.缺少需求目标 = true;
        结果.回执.状况 = 方法查找未命中;
        return 结果;
    }

    追加任务方法候选(任务头, 目标方法, now);
    if (auto* 候选选中方法 = 从任务候选集中选择当前方法(自我对象, 任务头, now)) {
        目标方法 = 候选选中方法;
    }
    绑定任务执行方法(任务头, 目标方法, now);
    结果.已绑定方法 = true;
    结果.已创建目标方法头 = 已新建目标方法头;
    写入方法节点引用(结果.回执.当前方法, 目标方法);
    同步任务选中自我能力值(任务头, 目标方法);

    if (已新建目标方法头) {
        (void)方法虚拟存在服务类::初始化方法虚拟存在信息(
            目标方法,
            自我对象.获取自我存在(),
            now);
        (void)方法虚拟存在服务类::记录方法虚拟存在特征(
            目标方法,
            私有_方法状态特征类型_执行桥_最小_v0(),
            特征值{ static_cast<I64>(0) },
            自我对象.获取自我存在(),
            now);
        (void)方法虚拟存在服务类::记录方法虚拟存在特征(
            目标方法,
            特征_方法成熟度阶段(),
            特征值{ static_cast<I64>(0) },
            自我对象.获取自我存在(),
            now);
        (void)方法虚拟存在服务类::记录方法虚拟存在特征(
            目标方法,
            特征_方法结构是否完整(),
            特征值{ static_cast<I64>(0) },
            自我对象.获取自我存在(),
            now);
        (void)方法虚拟存在服务类::记录方法虚拟存在特征(
            目标方法,
            私有_方法运行账完整性特征类型_执行桥_最小_v0(),
            特征值{ static_cast<I64>(0) },
            自我对象.获取自我存在(),
            now);
        (void)方法虚拟存在服务类::记录方法虚拟存在特征(
            目标方法,
            私有_方法稳定状态特征类型_执行桥_最小_v0(),
            特征值{ static_cast<I64>(0) },
            自我对象.获取自我存在(),
            now);
        (void)方法虚拟存在服务类::记录方法虚拟存在特征(
            目标方法,
            特征_方法允许自动召回(),
            特征值{ static_cast<I64>(0) },
            自我对象.获取自我存在(),
            now);
        (void)方法虚拟存在服务类::记录方法虚拟存在特征(
            目标方法,
            特征_方法允许默认执行(),
            特征值{ static_cast<I64>(0) },
            自我对象.获取自我存在(),
            now);
        任务类::标记任务待重筹办(任务头, now);
        结果.已建立方法头待重入 = true;
        结果.回执.状况 = 已建立方法头待重入;
        结果.回执.父任务需要重筹办 = true;
        return 结果;
    }

    const bool 目标方法是补齐本能 = 方法是学习补齐本能方法(目标方法);
    if (!私有_方法当前可用_执行桥_最小_v0(目标方法, now)
        && 返回方法状态可用性缺口(结果, 任务头, 目标方法, now)) {
        return 结果;
    }
    if (私有_方法动作骨架数量_执行桥_最小_v0(目标方法) <= 0
        && 返回方法结构缺口(结果, 任务头, 目标方法, 方法缺动作骨架, now)) {
        return 结果;
    }
    if (私有_方法可执行入口数量_执行桥_最小_v0(目标方法) <= 0
        && 返回方法结构缺口(结果, 任务头, 目标方法, 方法缺可执行入口, now)) {
        return 结果;
    }
    if (!目标方法是补齐本能
        && 私有_方法条件节点数量_执行桥_最小_v0(目标方法) <= 0
        && 返回方法结构缺口(结果, 任务头, 目标方法, 方法缺条件节点, now)) {
        return 结果;
    }
    if (!目标方法是补齐本能
        && 私有_方法结果节点数量_执行桥_最小_v0(目标方法) <= 0
        && 返回方法结构缺口(结果, 任务头, 目标方法, 方法缺结果节点, now)) {
        return 结果;
    }
    if (!目标方法是补齐本能
        && 私有_方法条件结果对数量_执行桥_最小_v0(目标方法) <= 0
        && 返回方法结构缺口(结果, 任务头, 目标方法, 方法缺条件结果对, now)) {
        return 结果;
    }

    结果.回执.状况 = 方法可执行;
    (void)任务类::写入任务当前阶段(
        任务头,
        枚举_任务阶段::执行,
        任务头->主信息.场景.指针,
        now);
    if (任务类::读取任务状态(任务头) == 枚举_任务状态::未启动
        || 任务类::读取任务状态(任务头) == 枚举_任务状态::筹办中
        || 任务类::读取任务状态(任务头) == 枚举_任务状态::待重筹办
        || 任务类::读取任务状态(任务头) == 枚举_任务状态::等待中
        || 任务类::读取任务状态(任务头) == 枚举_任务状态::挂起) {
        (void)任务类::写入任务状态(
            任务头,
            枚举_任务状态::就绪,
            任务头->主信息.场景.指针,
            now);
    }
    return 结果;
}

} // namespace 任务模块::筹办
