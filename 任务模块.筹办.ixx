    std::string 任务主键_筹办日志(const 任务节点* 节点)
    {
        return 节点 ? 节点->获取主键() : std::string("空");
    }

    std::string 需求主键_筹办日志(const 需求节点* 节点)
    {
        return 节点 ? 节点->获取主键() : std::string("空");
    }

    std::string 方法主键_筹办日志(const 方法节点* 节点)
    {
        return 节点 ? 节点->获取主键() : std::string("空");
    }

    std::string 基础主键_筹办日志(const 基础信息节点类* 节点)
    {
        return 节点 ? 节点->获取主键() : std::string("空");
    }

    std::string 入口主键_筹办日志(const 语素入口节点类* 节点)
    {
        return 节点 ? 节点->获取主键() : std::string("空");
    }

    std::string 状态主键_筹办日志(const 状态节点类* 节点)
    {
        return 节点 ? 节点->获取主键() : std::string("空");
    }

    void 写入筹办回执任务建议(
        任务模块::筹办::结构_任务推进回执& 回执,
        const 枚举_任务状态 状态,
        const 枚举_任务阶段 阶段) noexcept
    {
        // 筹办层只产出“任务层回执建议”，不直接写任务虚拟存在。
        // 真正的任务状态/阶段提交由任务管理工作线程统一完成。
        回执.建议任务状态 = 状态;
        回执.建议任务阶段 = 阶段;
    }

    void 记录筹办日志(const std::string& 文本) noexcept
    {
        项目运行日志("任务筹办跟踪 | " + 文本);
    }

    状态节点类* 读取派生需求状态_从结果场景(
        场景节点类* 结果场景,
        const 语素入口节点类* 状态特征类型) noexcept
    {
        if (!结果场景 || !状态特征类型) {
            return nullptr;
        }
        void* 指针 = nullptr;
        return 世界树.读取特征_指针(
                reinterpret_cast<基础信息节点类*>(结果场景),
                状态特征类型,
                指针)
            && 指针
            ? reinterpret_cast<状态节点类*>(指针)
            : nullptr;
    }

    void 记录缺口派生目标状态(
        const char* 阶段,
        const 任务节点* 任务头,
        const 方法节点* 目标方法,
        const 语素入口节点类* 缺口特征,
        const 可解析引用<基础信息节点类>& 缺口目标主体,
        场景节点类* 结果场景) noexcept
    {
        auto* 派生当前状态 = 读取派生需求状态_从结果场景(
            结果场景,
            私有_执行输出特征_派生需求当前状态_执行桥_最小_v0());
        auto* 派生目标状态 = 读取派生需求状态_从结果场景(
            结果场景,
            私有_执行输出特征_派生需求目标状态_执行桥_最小_v0());

        std::ostringstream 输出;
        输出 << (阶段 ? 阶段 : "缺口目标状态检查")
            << " | 任务=" << 任务主键_筹办日志(任务头)
            << " | 目标方法=" << 方法主键_筹办日志(目标方法)
            << " | 缺口目标主体=" << 基础主键_筹办日志(缺口目标主体.指针)
            << " | 缺口特征=" << 入口主键_筹办日志(缺口特征)
            << " | 派生当前状态=" << 状态主键_筹办日志(派生当前状态)
            << " | 派生目标状态=" << 状态主键_筹办日志(派生目标状态);
        记录筹办日志(输出.str());

        if (!派生目标状态) {
            记录筹办日志(std::string("缺口派生目标状态缺失")
                + " | 任务=" + 任务主键_筹办日志(任务头)
                + " | 目标方法=" + 方法主键_筹办日志(目标方法)
                + " | 缺口特征=" + 入口主键_筹办日志(缺口特征)
                + " | 结果场景=" + 基础主键_筹办日志(reinterpret_cast<基础信息节点类*>(结果场景)));
        }
    }

    void 写入方法节点引用(可解析引用<方法节点类>& 输出, 方法节点* 节点) noexcept
    {
        输出.指针 = reinterpret_cast<方法节点类*>(节点);
        输出.主键 = 节点 ? 节点->获取主键() : std::string{};
    }

    void 写入任务节点引用(可解析引用<任务节点类>& 输出, 任务节点* 节点) noexcept
    {
        输出.指针 = reinterpret_cast<任务节点类*>(节点);
        输出.主键 = 节点 ? 节点->获取主键() : std::string{};
    }

    void 写入需求节点引用(可解析引用<需求节点类>& 输出, 需求节点* 节点) noexcept
    {
        输出.指针 = reinterpret_cast<需求节点类*>(节点);
        输出.主键 = 节点 ? 节点->获取主键() : std::string{};
    }

    void 写入基础节点引用(可解析引用<基础信息节点类>& 输出, 基础信息节点类* 节点) noexcept
    {
        输出.指针 = 节点;
        输出.主键 = 节点 ? 节点->获取主键() : std::string{};
    }

    void 写入场景节点引用(可解析引用<场景节点类>& 输出, 场景节点类* 节点) noexcept
    {
        输出.指针 = 节点;
        输出.主键 = 节点 ? 节点->获取主键() : std::string{};
    }

    任务节点* 归一到任务头结点(任务节点* 节点) noexcept
    {
        auto* 当前 = 节点;
        while (当前) {
            if (任务类::读取任务节点种类(当前) == 枚举_任务节点种类::头结点) {
                return 当前;
            }
            当前 = static_cast<任务节点*>(当前->父);
        }
        return nullptr;
    }

    需求节点* 任务来源需求(const 任务节点* 任务头) noexcept
    {
        if (!任务头) {
            return nullptr;
        }
        if (任务头->主信息.对应需求.指针) {
            return reinterpret_cast<需求节点*>(任务头->主信息.对应需求.指针);
        }
        if (!任务头->主信息.对应需求.主键.empty()) {
            if (auto* 节点 = 世界树.基础信息().查找主键(任务头->主信息.对应需求.主键)) {
                return reinterpret_cast<需求节点*>(节点);
            }
        }
        return nullptr;
    }

    const 状态节点主信息类* 状态主信息(const 状态节点类* 状态节点) noexcept
    {
        return 状态节点
            ? 世界树.状态().取状态主信息(const_cast<状态节点类*>(状态节点))
            : nullptr;
    }

    const 语素入口节点类* 状态节点目标特征类型(const 状态节点类* 状态节点) noexcept
    {
        const auto* 主信息 = 状态主信息(状态节点);
        if (!主信息 || !主信息->状态特征.指针) {
            return nullptr;
        }
        const auto* 特征主信息 =
            dynamic_cast<const 特征节点主信息类*>(主信息->状态特征.指针->主信息);
        return 特征主信息 ? 特征主信息->类型 : nullptr;
    }

    基础信息节点类* 状态节点主体(const 状态节点类* 状态节点) noexcept
    {
        const auto* 主信息 = 状态主信息(状态节点);
        return 主信息 ? 主信息->状态主体.指针 : nullptr;
    }

    bool 状态节点I64值(const 状态节点类* 状态节点, I64& 输出值) noexcept
    {
        输出值 = 0;
        const auto* 主信息 = 状态主信息(状态节点);
        if (!主信息) {
            return false;
        }
        if (const auto* 标量 = std::get_if<I64>(&主信息->状态值)) {
            输出值 = *标量;
            return true;
        }
        return false;
    }

    bool 状态节点I64区间(const 状态节点类* 状态节点, I64区间& 输出区间) noexcept
    {
        输出区间 = I64区间{ 0, -1 };
        const auto* 主信息 = 状态主信息(状态节点);
        if (!主信息 || !主信息->状态特征.指针) {
            return false;
        }

        const auto* 特征主信息 =
            dynamic_cast<const 特征节点主信息类*>(主信息->状态特征.指针->主信息);
        if (!特征主信息) {
            return false;
        }

        if (特征主信息->局部区间覆盖.has_value()
            && 特征主信息->局部区间覆盖->有效()) {
            输出区间 = *特征主信息->局部区间覆盖;
            return true;
        }
        if (特征主信息->区间.has_value()
            && 特征主信息->区间->有效()) {
            输出区间 = *特征主信息->区间;
            return true;
        }

        const auto 读取抽象区间 =
            [&](const 基础信息节点类* 抽象节点, I64区间& 区间) noexcept -> bool {
            const auto* 抽象主信息 = 抽象节点
                ? dynamic_cast<const 抽象特征主信息类*>(抽象节点->主信息)
                : nullptr;
            if (抽象主信息
                && 抽象主信息->区间.has_value()
                && 抽象主信息->区间->有效()) {
                区间 = *抽象主信息->区间;
                return true;
            }
            return false;
        };

        if (读取抽象区间(特征主信息->当前命中抽象特征.指针, 输出区间)) {
            return true;
        }
        return 读取抽象区间(特征主信息->抽象特征.指针, 输出区间);
    }

    std::int32_t 需求目标方向编码(const 需求节点* 来源需求) noexcept
    {
        if (!来源需求) {
            return 0;
        }

        需求类 需求服务{};
        auto* 方向节点 = 需求服务.获取需求方向(const_cast<需求节点*>(来源需求));
        const auto* 方向主信息 = 方向节点
            ? dynamic_cast<const 二次特征主信息类*>(方向节点->主信息)
            : nullptr;
        if (!方向主信息) {
            return 0;
        }
        if (方向主信息->方向区间 != 二次特征主信息类::枚举_方向区间::未定义) {
            return 二次特征主信息类::方向区间编码(方向主信息->方向区间);
        }
        if (方向主信息->差值.has_value()) {
            return 二次特征主信息类::方向区间编码(
                二次特征主信息类::由差值判断方向区间(*方向主信息->差值));
        }
        if (方向主信息->值形态 == 枚举_二次特征值形态::枚举
            && 方向主信息->离散编码 >= -1
            && 方向主信息->离散编码 <= 1) {
            return 方向主信息->离散编码;
        }
        if (方向主信息->值形态 == 枚举_二次特征值形态::布尔) {
            return 方向主信息->是否满足 ? 1 : 0;
        }
        return 0;
    }

    bool 需求目标要求正值(const 需求节点* 来源需求) noexcept
    {
        if (!来源需求) {
            return false;
        }

        I64 点值 = 0;
        if (状态节点I64值(来源需求->主信息.需求状态.指针, 点值)) {
            return 点值 > 0;
        }

        I64区间 区间{};
        if (状态节点I64区间(来源需求->主信息.需求状态.指针, 区间)) {
            return 区间.低值 > 0;
        }

        return 需求目标方向编码(来源需求) > 0;
    }

    bool 需求目标要求至少(const 需求节点* 来源需求, I64 阈值) noexcept
    {
        if (!来源需求) {
            return false;
        }

        I64 点值 = 0;
        if (状态节点I64值(来源需求->主信息.需求状态.指针, 点值)) {
            return 点值 >= 阈值;
        }

        I64区间 区间{};
        if (状态节点I64区间(来源需求->主信息.需求状态.指针, 区间)) {
            return 区间.低值 >= 阈值;
        }

        return false;
    }

    bool 语素入口同一(const 语素入口节点类* 左, const 语素入口节点类* 右) noexcept
    {
        if (!左 || !右) {
            return false;
        }
        if (左 == 右) {
            return true;
        }
        const auto 左主键 = 左->获取主键();
        return !左主键.empty() && 左主键 == 右->获取主键();
    }

    const 语素入口节点类* 需求目标特征类型(const 需求节点* 需求) noexcept
    {
        return 需求 ? 状态节点目标特征类型(需求->主信息.需求状态.指针) : nullptr;
    }

    const 语素入口节点类* 任务对应需求目标特征类型(const 任务节点* 任务头) noexcept
    {
        return 需求目标特征类型(任务来源需求(任务头));
    }

    bool 需求已满足(const 需求节点* 需求) noexcept
    {
        if (!需求) {
            return false;
        }
        auto* 当前状态 = 需求->主信息.被需求当前状态.指针;
        auto* 目标状态 = 需求->主信息.需求状态.指针;
        if (当前状态 && 目标状态) {
            const auto 比较 = 世界树.特征().比较状态(当前状态, 目标状态);
            return 比较.可比较
                && 三向关系被接受(比较.关系, 需求->主信息.满足关系);
        }
        const auto& 当前主键 = 需求->主信息.被需求当前状态.主键;
        const auto& 目标主键 = 需求->主信息.需求状态.主键;
        return !当前主键.empty()
            && 当前主键 == 目标主键
            && 三向关系被接受(枚举_三向关系::等于, 需求->主信息.满足关系);
    }

    bool 存在活动直接子需求(const 需求节点* 需求) noexcept
    {
        if (!需求 || !需求->子) {
            return false;
        }
        auto* 首子 = reinterpret_cast<需求节点*>(需求->子);
        auto* 当前 = 首子;
        std::size_t 保护计数 = 0;
        do {
            if (当前
                && 当前->主信息.需求有效截止 == 0
                && 当前->主信息.是否阻塞父任务执行
                && !需求已满足(当前)) {
                return true;
            }
            当前 = reinterpret_cast<需求节点*>(当前 ? 当前->下 : nullptr);
            ++保护计数;
        } while (当前 && 当前 != 首子 && 保护计数 < 10000);
        return false;
    }

    I64 方法自我能力值(const 方法节点* 方法) noexcept
    {
        if (!方法
            || 方法->主信息.首节点信息().动作句柄.类型 != 枚举_动作句柄类型::本能函数ID) {
            return 0;
        }
        const I64 能力值 = 方法->主信息.首节点信息().动作句柄.本能ID;
        return 本能方法类::是有效本能方法能力值(能力值) ? 能力值 : 0;
    }

    枚举_本能方法ID 方法本能ID(const 方法节点* 方法) noexcept
    {
        const I64 能力值 = 方法自我能力值(方法);
        return 能力值 != 0
            ? static_cast<枚举_本能方法ID>(能力值)
            : 枚举_本能方法ID::未定义;
    }

    inline constexpr I64 历史本能方法ID_任务筹办 = 6062;
    inline constexpr I64 历史本能方法ID_任务执行 = 6063;

    I64 方法原始本能ID值(const 方法节点* 方法) noexcept
    {
        if (!方法
            || 方法->主信息.首节点信息().动作句柄.类型 != 枚举_动作句柄类型::本能函数ID
            || 方法->主信息.首节点信息().动作句柄.本能ID == 0) {
            return 0;
        }
        return 方法->主信息.首节点信息().动作句柄.本能ID;
    }

    bool 方法是本能方法(const 方法节点* 方法, 枚举_本能方法ID 本能ID) noexcept
    {
        return 方法本能ID(方法) == 本能ID;
    }

    bool 方法是学习补齐本能方法(const 方法节点* 方法) noexcept
    {
        const auto 本能ID = 方法本能ID(方法);
        return 本能ID == 枚举_本能方法ID::自我_尝试学习
            || 本能ID == 枚举_本能方法ID::自我_定向学习
            || 本能ID == 枚举_本能方法ID::自我_练习;
    }

    bool 方法是历史任务生命周期方法残留(const 方法节点* 方法) noexcept
    {
        // 任务筹办 / 任务执行已迁为任务管理生命周期普通函数；历史方法树中若残留
        // 6062 / 6063 方法头，也必须从任务候选集中排除。这里保留私有数值
        // 兼容历史数据，但不再把它们公开为当前本能方法枚举。
        const auto 本能ID = 方法原始本能ID值(方法);
        return 本能ID == 历史本能方法ID_任务筹办
            || 本能ID == 历史本能方法ID_任务执行;
    }

    bool 方法是筹办过程或协作本能方法(const 方法节点* 方法) noexcept
    {
        const auto 本能ID = 方法本能ID(方法);
        return 本能ID == 枚举_本能方法ID::自我_查找候选方法
            || 本能ID == 枚举_本能方法ID::自我_选择当前方法
            || 本能ID == 枚举_本能方法ID::自我_检查方法条件是否满足
            || 本能ID == 枚举_本能方法ID::自我_尝试学习
            || 本能ID == 枚举_本能方法ID::自我_定向学习
            || 本能ID == 枚举_本能方法ID::自我_练习
            || 本能ID == 枚举_本能方法ID::自我_建立条件结果对
            || 本能ID == 枚举_本能方法ID::自我_提交方法状态变化;
    }

    bool 任务目标是方法结构补齐需求(const 任务节点* 任务头) noexcept
    {
        const auto* 目标特征类型 = 任务对应需求目标特征类型(任务头);
        return 语素入口同一(目标特征类型, 私有_方法状态特征类型_执行桥_最小_v0())
            || 语素入口同一(目标特征类型, 私有_方法稳定状态特征类型_执行桥_最小_v0())
            || 语素入口同一(目标特征类型, 私有_方法运行账完整性特征类型_执行桥_最小_v0())
            || 语素入口同一(目标特征类型, 私有_方法动作骨架状态特征类型_执行桥_最小_v0())
            || 语素入口同一(目标特征类型, 私有_方法动作骨架数量特征类型_执行桥_最小_v0())
            || 语素入口同一(目标特征类型, 私有_方法可执行入口数量特征类型_执行桥_最小_v0())
            || 语素入口同一(目标特征类型, 私有_方法条件节点数量特征类型_执行桥_最小_v0())
            || 语素入口同一(目标特征类型, 私有_方法结果节点数量特征类型_执行桥_最小_v0())
            || 语素入口同一(目标特征类型, 私有_方法条件结果配对状态特征类型_执行桥_最小_v0());
    }

    枚举_本能方法ID 学习本能ID_按需求目标结果(const 任务节点* 任务头) noexcept
    {
        const auto* 来源需求 = 任务来源需求(任务头);
        const auto* 目标特征类型 = 任务对应需求目标特征类型(任务头);

        // 需求目标按“点值 > 区间 > 方向”的粒度判定；越细的约束越优先。
        // 方法状态可用这种阶段目标不能只靠方向推断，必须有点值或区间明确命中。
        if (语素入口同一(目标特征类型, 私有_方法稳定状态特征类型_执行桥_最小_v0())
            || 语素入口同一(目标特征类型, 私有_方法运行账完整性特征类型_执行桥_最小_v0())) {
            if (!需求目标要求正值(来源需求)) {
                return 枚举_本能方法ID::未定义;
            }
            return 枚举_本能方法ID::自我_练习;
        }

        if (语素入口同一(目标特征类型, 私有_方法状态特征类型_执行桥_最小_v0())
            && 需求目标要求至少(来源需求, 私有_方法状态_可用_执行桥_最小_v0())) {
            return 枚举_本能方法ID::自我_尝试学习;
        }

        if (语素入口同一(目标特征类型, 私有_方法条件结果配对状态特征类型_执行桥_最小_v0())) {
            if (!需求目标要求正值(来源需求)) {
                return 枚举_本能方法ID::未定义;
            }
            return 枚举_本能方法ID::自我_尝试学习;
        }

        // 定向学习只承接显式动作缺口；方法状态中间值不能隐式改写成“缺动作”。
        if (语素入口同一(目标特征类型, 私有_方法动作骨架状态特征类型_执行桥_最小_v0())
            || 语素入口同一(目标特征类型, 私有_方法动作骨架数量特征类型_执行桥_最小_v0())
            || 语素入口同一(目标特征类型, 私有_方法可执行入口数量特征类型_执行桥_最小_v0())) {
            if (!需求目标要求正值(来源需求)) {
                return 枚举_本能方法ID::未定义;
            }
            return 枚举_本能方法ID::自我_定向学习;
        }

        return 枚举_本能方法ID::未定义;
    }

    方法节点* 按方法虚拟存在查找方法(
        自我类& 自我对象,
        基础信息节点类* 方法虚拟存在,
        时间戳 now) noexcept
    {
        auto* 自我存在 = 自我对象.确保自我存在();
        auto* 方法根节点 = 自我存在 ? 世界树.存在().获取方法根节点(自我存在) : nullptr;
        if (!方法根节点 || !方法根节点->子 || !方法虚拟存在) {
            return nullptr;
        }

        auto* 首节点 = static_cast<方法节点*>(方法根节点->子);
        auto* 当前 = 首节点;
        std::size_t 保护计数 = 0;
        do {
            if (当前 && 当前->主信息.节点种类() == 枚举_方法节点种类::方法首节点) {
                auto* 当前虚拟存在 = 当前->主信息.首节点信息().方法虚拟存在.指针
                    ? 当前->主信息.首节点信息().方法虚拟存在.指针
                    : 方法虚拟存在服务类::取或创建方法虚拟存在(当前, 自我存在, now);
                if (当前虚拟存在 == 方法虚拟存在
                    || (当前虚拟存在
                        && !当前虚拟存在->获取主键().empty()
                        && 当前虚拟存在->获取主键() == 方法虚拟存在->获取主键())) {
                    return 当前;
                }
            }
            当前 = static_cast<方法节点*>(当前->下);
            ++保护计数;
        } while (当前 && 当前 != 首节点 && 保护计数 < 4096);
        return nullptr;
    }

    struct 结构_方法选择评分 {
        I64 直接满足等级 = 0;
        I64 禁止项惩罚 = 0;
        I64 风险惩罚 = 0;
        I64 前置冲突惩罚 = 0;
        I64 效率分 = 0;
        I64 耗时惩罚 = 0;
        I64 能耗惩罚 = 0;
        I64 资源惩罚 = 0;
        I64 副作用惩罚 = 0;
        I64 可补齐等级 = 0;
        I64 不确定性惩罚 = 0;
        I64 稳定性分 = 0;
        bool 有效 = false;
    };

    bool 方法选择评分更优(
        const 结构_方法选择评分& 左,
        const 结构_方法选择评分& 右) noexcept
    {
        if (左.有效 != 右.有效) return 左.有效;
        if (左.直接满足等级 != 右.直接满足等级) return 左.直接满足等级 > 右.直接满足等级;
        if (左.禁止项惩罚 != 右.禁止项惩罚) return 左.禁止项惩罚 < 右.禁止项惩罚;
        if (左.风险惩罚 != 右.风险惩罚) return 左.风险惩罚 < 右.风险惩罚;
        if (左.前置冲突惩罚 != 右.前置冲突惩罚) return 左.前置冲突惩罚 < 右.前置冲突惩罚;
        if (左.效率分 != 右.效率分) return 左.效率分 > 右.效率分;
        if (左.耗时惩罚 != 右.耗时惩罚) return 左.耗时惩罚 < 右.耗时惩罚;
        if (左.能耗惩罚 != 右.能耗惩罚) return 左.能耗惩罚 < 右.能耗惩罚;
        if (左.资源惩罚 != 右.资源惩罚) return 左.资源惩罚 < 右.资源惩罚;
        if (左.副作用惩罚 != 右.副作用惩罚) return 左.副作用惩罚 < 右.副作用惩罚;
        if (左.可补齐等级 != 右.可补齐等级) return 左.可补齐等级 > 右.可补齐等级;
        if (左.不确定性惩罚 != 右.不确定性惩罚) return 左.不确定性惩罚 < 右.不确定性惩罚;
        return 左.稳定性分 > 右.稳定性分;
    }

    std::string 方法选择评分文本(const 结构_方法选择评分& 评分)
    {
        std::ostringstream 输出;
        输出 << "直接=" << 评分.直接满足等级
            << ",禁=" << 评分.禁止项惩罚
            << ",险=" << 评分.风险惩罚
            << ",冲突=" << 评分.前置冲突惩罚
            << ",效率=" << 评分.效率分
            << ",耗时=" << 评分.耗时惩罚
            << ",能耗=" << 评分.能耗惩罚
            << ",资源=" << 评分.资源惩罚
            << ",副作用=" << 评分.副作用惩罚
            << ",可补=" << 评分.可补齐等级
            << ",不确定=" << 评分.不确定性惩罚
            << ",稳定=" << 评分.稳定性分;
        return 输出.str();
    }

    结构_方法选择评分 方法候选评分(任务节点* 任务头, 方法节点* 方法) noexcept
    {
        结构_方法选择评分 评分{};
        if (!方法 || 方法->主信息.节点种类() != 枚举_方法节点种类::方法首节点) {
            return 评分;
        }

        const bool 有本能入口 = 方法自我能力值(方法) != 0;
        const bool 有动作 =
            有本能入口
            || 方法->主信息.有动作骨架()
            || 私有_方法动作骨架数量_执行桥_最小_v0(方法) > 0;
        const bool 有入口 =
            有本能入口
            || 私有_方法可执行入口数量_执行桥_最小_v0(方法) > 0;
        const bool 有条件节点 = 私有_方法条件节点数量_执行桥_最小_v0(方法) > 0;
        const bool 有结果节点 = 私有_方法结果节点数量_执行桥_最小_v0(方法) > 0;
        const bool 有条件结果对 = 私有_方法条件结果对数量_执行桥_最小_v0(方法) > 0;
        const bool 是过程本能 = 方法是筹办过程或协作本能方法(方法);
        const bool 是学习本能 = 方法是学习补齐本能方法(方法);
        const bool 是方法结构任务 = 任务目标是方法结构补齐需求(任务头);

        评分.有效 = true;

        // 第一层：所有可直接执行条件都满足的方法优先。
        // 这里先用结构可用性近似“必需条件全部满足”；具体输入参数仍在后续
        // 检查方法条件 / 配对参数阶段验证，不能在选择阶段提前提交事实。
        if (!是过程本能 && 有动作 && 有入口 && 有条件节点 && 有结果节点 && 有条件结果对) {
            评分.直接满足等级 = 300;
        } else if (是过程本能 && 有动作 && 有入口) {
            // 过程本能方法只说明“可以推进筹办过程”，不是最终状态提交者。
            // 因此它低于直接可执行方法，但高于普通不可用方法。
            评分.直接满足等级 = 100;
        } else if (有动作 && 有入口) {
            评分.直接满足等级 = 20;
        } else if (有动作) {
            评分.直接满足等级 = 10;
        }

        // 第二层到第四层的真实禁止项、风险、能耗以后应从方法条件节点、
        // 禁止结果、资源账读取。当前没有稳定字段时保持 0，避免臆造约束。
        评分.禁止项惩罚 = 0;
        评分.风险惩罚 = 0;
        评分.前置冲突惩罚 = 0;
        评分.耗时惩罚 = 0;
        评分.能耗惩罚 = 0;
        评分.资源惩罚 = 0;
        评分.副作用惩罚 = 0;

        // 效率和稳定性先用已有结构成熟度、条件结果对数量和本能入口作保守近似。
        评分.效率分 =
            方法->主信息.首节点信息().成熟度阶段 * 100
            + 私有_方法条件结果对数量_执行桥_最小_v0(方法) * 10
            + (有本能入口 ? 50 : 0);
        评分.稳定性分 =
            方法->主信息.首节点信息().成熟度阶段 * 100
            + 私有_方法条件结果对数量_执行桥_最小_v0(方法) * 20;

        // 第五层：没有直接可执行方法时，再选能把条件变得可具备的方法。
        if (是方法结构任务 && 是学习本能) {
            评分.可补齐等级 = 900;
        } else if (是过程本能) {
            评分.可补齐等级 = 500;
        } else if (有动作 || 有入口) {
            评分.可补齐等级 = 100;
        }

        评分.不确定性惩罚 = 0;
        return 评分;
    }

    方法节点* 从任务候选集中选择当前方法(
        自我类& 自我对象,
        任务节点* 任务头,
        时间戳 now) noexcept
    {
        if (!任务头) {
            return nullptr;
        }

        auto 候选虚拟存在集 = 任务类::读取任务方法候选虚拟存在集(
            任务头,
            任务头->主信息.场景.指针);
        if (候选虚拟存在集.empty()) {
            return nullptr;
        }

        auto* 已绑定方法 = reinterpret_cast<方法节点*>(任务类::读取任务执行方法(任务头));
        (void)已绑定方法;

        方法节点* 最佳方法 = nullptr;
        结构_方法选择评分 最佳评分{};
        for (auto* 方法虚拟存在 : 候选虚拟存在集) {
            auto* 方法 = 按方法虚拟存在查找方法(
                自我对象,
                reinterpret_cast<基础信息节点类*>(方法虚拟存在),
                now);

            // 旧数据残留的任务筹办 / 任务执行方法头只作兼容识别，不参与候选选择。
            if (方法是历史任务生命周期方法残留(方法)) {
                记录筹办日志("选择当前方法跳过任务生命周期方法残留"
                    " | 任务=" + 任务主键_筹办日志(任务头)
                    + " | 方法=" + 方法主键_筹办日志(方法));
                continue;
            }

            const auto 分数 = 方法候选评分(任务头, 方法);
            {
                std::ostringstream 输出;
                输出 << "选择当前方法候选评分"
                    << " | 任务=" << 任务主键_筹办日志(任务头)
                    << " | 方法=" << 方法主键_筹办日志(方法)
                    << " | 评分=" << 方法选择评分文本(分数);
                记录筹办日志(输出.str());
            }
            if (方法 && (!最佳方法 || 方法选择评分更优(分数, 最佳评分))) {
                最佳方法 = 方法;
                最佳评分 = 分数;
            }
        }
        if (最佳方法) {
            std::ostringstream 输出;
            输出 << "选择当前方法完成"
                << " | 任务=" << 任务主键_筹办日志(任务头)
                << " | 方法=" << 方法主键_筹办日志(最佳方法)
                << " | 评分=" << 方法选择评分文本(最佳评分);
            记录筹办日志(输出.str());
        }
        return 最佳方法;
    }

    方法节点* 任务方法结构补齐目标方法(
        自我类& 自我对象,
        const 任务节点* 任务头,
        时间戳 now) noexcept
    {
        if (!任务头 || !任务目标是方法结构补齐需求(任务头)) {
            return nullptr;
        }
        const auto* 来源需求 = 任务来源需求(任务头);
        auto* 目标主体 = 来源需求 ? 状态节点主体(来源需求->主信息.需求状态.指针) : nullptr;
        if (!目标主体 && 来源需求) {
            目标主体 = 状态节点主体(来源需求->主信息.被需求当前状态.指针);
        }
        if (!目标主体 && 来源需求 && 来源需求->主信息.被需求存在.指针) {
            目标主体 = reinterpret_cast<基础信息节点类*>(来源需求->主信息.被需求存在.指针);
        }
        return 按方法虚拟存在查找方法(自我对象, 目标主体, now);
    }

