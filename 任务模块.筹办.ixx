export module 任务模块.筹办;

import 自我类;
import 任务模块.执行;

export namespace 任务模块::筹办 {

enum class 枚举_任务推进阶段 : std::uint8_t {
    未定义 = 0,
    筹办 = 1,
    执行 = 2,
};

enum class 枚举_任务推进状况 : std::uint8_t {
    未定义 = 0,

    父需求已满足 = 1,
    存在活动子需求 = 2,

    方法查找未命中 = 10,
    已建立方法头待重入 = 11,
    方法缺动作骨架 = 12,
    方法缺可执行入口 = 13,
    方法缺条件节点 = 14,
    方法缺结果节点 = 15,
    方法缺条件结果对 = 16,
    参数不可配 = 17,
    方法运行账不足 = 18,
    方法结果不稳定 = 19,
    方法可执行 = 20,

    动作执行失败 = 30,
    动作执行成功无可比较结果 = 31,
    目标结果符合 = 32,
    目标结果不符合 = 33,
    出现需要附带结果 = 34,
    出现不需要附带结果 = 35,
    出现禁止结果 = 36,
};

struct 结构_任务推进回执 {
    枚举_任务推进阶段 阶段 = 枚举_任务推进阶段::未定义;
    枚举_任务推进状况 状况 = 枚举_任务推进状况::未定义;

    可解析引用<任务节点类> 当前任务{};
    可解析引用<需求节点类> 对应需求{};
    可解析引用<方法节点类> 当前方法{};
    可解析引用<基础信息节点类> 缺口目标主体{};

    const 语素入口节点类* 目标特征类型 = nullptr;
    三向关系掩码 目标满足关系 = 关系_等于;

    const 语素入口节点类* 缺口特征类型 = nullptr;
    三向关系掩码 缺口满足关系 = 关系_等于;

    std::vector<可解析引用<状态节点类>> 实际结果状态集{};
    std::vector<可解析引用<状态节点类>> 禁止结果状态集{};
    std::vector<可解析引用<状态节点类>> 需要附带结果状态集{};

    bool 需要自我线程 = false;
    bool 父任务需要重筹办 = false;
    bool 需要创建或复用子需求 = false;
    bool 当前任务目标达成 = false;
    bool 治理结果可接受 = true;

    std::string 摘要{};
};

struct 结构_任务筹办结果 {
    bool 已执行筹办 = false;
    bool 已绑定方法 = false;
    bool 已创建目标方法头 = false;
    bool 已建立方法头待重入 = false;
    bool 缺少任务 = false;
    bool 缺少需求目标 = false;
    特征节点类* 方法运行结果 = nullptr;
    场景节点类* 结果场景 = nullptr;
    结构_任务推进回执 回执{};
    std::string 说明{};
};

} // namespace 任务模块::筹办

namespace {
    using 方法节点 = 方法类::节点类;
    using 任务节点 = 任务类::节点类;
    using 需求节点 = 需求类::节点类;

    void 写入方法节点引用(可解析引用<方法节点类>& 输出, 方法节点* 节点) noexcept
    {
        输出.指针 = reinterpret_cast<方法节点类*>(节点);
        输出.主键 = 节点 ? 节点->获取主键() : std::string{};
    }

    void 写入任务节点引用(可解析引用<任务节点类>& 输出, 任务节点* 节点) noexcept
    {
        输出.指针 = reinterpret_cast<任务节点类*>(节点);
        输出.主键 = 节点 ? 节点->获取主键() : std::string{};
    }

    void 写入需求节点引用(可解析引用<需求节点类>& 输出, 需求节点* 节点) noexcept
    {
        输出.指针 = reinterpret_cast<需求节点类*>(节点);
        输出.主键 = 节点 ? 节点->获取主键() : std::string{};
    }

    void 写入基础节点引用(可解析引用<基础信息节点类>& 输出, 基础信息节点类* 节点) noexcept
    {
        输出.指针 = 节点;
        输出.主键 = 节点 ? 节点->获取主键() : std::string{};
    }

    任务节点* 归一到任务头结点(任务节点* 节点) noexcept
    {
        auto* 当前 = 节点;
        while (当前) {
            if (任务类::读取任务节点种类(当前) == 枚举_任务节点种类::头结点) {
                return 当前;
            }
            当前 = static_cast<任务节点*>(当前->父);
        }
        return nullptr;
    }

    需求节点* 任务来源需求(const 任务节点* 任务头) noexcept
    {
        if (!任务头) {
            return nullptr;
        }
        if (任务头->主信息.对应需求.指针) {
            return reinterpret_cast<需求节点*>(任务头->主信息.对应需求.指针);
        }
        if (!任务头->主信息.对应需求.主键.empty()) {
            if (auto* 节点 = 世界树.基础信息().查找主键(任务头->主信息.对应需求.主键)) {
                return reinterpret_cast<需求节点*>(节点);
            }
        }
        return nullptr;
    }

    const 状态节点主信息类* 状态主信息(const 状态节点类* 状态节点) noexcept
    {
        return 状态节点
            ? 世界树.状态().取状态主信息(const_cast<状态节点类*>(状态节点))
            : nullptr;
    }

    const 语素入口节点类* 状态节点目标特征类型(const 状态节点类* 状态节点) noexcept
    {
        const auto* 主信息 = 状态主信息(状态节点);
        if (!主信息 || !主信息->状态特征.指针) {
            return nullptr;
        }
        const auto* 特征主信息 =
            dynamic_cast<const 特征节点主信息类*>(主信息->状态特征.指针->主信息);
        return 特征主信息 ? 特征主信息->类型 : nullptr;
    }

    基础信息节点类* 状态节点主体(const 状态节点类* 状态节点) noexcept
    {
        const auto* 主信息 = 状态主信息(状态节点);
        return 主信息 ? 主信息->状态主体.指针 : nullptr;
    }

    bool 语素入口同一(const 语素入口节点类* 左, const 语素入口节点类* 右) noexcept
    {
        if (!左 || !右) {
            return false;
        }
        if (左 == 右) {
            return true;
        }
        const auto 左主键 = 左->获取主键();
        return !左主键.empty() && 左主键 == 右->获取主键();
    }

    const 语素入口节点类* 需求目标特征类型(const 需求节点* 需求) noexcept
    {
        return 需求 ? 状态节点目标特征类型(需求->主信息.需求状态.指针) : nullptr;
    }

    const 语素入口节点类* 任务对应需求目标特征类型(const 任务节点* 任务头) noexcept
    {
        return 需求目标特征类型(任务来源需求(任务头));
    }

    二次特征节点类* 任务需求方向(const 任务节点* 任务头) noexcept
    {
        auto* 来源需求 = const_cast<需求节点*>(任务来源需求(任务头));
        if (!来源需求) {
            return nullptr;
        }
        需求类 需求服务{};
        return 需求服务.获取需求方向(来源需求);
    }

    bool 需求已满足(const 需求节点* 需求) noexcept
    {
        if (!需求) {
            return false;
        }
        auto* 当前状态 = 需求->主信息.被需求当前状态.指针;
        auto* 目标状态 = 需求->主信息.需求状态.指针;
        if (当前状态 && 目标状态) {
            const auto 比较 = 世界树.特征().比较状态(当前状态, 目标状态);
            return 比较.可比较
                && 三向关系被接受(比较.关系, 需求->主信息.满足关系);
        }
        const auto& 当前主键 = 需求->主信息.被需求当前状态.主键;
        const auto& 目标主键 = 需求->主信息.需求状态.主键;
        return !当前主键.empty()
            && 当前主键 == 目标主键
            && 三向关系被接受(枚举_三向关系::等于, 需求->主信息.满足关系);
    }

    bool 存在活动直接子需求(const 需求节点* 需求) noexcept
    {
        if (!需求 || !需求->子) {
            return false;
        }
        auto* 首子 = reinterpret_cast<需求节点*>(需求->子);
        auto* 当前 = 首子;
        std::size_t 保护计数 = 0;
        do {
            if (当前
                && 当前->主信息.需求有效截止 == 0
                && 当前->主信息.是否阻塞父任务执行
                && !需求已满足(当前)) {
                return true;
            }
            当前 = reinterpret_cast<需求节点*>(当前 ? 当前->下 : nullptr);
            ++保护计数;
        } while (当前 && 当前 != 首子 && 保护计数 < 10000);
        return false;
    }

    I64 方法自我能力值(const 方法节点* 方法) noexcept
    {
        if (!方法
            || 方法->主信息.首节点信息().动作句柄.类型 != 枚举_动作句柄类型::本能函数ID) {
            return 0;
        }
        const I64 能力值 = 方法->主信息.首节点信息().动作句柄.本能ID;
        return 本能方法类::是有效本能方法能力值(能力值) ? 能力值 : 0;
    }

    void 同步任务选中自我能力值(任务节点* 任务头, const 方法节点* 方法) noexcept
    {
        if (!任务头) {
            return;
        }
        if (const I64 能力值 = 方法自我能力值(方法); 能力值 != 0) {
            (void)任务类::写入任务选中自我能力值(
                任务头,
                能力值,
                任务头->主信息.场景.指针);
        }
    }

    void 追加任务方法候选(任务节点* 任务头, 方法节点* 方法, 时间戳 now) noexcept
    {
        if (!任务头 || !方法) {
            return;
        }
        auto* 方法虚拟存在 = 方法->主信息.首节点信息().方法虚拟存在.指针
            ? 方法->主信息.首节点信息().方法虚拟存在.指针
            : 方法虚拟存在服务类::取或创建方法虚拟存在(方法, nullptr, now);
        if (方法虚拟存在) {
            (void)任务类::追加任务方法候选虚拟存在(
                任务头,
                方法虚拟存在,
                任务头->主信息.场景.指针,
                now);
        }
    }

    void 绑定任务执行方法(任务节点* 任务头, 方法节点* 方法, 时间戳 now) noexcept
    {
        if (!任务头 || !方法) {
            return;
        }
        if (now == 0) {
            now = 结构体_时间戳::当前_微秒();
        }
        追加任务方法候选(任务头, 方法, now);
        (void)任务类::写入任务执行方法(
            任务头,
            reinterpret_cast<方法节点类*>(方法),
            任务头->主信息.场景.指针,
            now);
        if (auto* 方法虚拟存在 = 方法->主信息.首节点信息().方法虚拟存在.指针
                ? 方法->主信息.首节点信息().方法虚拟存在.指针
                : 方法虚拟存在服务类::取或创建方法虚拟存在(方法, nullptr, now)) {
            (void)任务类::写入任务当前方法虚拟存在(
                任务头,
                方法虚拟存在,
                任务头->主信息.场景.指针,
                now);
        }
        同步任务选中自我能力值(任务头, 方法);
    }

    bool 方法是学习补齐本能方法(const 方法节点* 方法) noexcept
    {
        if (!方法
            || 方法->主信息.首节点信息().动作句柄.类型 != 枚举_动作句柄类型::本能函数ID) {
            return false;
        }
        const auto 本能ID =
            static_cast<枚举_本能方法ID>(方法->主信息.首节点信息().动作句柄.本能ID);
        return 本能ID == 枚举_本能方法ID::自我_尝试学习
            || 本能ID == 枚举_本能方法ID::自我_定向学习
            || 本能ID == 枚举_本能方法ID::自我_练习;
    }

    bool 任务目标是方法结构补齐需求(const 任务节点* 任务头) noexcept
    {
        const auto* 目标特征类型 = 任务对应需求目标特征类型(任务头);
        return 语素入口同一(目标特征类型, 私有_方法状态特征类型_执行桥_最小_v0())
            || 语素入口同一(目标特征类型, 私有_方法稳定状态特征类型_执行桥_最小_v0())
            || 语素入口同一(目标特征类型, 私有_方法运行账完整性特征类型_执行桥_最小_v0())
            || 语素入口同一(目标特征类型, 私有_方法动作骨架状态特征类型_执行桥_最小_v0())
            || 语素入口同一(目标特征类型, 私有_方法动作骨架数量特征类型_执行桥_最小_v0())
            || 语素入口同一(目标特征类型, 私有_方法可执行入口数量特征类型_执行桥_最小_v0())
            || 语素入口同一(目标特征类型, 私有_方法条件节点数量特征类型_执行桥_最小_v0())
            || 语素入口同一(目标特征类型, 私有_方法结果节点数量特征类型_执行桥_最小_v0())
            || 语素入口同一(目标特征类型, 私有_方法条件结果配对状态特征类型_执行桥_最小_v0());
    }

    方法节点* 按方法虚拟存在查找方法(
        自我类& 自我对象,
        基础信息节点类* 方法虚拟存在,
        时间戳 now) noexcept
    {
        auto* 自我存在 = 自我对象.确保自我存在();
        auto* 方法根节点 = 自我存在 ? 世界树.存在().获取方法根节点(自我存在) : nullptr;
        if (!方法根节点 || !方法根节点->子 || !方法虚拟存在) {
            return nullptr;
        }

        auto* 首节点 = static_cast<方法节点*>(方法根节点->子);
        auto* 当前 = 首节点;
        std::size_t 保护计数 = 0;
        do {
            if (当前 && 当前->主信息.节点种类() == 枚举_方法节点种类::方法首节点) {
                auto* 当前虚拟存在 = 当前->主信息.首节点信息().方法虚拟存在.指针
                    ? 当前->主信息.首节点信息().方法虚拟存在.指针
                    : 方法虚拟存在服务类::取或创建方法虚拟存在(当前, 自我存在, now);
                if (当前虚拟存在 == 方法虚拟存在
                    || (当前虚拟存在
                        && !当前虚拟存在->获取主键().empty()
                        && 当前虚拟存在->获取主键() == 方法虚拟存在->获取主键())) {
                    return 当前;
                }
            }
            当前 = static_cast<方法节点*>(当前->下);
            ++保护计数;
        } while (当前 && 当前 != 首节点 && 保护计数 < 4096);
        return nullptr;
    }

    I64 方法候选评分(方法节点* 方法) noexcept
    {
        if (!方法 || 方法->主信息.节点种类() != 枚举_方法节点种类::方法首节点) {
            return -1;
        }

        I64 分数 = 0;
        if (私有_方法动作骨架数量_执行桥_最小_v0(方法) > 0) {
            分数 += 100000;
        }
        if (私有_方法可执行入口数量_执行桥_最小_v0(方法) > 0) {
            分数 += 100000;
        }
        if (私有_方法条件节点数量_执行桥_最小_v0(方法) > 0) {
            分数 += 50000;
        }
        if (私有_方法结果节点数量_执行桥_最小_v0(方法) > 0) {
            分数 += 50000;
        }
        if (私有_方法条件结果对数量_执行桥_最小_v0(方法) > 0) {
            分数 += 50000;
        }
        if (方法是学习补齐本能方法(方法)) {
            分数 += 10000;
        }
        if (方法自我能力值(方法) != 0) {
            分数 += 5000;
        }
        分数 += 方法->主信息.首节点信息().成熟度阶段 * 100;
        return 分数;
    }

    方法节点* 从任务候选集中选择当前方法(
        自我类& 自我对象,
        任务节点* 任务头,
        时间戳 now) noexcept
    {
        if (!任务头) {
            return nullptr;
        }

        auto 候选虚拟存在集 = 任务类::读取任务方法候选虚拟存在集(
            任务头,
            任务头->主信息.场景.指针);
        if (候选虚拟存在集.empty()) {
            return nullptr;
        }

        方法节点* 最佳方法 = nullptr;
        I64 最佳分数 = -1;
        for (auto* 方法虚拟存在 : 候选虚拟存在集) {
            auto* 方法 = 按方法虚拟存在查找方法(
                自我对象,
                reinterpret_cast<基础信息节点类*>(方法虚拟存在),
                now);
            const I64 分数 = 方法候选评分(方法);
            if (方法 && (!最佳方法 || 分数 > 最佳分数)) {
                最佳方法 = 方法;
                最佳分数 = 分数;
            }
        }
        return 最佳方法;
    }

    方法节点* 任务方法结构补齐目标方法(
        自我类& 自我对象,
        const 任务节点* 任务头,
        时间戳 now) noexcept
    {
        if (!任务头 || !任务目标是方法结构补齐需求(任务头)) {
            return nullptr;
        }
        const auto* 来源需求 = 任务来源需求(任务头);
        auto* 目标主体 = 来源需求 ? 状态节点主体(来源需求->主信息.需求状态.指针) : nullptr;
        if (!目标主体 && 来源需求) {
            目标主体 = 状态节点主体(来源需求->主信息.被需求当前状态.指针);
        }
        if (!目标主体 && 来源需求 && 来源需求->主信息.被需求存在.指针) {
            目标主体 = reinterpret_cast<基础信息节点类*>(来源需求->主信息.被需求存在.指针);
        }
        return 按方法虚拟存在查找方法(自我对象, 目标主体, now);
    }

