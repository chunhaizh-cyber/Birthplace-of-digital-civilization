    void 写入方法补齐任务输入目标方法(
        任务节点* 任务头,
        方法节点* 被补方法,
        时间戳 now) noexcept
    {
        if (!任务头 || !被补方法 || !任务头->主信息.场景.指针) {
            return;
        }
        auto* 输入包 = 世界树.确保特征(
            任务头->主信息.场景.指针,
            特征_输入条件包());
        if (!输入包) {
            return;
        }
        (void)世界树.写入特征_指针(
            输入包,
            特征_目标方法头节点(),
            被补方法,
            now);
        if (auto* 来源需求 = 任务来源需求(任务头)) {
            if (auto* 目标特征类型 = 需求目标特征类型(来源需求)) {
                // 学习方法执行时以条件节点绑定输入。被补方法只说明“补谁”，
                // 目标特征类型说明“补这个方法的哪个状态/结构槽”，二者缺一不可。
                (void)世界树.写入特征_指针(
                    输入包,
                    特征_目标特征类型(),
                    目标特征类型,
                    now);
                (void)世界树.写入特征_指针(
                    输入包,
                    特征_目标抽象特征(),
                    目标特征类型,
                    now);
            }
        }
        {
            std::ostringstream 输出;
            const auto& 动作句柄 = 被补方法->主信息.首节点信息().动作句柄;
            输出 << "写入方法补齐任务目标"
                << " | 任务=" << 任务主键_筹办日志(任务头)
                << " | 被补方法=" << 方法主键_筹办日志(被补方法)
                << " | 被补方法有动作骨架=" << (被补方法->主信息.有动作骨架() ? 1 : 0)
                << " | 被补方法动作句柄有效=" << (动作句柄.有效() ? 1 : 0)
                << " | 被补方法动作句柄类型=" << static_cast<int>(动作句柄.类型)
                << " | 被补方法本能ID=" << 动作句柄.本能ID
                << " | 目标特征=" << 入口主键_筹办日志(任务对应需求目标特征类型(任务头));
            记录筹办日志(输出.str());
        }
    }

    bool 方法结果项命中目标特征(
        const 结构_方法结果项& 结果项,
        const 语素入口节点类* 目标特征类型) noexcept
    {
        if (!目标特征类型) {
            return false;
        }
        if (结果项.特征类型由参数决定) {
            return 结果项.特征类型参数 != nullptr;
        }
        return 语素入口同一(结果项.特征类型, 目标特征类型);
    }

    bool 方法结果能力命中目标特征(
        方法节点* 方法,
        const 语素入口节点类* 目标特征类型) noexcept
    {
        if (!方法
            || 方法->主信息.节点种类() != 枚举_方法节点种类::方法首节点
            || !目标特征类型) {
            return false;
        }
        auto* 首信息 = 方法->主信息.取首节点信息();
        if (!首信息
            || !首信息->能力.可被方法查找命中
            || 首信息->能力.是否根写入原语) {
            return false;
        }
        for (const auto& 结果项 : 首信息->能力.结果包.结果项集) {
            if (方法结果项命中目标特征(结果项, 目标特征类型)) {
                return true;
            }
        }
        return false;
    }

    bool 方法已有参数化结果能力(
        方法节点* 方法,
        const 语素入口节点类* 特征类型参数) noexcept
    {
        auto* 首信息 = 方法 && 方法->主信息.是否方法首节点()
            ? 方法->主信息.取首节点信息()
            : nullptr;
        if (!首信息 || !特征类型参数) {
            return false;
        }
        for (const auto& 结果项 : 首信息->能力.结果包.结果项集) {
            if (结果项.特征类型由参数决定
                && 语素入口同一(结果项.特征类型参数, 特征类型参数)) {
                return true;
            }
        }
        return false;
    }

    void 确保改变特征值方法可按任意特征召回(方法节点* 方法) noexcept
    {
        // 筹办阶段只需要方法头的大范围召回能力。这里声明“结果特征类型由输入参数决定”，
        // 真正的目标宿主、目标值和约束仍由条件节点/输入包在执行前绑定。
        auto* 首信息 = 方法 && 方法->主信息.是否方法首节点()
            ? 方法->主信息.取首节点信息()
            : nullptr;
        if (!首信息) {
            return;
        }
        首信息->能力.可被方法查找命中 = true;
        首信息->能力.是否根写入原语 = false;
        if (方法已有参数化结果能力(方法, 特征_目标特征类型())) {
            return;
        }

        结构_方法结果项 参数化结果{};
        参数化结果.特征类型由参数决定 = true;
        参数化结果.特征类型参数 = 特征_目标特征类型();
        首信息->能力.结果包.结果项集.push_back(参数化结果);
    }

    std::size_t 追加方法到任务候选集(
        自我类& 自我对象,
        任务节点* 任务头,
        方法节点* 方法,
        时间戳 now,
        const char* 来源) noexcept
    {
        if (!任务头 || !方法 || 方法->主信息.节点种类() != 枚举_方法节点种类::方法首节点) {
            return 0;
        }
        if (方法是历史任务生命周期方法残留(方法)) {
            // 任务筹办/任务执行是任务管理生命周期普通函数，由工作线程按任务状态直接调用。
            // 历史方法树中若残留对应方法头，也不能进入候选方法集。
            记录筹办日志("候选集填充跳过任务生命周期函数残留方法"
                " | 来源=" + std::string(来源 ? 来源 : "空")
                + " | 任务=" + 任务主键_筹办日志(任务头)
                + " | 方法=" + 方法主键_筹办日志(方法));
            return 0;
        }
        auto 原候选数量 = 任务类::读取任务方法候选虚拟存在集(
            任务头,
            任务头->主信息.场景.指针).size();

        auto* 自我存在 = 自我对象.确保自我存在();
        auto* 方法存在 = 方法->主信息.首节点信息().方法虚拟存在.指针
            ? 方法->主信息.首节点信息().方法虚拟存在.指针
            : 方法虚拟存在服务类::取或创建方法虚拟存在(方法, 自我存在, now);
        if (!方法存在) {
            return 0;
        }

        (void)任务类::追加任务方法候选虚拟存在(
            任务头,
            方法存在,
            任务头->主信息.场景.指针,
            now);

        const auto 新候选数量 = 任务类::读取任务方法候选虚拟存在集(
            任务头,
            任务头->主信息.场景.指针).size();
        {
            std::ostringstream 输出;
            输出 << "候选集填充"
                << " | 来源=" << (来源 ? 来源 : "空")
                << " | 任务=" << 任务主键_筹办日志(任务头)
                << " | 方法=" << 方法主键_筹办日志(方法)
                << " | 方法虚拟存在=" << 基础主键_筹办日志(reinterpret_cast<基础信息节点类*>(方法存在))
                << " | 候选数=" << 新候选数量;
            记录筹办日志(输出.str());
        }
        return 新候选数量 > 原候选数量 ? 1u : 0u;
    }

    std::size_t 填充候选集_按结果能力(
        自我类& 自我对象,
        任务节点* 任务头,
        方法节点* 方法根节点,
        const 语素入口节点类* 目标特征类型,
        时间戳 now) noexcept
    {
        if (!任务头 || !方法根节点 || !目标特征类型) {
            return 0;
        }

        std::size_t 新增数量 = 0;
        auto* 自我存在 = 自我对象.确保自我存在();
        if (auto* 改变特征值方法 = 本能方法类::查找或创建本能方法首节点(
                自我存在,
                枚举_本能方法ID::自我_改变特征值,
                now)) {
            确保改变特征值方法可按任意特征召回(改变特征值方法);
        }

        std::vector<方法节点*> 待访问{};
        std::vector<方法节点*> 已入栈{};

        const auto 已记录节点 = [&](const 方法节点* 节点) noexcept {
            for (const auto* 已记录 : 已入栈) {
                if (已记录 == 节点) {
                    return true;
                }
            }
            return false;
        };

        const auto 压入待访问 = [&](方法节点* 节点) noexcept {
            if (!节点 || 已记录节点(节点)) {
                return;
            }
            已入栈.push_back(节点);
            待访问.push_back(节点);
        };

        const auto 压入直接子链 = [&](方法节点* 父节点) noexcept {
            auto* 首子 = 父节点
                ? static_cast<方法节点*>(父节点->子)
                : nullptr;
            if (!首子) {
                return;
            }

            // 节点的兄弟链可能是环形链，也可能以空指针结束；两种情况都要安全枚举。
            auto* 当前子 = 首子;
            std::size_t 兄弟保护计数 = 0;
            do {
                压入待访问(当前子);
                当前子 = static_cast<方法节点*>(当前子->下);
                ++兄弟保护计数;
            } while (当前子 && 当前子 != 首子 && 兄弟保护计数 < 4096);

            if (兄弟保护计数 >= 4096) {
                记录筹办日志("候选集填充全树遍历兄弟链达到保护上限"
                    " | 任务=" + 任务主键_筹办日志(任务头)
                    + " | 父方法=" + 方法主键_筹办日志(父节点)
                    + " | 目标特征=" + 入口主键_筹办日志(目标特征类型));
            }
        };

        // 从方法根开始做全树遍历，而不是只看根下一层。根本身若不是方法首节点会被命中检查自然过滤。
        压入待访问(方法根节点);

        std::size_t 访问计数 = 0;
        constexpr std::size_t 访问保护上限 = 65536;
        while (!待访问.empty() && 访问计数 < 访问保护上限) {
            auto* 当前 = 待访问.back();
            待访问.pop_back();
            ++访问计数;

            if (方法结果能力命中目标特征(当前, 目标特征类型)) {
                新增数量 += 追加方法到任务候选集(
                    自我对象,
                    任务头,
                    当前,
                    now,
                    "结果能力");
            }

            压入直接子链(当前);
        }

        {
            std::ostringstream 输出;
            输出 << "候选集填充全树遍历完成"
                << " | 任务=" << 任务主键_筹办日志(任务头)
                << " | 目标特征=" << 入口主键_筹办日志(目标特征类型)
                << " | 访问节点数=" << 访问计数
                << " | 新增候选数=" << 新增数量
                << " | 达到保护上限=" << (访问计数 >= 访问保护上限 ? 1 : 0);
            记录筹办日志(输出.str());
        }

        return 新增数量;
    }

    方法节点* 任务已绑定非治理方法(
        自我类* 自我对象,
        任务节点* 任务头,
        时间戳 now) noexcept;

    void 填充任务方法候选集(
        自我类& 自我对象,
        任务节点* 任务头,
        方法节点* 方法根节点,
        时间戳 now,
        bool* 输出已新建占位方法) noexcept
    {
        if (输出已新建占位方法) {
            *输出已新建占位方法 = false;
        }
        if (!任务头 || !方法根节点) {
            return;
        }

        if (auto* 已绑定方法 = 任务已绑定非治理方法(&自我对象, 任务头, now)) {
            (void)追加方法到任务候选集(
                自我对象,
                任务头,
                已绑定方法,
                now,
                "已绑定方法");
        }

        if (任务目标是方法结构补齐需求(任务头)) {
            const auto 学习本能ID = 学习本能ID_按需求目标结果(任务头);
            {
                std::ostringstream 输出;
                输出 << "方法结构补齐需求匹配学习本能"
                    << " | 任务=" << 任务主键_筹办日志(任务头)
                    << " | 来源需求=" << 需求主键_筹办日志(任务来源需求(任务头))
                    << " | 目标特征=" << 入口主键_筹办日志(任务对应需求目标特征类型(任务头))
                    << " | 学习本能ID=" << static_cast<int>(学习本能ID);
                记录筹办日志(输出.str());
            }
            auto* 自我存在 = 自我对象.确保自我存在();

            auto* 学习方法 = 学习本能ID != 枚举_本能方法ID::未定义
                ? 本能方法类::查找或创建本能方法首节点(
                    自我存在,
                    学习本能ID,
                    now)
                : nullptr;
            if (学习方法) {
                (void)追加方法到任务候选集(
                    自我对象,
                    任务头,
                    学习方法,
                    now,
                    "方法结构补齐学习本能");
                if (auto* 被补方法 = 任务方法结构补齐目标方法(自我对象, 任务头, now)) {
                    写入方法补齐任务输入目标方法(任务头, 被补方法, now);
                    std::ostringstream 输出;
                    输出 << "写入学习目标方法"
                        << " | 任务=" << 任务主键_筹办日志(任务头)
                        << " | 学习方法=" << 方法主键_筹办日志(学习方法)
                        << " | 被补方法=" << 方法主键_筹办日志(被补方法);
                    记录筹办日志(输出.str());
                }
            } else {
                std::ostringstream 输出;
                输出 << "方法结构补齐需求未匹配学习本能"
                    << " | 任务=" << 任务主键_筹办日志(任务头)
                    << " | 来源需求=" << 需求主键_筹办日志(任务来源需求(任务头))
                    << " | 目标特征=" << 入口主键_筹办日志(任务对应需求目标特征类型(任务头));
                记录筹办日志(输出.str());
            }
            return;
        }

        const auto* 目标特征类型 = 任务对应需求目标特征类型(任务头);
        if (!目标特征类型) {
            return;
        }
        (void)填充候选集_按结果能力(
            自我对象,
            任务头,
            方法根节点,
            目标特征类型,
            now);

        const auto 候选数量 = 任务类::读取任务方法候选虚拟存在集(
            任务头,
            任务头->主信息.场景.指针).size();
        {
            std::ostringstream 输出;
            输出 << "候选集填充完成"
                << " | 对应本能方法=查找候选方法"
                << " | 任务=" << 任务主键_筹办日志(任务头)
                << " | 来源需求=" << 需求主键_筹办日志(任务来源需求(任务头))
                << " | 目标特征=" << 入口主键_筹办日志(目标特征类型)
                << " | 候选数=" << 候选数量;
            记录筹办日志(输出.str());
        }
        if (候选数量 > 0) {
            return;
        }

        const auto 原方法根子节点数 = 方法根节点->子节点数量;
        // 只有在方法树没有任何可召回候选时才创建占位方法头，并立刻写入候选集。
        auto* 目标方法 = 方法类::注册需求位方法首节点(
            方法根节点,
            目标特征类型,
            枚举_方法来源::运行时方法沉淀,
            now);
        if (!目标方法) {
            return;
        }
        if (输出已新建占位方法) {
            *输出已新建占位方法 = 方法根节点->子节点数量 > 原方法根子节点数;
        }
        写入任务节点引用(目标方法->主信息.首节点信息().来源任务, 任务头);
        (void)追加方法到任务候选集(
            自我对象,
            任务头,
            目标方法,
            now,
            "占位方法头");
        {
            std::ostringstream 输出;
            输出 << "按需求目标创建占位方法头并加入候选集"
                << " | 任务=" << 任务主键_筹办日志(任务头)
                << " | 来源需求=" << 需求主键_筹办日志(任务来源需求(任务头))
                << " | 目标特征=" << 入口主键_筹办日志(目标特征类型)
                << " | 方法=" << 方法主键_筹办日志(目标方法)
                << " | 新建=" << (输出已新建占位方法 && *输出已新建占位方法 ? 1 : 0);
            记录筹办日志(输出.str());
        }
    }

    基础信息节点类* 任务参数缺口目标主体(
        任务节点* 任务头,
        方法节点* 目标方法,
        时间戳 now) noexcept
    {
        if (!任务头 || !任务头->主信息.场景.指针) {
            return nullptr;
        }
        auto* 输入包 = 世界树.确保特征(
            任务头->主信息.场景.指针,
            特征_输入条件包());
        if (!输入包) {
            return reinterpret_cast<基础信息节点类*>(任务头->主信息.场景.指针);
        }
        if (目标方法) {
            (void)世界树.写入特征_指针(
                输入包,
                特征_目标方法头节点(),
                目标方法,
                now);
        }
        return reinterpret_cast<基础信息节点类*>(输入包);
    }

    方法节点* 任务已绑定非治理方法(
        自我类* 自我对象,
        任务节点* 任务头,
        时间戳 now) noexcept
    {
        if (!任务头) {
            return nullptr;
        }
        auto* 方法 = reinterpret_cast<方法节点*>(任务类::读取任务执行方法(任务头));
        if (!方法) {
            return nullptr;
        }
        if (自我对象
            && 任务目标是方法结构补齐需求(任务头)
            && !方法是学习补齐本能方法(方法)) {
            auto* 被补方法 = 任务方法结构补齐目标方法(*自我对象, 任务头, now);
            // 方法结构补齐任务必须由学习本能承接。旧链可能把“方法状态 / 动作骨架”等
            // 泛化方法头绑定到任务上；继续沿用会把补齐需求带偏到“方法动作骨架状态”。
            if (被补方法) {
                写入方法补齐任务输入目标方法(任务头, 被补方法, now);
            }
            return nullptr;
        }
        return 方法;
    }

    方法节点* 解析或创建任务目标方法(
        自我类& 自我对象,
        任务节点* 任务头,
        时间戳 now,
        bool* 输出已新建占位方法) noexcept
    {
        if (输出已新建占位方法) {
            *输出已新建占位方法 = false;
        }
        if (!任务头) {
            return nullptr;
        }

        auto* 自我存在 = 自我对象.确保自我存在();
        auto* 方法根节点 = 自我存在 ? 世界树.存在().获取方法根节点(自我存在) : nullptr;
        if (!方法根节点) {
            return nullptr;
        }

        // 新筹办流程：先把所有可解释的解法放入任务候选集，再从候选集中选择当前方法。
        // 这保证“改变特征值”这类参数化结果能力会先进入候选，而不是被占位方法头抢先承接。
        填充任务方法候选集(
            自我对象,
            任务头,
            方法根节点,
            now,
            输出已新建占位方法);

        if (auto* 候选选择方法 = 从任务候选集中选择当前方法(自我对象, 任务头, now)) {
            // 候选集是任务可选解法的权威入口；筹办只在候选集填充后选择当前方法。
            std::ostringstream 输出;
            输出 << "候选集填充后选择当前方法"
                << " | 对应本能方法=选择当前方法"
                << " | 任务=" << 任务主键_筹办日志(任务头)
                << " | 方法=" << 方法主键_筹办日志(候选选择方法);
            记录筹办日志(输出.str());
            return 候选选择方法;
        }
        {
            std::ostringstream 输出;
            输出 << "候选集填充后仍无当前方法"
                << " | 对应本能方法=选择当前方法"
                << " | 任务=" << 任务主键_筹办日志(任务头)
                << " | 来源需求=" << 需求主键_筹办日志(任务来源需求(任务头))
                << " | 目标特征=" << 入口主键_筹办日志(任务对应需求目标特征类型(任务头));
            记录筹办日志(输出.str());
        }
        return nullptr;
    }

    const 语素入口节点类* 筹办缺口特征类型(
        任务模块::筹办::枚举_任务推进状况 状况) noexcept
    {
        using 任务模块::筹办::枚举_任务推进状况;
        switch (状况) {
        case 枚举_任务推进状况::方法缺动作骨架:
            return 私有_方法动作骨架状态特征类型_执行桥_最小_v0();
        case 枚举_任务推进状况::方法缺可执行入口:
            return 私有_方法可执行入口数量特征类型_执行桥_最小_v0();
        case 枚举_任务推进状况::方法缺条件节点:
            return 私有_方法条件节点数量特征类型_执行桥_最小_v0();
        case 枚举_任务推进状况::方法缺结果节点:
            return 私有_方法结果节点数量特征类型_执行桥_最小_v0();
        case 枚举_任务推进状况::方法缺条件结果对:
            return 私有_方法条件结果配对状态特征类型_执行桥_最小_v0();
        case 枚举_任务推进状况::参数不可配:
            return 特征_参数配对状态();
        case 枚举_任务推进状况::方法运行账不足:
            return 私有_方法运行账完整性特征类型_执行桥_最小_v0();
        case 枚举_任务推进状况::方法结果不稳定:
            return 私有_方法稳定状态特征类型_执行桥_最小_v0();
        default:
            return nullptr;
        }
    }

    bool 返回方法结构缺口(
        任务模块::筹办::结构_任务筹办结果& 结果,
        任务节点* 任务头,
        方法节点* 目标方法,
        任务模块::筹办::枚举_任务推进状况 状况,
        时间戳 now) noexcept
    {
        if (!任务头 || !目标方法) {
            return false;
        }

        using 任务模块::筹办::枚举_任务推进状况;

        场景节点类* 结果场景 = 任务头->主信息.场景.指针;
        特征节点类* 运行结果 = nullptr;
        基础信息节点类* 缺口目标主体 = nullptr;
        switch (状况) {
        case 枚举_任务推进状况::方法缺动作骨架:
            运行结果 = 私有_填充方法缺动作骨架执行结果_执行桥_最小_v0(目标方法, 结果场景, now);
            break;
        case 枚举_任务推进状况::方法缺可执行入口:
            运行结果 = 私有_填充方法缺可执行入口执行结果_执行桥_最小_v0(目标方法, 结果场景, now);
            break;
        case 枚举_任务推进状况::方法缺条件节点:
            运行结果 = 私有_填充方法缺条件节点执行结果_执行桥_最小_v0(目标方法, 结果场景, now);
            break;
        case 枚举_任务推进状况::方法缺结果节点:
            运行结果 = 私有_填充方法缺结果节点执行结果_执行桥_最小_v0(目标方法, 结果场景, now);
            break;
        case 枚举_任务推进状况::方法缺条件结果对:
            运行结果 = 私有_填充方法缺条件结果对执行结果_执行桥_最小_v0(目标方法, 结果场景, now);
            break;
        case 枚举_任务推进状况::参数不可配:
            缺口目标主体 = 任务参数缺口目标主体(任务头, 目标方法, now);
            运行结果 = 私有_填充参数配对缺口执行结果_执行桥_最小_v0(
                目标方法,
                缺口目标主体,
                结果场景,
                now);
            break;
        case 枚举_任务推进状况::方法运行账不足:
            运行结果 = 私有_填充方法运行账不足执行结果_执行桥_最小_v0(目标方法, 结果场景, now);
            break;
        case 枚举_任务推进状况::方法结果不稳定:
            运行结果 = 私有_填充方法结果不稳定执行结果_执行桥_最小_v0(目标方法, 结果场景, now);
            break;
        default:
            return false;
        }
        if (!运行结果) {
            return false;
        }

        结果.方法运行结果 = 运行结果;
        结果.结果场景 = 结果场景;
        结果.回执.状况 = 状况;
        写入筹办回执任务建议(
            结果.回执,
            枚举_任务状态::等待中,
            枚举_任务阶段::筹办);
        结果.回执.缺口特征类型 = 筹办缺口特征类型(状况);
        {
            std::ostringstream 输出;
            输出 << "返回方法结构缺口"
                << " | 任务=" << 任务主键_筹办日志(任务头)
                << " | 目标方法=" << 方法主键_筹办日志(目标方法)
                << " | 状况=" << static_cast<int>(状况)
                << " | 缺口特征=" << 入口主键_筹办日志(结果.回执.缺口特征类型)
                << " | 目标方法有动作骨架=" << (目标方法->主信息.有动作骨架() ? 1 : 0)
                << " | 动作骨架数=" << 私有_方法动作骨架数量_执行桥_最小_v0(目标方法)
                << " | 可执行入口数=" << 私有_方法可执行入口数量_执行桥_最小_v0(目标方法)
                << " | 条件结果对数=" << 私有_方法条件结果对数量_执行桥_最小_v0(目标方法);
            记录筹办日志(输出.str());
        }
        if (缺口目标主体) {
            写入基础节点引用(
                结果.回执.缺口目标主体,
                缺口目标主体);
        } else if (auto* 方法虚拟存在 = 目标方法->主信息.首节点信息().方法虚拟存在.指针
                ? 目标方法->主信息.首节点信息().方法虚拟存在.指针
                : 方法虚拟存在服务类::取或创建方法虚拟存在(目标方法, nullptr, now)) {
            // 方法类缺口归入方法虚拟存在的“方法状态”集合特征；
            // 学习需求以该集合特征为目标主体，再围绕具体缺口特征展开。
            auto* 方法状态 = 世界树.确保特征(
                reinterpret_cast<基础信息节点类*>(方法虚拟存在),
                私有_方法状态特征类型_执行桥_最小_v0());
            写入基础节点引用(
                结果.回执.缺口目标主体,
                方法状态
                    ? reinterpret_cast<基础信息节点类*>(方法状态)
                    : reinterpret_cast<基础信息节点类*>(方法虚拟存在));
        }
        记录缺口派生目标状态(
            "方法结构缺口派生目标状态",
            任务头,
            目标方法,
            结果.回执.缺口特征类型,
            结果.回执.缺口目标主体,
            结果场景);
        结果.回执.需要自我线程 = true;
        结果.回执.需要创建或复用子需求 = true;
        结果.回执.父任务需要重筹办 = false;
        return true;
    }

    bool 返回方法状态可用性缺口(
        任务模块::筹办::结构_任务筹办结果& 结果,
        任务节点* 任务头,
        方法节点* 目标方法,
        时间戳 now) noexcept
    {
        if (!任务头 || !目标方法) {
            return false;
        }

        auto* 结果场景 = 任务头->主信息.场景.指针;
        auto* 运行结果 = 私有_填充方法不可用执行结果_执行桥_最小_v0(
            目标方法,
            结果场景,
            now);
        if (!运行结果) {
            return false;
        }

        auto* 方法虚拟存在 = 目标方法->主信息.首节点信息().方法虚拟存在.指针
            ? 目标方法->主信息.首节点信息().方法虚拟存在.指针
            : 方法虚拟存在服务类::取或创建方法虚拟存在(目标方法, nullptr, now);

        结果.方法运行结果 = 运行结果;
        结果.结果场景 = 结果场景;
        // 候选方法已经明确存在，但尚未达到“方法状态=可用”的最低判据。
        // 这里不细分为动作/条件/结果节点需求，避免筹办在缺口不明确时误派生动作骨架需求。
        结果.回执.状况 = 任务模块::筹办::枚举_任务推进状况::方法缺条件结果对;
        写入筹办回执任务建议(
            结果.回执,
            枚举_任务状态::等待中,
            枚举_任务阶段::筹办);
        结果.回执.缺口特征类型 = 私有_方法状态特征类型_执行桥_最小_v0();
        if (方法虚拟存在) {
            写入基础节点引用(
                结果.回执.缺口目标主体,
                reinterpret_cast<基础信息节点类*>(方法虚拟存在));
        }
        记录缺口派生目标状态(
            "方法状态可用性缺口派生目标状态",
            任务头,
            目标方法,
            结果.回执.缺口特征类型,
            结果.回执.缺口目标主体,
            结果场景);
        结果.回执.需要自我线程 = true;
        结果.回执.需要创建或复用子需求 = true;
        结果.回执.父任务需要重筹办 = false;
        结果.回执.治理结果可接受 = false;
        {
            std::ostringstream 输出;
            输出 << "返回方法状态可用性缺口"
                << " | 任务=" << 任务主键_筹办日志(任务头)
                << " | 目标方法=" << 方法主键_筹办日志(目标方法)
                << " | 缺口特征=" << 入口主键_筹办日志(结果.回执.缺口特征类型)
                << " | 目标方法有动作骨架=" << (目标方法->主信息.有动作骨架() ? 1 : 0)
                << " | 本能能力=" << 方法自我能力值(目标方法)
                << " | 动作骨架数=" << 私有_方法动作骨架数量_执行桥_最小_v0(目标方法)
                << " | 可执行入口数=" << 私有_方法可执行入口数量_执行桥_最小_v0(目标方法)
                << " | 条件节点数=" << 私有_方法条件节点数量_执行桥_最小_v0(目标方法)
                << " | 结果节点数=" << 私有_方法结果节点数量_执行桥_最小_v0(目标方法)
                << " | 条件结果对数=" << 私有_方法条件结果对数量_执行桥_最小_v0(目标方法);
            记录筹办日志(输出.str());
        }
        return true;
    }

    任务模块::筹办::枚举_任务推进状况 候选方法不可就绪状况(
        方法节点* 目标方法,
        时间戳 now) noexcept
    {
        using 任务模块::筹办::枚举_任务推进状况;
        if (!目标方法) {
            return 枚举_任务推进状况::方法查找未命中;
        }

        const bool 有本能动作入口 = 方法自我能力值(目标方法) != 0;
        const bool 有动作骨架 =
            有本能动作入口
            || 目标方法->主信息.有动作骨架()
            || 私有_方法动作骨架数量_执行桥_最小_v0(目标方法) > 0;
        if (!有动作骨架) {
            return 枚举_任务推进状况::方法缺动作骨架;
        }

        const bool 有可执行入口 =
            有本能动作入口
            || 私有_方法可执行入口数量_执行桥_最小_v0(目标方法) > 0;
        if (!有可执行入口) {
            return 枚举_任务推进状况::方法缺可执行入口;
        }

        // 普通方法“可用”的最低判据是至少存在一组有效条件结果对。
        // 学习补齐本能本身是内核反射：它负责给目标方法产出条件结果对，
        // 只要动作入口存在且输入场景已绑定，就不再用自身条件结果对反向阻塞自身。
        if (方法是学习补齐本能方法(目标方法)) {
            return 枚举_任务推进状况::未定义;
        }
        if (方法是筹办过程或协作本能方法(目标方法)) {
            return 枚举_任务推进状况::未定义;
        }
        if (私有_方法条件结果对数量_执行桥_最小_v0(目标方法) <= 0) {
            return 枚举_任务推进状况::方法缺条件结果对;
        }

        return 枚举_任务推进状况::未定义;
    }
}

export namespace 任务模块::筹办 {

结构_任务筹办结果 筹办任务(
    ::自我类& 自我对象,
    任务类::节点类* 输入任务,
    时间戳 now) noexcept
{
    using enum 枚举_任务推进状况;

    结构_任务筹办结果 结果{};
    结果.已执行筹办 = true;
    if (now == 0) {
        now = 结构体_时间戳::当前_微秒();
    }

    auto* 任务头 = 归一到任务头结点(输入任务);
    结果.回执.阶段 = 枚举_任务推进阶段::筹办;
    写入任务节点引用(结果.回执.当前任务, 任务头);
    if (!任务头) {
        结果.缺少任务 = true;
        结果.回执.状况 = 未定义;
        return 结果;
    }

    auto* 来源需求 = 任务来源需求(任务头);
    const auto* 目标特征类型 = 需求目标特征类型(来源需求);
    auto* 当前状态 = 来源需求 ? 来源需求->主信息.被需求当前状态.指针 : nullptr;
    auto* 目标状态 = 来源需求 ? 来源需求->主信息.需求状态.指针 : nullptr;
    auto* 目标宿主 = 来源需求 && 来源需求->主信息.被需求存在.指针
        ? reinterpret_cast<基础信息节点类*>(来源需求->主信息.被需求存在.指针)
        : nullptr;
    if (!目标宿主) {
        目标宿主 = 状态节点主体(目标状态);
    }
    if (!目标宿主) {
        目标宿主 = 状态节点主体(当前状态);
    }
    结果.回执.目标特征类型 = 目标特征类型;
    {
        std::ostringstream 输出;
        输出 << "进入筹办"
            << " | 任务=" << 任务主键_筹办日志(任务头)
            << " | 来源需求=" << 需求主键_筹办日志(来源需求)
            << " | 目标宿主=" << 基础主键_筹办日志(目标宿主)
            << " | 目标特征=" << 入口主键_筹办日志(目标特征类型)
            << " | 当前状态=" << 状态主键_筹办日志(当前状态)
            << " | 目标状态=" << 状态主键_筹办日志(目标状态)
            << " | 满足关系=" << static_cast<I64>(来源需求 ? 来源需求->主信息.满足关系 : 0);
        记录筹办日志(输出.str());
    }
    if (来源需求 && !目标状态) {
        记录筹办日志("缺少需求目标状态 | 任务=" + 任务主键_筹办日志(任务头)
            + " | 来源需求=" + 需求主键_筹办日志(来源需求)
            + " | 目标宿主=" + 基础主键_筹办日志(目标宿主)
            + " | 目标特征=" + 入口主键_筹办日志(目标特征类型));
    }
    if (来源需求 && !目标宿主) {
        记录筹办日志("缺少需求目标宿主 | 任务=" + 任务主键_筹办日志(任务头)
            + " | 来源需求=" + 需求主键_筹办日志(来源需求)
            + " | 目标特征=" + 入口主键_筹办日志(目标特征类型)
            + " | 当前状态=" + 状态主键_筹办日志(当前状态)
            + " | 目标状态=" + 状态主键_筹办日志(目标状态));
    }
    if (来源需求) {
        写入需求节点引用(结果.回执.对应需求, 来源需求);
        结果.回执.目标满足关系 = 来源需求->主信息.满足关系;
    }

    if (来源需求 && 需求已满足(来源需求)) {
        记录筹办日志("父需求已满足 | 任务=" + 任务主键_筹办日志(任务头)
            + " | 来源需求=" + 需求主键_筹办日志(来源需求));
        结果.回执.状况 = 父需求已满足;
        结果.回执.当前任务目标达成 = true;
        结果.回执.需要自我线程 = true;
        写入筹办回执任务建议(
            结果.回执,
            枚举_任务状态::完成,
            枚举_任务阶段::已完成);
        return 结果;
    }

    if (来源需求 && 存在活动直接子需求(来源需求)) {
        记录筹办日志("存在活动子需求，筹办阻塞 | 任务=" + 任务主键_筹办日志(任务头)
            + " | 来源需求=" + 需求主键_筹办日志(来源需求));
        结果.回执.状况 = 存在活动子需求;
        写入筹办回执任务建议(
            结果.回执,
            枚举_任务状态::等待中,
            枚举_任务阶段::阻塞);
        return 结果;
    }

    if (!目标特征类型) {
        记录筹办日志("缺少需求目标特征 | 任务=" + 任务主键_筹办日志(任务头)
            + " | 来源需求=" + 需求主键_筹办日志(来源需求));
        结果.缺少需求目标 = true;
        结果.回执.状况 = 未定义;
        写入筹办回执任务建议(
            结果.回执,
            枚举_任务状态::无法执行,
            枚举_任务阶段::筹办);
        return 结果;
    }

    if (!目标宿主) {
        记录筹办日志("无法筹办：缺少需求目标宿主 | 任务=" + 任务主键_筹办日志(任务头)
            + " | 来源需求=" + 需求主键_筹办日志(来源需求)
            + " | 目标特征=" + 入口主键_筹办日志(目标特征类型)
            + " | 当前状态=" + 状态主键_筹办日志(当前状态)
            + " | 目标状态=" + 状态主键_筹办日志(目标状态));
        结果.缺少需求目标 = true;
        结果.回执.状况 = 未定义;
        写入筹办回执任务建议(
            结果.回执,
            枚举_任务状态::无法执行,
            枚举_任务阶段::筹办);
        return 结果;
    }

    bool 已新建目标方法头 = false;
    auto* 目标方法 = 解析或创建任务目标方法(
        自我对象,
        任务头,
        now,
        &已新建目标方法头);
    if (!目标方法) {
        记录筹办日志("方法查找未命中 | 任务=" + 任务主键_筹办日志(任务头)
            + " | 来源需求=" + 需求主键_筹办日志(来源需求)
            + " | 目标特征=" + 入口主键_筹办日志(目标特征类型));
        结果.缺少需求目标 = true;
        结果.回执.状况 = 方法查找未命中;
        写入筹办回执任务建议(
            结果.回执,
            枚举_任务状态::待重筹办,
            枚举_任务阶段::筹办);
        return 结果;
    }

    结果.已绑定方法 = true;
    结果.已创建目标方法头 = 已新建目标方法头;
    写入方法节点引用(结果.回执.当前方法, 目标方法);
    if (任务目标是方法结构补齐需求(任务头)
        && 方法是学习补齐本能方法(目标方法)
        && 任务头->主信息.场景.指针) {
        // 方法补齐任务的目标方法已经写入任务场景的输入条件包。
        // 因此该任务场景本身就是学习本能可执行输入参数场景；
        // 后续由“同步筹办回执到任务”写入任务虚拟存在，执行阶段再读取。
        写入场景节点引用(
            结果.回执.可执行输入参数场景,
            任务头->主信息.场景.指针);
        记录筹办日志("学习本能可执行输入场景已绑定 | 任务="
            + 任务主键_筹办日志(任务头)
            + " | 当前方法=" + 方法主键_筹办日志(目标方法)
            + " | 输入场景=" + 基础主键_筹办日志(
                reinterpret_cast<基础信息节点类*>(任务头->主信息.场景.指针)));
    }

    if (已新建目标方法头) {
        (void)方法虚拟存在服务类::初始化方法虚拟存在信息(
            目标方法,
            自我对象.获取自我存在(),
            now);
        (void)方法虚拟存在服务类::记录方法虚拟存在特征(
            目标方法,
            私有_方法状态特征类型_执行桥_最小_v0(),
            特征值{ static_cast<I64>(0) },
            自我对象.获取自我存在(),
            now);
        (void)方法虚拟存在服务类::记录方法虚拟存在特征(
            目标方法,
            特征_方法成熟度阶段(),
            特征值{ static_cast<I64>(0) },
            自我对象.获取自我存在(),
            now);
        (void)方法虚拟存在服务类::记录方法虚拟存在特征(
            目标方法,
            特征_方法结构是否完整(),
            特征值{ static_cast<I64>(0) },
            自我对象.获取自我存在(),
            now);
        (void)方法虚拟存在服务类::记录方法虚拟存在特征(
            目标方法,
            私有_方法运行账完整性特征类型_执行桥_最小_v0(),
            特征值{ static_cast<I64>(0) },
            自我对象.获取自我存在(),
            now);
        (void)方法虚拟存在服务类::记录方法虚拟存在特征(
            目标方法,
            私有_方法稳定状态特征类型_执行桥_最小_v0(),
            特征值{ static_cast<I64>(0) },
            自我对象.获取自我存在(),
            now);
        (void)方法虚拟存在服务类::记录方法虚拟存在特征(
            目标方法,
            特征_方法允许自动召回(),
            特征值{ static_cast<I64>(0) },
            自我对象.获取自我存在(),
            now);
        (void)方法虚拟存在服务类::记录方法虚拟存在特征(
            目标方法,
            特征_方法允许默认执行(),
            特征值{ static_cast<I64>(0) },
            自我对象.获取自我存在(),
            now);
    }

    const auto 方法不可就绪状况 = 候选方法不可就绪状况(目标方法, now);
    if (方法不可就绪状况 != 未定义) {
        // 筹办的职责是形成“任务可就绪”的过程回执。
        // 找到并绑定当前方法只说明候选召回成功，不等于任务已经可执行。
        // 只有明确缺动作/入口时才返回结构缺口；已有动作但未可用时，统一围绕“方法状态=可用”生长学习需求。
        记录筹办日志("检查方法条件是否满足对应缺口 | 对应本能方法=检查方法条件是否满足 | 任务="
            + 任务主键_筹办日志(任务头)
            + " | 当前方法=" + 方法主键_筹办日志(目标方法)
            + " | 状况=" + std::to_string(static_cast<int>(方法不可就绪状况)));
        if (方法不可就绪状况 == 方法缺动作骨架
            || 方法不可就绪状况 == 方法缺可执行入口) {
            return 返回方法结构缺口(
                结果,
                任务头,
                目标方法,
                方法不可就绪状况,
                now)
                ? 结果
                : 结果;
        }

        if (返回方法状态可用性缺口(
                结果,
                任务头,
                目标方法,
                now)) {
            return 结果;
        }

        记录筹办日志("方法状态可用性缺口生成失败 | 任务=" + 任务主键_筹办日志(任务头)
            + " | 当前方法=" + 方法主键_筹办日志(目标方法)
            + " | 状况=" + std::to_string(static_cast<int>(方法不可就绪状况)));
        结果.回执.状况 = 方法不可就绪状况;
        写入筹办回执任务建议(
            结果.回执,
            枚举_任务状态::等待中,
            枚举_任务阶段::筹办);
        return 结果;
    }

    // 通过可用性检查后，筹办才可以形成“任务可就绪”的回执。
    // 任务状态真正进入就绪仍由同步筹办回执和提交任务状态变化两个提交本能方法完成。
    结果.回执.状况 = 方法可执行;
    写入筹办回执任务建议(
        结果.回执,
        枚举_任务状态::就绪,
        枚举_任务阶段::执行);
    {
        std::ostringstream 输出;
        输出 << "筹办完成进入执行"
            << " | 任务=" << 任务主键_筹办日志(任务头)
            << " | 来源需求=" << 需求主键_筹办日志(来源需求)
            << " | 当前方法=" << 方法主键_筹办日志(目标方法)
            << " | 新建方法头=" << (已新建目标方法头 ? 1 : 0);
        记录筹办日志(输出.str());
    }
    return 结果;
}

} // namespace 任务模块::筹办
