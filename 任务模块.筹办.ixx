export namespace 任务模块::筹办 {

enum class 枚举_任务推进阶段 : std::uint8_t {
    未定义 = 0,
    筹办 = 1,
    执行 = 2,
};

enum class 枚举_任务推进状况 : std::uint8_t {
    未定义 = 0,

    父需求已满足 = 1,
    存在活动子需求 = 2,

    方法查找未命中 = 10,
    已建立方法头待重入 = 11,
    方法缺动作骨架 = 12,
    方法缺可执行入口 = 13,
    方法缺条件节点 = 14,
    方法缺结果节点 = 15,
    方法缺条件结果对 = 16,
    参数不可配 = 17,
    方法运行账不足 = 18,
    方法结果不稳定 = 19,
    方法可执行 = 20,

    动作执行失败 = 30,
    动作执行成功无可比较结果 = 31,
    目标结果符合 = 32,
    目标结果不符合 = 33,
    出现需要附带结果 = 34,
    出现不需要附带结果 = 35,
    出现禁止结果 = 36,
};

struct 结构_任务推进回执 {
    枚举_任务推进阶段 阶段 = 枚举_任务推进阶段::未定义;
    枚举_任务推进状况 状况 = 枚举_任务推进状况::未定义;
    枚举_任务状态 建议任务状态 = 枚举_任务状态::未定义;
    枚举_任务阶段 建议任务阶段 = 枚举_任务阶段::未定义;

    可解析引用<任务节点类> 当前任务{};
    可解析引用<需求节点类> 对应需求{};
    可解析引用<方法节点类> 当前方法{};
    可解析引用<基础信息节点类> 缺口目标主体{};
    可解析引用<场景节点类> 可执行输入参数场景{};

    const 语素入口节点类* 目标特征类型 = nullptr;
    三向关系掩码 目标满足关系 = 关系_等于;

    const 语素入口节点类* 缺口特征类型 = nullptr;
    三向关系掩码 缺口满足关系 = 关系_等于;

    std::vector<可解析引用<状态节点类>> 实际结果状态集{};
    std::vector<可解析引用<状态节点类>> 禁止结果状态集{};
    std::vector<可解析引用<状态节点类>> 需要附带结果状态集{};

    bool 需要自我线程 = false;
    bool 父任务需要重筹办 = false;
    bool 需要创建或复用子需求 = false;
    bool 当前任务目标达成 = false;
    bool 治理结果可接受 = true;

    std::string 摘要{};
};

struct 结构_任务筹办结果 {
    bool 已执行筹办 = false;
    bool 已绑定方法 = false;
    bool 已创建目标方法头 = false;
    bool 已建立方法头待重入 = false;
    bool 缺少任务 = false;
    bool 缺少需求目标 = false;
    特征节点类* 方法运行结果 = nullptr;
    场景节点类* 结果场景 = nullptr;
    结构_任务推进回执 回执{};
    std::string 说明{};
};

} // namespace 任务模块::筹办

namespace {
