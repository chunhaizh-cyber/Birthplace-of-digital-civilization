// P-1：主体化过渡类型。
// 它们用于先把“主体、分身、需求位、能力缺口”立成正式语义层，
// 不改变当前“每宿主最多一个运行时实例”的运行时边界。
struct 结构_任务管理主体虚拟存在 {
    时间戳 创建时间 = 0;
    时间戳 最近激活时间 = 0;
    时间戳 最近回并时间 = 0;
    时间戳 最近学习反馈时间 = 0;
    时间戳 最近学习回流时间 = 0;

    std::uint64_t 主体ID = 0;
    std::uint32_t 版本号 = 0;

    bool 总目标为推进任务完成 = true;
    std::int32_t 安全取向_Q10000 = 10000;
    std::int32_t 服务取向_Q10000 = 10000;
    std::int32_t 当前预算_Q10000 = 0;
    bool 风险偏保守 = true;

    枚举_任务管理功能域 最近功能域 = 枚举_任务管理功能域::未定义;
    枚举_任务管理缺口类型 最近主缺口类型 = 枚举_任务管理缺口类型::未定义;
