    枚举_任务管理本能能力缺口类型 最近本能能力缺口类型 = 枚举_任务管理本能能力缺口类型::未定义;
    枚举_任务管理总控结果 最近总控结果 = 枚举_任务管理总控结果::未定义;

    std::string 最近输入条件主键{};
    std::string 最近结果主键{};
    std::string 最近原因摘要{};
    std::string 最近治理态型{};

    std::uint32_t 当前活跃分身数 = 0;
    std::uint32_t 累计回并分身数 = 0;
    std::uint32_t 累计推进次数 = 0;
    std::uint32_t 累计完成次数 = 0;
    std::uint32_t 累计失败次数 = 0;
    std::uint32_t 累计稳定复现次数 = 0;
    std::uint32_t 累计价值成立次数 = 0;
    std::uint32_t 累计学习反馈次数 = 0;
    std::uint32_t 累计学习回流次数 = 0;
    std::uint32_t 累计已使用已完善方法次数 = 0;
    std::uint32_t 累计正式方法资产提交次数 = 0;
    std::uint32_t 累计长期策略成功次数 = 0;
    std::uint32_t 累计长期策略失败次数 = 0;
    std::uint32_t 当前长期策略权重_Q10000 = 0;
    std::uint32_t 当前长期策略降权级别 = 0;
    std::uint32_t 最近回并序号 = 0;

    std::uint32_t 需求位命中次数[8]{};
    std::uint32_t 需求位成功次数[8]{};
    std::uint32_t 需求位弱出生证据次数[8]{};
    std::uint32_t 需求位验证证据次数[8]{};
    std::uint32_t 需求位升格证据次数[8]{};
    std::uint32_t 需求位学习反馈次数[8]{};
    std::uint32_t 需求位学习回流次数[8]{};
    std::uint32_t 需求位已使用已完善方法次数[8]{};
    std::uint32_t 需求位正式资产提交次数[8]{};

    任务类::节点类* 最近宿主任务 = nullptr;
    方法类::节点类* 最近管理方法 = nullptr;
    任务类::节点类* 最近步骤节点 = nullptr;
    任务类::节点类* 最近结果节点 = nullptr;
    动态节点类* 最近方法位专项动态 = nullptr;
    动态节点类* 最近最小原语动态 = nullptr;
    因果实例节点类* 最近实例因果 = nullptr;
