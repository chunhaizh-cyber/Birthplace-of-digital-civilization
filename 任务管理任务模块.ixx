    bool 总目标为推进任务完成 = true;
    std::int32_t 安全取向_Q10000 = 10000;
    std::int32_t 服务取向_Q10000 = 10000;
    std::int32_t 当前预算_Q10000 = 0;
    bool 风险偏保守 = true;

    枚举_任务管理功能域 最近功能域 = 枚举_任务管理功能域::未定义;
