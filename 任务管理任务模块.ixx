    枚举_任务管理本能能力缺口类型 最近本能能力缺口类型 = 枚举_任务管理本能能力缺口类型::未定义;
    std::uint64_t 最近来源最小原语位图 = 0;
    std::string 最近来源正式原语摘要{};
    std::string 最近原因说明{};
    std::string 最近反馈摘要{};
    std::string 最近条件主键{};
    std::string 最近结果节点主键{};
    std::string 最近治理态型{};
    std::string 最近方法位专项动态标题{};
    std::string 最近最小原语动态标题{};
    std::string 最近来源主观察特征{};
    std::string 最近影子验证状态{};
    std::string 最近学习承接摘要{};
    std::string 最近学习等待摘要{};
    std::string 最近学习反馈摘要{};
    std::string 最近学习回流摘要{};
    std::string 当前恢复点类型{};
    bool 存在待消费学习反馈 = false;
    bool 存在待消费学习回流 = false;
    bool 存在待消费外部反馈 = false;
    std::size_t 待恢复治理事件数 = 0;
    std::vector<结构_治理恢复事件镜像> 待恢复治理事件列表{};
    std::string 待恢复治理事件摘要{};
    std::string 最近已消费治理事件幂等键{};
    std::uint32_t 最近已消费治理事件重放代数 = 0;
    std::string 最近已消费治理事件结果{};
    bool 允许正式资产提交 = false;
    std::string 摘要{};
};

