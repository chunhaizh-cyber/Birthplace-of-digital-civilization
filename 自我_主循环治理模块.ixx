module;

#include <cstdint>
#include <string>
#include <vector>

#include "需求类.h"
#include "任务类.h"
#include "方法类.h"

export module 自我_主循环治理模块;

import 自我模块;
import 自我线程模块;
import 自我_学习承接模块;

export {

enum class 枚举_主循环缺口类型 : std::uint8_t {
    未定义 = 0,
    无主需求 = 1,
    缺方法 = 2,
    候选不可执行 = 3,
    执行失败 = 4,
    等待学习 = 5,
    待机保护 = 6,
    无缺口 = 7,
};

enum class 枚举_主循环去向 : std::uint8_t {
    未定义 = 0,
    继续治理 = 1,
    执行方法 = 2,
    转入学习 = 3,
    进入等待 = 4,
    待机 = 5,
    停止 = 6,
};

enum class 枚举_根层重判时机 : std::uint8_t {
    未定义 = 0,
    预测前 = 1,
    回收后 = 2,
};

enum class 枚举_根层结果来源类型 : std::uint8_t {
    无结果 = 0,
    预测结果 = 1,
    实际结果 = 2,
};

enum class 枚举_目标对齐结论 : std::uint8_t {
    未定义 = 0,
    未满足 = 1,
    已满足 = 2,
    超额 = 3,
};

enum class 枚举_结果方向结论摘要 : std::uint8_t {
    未定义 = 0,
    无结果 = 1,
    正向 = 2,
    无推进 = 3,
    反向 = 4,
};

enum class 枚举_根层禁止原因类型 : std::uint8_t {
    无禁止 = 0,
    已消亡 = 1,
    服务归零待机 = 2,
    根层其它禁止 = 3,
};

enum class 枚举_治理功能域判定结果 : std::uint8_t {
    未定义 = 0,
    根治理 = 1,
    普通执行 = 2,
    学习治理 = 3,
    边界处理 = 4,
};

enum class 枚举_治理状态迁移 : std::uint8_t {
    未定义 = 0,
    无变化 = 1,
    进入就绪 = 2,
    进入执行中 = 3,
    进入等待学习 = 4,
    进入完成 = 5,
    进入失败 = 6,
    进入待机 = 7,
    进入停止 = 8,
};

enum class 枚举_最近总控结果 : std::uint8_t {
    未定义 = 0,
    停止 = 1,
    等待学习回流 = 2,
    无主需求 = 3,
    待机 = 4,
    缺方法 = 5,
    候选不可执行 = 6,
    执行正向推进 = 7,
    需求满足 = 8,
    执行失败 = 9,
};

enum class 枚举_最近反馈类型 : std::uint8_t {
    无反馈 = 0,
    执行反馈 = 1,
    学习回流 = 2,
    外部反馈 = 3,
};

namespace 自我_主循环治理模块_detail {
    inline 枚举_主循环去向 从线程最终去向映射主循环去向(枚举_自我线程最终去向 去向) noexcept;
    inline 枚举_治理功能域判定结果 从线程最终去向映射功能域(枚举_自我线程最终去向 去向) noexcept;
    inline 枚举_最近总控结果 从线程最终去向映射总控结果(枚举_自我线程最终去向 去向) noexcept;
}

struct 结构_根层重判结果_最小 {
    枚举_根层重判时机 重判时机 = 枚举_根层重判时机::未定义;
    枚举_根层结果来源类型 结果来源类型 = 枚举_根层结果来源类型::无结果;
    需求类::节点类* 当前主需求指针 = nullptr;
    枚举_目标对齐结论 安全方向结论 = 枚举_目标对齐结论::未定义;
    枚举_目标对齐结论 服务方向结论 = 枚举_目标对齐结论::未定义;
    枚举_结果方向结论摘要 结果方向结论摘要 = 枚举_结果方向结论摘要::无结果;
    bool 是否允许继续推进 = true;
    bool 是否允许当前执行 = true;
    bool 是否命中根层禁止 = false;
    bool 是否仅允许收束待机停止 = false;
    枚举_根层禁止原因类型 根层禁止原因类型 = 枚举_根层禁止原因类型::无禁止;
    bool 允许执行普通链 = true;
    bool 应待机 = false;
    bool 应停止 = false;
    I64 安全差值 = 0;
    I64 服务差值 = 0;
};

struct 结构_治理上下文_最小 {
    结构_根层重判结果_最小 最近根层重判{};
    需求类::节点类* 当前主需求 = nullptr;
    任务类::节点类* 当前主任务 = nullptr;
    任务类::节点类* 当前管理对象 = nullptr;
    方法类::节点类* 当前主方法 = nullptr;
    枚举_主循环缺口类型 当前缺口类型 = 枚举_主循环缺口类型::未定义;
    枚举_主循环去向 当前下一步去向 = 枚举_主循环去向::未定义;
};

struct 结构_根任务锚点_最小 {
    需求类::节点类* 安全需求 = nullptr;
    需求类::节点类* 服务需求 = nullptr;
    任务类::节点类* 安全任务 = nullptr;
    任务类::节点类* 服务任务 = nullptr;
    任务类::节点类* 治理任务 = nullptr;
};

struct 结构_一步治理输入_最小 {
    时间戳 当前时间 = 0;
    结构_根层重判结果_最小 最近根层重判{};
    需求类::节点类* 当前主需求 = nullptr;
    任务类::节点类* 当前主任务 = nullptr;
    任务类::节点类* 当前管理对象 = nullptr;
    方法类::节点类* 当前方法挂点 = nullptr;
    std::vector<方法类::节点类*> 当前方法候选列表{};
    枚举_主循环缺口类型 当前缺口类型 = 枚举_主循环缺口类型::未定义;
    枚举_主循环去向 当前下一步去向候选 = 枚举_主循环去向::未定义;
    bool 已消费学习回流 = false;
    结构_已消费学习回流_最小_v0 已消费学习回流结果{};
};

struct 结构_一步治理结果_最小 {
    需求类::节点类* 当前主需求指针镜像 = nullptr;
    任务类::节点类* 当前主任务指针镜像 = nullptr;
    任务类::节点类* 当前管理对象指针 = nullptr;
    枚举_治理功能域判定结果 当前功能域判定结果 = 枚举_治理功能域判定结果::未定义;
    枚举_主循环缺口类型 当前缺口类型 = 枚举_主循环缺口类型::未定义;
    枚举_主循环去向 当前下一步去向候选 = 枚举_主循环去向::未定义;
    枚举_治理状态迁移 当前治理状态迁移 = 枚举_治理状态迁移::未定义;
    任务类::节点类* 当前步骤指针镜像 = nullptr;
    方法类::节点类* 当前方法首节点指针镜像 = nullptr;
    任务类::节点类* 最近结果节点指针镜像 = nullptr;
    std::size_t 当前方法候选数量 = 0;
    bool 是否允许进入执行链 = false;
    bool 是否需要触发尝试学习 = false;
    bool 是否进入等待链 = false;
    bool 是否请求停止 = false;
    枚举_最近总控结果 最近总控结果 = 枚举_最近总控结果::未定义;
    枚举_最近反馈类型 最近反馈类型 = 枚举_最近反馈类型::无反馈;
    std::string 最近反馈摘要{};
};

inline 结构_根任务锚点_最小 读取根任务锚点_最小_v0(const 自我类& 自我对象) noexcept
{
    结构_根任务锚点_最小 输出{};
    输出.安全需求 = 自我对象.获取安全根需求();
    输出.服务需求 = 自我对象.获取服务根需求();
    输出.安全任务 = 自我对象.获取安全根任务();
    输出.服务任务 = 自我对象.获取服务根任务();
    输出.治理任务 = 自我对象.获取任务管理任务();
    return 输出;
}

inline 结构_根层重判结果_最小 生成根层重判结果_最小_v0(
    const 自我类& 自我对象,
    枚举_根层重判时机 重判时机 = 枚举_根层重判时机::预测前,
    枚举_根层结果来源类型 来源类型 = 枚举_根层结果来源类型::预测结果) noexcept
{
    结构_根层重判结果_最小 输出{};
    输出.重判时机 = 重判时机;
    输出.结果来源类型 = 来源类型;
    输出.当前主需求指针 = 自我对象.获取当前主需求();
    输出.安全差值 = 自我对象.安全根方向差值();
    输出.服务差值 = (std::max<I64>)(0, 自我对象.根目标服务值() - 自我对象.获取服务值());

    const auto 对齐结论 = [](I64 差值, I64 当前值, I64 目标值) noexcept {
        if (差值 > 0) {
            return 枚举_目标对齐结论::未满足;
        }
        if (当前值 > 目标值) {
            return 枚举_目标对齐结论::超额;
        }
        return 枚举_目标对齐结论::已满足;
    };

    输出.安全方向结论 = 对齐结论(
        输出.安全差值,
        自我对象.获取安全值(),
        自我对象.根目标安全值());
    输出.服务方向结论 = 对齐结论(
        输出.服务差值,
        自我对象.获取服务值(),
        自我对象.根目标服务值());

    if (输出.安全差值 == 0 && 输出.服务差值 == 0) {
        输出.结果方向结论摘要 = 枚举_结果方向结论摘要::正向;
    } else if (输出.安全差值 > 0 || 输出.服务差值 > 0) {
        输出.结果方向结论摘要 = 枚举_结果方向结论摘要::无推进;
    } else {
        输出.结果方向结论摘要 = 枚举_结果方向结论摘要::无结果;
    }

    输出.应停止 = 自我对象.是否已消亡();
    输出.应待机 = 自我对象.是否待机状态();
    输出.是否命中根层禁止 = 输出.应停止 || 输出.应待机;
    输出.是否仅允许收束待机停止 = 输出.是否命中根层禁止;
    输出.是否允许继续推进 = !输出.是否命中根层禁止;
    输出.是否允许当前执行 = !输出.是否命中根层禁止;
    输出.允许执行普通链 = !输出.是否命中根层禁止;
    输出.根层禁止原因类型 = 输出.应停止
        ? 枚举_根层禁止原因类型::已消亡
        : (输出.应待机
            ? 枚举_根层禁止原因类型::服务归零待机
            : 枚举_根层禁止原因类型::无禁止);
    return 输出;
}

inline 结构_一步治理输入_最小 装配一步治理输入_最小_v0(
    时间戳 now,
    const 结构_根层重判结果_最小& 最近根层重判,
    const 结构_已消费学习回流_最小_v0& 已消费学习回流,
    需求类::节点类* 当前主需求,
    任务类::节点类* 当前主任务,
    任务类::节点类* 当前管理对象,
    方法类::节点类* 当前方法挂点,
    const std::vector<方法类::节点类*>& 当前方法候选列表,
    枚举_主循环缺口类型 当前缺口类型,
    枚举_主循环去向 当前下一步去向候选)
{
    结构_一步治理输入_最小 输出{};
    输出.当前时间 = now;
    输出.最近根层重判 = 最近根层重判;
    输出.最近根层重判.当前主需求指针 = 已消费学习回流.有效
        ? 已消费学习回流.来源需求
        : 当前主需求;
    输出.当前主需求 = 已消费学习回流.有效
        ? 已消费学习回流.来源需求
        : 当前主需求;
    输出.当前主任务 = 已消费学习回流.有效
        ? (已消费学习回流.来源宿主任务头结点
            ? 已消费学习回流.来源宿主任务头结点
            : 当前主任务)
        : 当前主任务;
    输出.当前管理对象 = 已消费学习回流.有效
        ? (已消费学习回流.来源宿主任务头结点
            ? 已消费学习回流.来源宿主任务头结点
            : 当前管理对象)
        : 当前管理对象;
    输出.当前方法挂点 = 已消费学习回流.有效
        ? (已消费学习回流.来源当前方法首节点
            ? 已消费学习回流.来源当前方法首节点
            : 当前方法挂点)
        : 当前方法挂点;
    输出.当前方法候选列表 = 当前方法候选列表;
    输出.当前缺口类型 = 当前缺口类型;
    输出.当前下一步去向候选 = 当前下一步去向候选;
    输出.已消费学习回流 = 已消费学习回流.有效;
    输出.已消费学习回流结果 = 已消费学习回流;
    return 输出;
}

inline 结构_一步治理结果_最小 生成一步治理结果_最小_v0(
    需求类::节点类* 当前主需求,
    任务类::节点类* 当前主任务,
    任务类::节点类* 当前管理对象默认值,
    方法类::节点类* 当前主方法,
    枚举_主循环缺口类型 当前缺口类型,
    枚举_主循环去向 当前下一步去向候选,
    枚举_治理功能域判定结果 功能域,
    枚举_治理状态迁移 状态迁移,
    枚举_最近总控结果 总控结果,
    枚举_最近反馈类型 反馈类型,
    std::string 反馈摘要 = {},
    任务类::节点类* 当前步骤 = nullptr,
    方法类::节点类* 当前方法 = nullptr,
    任务类::节点类* 最近结果节点 = nullptr,
    任务类::节点类* 当前管理对象 = nullptr,
    std::size_t 当前方法候选数量 = 0)
{
    结构_一步治理结果_最小 输出{};
    输出.当前主需求指针镜像 = 当前主需求;
    输出.当前主任务指针镜像 = 当前主任务;
    输出.当前管理对象指针 = 当前管理对象 ? 当前管理对象 : 当前管理对象默认值;
    输出.当前功能域判定结果 = 功能域;
    输出.当前缺口类型 = 当前缺口类型;
    输出.当前下一步去向候选 = 当前下一步去向候选;
    输出.当前治理状态迁移 = 状态迁移;
    输出.当前步骤指针镜像 = 当前步骤;
    输出.当前方法首节点指针镜像 = 当前方法 ? 当前方法 : 当前主方法;
    输出.最近结果节点指针镜像 = 最近结果节点;
    输出.当前方法候选数量 = 当前方法候选数量;
    输出.是否允许进入执行链 = 当前下一步去向候选 == 枚举_主循环去向::执行方法;
    输出.是否需要触发尝试学习 = 当前下一步去向候选 == 枚举_主循环去向::转入学习;
    输出.是否进入等待链 = 当前下一步去向候选 == 枚举_主循环去向::进入等待
        || 当前下一步去向候选 == 枚举_主循环去向::待机;
    输出.是否请求停止 = 当前下一步去向候选 == 枚举_主循环去向::停止;
    输出.最近总控结果 = 总控结果;
    输出.最近反馈类型 = 反馈类型;
    输出.最近反馈摘要 = std::move(反馈摘要);
    return 输出;
}

inline 结构_一步治理结果_最小 读取一步治理结果快照_最小_v0(
    const 自我类& 自我对象,
    const 自我线程类& 自我线程对象)
{
    const auto 最近最终去向 = 自我线程对象.读取最近最终去向();
    const auto 主派发快照 = 自我线程对象.读取最近主派发输出快照();
    const auto 结算快照 = 自我线程对象.读取最近结算治理输出快照();

    枚举_最近反馈类型 反馈类型 = 枚举_最近反馈类型::无反馈;
    if (结算快照.学习恢复接口.应触发学习) {
        反馈类型 = 枚举_最近反馈类型::学习回流;
    } else if (!结算快照.摘要.empty()) {
        反馈类型 = 枚举_最近反馈类型::执行反馈;
    }

    return 生成一步治理结果_最小_v0(
        自我对象.获取当前主需求(),
        自我对象.获取当前主任务(),
        自我对象.获取任务管理任务(),
        自我对象.获取当前主方法(),
        自我对象.获取当前主需求() ? 枚举_主循环缺口类型::无缺口 : 枚举_主循环缺口类型::无主需求,
        自我_主循环治理模块_detail::从线程最终去向映射主循环去向(最近最终去向),
        自我_主循环治理模块_detail::从线程最终去向映射功能域(最近最终去向),
        最近最终去向 == 枚举_自我线程最终去向::停止
            ? 枚举_治理状态迁移::进入停止
            : (最近最终去向 == 枚举_自我线程最终去向::待机
                ? 枚举_治理状态迁移::进入待机
                : 枚举_治理状态迁移::无变化),
        自我_主循环治理模块_detail::从线程最终去向映射总控结果(最近最终去向),
        反馈类型,
        !结算快照.摘要.empty() ? 结算快照.摘要 : 自我线程对象.读取最近运行摘要(),
        nullptr,
        自我对象.获取当前主方法(),
        nullptr,
        自我对象.获取任务管理任务(),
        主派发快照.派发动作列表.size());
}

} // export

namespace 自我_主循环治理模块_detail {
    inline 枚举_主循环去向 从线程最终去向映射主循环去向(枚举_自我线程最终去向 去向) noexcept
    {
        switch (去向) {
        case 枚举_自我线程最终去向::继续提交:
            return 枚举_主循环去向::执行方法;
        case 枚举_自我线程最终去向::回到重筹办:
            return 枚举_主循环去向::继续治理;
        case 枚举_自我线程最终去向::转入学习:
            return 枚举_主循环去向::转入学习;
        case 枚举_自我线程最终去向::进入收束:
            return 枚举_主循环去向::进入等待;
        case 枚举_自我线程最终去向::待机:
            return 枚举_主循环去向::待机;
        case 枚举_自我线程最终去向::停止:
            return 枚举_主循环去向::停止;
        default:
            return 枚举_主循环去向::未定义;
        }
    }

    inline 枚举_治理功能域判定结果 从线程最终去向映射功能域(枚举_自我线程最终去向 去向) noexcept
    {
        switch (去向) {
        case 枚举_自我线程最终去向::继续提交:
        case 枚举_自我线程最终去向::回到重筹办:
            return 枚举_治理功能域判定结果::普通执行;
        case 枚举_自我线程最终去向::转入学习:
            return 枚举_治理功能域判定结果::学习治理;
        case 枚举_自我线程最终去向::进入收束:
        case 枚举_自我线程最终去向::待机:
        case 枚举_自我线程最终去向::停止:
            return 枚举_治理功能域判定结果::边界处理;
        default:
            return 枚举_治理功能域判定结果::未定义;
        }
    }

    inline 枚举_最近总控结果 从线程最终去向映射总控结果(枚举_自我线程最终去向 去向) noexcept
    {
        switch (去向) {
        case 枚举_自我线程最终去向::继续提交:
            return 枚举_最近总控结果::执行正向推进;
        case 枚举_自我线程最终去向::回到重筹办:
            return 枚举_最近总控结果::无主需求;
        case 枚举_自我线程最终去向::转入学习:
            return 枚举_最近总控结果::等待学习回流;
        case 枚举_自我线程最终去向::待机:
            return 枚举_最近总控结果::待机;
        case 枚举_自我线程最终去向::停止:
            return 枚举_最近总控结果::停止;
        default:
            return 枚举_最近总控结果::未定义;
        }
    }
}
