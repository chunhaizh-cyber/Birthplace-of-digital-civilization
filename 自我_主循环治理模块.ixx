    std::uintptr_t 结果方向结论摘要抽象特征指针 = 0;
    I64 结果方向结论摘要值 = 0;
    bool 是否允许继续推进 = true;
    bool 是否允许当前执行 = true;
    bool 是否命中根层禁止 = false;
    bool 是否仅允许收束待机停止 = false;
    枚举_根层禁止原因类型 根层禁止原因类型 = 枚举_根层禁止原因类型::无禁止;
    std::uintptr_t 根层禁止原因类型抽象特征指针 = 0;
    I64 根层禁止原因类型值 = 0;
    bool 允许执行普通链 = true;
    bool 应待机 = false;
