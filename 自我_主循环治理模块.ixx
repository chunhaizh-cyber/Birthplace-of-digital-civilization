export {

enum class 枚举_主循环缺口类型 : std::uint8_t {
    未定义 = 0,
    无主需求 = 1,
    缺方法 = 2,
    候选不可执行 = 3,
    执行失败 = 4,
    等待缺口 = 5,
    待机保护 = 6,
    无缺口 = 7,
    待实例化派生需求 = 8,
};

enum class 枚举_主循环去向 : std::uint8_t {
    未定义 = 0,
    继续治理 = 1,
    执行方法 = 2,
    转入缺口承接 = 3,
    进入等待 = 4,
    待机 = 5,
    停止 = 6,
};

enum class 枚举_根层重判时机 : std::uint8_t {
    未定义 = 0,
    预测前 = 1,
    回收后 = 2,
};

enum class 枚举_根层结果来源类型 : std::uint8_t {
    无结果 = 0,
    预测结果 = 1,
    实际结果 = 2,
};

enum class 枚举_目标对齐结论 : std::uint8_t {
    未定义 = 0,
    未满足 = 1,
    已满足 = 2,
    超额 = 3,
};

enum class 枚举_结果方向结论摘要 : std::uint8_t {
    未定义 = 0,
    无结果 = 1,
    正向 = 2,
    无推进 = 3,
    反向 = 4,
};

enum class 枚举_根层禁止原因类型 : std::uint8_t {
    无禁止 = 0,
    已消亡 = 1,
    服务归零待机 = 2,
    根层其它禁止 = 3,
};

enum class 枚举_治理功能域判定结果 : std::uint8_t {
    未定义 = 0,
    根治理 = 1,
    普通执行 = 2,
    缺口治理 = 3,
    边界处理 = 4,
};

enum class 枚举_治理状态迁移 : std::uint8_t {
    未定义 = 0,
    无变化 = 1,
    进入就绪 = 2,
    进入执行中 = 3,
    进入等待缺口 = 4,
    进入完成 = 5,
    进入失败 = 6,
    进入待机 = 7,
    进入停止 = 8,
};

enum class 枚举_最近总控结果 : std::uint8_t {
    未定义 = 0,
    停止 = 1,
    等待缺口回流 = 2,
    无主需求 = 3,
    待机 = 4,
    缺方法 = 5,
    候选不可执行 = 6,
    执行正向推进 = 7,
    需求满足 = 8,
    执行失败 = 9,
};

enum class 枚举_最近反馈类型 : std::uint8_t {
    无反馈 = 0,
    执行反馈 = 1,
    缺口回流 = 2,
    外部反馈 = 3,
};

namespace 自我_主循环治理模块_detail {
    inline 枚举_主循环去向 从批次执行去向映射主循环去向(
        std::uint8_t 去向编码) noexcept;
    inline 枚举_主循环去向 从线程最终去向映射主循环去向(枚举_自我线程最终去向 去向) noexcept;
    inline 枚举_治理功能域判定结果 从线程最终去向映射功能域(枚举_自我线程最终去向 去向) noexcept;
    inline 枚举_最近总控结果 从线程最终去向映射总控结果(枚举_自我线程最终去向 去向) noexcept;
    inline const char* 批次执行去向文本(
        std::uint8_t 去向编码) noexcept;
    inline const char* 主循环去向文本(枚举_主循环去向 去向) noexcept;
    inline const char* 主循环缺口类型文本(枚举_主循环缺口类型 类型) noexcept;
    inline const char* 治理功能域文本(枚举_治理功能域判定结果 结果) noexcept;
    inline const char* 治理状态迁移文本(枚举_治理状态迁移 状态) noexcept;
    inline const char* 最近总控结果文本(枚举_最近总控结果 结果) noexcept;
}

